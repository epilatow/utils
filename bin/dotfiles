#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.11"
# ///
# This is AI generated code
#
# IMPORTANT: This script has tests in tests/test_dotfiles.py
# (and tests/test_binfiles.py when invoked as binfiles).
# Always run the `self-test` subcommand after making modifications.

from __future__ import annotations

import argparse
import enum
import fnmatch
import logging
import os
import subprocess
import sys
import traceback
from dataclasses import dataclass, field
from enum import Enum
from pathlib import Path
from typing import Callable, Iterator, List, Optional, Set

# =============================================================================
# DESIGN
# =============================================================================
#
# This tool creates symlinks from a target root (e.g. $HOME) to files in a
# "source directory". Two profiles are supported, picked from the program
# name in argv[0]:
#
#   dotfiles  - target root is $HOME, top-level entries get a "." prefix,
#               entries are discovered recursively.
#   binfiles  - target root is ~/.local/bin, names are linked verbatim,
#               only top-level entries are considered (flat), and only
#               files with the executable bit set are linked.
#
# Tracking:
#   Installed source directories are recorded in ~/.dotfiles.installed
#   (dotfiles) or ~/.binfiles.installed (binfiles), one absolute path
#   per line.
#
# Conflicts:
#   A conflict occurs when a target path exists but doesn't point to the
#   expected source. With --force, conflicting symlinks are replaced.
#   Regular files/directories are never removed by --force.
#
# Cleanup:
#   The cleanup subcommand removes ALL dangling symlinks from the
#   directories the active profile manages: ~/.local/bin for binfiles;
#   $HOME plus parent directories of currently-discovered targets across
#   all installed source dirs for dotfiles.
#
# =============================================================================

# Configure logging
logging.basicConfig(
    format="%(message)s",
    level=logging.INFO,
)
logger = logging.getLogger(__name__)


# =============================================================================
# PROFILE
# =============================================================================


@dataclass(frozen=True)
class Profile:
    """Discriminator for the dotfiles vs binfiles invocations.

    target_root, transform_segment, and installed_file are callables so
    that test monkeypatches of Path.home propagate through.
    """

    name: str
    description: str
    target_root: Callable[[], Path]
    transform_segment: Callable[[str], str]
    installed_file: Callable[[], Path]
    flat: bool
    executable_only: bool


def _dot_prefix(segment: str) -> str:
    return "." + segment


def _identity(segment: str) -> str:
    return segment


DOTFILES_PROFILE = Profile(
    name="dotfiles",
    description="Manage dotfiles by creating symlinks from $HOME",
    target_root=lambda: Path.home(),
    transform_segment=_dot_prefix,
    installed_file=lambda: Path.home() / ".dotfiles.installed",
    flat=False,
    executable_only=False,
)


BINFILES_PROFILE = Profile(
    name="binfiles",
    description=("Manage executables by creating symlinks in ~/.local/bin"),
    target_root=lambda: Path.home() / ".local" / "bin",
    transform_segment=_identity,
    installed_file=lambda: Path.home() / ".binfiles.installed",
    flat=True,
    executable_only=True,
)


def select_profile(argv0: str) -> Profile:
    """Pick a Profile from the program name in argv[0]."""
    name = Path(argv0).name
    if name == "binfiles":
        return BINFILES_PROFILE
    return DOTFILES_PROFILE


# Active profile, set by cli() based on argv[0]. Default is dotfiles so
# that direct function calls (e.g. from tests) get the dotfiles
# behavior unless they pass an explicit profile.
ACTIVE_PROFILE: Profile = DOTFILES_PROFILE

# Active tracking file, kept in sync with ACTIVE_PROFILE by cli(). Tests
# monkeypatch this directly to point at a tmpdir.
INSTALLED_FILE: Path = DOTFILES_PROFILE.installed_file()


# =============================================================================
# EXIT CODES
# =============================================================================


class ExitCode(enum.IntEnum):
    SUCCESS = 0, "Success"
    WARNING = 1, "Warning"
    USAGE = 2, "Usage/argument error"
    CONFIG = 3, "Configuration error"
    ERROR = 4, "General error"
    SUBPROCESS = 5, "Subprocess error"
    CONFLICTS = 6, "Conflicts or missing entries"
    MISSING_DIR = 7, "Missing source directory"

    def __new__(cls, value: int, description: str = "") -> ExitCode:
        obj = int.__new__(cls, value)
        obj._value_ = value
        obj.description = description  # type: ignore[attr-defined]
        return obj

    @classmethod
    def epilog(cls) -> str:
        lines = ["exit codes:"]
        for member in cls:
            lines.append(
                f"  {member.value}  {member.description}"  # type: ignore[attr-defined]
            )
        return "\n".join(lines)


# =============================================================================
# EXCEPTIONS
# =============================================================================


class DotfilesError(RuntimeError):
    """Base exception for dotfiles errors."""

    exit_code: ExitCode = ExitCode.ERROR


class ConflictsFound(DotfilesError):
    """Raised when conflicts or missing dotfiles are found."""

    exit_code = ExitCode.CONFLICTS


class UsageError(DotfilesError):
    """Raised for usage/argument errors."""

    exit_code = ExitCode.USAGE


class MissingDotfilesDirectory(DotfilesError):
    """Raised when a source directory does not exist or is invalid."""

    exit_code = ExitCode.MISSING_DIR


# =============================================================================
# STATUS ENUM
# =============================================================================


class DotfileStatus(Enum):
    """Status of a dotfile during operations."""

    FILE_CONFLICT = "file-conflict"
    LINK_CONFLICT = "link-conflict"
    OK = "ok"
    MISSING = "missing"
    INSTALLED = "installed"
    REMOVED = "removed"


# =============================================================================
# DATA CLASSES
# =============================================================================


@dataclass
class DotfileEntry:
    """Represents a single source-to-target link."""

    relative_path: Path  # Path relative to source directory
    dotfile_dir: Path  # Absolute path to source directory
    profile: Profile = field(default_factory=lambda: ACTIVE_PROFILE)

    @property
    def source_path(self) -> Path:
        """Absolute path to the source file."""
        return self.dotfile_dir / self.relative_path

    @property
    def target_path(self) -> Path:
        """Absolute path to the target symlink under target_root."""
        parts = self.relative_path.parts
        transformed = (self.profile.transform_segment(parts[0]),) + parts[1:]
        return self.profile.target_root() / Path(*transformed)

    def compute_relative_symlink(self) -> Path:
        """Compute relative path from target to source."""
        target_dir = self.target_path.parent
        return Path(os.path.relpath(self.source_path, target_dir))


@dataclass
class OperationResult:
    """Result of a dotfile operation."""

    entry: DotfileEntry
    status: DotfileStatus


# =============================================================================
# INSTALLED DIRECTORIES MANAGEMENT
# =============================================================================


def load_installed_directories() -> List[Path]:
    """Load list of installed dotfile directories."""
    if not INSTALLED_FILE.exists():
        return []

    directories: List[Path] = []
    content = INSTALLED_FILE.read_text(encoding="utf-8")
    for line in content.strip().split("\n"):
        line = line.strip()
        if line:
            directories.append(Path(line))
    return directories


def save_installed_directories(directories: List[Path]) -> None:
    """Save list of installed dotfile directories."""
    content = "\n".join(str(d) for d in directories)
    if content:
        content += "\n"
    INSTALLED_FILE.write_text(content, encoding="utf-8")


def add_installed_directory(directory: Path) -> None:
    """Add a directory to the installed list if not already present."""
    directories = load_installed_directories()
    abs_dir = directory.resolve()
    if abs_dir not in directories:
        directories.append(abs_dir)
        save_installed_directories(directories)


def remove_installed_directory(directory: Path) -> None:
    """Remove a directory from the installed list."""
    directories = load_installed_directories()
    abs_dir = directory.resolve()
    if abs_dir in directories:
        directories.remove(abs_dir)
        save_installed_directories(directories)


# =============================================================================
# DOTFILE DISCOVERY
# =============================================================================


# Version control directories to skip when discovering dotfiles
VCS_DIRS = {".git", ".hg"}

# Ignore file names to load patterns from. .dotfilesignore is the
# preferred way to keep something tracked in git but unlinked by
# install (e.g. tests/, README.md, .github/, pyproject.toml). The
# .gitignore / .hgignore reads cover the common case where a file
# you don't want tracked also shouldn't be linked (editor backups,
# build outputs).
IGNORE_FILES = {".gitignore", ".hgignore", ".dotfilesignore"}

# Editor / swap / autosave patterns always excluded, even when no
# ignore file is reachable. Matched as fnmatch globs against filename
# and path components.
HARDCODED_IGNORE_PATTERNS: frozenset[str] = frozenset(
    {
        "*~",
        "*.swp",
        "*.swo",
        ".*.swp",
        "#*#",
    }
)


def _ignore_search_dirs(dotfile_dir: Path) -> List[Path]:
    """Return dotfile_dir plus ancestors up to (and including) $HOME.

    If dotfile_dir is not inside $HOME, only dotfile_dir itself is
    returned -- the walk only makes sense within the user's home tree.
    """
    abs_dir = dotfile_dir.resolve()
    dirs = [abs_dir]
    try:
        home = Path.home().resolve()
    except (OSError, RuntimeError):
        return dirs
    if abs_dir == home:
        return dirs
    if home not in abs_dir.parents:
        return dirs
    for parent in abs_dir.parents:
        dirs.append(parent)
        if parent == home:
            break
    return dirs


def load_ignore_patterns(dotfile_dir: Path) -> Set[str]:
    """
    Load ignore patterns from .gitignore, .hgignore, and
    .dotfilesignore files.

    Patterns are collected from dotfile_dir and each ancestor directory
    up to and including $HOME, plus a hardcoded set of editor / swap /
    autosave file patterns that always apply.

    .dotfilesignore is the preferred way to exclude something that is
    tracked in git but should not be linked into the target tree
    (tests/, README.md, project config). .gitignore / .hgignore covers
    the case where a file you don't want tracked also shouldn't be
    linked (editor backups, build outputs).

    Patterns are simple glob patterns (supports *, ?, []).
    Lines starting with # are comments.
    Empty lines are skipped.
    Negation patterns (!) are not supported.

    Returns:
        Set of glob patterns to ignore.
    """
    patterns: Set[str] = set(HARDCODED_IGNORE_PATTERNS)

    for directory in _ignore_search_dirs(dotfile_dir):
        for ignore_file in IGNORE_FILES:
            ignore_path = directory / ignore_file
            if not (ignore_path.exists() and ignore_path.is_file()):
                continue
            try:
                content = ignore_path.read_text(encoding="utf-8")
            except OSError:
                continue
            for line in content.splitlines():
                line = line.strip()
                if not line or line.startswith("#"):
                    continue
                if line.startswith("!"):
                    continue
                # gitignore patterns use '\X' to escape a literal X
                # anywhere in the pattern (git's wildmatch). fnmatch
                # treats '\' as a literal character with no escape
                # semantics, so unescape '\#' and '\!' before adding --
                # otherwise a real-world pattern like '\#*\#' (matching
                # emacs autosave files) would never fire.
                pattern = line.replace(r"\#", "#").replace(r"\!", "!")
                # gitignore convention suffixes directory patterns with
                # '/' (e.g. 'tests/'). fnmatch has no concept of
                # trailing slash; strip it so the path-component check
                # in matches_ignore_pattern does the right thing.
                if pattern.endswith("/") and len(pattern) > 1:
                    pattern = pattern[:-1]
                patterns.add(pattern)

    return patterns


def matches_ignore_pattern(path: Path, patterns: Set[str]) -> bool:
    """
    Check if a path matches any of the ignore patterns.

    The path is checked against patterns using fnmatch.
    Both the full path and the filename are checked.

    Args:
        path: Relative path to check
        patterns: Set of glob patterns

    Returns:
        True if the path matches any pattern.
    """
    path_str = str(path)
    filename = path.name

    for pattern in patterns:
        # Check if pattern matches the filename
        if fnmatch.fnmatch(filename, pattern):
            return True
        # Check if pattern matches the full relative path
        if fnmatch.fnmatch(path_str, pattern):
            return True
        # Check if pattern matches any path component
        for part in path.parts:
            if fnmatch.fnmatch(part, pattern):
                return True

    return False


def _is_executable(path: Path) -> bool:
    """Return True if path resolves to a file with the executable bit set.

    Follows symlinks. Returns False if the symlink is broken or stat fails.
    """
    try:
        st = path.stat()
    except OSError:
        return False
    return bool(st.st_mode & 0o111)


def discover_dotfiles(
    dotfile_dir: Path, *, profile: Optional[Profile] = None
) -> List[DotfileEntry]:
    """
    Discover entries in a source directory.

    Common rules:
    - Skip version control directories (.git, .hg).
    - Skip root-level dotfiles (files starting with '.' in the source root).
    - Skip files matching patterns in .gitignore / .hgignore /
      .dotfilesignore from dotfile_dir and each ancestor up to $HOME,
      plus a hardcoded set of editor / swap / autosave patterns.

    With profile.flat=True, only top-level entries are considered;
    subdirectories are not descended into.

    With profile.executable_only=True, non-executable files are skipped
    with a warning.

    Raises:
        MissingDotfilesDirectory: If the directory doesn't exist or isn't valid.
    """
    if profile is None:
        profile = ACTIVE_PROFILE

    if not dotfile_dir.exists():
        raise MissingDotfilesDirectory(
            f"Source directory does not exist: {dotfile_dir}"
        )
    if not dotfile_dir.is_dir():
        raise MissingDotfilesDirectory(f"Not a directory: {dotfile_dir}")

    abs_dotfile_dir = dotfile_dir.resolve()
    entries: List[DotfileEntry] = []

    ignore_patterns = load_ignore_patterns(abs_dotfile_dir)

    candidates: Iterator[Path]
    if profile.flat:
        candidates = abs_dotfile_dir.iterdir()
    else:
        candidates = abs_dotfile_dir.rglob("*")

    for item in candidates:
        # Include files and symlinks, but not directories
        # (symlinks are included even if they point to directories).
        if not (item.is_file() or item.is_symlink()):
            continue
        relative = item.relative_to(abs_dotfile_dir)
        if relative.parts[0] in VCS_DIRS:
            continue
        if len(relative.parts) == 1 and relative.name.startswith("."):
            continue
        if matches_ignore_pattern(relative, ignore_patterns):
            continue
        if profile.executable_only and not _is_executable(item):
            logger.warning("skipping non-executable file: %s", relative)
            continue
        entries.append(
            DotfileEntry(
                relative_path=relative,
                dotfile_dir=abs_dotfile_dir,
                profile=profile,
            )
        )

    entries.sort(key=lambda e: str(e.relative_path))
    return entries


# =============================================================================
# DOTFILE OPERATIONS
# =============================================================================


def check_dotfile_status(entry: DotfileEntry) -> DotfileStatus:
    """
    Check the current status of a dotfile entry.

    Returns:
        OK - if correctly linked
        MISSING - if target doesn't exist
        FILE_CONFLICT - if target is a regular file or directory
        LINK_CONFLICT - if target is a symlink to wrong location
    """
    target = entry.target_path

    if not target.exists() and not target.is_symlink():
        return DotfileStatus.MISSING

    if target.is_symlink():
        # Check if it points to the correct location
        try:
            current = Path(os.readlink(target))
        except OSError:
            return DotfileStatus.LINK_CONFLICT

        # Resolve both to compare
        try:
            current_resolved = (target.parent / current).resolve()
            expected_resolved = entry.source_path.resolve()
            if current_resolved == expected_resolved:
                return DotfileStatus.OK
        except OSError:
            pass
        return DotfileStatus.LINK_CONFLICT

    # It's a regular file or directory
    return DotfileStatus.FILE_CONFLICT


def install_dotfile(
    entry: DotfileEntry,
    *,
    dry_run: bool = False,
    force: bool = False,
) -> OperationResult:
    """
    Install a single dotfile.

    Args:
        entry: The dotfile entry to install
        dry_run: If True, don't make any changes
        force: If True, replace conflicting symlinks (not files)

    Returns:
        OperationResult with appropriate status
    """
    status = check_dotfile_status(entry)

    if status == DotfileStatus.OK:
        return OperationResult(entry=entry, status=DotfileStatus.OK)

    if status == DotfileStatus.FILE_CONFLICT:
        return OperationResult(entry=entry, status=DotfileStatus.FILE_CONFLICT)

    if status == DotfileStatus.LINK_CONFLICT:
        if not force:
            return OperationResult(
                entry=entry, status=DotfileStatus.LINK_CONFLICT
            )
        # Force mode: remove the conflicting symlink
        if not dry_run:
            entry.target_path.unlink()
        # Continue to install

    # MISSING or (LINK_CONFLICT with force) - proceed with installation
    if not dry_run:
        # Ensure parent directory exists
        entry.target_path.parent.mkdir(parents=True, exist_ok=True)
        # Create relative symlink
        relative_link = entry.compute_relative_symlink()
        entry.target_path.symlink_to(relative_link)

    return OperationResult(entry=entry, status=DotfileStatus.INSTALLED)


def remove_dotfile(
    entry: DotfileEntry,
    *,
    dry_run: bool = False,
) -> OperationResult:
    """
    Remove a single dotfile.

    Only removes symlinks that point to the correct source.
    Leaves invalid/conflicting dotfiles alone.

    Args:
        entry: The dotfile entry to remove
        dry_run: If True, don't make any changes

    Returns:
        OperationResult with appropriate status
    """
    status = check_dotfile_status(entry)

    if status == DotfileStatus.MISSING:
        # Already gone, nothing to do
        return OperationResult(entry=entry, status=DotfileStatus.MISSING)

    if status == DotfileStatus.OK:
        # Correctly linked, safe to remove
        if not dry_run:
            entry.target_path.unlink()
            _cleanup_empty_parents(entry.target_path.parent, entry.profile)
        return OperationResult(entry=entry, status=DotfileStatus.REMOVED)

    # FILE_CONFLICT or LINK_CONFLICT - leave alone
    return OperationResult(entry=entry, status=status)


def _cleanup_empty_parents(directory: Path, profile: Profile) -> None:
    """Remove empty parent directories up to but not including target_root."""
    target_root = profile.target_root()
    current = directory
    while current != target_root and current.exists():
        try:
            current.rmdir()  # Only succeeds if empty
            current = current.parent
        except OSError:
            break


def audit_dotfile(entry: DotfileEntry) -> OperationResult:
    """
    Audit a single dotfile.

    Returns the current status without making any changes.
    """
    status = check_dotfile_status(entry)
    return OperationResult(entry=entry, status=status)


# =============================================================================
# DIRECTORY OPERATIONS
# =============================================================================


def process_directory(
    dotfile_dir: Path,
    operation: str,
    *,
    dry_run: bool = False,
    force: bool = False,
    profile: Optional[Profile] = None,
) -> List[OperationResult]:
    """
    Process all entries in a source directory.

    Args:
        dotfile_dir: Path to source directory
        operation: One of "install", "remove", "audit"
        dry_run: If True, don't make any changes
        force: If True, replace conflicting symlinks (install only)
        profile: Profile to use for discovery; defaults to ACTIVE_PROFILE

    Returns:
        List of OperationResult objects
    """
    entries = discover_dotfiles(dotfile_dir, profile=profile)
    results: List[OperationResult] = []

    for entry in entries:
        if operation == "install":
            result = install_dotfile(entry, dry_run=dry_run, force=force)
        elif operation == "remove":
            result = remove_dotfile(entry, dry_run=dry_run)
        elif operation == "audit":
            result = audit_dotfile(entry)
        else:
            raise ValueError(f"Unknown operation: {operation}")
        results.append(result)

    return results


def log_results(dotfile_dir: Path, results: List[OperationResult]) -> None:
    """Log the results of processing a directory."""
    logger.info("%s", dotfile_dir)
    for result in results:
        logger.info(
            "  %s: %s",
            result.entry.relative_path,
            result.status.value,
        )


def has_conflicts(results: List[OperationResult]) -> bool:
    """Check if any results indicate a conflict."""
    conflict_statuses = {
        DotfileStatus.FILE_CONFLICT,
        DotfileStatus.LINK_CONFLICT,
    }
    return any(r.status in conflict_statuses for r in results)


def has_missing(results: List[OperationResult]) -> bool:
    """Check if any results indicate missing entries."""
    return any(r.status == DotfileStatus.MISSING for r in results)


# =============================================================================
# SUBCOMMAND IMPLEMENTATIONS
# =============================================================================


def do_install(
    directory: Optional[Path],
    *,
    dry_run: bool,
    force: bool,
) -> None:
    """Install entries from one or all source directories.

    Args:
        directory: Specific directory to install, or None for all
        dry_run: If True, don't make any changes
        force: If True, replace conflicting symlinks

    Raises:
        ConflictsFound: If any conflicts were detected.
        MissingDotfilesDirectory: If a directory does not exist.
    """
    if directory is not None:
        directories = [directory.resolve()]
        if not dry_run:
            add_installed_directory(directory)
    else:
        directories = load_installed_directories()
        if not directories:
            logger.info("No %s directories installed.", ACTIVE_PROFILE.name)
            return

    had_conflicts = False
    for dotfile_dir in directories:
        if not dotfile_dir.exists():
            raise MissingDotfilesDirectory(
                f"Source directory does not exist: {dotfile_dir}"
            )

        results = process_directory(
            dotfile_dir, "install", dry_run=dry_run, force=force
        )
        log_results(dotfile_dir, results)
        if has_conflicts(results):
            had_conflicts = True

    if had_conflicts:
        raise ConflictsFound("Conflicts found during install")


def do_remove(
    directory: Optional[Path],
    *,
    dry_run: bool,
) -> None:
    """Remove entries for one or all source directories.

    Args:
        directory: Specific directory to remove, or None for all
        dry_run: If True, don't make any changes

    Raises:
        MissingDotfilesDirectory: If a directory does not exist.
    """
    if directory is not None:
        directories = [directory.resolve()]
    else:
        directories = load_installed_directories()
        if not directories:
            logger.info("No %s directories installed.", ACTIVE_PROFILE.name)
            return

    for dotfile_dir in directories:
        if not dotfile_dir.exists():
            raise MissingDotfilesDirectory(
                f"Source directory does not exist: {dotfile_dir}"
            )

        results = process_directory(dotfile_dir, "remove", dry_run=dry_run)
        log_results(dotfile_dir, results)

        if not dry_run:
            remove_installed_directory(dotfile_dir)


def do_audit(directory: Optional[Path]) -> None:
    """Audit entries for one or all source directories.

    Args:
        directory: Specific directory to audit, or None for all

    Raises:
        ConflictsFound: If conflicts or missing entries found.
    """
    if directory is not None:
        directories = [directory.resolve()]
    else:
        directories = load_installed_directories()
        if not directories:
            return

    had_issues = False
    for dotfile_dir in directories:
        if not dotfile_dir.exists():
            continue

        results = process_directory(dotfile_dir, "audit")
        log_results(dotfile_dir, results)
        if has_conflicts(results) or has_missing(results):
            had_issues = True

    if had_issues:
        raise ConflictsFound("Conflicts or missing entries found during audit")


def do_cleanup(*, dry_run: bool) -> None:
    """Remove all dangling symlinks from directories the profile manages.

    The scan set is target_root plus the parent directory of every entry
    currently discovered across all installed source directories. For
    binfiles (flat) this collapses to {target_root}; for dotfiles it
    typically includes $HOME plus any subdirs where dotfiles delivers
    nested files.

    Args:
        dry_run: If True, log what would be removed without removing it.
    """
    profile = ACTIVE_PROFILE
    scan_dirs: Set[Path] = {profile.target_root()}

    for src_dir in load_installed_directories():
        if not src_dir.exists():
            continue
        for entry in discover_dotfiles(src_dir, profile=profile):
            scan_dirs.add(entry.target_path.parent)

    for scan_dir in sorted(scan_dirs):
        if not scan_dir.is_dir():
            continue
        for item in sorted(scan_dir.iterdir()):
            if not item.is_symlink():
                continue
            if item.exists():
                continue
            logger.info("removing dangling symlink: %s", item)
            if not dry_run:
                item.unlink()


def do_self_test(*, verbose: bool = False, coverage: bool = False) -> int:
    """Run tests by invoking the active profile's test file directly."""
    repo_root = Path(__file__).resolve().parent.parent
    test_file = repo_root / "tests" / f"test_{ACTIVE_PROFILE.name}.py"

    cmd = [str(test_file)]
    if verbose:
        cmd.append("--verbose")
    if coverage:
        cmd.append("--coverage")

    return subprocess.run(cmd, cwd=repo_root).returncode


# =============================================================================
# ARGUMENT PARSER
# =============================================================================


def build_parser() -> argparse.ArgumentParser:
    """
    Build and return the argument parser for the active profile.

    Returns:
        Configured ArgumentParser instance
    """
    parser = argparse.ArgumentParser(
        prog=ACTIVE_PROFILE.name,
        description=ACTIVE_PROFILE.description,
        epilog=ExitCode.epilog(),
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )
    subparsers = parser.add_subparsers(dest="command", help="Subcommands")

    # Install subcommand
    install_parser = subparsers.add_parser(
        "install", help="Install entries from a source directory"
    )
    install_parser.add_argument(
        "--dry-run",
        action="store_true",
        help="Show what would be done without making changes",
    )
    install_parser.add_argument(
        "-f",
        "--force",
        action="store_true",
        help="Replace conflicting symlinks (not files)",
    )
    install_parser.add_argument(
        "directory",
        type=Path,
        nargs="?",
        help="Source directory to install entries from",
    )

    # Remove subcommand
    remove_parser = subparsers.add_parser(
        "remove", help="Remove installed entries"
    )
    remove_parser.add_argument(
        "--dry-run",
        action="store_true",
        help="Show what would be done without making changes",
    )
    remove_parser.add_argument(
        "directory",
        type=Path,
        nargs="?",
        help="Source directory whose entries should be removed",
    )

    # Audit subcommand
    audit_parser = subparsers.add_parser(
        "audit", help="Audit installed entries"
    )
    audit_parser.add_argument(
        "directory",
        type=Path,
        nargs="?",
        help="Source directory to audit",
    )

    # Cleanup subcommand
    cleanup_parser = subparsers.add_parser(
        "cleanup",
        help="Remove dangling symlinks from managed directories",
    )
    cleanup_parser.add_argument(
        "--dry-run",
        action="store_true",
        help="Show what would be removed without removing it",
    )

    # Self-test subcommand
    test_parser = subparsers.add_parser("self-test", help="Run tests")
    test_parser.add_argument(
        "-v",
        "--verbose",
        action="store_true",
        help="Verbose test output",
    )
    test_parser.add_argument(
        "--coverage",
        action="store_true",
        help="Run with coverage report",
    )

    return parser


# =============================================================================
# COMMAND DISPATCH
# =============================================================================

COMMAND_CALLBACKS: dict[str, Callable[..., None]] = {
    "install": do_install,
    "remove": do_remove,
    "audit": do_audit,
    "cleanup": do_cleanup,
}


def _activate_profile(profile: Profile) -> None:
    """Set the module-level ACTIVE_PROFILE and INSTALLED_FILE."""
    global ACTIVE_PROFILE, INSTALLED_FILE
    ACTIVE_PROFILE = profile
    INSTALLED_FILE = profile.installed_file()


def cli() -> int:
    """CLI entry point with exception handling."""
    _activate_profile(select_profile(sys.argv[0]))

    parser = build_parser()
    args = parser.parse_args()

    args_dict = vars(args)
    command = args_dict.pop("command")

    if not command:
        parser.print_help()
        return ExitCode.USAGE

    if command == "self-test":
        return do_self_test(
            verbose=args_dict.pop("verbose"),
            coverage=args_dict.pop("coverage"),
        )

    try:
        COMMAND_CALLBACKS[command](**args_dict)
    except KeyError:
        raise UsageError(f"Unknown command '{command}'")
    except DotfilesError as e:
        logger.error("ERROR: %s", e)
        return e.exit_code
    except Exception:
        traceback.print_exc()
        return ExitCode.ERROR
    return ExitCode.SUCCESS


if __name__ == "__main__":
    raise SystemExit(cli())
