@dataclass
class Profile:
    name: str
    path: Path
    is_default: bool


@dataclass
class Container:
    id: int
    name: str
    icon: str
    color: str


@dataclass
class Cookie:
    host: str
    name: str
    value: str
    path: str
    expiry: int
    is_secure: bool
    is_http_only: bool
    same_site: int
    origin_attributes: str


@dataclass
class ContainerConflict:
    host: str
    name: str
    path: str
    kept_container_id: int
    omitted_container_ids: list[int]


