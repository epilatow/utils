#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.11"
# ///
# This is AI generated code
#
# IMPORTANT: This script has tests in tests/test_linkfiles.py.

from __future__ import annotations

import argparse
import fnmatch
import logging
import os
import sys
from collections.abc import Callable, Iterable, Iterator
from dataclasses import dataclass
from enum import Enum
from pathlib import Path

# First-party shared helpers live under <repo>/src. The entry script's
# own directory (bin/) is on sys.path, but the package dir is not, so
# prepend it. resolve() follows any symlink to the real file first, so
# the parent walk reaches the repo root even when the entry is invoked
# through a symlink.
sys.path.insert(0, str(Path(__file__).resolve().parent.parent / "src"))

from common.argparse_ext import StrictArgumentParser  # noqa: E402
from common.cli import cli_entrypoint  # noqa: E402
from common.exitcodes import CommonExitCode, ExitCodeBase  # noqa: E402

# =============================================================================
# DESIGN
# =============================================================================
#
# This tool symlinks the files in a "source directory" into an explicit
# "target directory":
#
#   linkfiles install <src> <dst>
#
# links each of src's entries to the matching path under dst. --dotfiles
# dot-prefixes each top-level entry; --no-recurse links only top-level
# entries. Entries are discovered recursively by default.
#
# Tracking:
#   Each install is recorded in ~/.linkfiles.installed as
#   `<dst>\t<src>[\t<flags>]`, sorted by (dst, src); dst / src are
#   escaped so any path round-trips, and <flags> is a comma-separated
#   subset of {dotfiles, no-recurse}. audit / cleanup / a no-arg install
#   replay every record.
#
# Conflicts:
#   A conflict occurs when a target path exists but doesn't point to the
#   expected source. With --force, conflicting symlinks are replaced.
#   Regular files/directories are never removed by --force.
#
# Stale managed links:
#   A symlink is "managed" when its resolved target lies inside an
#   installed source directory. It becomes "stale" when the relative
#   path within that source is no longer in the source's discovered
#   set -- because the file was removed from the repo or now matches an
#   ignore pattern. The three subcommands handle stale managed links as
#   follows:
#     - audit   reports them as STALE and fails (ConflictsFound).
#     - cleanup removes them (alongside the existing dangling-symlink
#               removal). Foreign symlinks are left alone.
#     - install removes them, scoped to the source dir being installed.
#               This makes install a sync: after it runs, the target
#               tree matches the repo's current discovered set as if
#               from a fresh clone.
#
#   The scan set for stale-link detection is target_root plus the
#   parent directory of every currently-discovered entry, the same
#   convention dangling-symlink cleanup uses. Stale links inside
#   subdirectories that hold no current entries are not reached.
#
# =============================================================================


# Configure logging: result output (info / debug) goes to stdout; only
# diagnostics (warning / error) go to stderr. The default
# logging.basicConfig sends everything to stderr, which mixes
# subcommand result lines (e.g. audit's per-entry status) into the
# error stream and prevents callers from piping them.
def _configure_logging() -> None:
    root = logging.getLogger()
    root.setLevel(logging.INFO)
    for handler in list(root.handlers):
        root.removeHandler(handler)
    formatter = logging.Formatter("%(message)s")
    info_handler = logging.StreamHandler(sys.stdout)
    info_handler.setLevel(logging.DEBUG)
    info_handler.addFilter(lambda r: r.levelno < logging.WARNING)
    info_handler.setFormatter(formatter)
    err_handler = logging.StreamHandler(sys.stderr)
    err_handler.setLevel(logging.WARNING)
    err_handler.setFormatter(formatter)
    root.addHandler(info_handler)
    root.addHandler(err_handler)


_configure_logging()
logger = logging.getLogger(__name__)


# =============================================================================
# OUTPUT FORMATTING
# =============================================================================

# ANSI color escape sequences for status output. Applied only when
# stdout is a TTY and NO_COLOR is unset (https://no-color.org/).
_ANSI_GREEN = "\033[32m"
_ANSI_RED = "\033[31m"
_ANSI_RESET = "\033[0m"


def _color_supported() -> bool:
    """Return True if ANSI color escape sequences should be emitted.

    Color is suppressed when NO_COLOR is set in the environment or
    when the result stream (stdout) isn't a TTY -- redirecting to a
    file or piping into another process should produce plain text.
    """
    if os.environ.get("NO_COLOR"):
        return False
    return sys.stdout.isatty()


def _colorize(text: str, code: str) -> str:
    if not _color_supported():
        return text
    return f"{code}{text}{_ANSI_RESET}"


# =============================================================================
# PROFILE
# =============================================================================


@dataclass(frozen=True)
class Profile:
    """How a source dir maps onto symlinks: where they go (target_root),
    how each top-level name is transformed, which tracking file records
    installs, and whether discovery is flat. Each install builds its own
    (see `LinkRecord.profile`).

    target_root, transform_segment, and installed_file are callables so
    that test monkeypatches of Path.home propagate through.
    """

    name: str
    description: str
    target_root: Callable[[], Path]
    transform_segment: Callable[[str], str]
    installed_file: Callable[[], Path]
    flat: bool


def _dot_prefix(segment: str) -> str:
    return "." + segment


def _identity(segment: str) -> str:
    return segment


def _no_static_target() -> Path:
    """The linkfiles profile has no fixed target root -- each install
    names its own dst, so operations build a per-record profile (see
    `LinkRecord.profile`) and never read this profile's `target_root`.
    Calling it is a bug."""
    raise AssertionError("linkfiles builds a per-record target root")


# Carries the parser identity and the tracking-file location. Each
# install reconstitutes a concrete profile (its own dst + flags) via
# `LinkRecord.profile`, so this profile's `target_root` is never read.
LINKFILES_PROFILE = Profile(
    name="linkfiles",
    description="Symlink a source dir's contents into an explicit target",
    target_root=_no_static_target,
    transform_segment=_identity,
    installed_file=lambda: Path.home() / ".linkfiles.installed",
    flat=False,
)

# The tracking file (~/.linkfiles.installed). Tests monkeypatch this to
# point at a tmpdir.
INSTALLED_FILE: Path = LINKFILES_PROFILE.installed_file()


# =============================================================================
# EXIT CODES
# =============================================================================


class ExitCode(ExitCodeBase):
    SUCCESS = CommonExitCode.SUCCESS
    WARNING = CommonExitCode.WARNING
    USAGE = CommonExitCode.USAGE
    CONFIG = CommonExitCode.CONFIG
    ERROR = CommonExitCode.ERROR
    SUBPROCESS = CommonExitCode.SUBPROCESS
    CRASHED = CommonExitCode.CRASHED
    CONFLICTS = 10, "Conflicts or missing entries"
    MISSING_DIR = 11, "Missing source directory"


# =============================================================================
# EXCEPTIONS
# =============================================================================


class DotfilesError(RuntimeError):
    """Base exception for dotfiles errors."""

    exit_code: ExitCode = ExitCode.ERROR


class ConflictsFound(DotfilesError):
    """Raised when conflicts or missing dotfiles are found."""

    exit_code = ExitCode.CONFLICTS


class UsageError(DotfilesError):
    """Raised for usage/argument errors."""

    exit_code = ExitCode.USAGE


class MissingDotfilesDirectory(DotfilesError):
    """Raised when a source directory does not exist or is invalid."""

    exit_code = ExitCode.MISSING_DIR


# =============================================================================
# STATUS ENUM
# =============================================================================


class DotfileStatus(Enum):
    """Status of a dotfile during operations."""

    FILE_CONFLICT = "file-conflict"
    LINK_CONFLICT = "link-conflict"
    OK = "ok"
    MISSING = "missing"
    INSTALLED = "installed"
    REMOVED = "removed"
    STALE = "stale"


# =============================================================================
# DATA CLASSES
# =============================================================================


@dataclass
class DotfileEntry:
    """Represents a single source-to-target link."""

    relative_path: Path  # Path relative to source directory
    dotfile_dir: Path  # Absolute path to source directory
    profile: Profile

    @property
    def source_path(self) -> Path:
        """Absolute path to the source file."""
        return self.dotfile_dir / self.relative_path

    @property
    def target_path(self) -> Path:
        """Absolute path to the target symlink under target_root."""
        parts = self.relative_path.parts
        transformed = (self.profile.transform_segment(parts[0]),) + parts[1:]
        return self.profile.target_root() / Path(*transformed)

    def compute_relative_symlink(self) -> Path:
        """Compute relative path from target to source."""
        target_dir = self.target_path.parent
        return Path(os.path.relpath(self.source_path, target_dir))


@dataclass
class OperationResult:
    """Result of a dotfile operation."""

    entry: DotfileEntry
    status: DotfileStatus


# =============================================================================
# LINKFILES RECORDS
# =============================================================================
#
# The linkfiles tracking file (~/.linkfiles.installed) records one
# install per line as `<dst>\t<src>[\t<flags>]`, kept sorted by
# (dst, src). dst / src are tab-and-backslash escaped so an arbitrary
# path (including one containing a tab or newline) round-trips on a
# single line; <flags> is a comma-separated subset of the fixed
# vocabulary below and needs no escaping.

_FLAG_DOTFILES = "dotfiles"
_FLAG_NO_RECURSE = "no-recurse"


@dataclass(frozen=True)
class LinkRecord:
    """One tracked linkfiles install: a source dir linked into a target
    dir, plus the flags that shaped the link. Identity is (dst, src)."""

    dst: Path
    src: Path
    dotfiles: bool
    no_recurse: bool

    def flag_tokens(self) -> list[str]:
        """The flags as their on-disk tokens, in a stable order."""
        tokens: list[str] = []
        if self.dotfiles:
            tokens.append(_FLAG_DOTFILES)
        if self.no_recurse:
            tokens.append(_FLAG_NO_RECURSE)
        return tokens

    def profile(self) -> Profile:
        """The concrete Profile this record installs under: its dst as
        the target root, dot-prefixing iff the dotfiles flag is set,
        flat iff no-recurse is set."""
        return Profile(
            name=LINKFILES_PROFILE.name,
            description=LINKFILES_PROFILE.description,
            target_root=lambda: self.dst,
            transform_segment=(_dot_prefix if self.dotfiles else _identity),
            installed_file=LINKFILES_PROFILE.installed_file,
            flat=self.no_recurse,
        )


def _escape_field(value: str) -> str:
    """Escape a path field for the tab-delimited tracking file: the
    escape char, the field separator (tab), and the record separator
    (newline)."""
    return value.replace("\\", "\\\\").replace("\t", "\\t").replace("\n", "\\n")


def _unescape_field(value: str) -> str:
    """Inverse of `_escape_field`."""
    out: list[str] = []
    i = 0
    while i < len(value):
        ch = value[i]
        if ch == "\\" and i + 1 < len(value):
            nxt = value[i + 1]
            mapped = {"\\": "\\", "t": "\t", "n": "\n"}.get(nxt)
            if mapped is not None:
                out.append(mapped)
                i += 2
                continue
        out.append(ch)
        i += 1
    return "".join(out)


def _split_escaped(line: str) -> list[str]:
    """Split a record line on unescaped tabs, returning still-escaped
    fields (each caller unescapes what it keeps)."""
    fields: list[str] = []
    cur: list[str] = []
    i = 0
    while i < len(line):
        ch = line[i]
        if ch == "\\" and i + 1 < len(line):
            cur.append(ch)
            cur.append(line[i + 1])
            i += 2
            continue
        if ch == "\t":
            fields.append("".join(cur))
            cur = []
            i += 1
            continue
        cur.append(ch)
        i += 1
    fields.append("".join(cur))
    return fields


def load_link_records() -> list[LinkRecord]:
    """Parse the linkfiles tracking file into records. A line with
    fewer than two fields is malformed and skipped."""
    if not INSTALLED_FILE.exists():
        return []
    records: list[LinkRecord] = []
    for line in INSTALLED_FILE.read_text(encoding="utf-8").splitlines():
        if not line.strip():
            continue
        fields = _split_escaped(line)
        if len(fields) < 2:
            logger.warning("skipping malformed linkfiles record: %s", line)
            continue
        dst = Path(_unescape_field(fields[0]))
        src = Path(_unescape_field(fields[1]))
        flags = set(fields[2].split(",")) if len(fields) > 2 else set()
        records.append(
            LinkRecord(
                dst=dst,
                src=src,
                dotfiles=_FLAG_DOTFILES in flags,
                no_recurse=_FLAG_NO_RECURSE in flags,
            )
        )
    return records


def save_link_records(records: list[LinkRecord]) -> None:
    """Write records to the linkfiles tracking file, sorted by
    (dst, src)."""
    ordered = sorted(records, key=lambda r: (str(r.dst), str(r.src)))
    lines: list[str] = []
    for rec in ordered:
        parts = [_escape_field(str(rec.dst)), _escape_field(str(rec.src))]
        tokens = rec.flag_tokens()
        if tokens:
            parts.append(",".join(tokens))
        lines.append("\t".join(parts))
    content = "\n".join(lines)
    if content:
        content += "\n"
    INSTALLED_FILE.write_text(content, encoding="utf-8")


def add_link_record(record: LinkRecord) -> None:
    """Record an install, replacing any prior record with the same
    (dst, src) so re-installing updates its flags."""
    records = [
        r
        for r in load_link_records()
        if not (r.dst == record.dst and r.src == record.src)
    ]
    records.append(record)
    save_link_records(records)


def remove_link_record(dst: Path, src: Path) -> None:
    """Drop the (dst, src) record if present."""
    records = [
        r for r in load_link_records() if not (r.dst == dst and r.src == src)
    ]
    save_link_records(records)


def load_installed_entries() -> list[tuple[Path, Profile]]:
    """The (source dir, profile) pair for each tracked install, each
    profile carrying that record's dst and flags."""
    return [(rec.src, rec.profile()) for rec in load_link_records()]


# =============================================================================
# DOTFILE DISCOVERY
# =============================================================================


# Ignore file names to load patterns from. .dotfilesignore /
# .linkfiles.ignore are the preferred way to keep something tracked in
# git but unlinked by install (e.g. tests/, README.md, .github/,
# pyproject.toml). The .gitignore / .hgignore reads cover the common
# case where a file you don't want tracked also shouldn't be linked
# (editor backups, build outputs). All modes read the whole set.
IGNORE_FILES = {
    ".gitignore",
    ".hgignore",
    ".dotfilesignore",
    ".linkfiles.ignore",
}

# Editor / swap / autosave patterns always excluded, even when no
# ignore file is reachable. Matched as fnmatch globs against filename
# and path components.
HARDCODED_IGNORE_PATTERNS: frozenset[str] = frozenset(
    {
        "*~",
        "*.swp",
        "*.swo",
        ".*.swp",
        "#*#",
    }
)


def _is_repo_root(path: Path) -> bool:
    """Return True if path looks like a git or hg repo root.

    Both '.git' and '.hg' may be a directory or, for git worktrees /
    submodules, a regular file containing a 'gitdir:' pointer --
    Path.exists() catches both shapes.
    """
    return (path / ".git").exists() or (path / ".hg").exists()


def _ignore_search_dirs(dotfile_dir: Path) -> list[Path]:
    """Return dotfile_dir plus ancestors up to the enclosing repo root.

    The walk consumes dotfile_dir and continues upward until it hits
    (and includes) the first ancestor that contains a '.git' or '.hg'
    entry -- the enclosing git/hg repo root. This covers the
    motivating case ('binfiles install ~/utils/bin' needs to see
    '~/utils/.gitignore', which lives one level above bin) without
    pulling in the user's $HOME-level ignore files, where flat-merged
    patterns -- especially leading-/ anchored ones -- would be
    re-interpreted relative to dotfile_dir and silently mismatch.

    If no enclosing repo root exists between dotfile_dir and $HOME,
    the walk falls back to stopping at $HOME inclusive. A dotfile_dir
    outside $HOME consults only dotfile_dir itself.
    """
    abs_dir = dotfile_dir.resolve()
    dirs = [abs_dir]
    try:
        home = Path.home().resolve()
    except (OSError, RuntimeError):
        return dirs
    if abs_dir == home:
        return dirs
    if home not in abs_dir.parents:
        return dirs
    if _is_repo_root(abs_dir):
        return dirs
    for parent in abs_dir.parents:
        dirs.append(parent)
        if _is_repo_root(parent):
            break
        if parent == home:
            break
    return dirs


def load_ignore_patterns(dotfile_dir: Path) -> set[str]:
    """
    Load ignore patterns from each file in IGNORE_FILES.

    Patterns are collected from dotfile_dir and each ancestor directory
    up to and including the enclosing repo root (see
    _ignore_search_dirs for the exact walk bound), plus a hardcoded
    set of editor / swap / autosave file patterns that always apply.

    .dotfilesignore / .linkfiles.ignore are the preferred way to exclude
    something that is tracked in git but should not be linked into the
    target tree (tests/, README.md, project config). .gitignore /
    .hgignore covers the case where a file you don't want tracked also
    shouldn't be linked (editor backups, build outputs).

    Patterns are simple glob patterns (supports *, ?, []).
    Lines starting with # are comments.
    Empty lines are skipped.
    Negation patterns (!) are not supported.

    A leading '/' anchors the pattern to dotfile_dir's root, matching
    gitignore semantics: '/CLAUDE.md' excludes only the root-level
    CLAUDE.md, leaving nested files like 'claude/CLAUDE.md' eligible
    for linking. The leading slash is preserved in the returned set
    and interpreted by matches_ignore_pattern.

    Note: anchored patterns collected from an ancestor ignore file
    (e.g. '/foo' in the repo root's '.gitignore' while dotfile_dir
    is a subdir of the repo) anchor to dotfile_dir, not to the
    ancestor directory the pattern was written in. This diverges
    from gitignore proper, which anchors each pattern at its own
    .gitignore's directory. The flat-merge collection here is the
    underlying cause; practical impact is bounded because the walk
    stops at the enclosing repo root (see _ignore_search_dirs).

    Returns:
        Set of glob patterns to ignore.
    """
    patterns: set[str] = set(HARDCODED_IGNORE_PATTERNS)

    for directory in _ignore_search_dirs(dotfile_dir):
        for ignore_file in IGNORE_FILES:
            ignore_path = directory / ignore_file
            if not (ignore_path.exists() and ignore_path.is_file()):
                continue
            try:
                content = ignore_path.read_text(encoding="utf-8")
            except OSError:
                continue
            for line in content.splitlines():
                line = line.strip()
                if not line or line.startswith("#"):
                    continue
                if line.startswith("!"):
                    continue
                # gitignore patterns use '\X' to escape a literal X
                # anywhere in the pattern (git's wildmatch). fnmatch
                # treats '\' as a literal character with no escape
                # semantics, so unescape '\#' and '\!' before adding --
                # otherwise a real-world pattern like '\#*\#' (matching
                # emacs autosave files) would never fire.
                pattern = line.replace(r"\#", "#").replace(r"\!", "!")
                # gitignore convention suffixes directory patterns with
                # '/' (e.g. 'tests/'). fnmatch has no concept of
                # trailing slash; strip it so the path-component check
                # in matches_ignore_pattern does the right thing. A
                # leading '/' is kept as the anchored-pattern marker
                # consumed by matches_ignore_pattern.
                if pattern.endswith("/") and len(pattern) > 1:
                    pattern = pattern[:-1]
                patterns.add(pattern)

    return patterns


def matches_ignore_pattern(path: Path, patterns: set[str]) -> bool:
    """
    Check if a path matches any of the ignore patterns.

    Unanchored patterns are checked via fnmatch against the basename,
    the full relative path, and each path component -- so a bare
    'CLAUDE.md' excludes that file at any depth.

    Patterns with a leading '/' are anchored to the dotfile_dir root,
    matching gitignore semantics. An anchored bare name like
    '/CLAUDE.md' matches only the first path component (root-level
    file or root-level directory by that name), leaving nested
    'claude/CLAUDE.md' eligible for linking. An anchored multi-segment
    pattern like '/foo/bar' matches the full relative path AND any
    descendant of it ('/foo/bar' excludes 'foo/bar' itself plus
    'foo/bar/baz') so it works as a directory exclusion the same way
    the bare-name branch does.

    Args:
        path: Relative path to check
        patterns: Set of glob patterns

    Returns:
        True if the path matches any pattern.
    """
    path_str = str(path)
    filename = path.name
    first_part = path.parts[0] if path.parts else ""

    for pattern in patterns:
        if pattern.startswith("/") and len(pattern) > 1:
            anchored = pattern[1:]
            if "/" in anchored:
                if fnmatch.fnmatch(path_str, anchored) or fnmatch.fnmatch(
                    path_str, anchored + "/*"
                ):
                    return True
            else:
                if fnmatch.fnmatch(first_part, anchored):
                    return True
            continue
        # Check if pattern matches the filename
        if fnmatch.fnmatch(filename, pattern):
            return True
        # Check if pattern matches the full relative path
        if fnmatch.fnmatch(path_str, pattern):
            return True
        # Check if pattern matches any path component
        for part in path.parts:
            if fnmatch.fnmatch(part, pattern):
                return True

    return False


def discover_dotfiles(
    dotfile_dir: Path, *, profile: Profile
) -> list[DotfileEntry]:
    """
    Discover entries in a source directory.

    Common rules:
    - Skip any dotfile -- an entry with a leading-'.' component at any
      depth (so .git / .hg / .github, the ignore files, and editor
      state never link).
    - Skip files matching patterns in .gitignore / .hgignore /
      .dotfilesignore / .linkfiles.ignore from dotfile_dir and each
      ancestor up to the enclosing repo root, plus a hardcoded set of
      editor / swap / autosave patterns.

    With profile.flat=True, only top-level entries are considered;
    subdirectories are not descended into.

    Raises:
        MissingDotfilesDirectory: If the directory doesn't exist or isn't valid.
    """
    if not dotfile_dir.exists():
        raise MissingDotfilesDirectory(
            f"Source directory does not exist: {dotfile_dir}"
        )
    if not dotfile_dir.is_dir():
        raise MissingDotfilesDirectory(f"Not a directory: {dotfile_dir}")

    abs_dotfile_dir = dotfile_dir.resolve()
    entries: list[DotfileEntry] = []

    ignore_patterns = load_ignore_patterns(abs_dotfile_dir)

    candidates: Iterator[Path]
    if profile.flat:
        candidates = abs_dotfile_dir.iterdir()
    else:
        candidates = abs_dotfile_dir.rglob("*")

    for item in candidates:
        # Include files and symlinks, but not directories
        # (symlinks are included even if they point to directories).
        if not (item.is_file() or item.is_symlink()):
            continue
        relative = item.relative_to(abs_dotfile_dir)
        # Skip any dotfile -- a leading-'.' component at any depth. This
        # covers VCS / metadata dirs (.git, .hg, .github), the ignore
        # files themselves, and editor state, without linking them into
        # the target tree.
        if any(part.startswith(".") for part in relative.parts):
            continue
        if matches_ignore_pattern(relative, ignore_patterns):
            continue
        entries.append(
            DotfileEntry(
                relative_path=relative,
                dotfile_dir=abs_dotfile_dir,
                profile=profile,
            )
        )

    entries.sort(key=lambda e: str(e.relative_path))
    return entries


# =============================================================================
# DOTFILE OPERATIONS
# =============================================================================


def check_dotfile_status(entry: DotfileEntry) -> DotfileStatus:
    """
    Check the current status of a dotfile entry.

    Returns:
        OK - if correctly linked
        MISSING - if target doesn't exist
        FILE_CONFLICT - if target is a regular file or directory
        LINK_CONFLICT - if target is a symlink to wrong location
    """
    target = entry.target_path

    if not target.exists() and not target.is_symlink():
        return DotfileStatus.MISSING

    if target.is_symlink():
        # Check if it points to the correct location
        try:
            current = Path(os.readlink(target))
        except OSError:
            return DotfileStatus.LINK_CONFLICT

        # Resolve both to compare
        try:
            current_resolved = (target.parent / current).resolve()
            expected_resolved = entry.source_path.resolve()
            if current_resolved == expected_resolved:
                return DotfileStatus.OK
        except OSError:
            pass
        return DotfileStatus.LINK_CONFLICT

    # It's a regular file or directory
    return DotfileStatus.FILE_CONFLICT


def _resolve_link_target(symlink: Path) -> Path | None:
    """Compute the symlink's immediate target as an absolute path.

    The symlink's parent directory is resolved (so paths like
    /tmp/... canonicalize to /private/tmp/... on macOS, matching the
    resolved source dirs the result is compared against). The
    readlink value is appended literally and any '.'/'..' segments
    in the joined path are normalized -- but symlinks within the
    target are NOT followed.

    The non-following matters when the source dir contains internal
    symlinks: e.g. claude/DEVELOPMENT_SHARED.md -> ../_repo_shared/
    files/DEVELOPMENT_SHARED.md. A managed link
    ~/.claude/DEVELOPMENT_SHARED.md -> .../dotfiles/claude/
    DEVELOPMENT_SHARED.md should resolve to the immediate
    claude/DEVELOPMENT_SHARED.md (which is in the discovered set,
    so not stale), not to the chain end at _repo_shared/files/...
    (which would otherwise be classified stale and unlinked,
    destroying the install).

    Returns None if the symlink can't be read.
    """
    try:
        link_value = Path(os.readlink(symlink))
    except OSError:
        return None
    try:
        parent_resolved = symlink.parent.resolve(strict=False)
    except OSError:
        return None
    return Path(os.path.normpath(str(parent_resolved / link_value)))


def _link_source_dir(
    symlink: Path, source_dirs: list[Path]
) -> tuple[Path, Path] | None:
    """If symlink resolves into one of source_dirs, return
    (matching_source_dir, relative_path_within_it).

    source_dirs must already be resolved (no further .resolve() done
    here). Returns None when the symlink points outside every
    candidate or can't be read.
    """
    target = _resolve_link_target(symlink)
    if target is None:
        return None
    for src in source_dirs:
        try:
            rel = target.relative_to(src)
        except ValueError:
            continue
        return (src, rel)
    return None


def _stale_managed_links(
    sources: dict[Path, set[Path]],
    scan_dirs: Iterable[Path],
) -> list[tuple[Path, Path, Path]]:
    """Find managed-but-stale symlinks under scan_dirs.

    A managed link is one whose resolved target lies inside a key of
    `sources` (which maps a resolved source dir to the set of relative
    paths currently delivered by that source). A managed link is stale
    when its relative path is not in that set -- either because the
    file was removed from the source repo or now matches an ignore
    pattern.

    Returns a list of (symlink, source_dir, relative_path) tuples.
    """
    src_list = list(sources.keys())
    found: list[tuple[Path, Path, Path]] = []
    for scan_dir in sorted(set(scan_dirs)):
        if not scan_dir.is_dir():
            continue
        for item in sorted(scan_dir.iterdir()):
            if not item.is_symlink():
                continue
            link = _link_source_dir(item, src_list)
            if link is None:
                continue
            src, rel = link
            if rel not in sources[src]:
                found.append((item, src, rel))
    return found


def _scan_dirs_for_entries(
    entries: list[DotfileEntry], profile: Profile
) -> set[Path]:
    """Return the directory set to scan for symlinks managed by the
    given entries: target_root plus the parent directory of each
    entry's target_path."""
    scan_dirs: set[Path] = {profile.target_root()}
    for entry in entries:
        scan_dirs.add(entry.target_path.parent)
    return scan_dirs


def install_dotfile(
    entry: DotfileEntry,
    *,
    dry_run: bool = False,
    force: bool = False,
) -> OperationResult:
    """
    Install a single dotfile.

    Args:
        entry: The dotfile entry to install
        dry_run: If True, don't make any changes
        force: If True, replace conflicting symlinks (not files)

    Returns:
        OperationResult with appropriate status
    """
    status = check_dotfile_status(entry)

    if status == DotfileStatus.OK:
        return OperationResult(entry=entry, status=DotfileStatus.OK)

    if status == DotfileStatus.FILE_CONFLICT:
        return OperationResult(entry=entry, status=DotfileStatus.FILE_CONFLICT)

    if status == DotfileStatus.LINK_CONFLICT:
        if not force:
            return OperationResult(
                entry=entry, status=DotfileStatus.LINK_CONFLICT
            )
        # Force mode: remove the conflicting symlink
        if not dry_run:
            entry.target_path.unlink()
        # Continue to install

    # MISSING or (LINK_CONFLICT with force) - proceed with installation
    if not dry_run:
        # Ensure parent directory exists
        entry.target_path.parent.mkdir(parents=True, exist_ok=True)
        # Create relative symlink
        relative_link = entry.compute_relative_symlink()
        entry.target_path.symlink_to(relative_link)

    return OperationResult(entry=entry, status=DotfileStatus.INSTALLED)


def remove_dotfile(
    entry: DotfileEntry,
    *,
    dry_run: bool = False,
) -> OperationResult:
    """
    Remove a single dotfile.

    Only removes symlinks that point to the correct source.
    Leaves invalid/conflicting dotfiles alone.

    Args:
        entry: The dotfile entry to remove
        dry_run: If True, don't make any changes

    Returns:
        OperationResult with appropriate status
    """
    status = check_dotfile_status(entry)

    if status == DotfileStatus.MISSING:
        # Already gone, nothing to do
        return OperationResult(entry=entry, status=DotfileStatus.MISSING)

    if status == DotfileStatus.OK:
        # Correctly linked, safe to remove
        if not dry_run:
            entry.target_path.unlink()
            _cleanup_empty_parents(entry.target_path.parent, entry.profile)
        return OperationResult(entry=entry, status=DotfileStatus.REMOVED)

    # FILE_CONFLICT or LINK_CONFLICT - leave alone
    return OperationResult(entry=entry, status=status)


def _prune_empty_dirs(directory: Path, stop_at: set[Path]) -> None:
    """Remove empty directories from `directory` upward, stopping
    before any path in `stop_at` -- the managed target roots, which
    must never be removed even when emptied."""
    current = directory
    while current not in stop_at and current.exists():
        try:
            current.rmdir()  # Only succeeds if empty
            current = current.parent
        except OSError:
            break


def _cleanup_empty_parents(directory: Path, profile: Profile) -> None:
    """Remove empty parent directories up to but not including the
    profile's target_root."""
    _prune_empty_dirs(directory, {profile.target_root()})


def audit_dotfile(entry: DotfileEntry) -> OperationResult:
    """
    Audit a single dotfile.

    Returns the current status without making any changes.
    """
    status = check_dotfile_status(entry)
    return OperationResult(entry=entry, status=status)


# =============================================================================
# DIRECTORY OPERATIONS
# =============================================================================


def _process_entries(
    entries: list[DotfileEntry],
    operation: str,
    *,
    dry_run: bool = False,
    force: bool = False,
) -> list[OperationResult]:
    """Apply operation to each entry and return the results."""
    results: list[OperationResult] = []
    for entry in entries:
        if operation == "install":
            result = install_dotfile(entry, dry_run=dry_run, force=force)
        elif operation == "remove":
            result = remove_dotfile(entry, dry_run=dry_run)
        elif operation == "audit":
            result = audit_dotfile(entry)
        else:
            raise ValueError(f"Unknown operation: {operation}")
        results.append(result)
    return results


def process_directory(
    dotfile_dir: Path,
    operation: str,
    *,
    dry_run: bool = False,
    force: bool = False,
    profile: Profile,
) -> list[OperationResult]:
    """
    Process all entries in a source directory.

    Args:
        dotfile_dir: Path to source directory
        operation: One of "install", "remove", "audit"
        dry_run: If True, don't make any changes
        force: If True, replace conflicting symlinks (install only)
        profile: Profile to use for discovery

    Returns:
        List of OperationResult objects
    """
    entries = discover_dotfiles(dotfile_dir, profile=profile)
    return _process_entries(entries, operation, dry_run=dry_run, force=force)


# Per-operation classification of which DotfileStatus values count
# as *problems* (anything else is either OK or a successful action).
# install / remove that complete cleanly may yield INSTALLED, REMOVED,
# or (for install) STALE-pruned entries -- those are state changes,
# not errors. audit, by contrast, doesn't fix anything, so any
# status that says the target tree diverges from the discovered set
# is a problem the user needs to see.
_INSTALL_PROBLEM_STATUSES: frozenset[DotfileStatus] = frozenset(
    {DotfileStatus.FILE_CONFLICT, DotfileStatus.LINK_CONFLICT}
)
_REMOVE_PROBLEM_STATUSES: frozenset[DotfileStatus] = frozenset(
    {DotfileStatus.FILE_CONFLICT, DotfileStatus.LINK_CONFLICT}
)
_AUDIT_PROBLEM_STATUSES: frozenset[DotfileStatus] = frozenset(
    {
        DotfileStatus.MISSING,
        DotfileStatus.FILE_CONFLICT,
        DotfileStatus.LINK_CONFLICT,
        DotfileStatus.STALE,
    }
)


def _format_status(
    status: DotfileStatus, problem_statuses: frozenset[DotfileStatus]
) -> str:
    code = _ANSI_RED if status in problem_statuses else _ANSI_GREEN
    return _colorize(status.value, code)


def log_results(
    dotfile_dir: Path,
    results: list[OperationResult],
    *,
    verbose: bool = False,
    problem_statuses: frozenset[DotfileStatus] = frozenset(),
) -> None:
    """Log the results of processing a directory.

    Default mode collapses an all-ok run to a single '<dir>: ok'
    line. When some entries are non-ok (state changes like INSTALLED
    or actual problems like LINK_CONFLICT), those entries print
    under the dir header. The header itself reads ': error' only
    when at least one entry's status is in problem_statuses --
    successful state changes don't flip the header. Verbose mode
    prints every entry, ok included.

    problem_statuses is the per-operation classifier: install /
    remove flag only file/link conflicts (so INSTALLED, REMOVED,
    STALE-pruned all count as success), while audit flags anything
    that says the target tree diverges from the discovered set.

    On a color-capable TTY the header suffix and per-entry status
    text are colored: green for non-problem, red for problem.
    """
    has_problem = any(r.status in problem_statuses for r in results)
    if has_problem:
        header_suffix = _colorize("error", _ANSI_RED)
    else:
        header_suffix = _colorize("ok", _ANSI_GREEN)

    if verbose:
        logger.info("%s: %s", dotfile_dir, header_suffix)
        for result in results:
            logger.info(
                "    %s: %s",
                result.entry.relative_path,
                _format_status(result.status, problem_statuses),
            )
        return

    non_ok = [r for r in results if r.status != DotfileStatus.OK]
    if not non_ok:
        logger.info("%s: %s", dotfile_dir, header_suffix)
        return

    logger.info("%s: %s", dotfile_dir, header_suffix)
    for result in non_ok:
        logger.info(
            "    %s: %s",
            result.entry.relative_path,
            _format_status(result.status, problem_statuses),
        )


def has_conflicts(results: list[OperationResult]) -> bool:
    """Check if any results indicate a conflict."""
    conflict_statuses = {
        DotfileStatus.FILE_CONFLICT,
        DotfileStatus.LINK_CONFLICT,
    }
    return any(r.status in conflict_statuses for r in results)


def has_missing(results: list[OperationResult]) -> bool:
    """Check if any results indicate missing entries."""
    return any(r.status == DotfileStatus.MISSING for r in results)


def has_stale(results: list[OperationResult]) -> bool:
    """Check if any results indicate a stale managed symlink."""
    return any(r.status == DotfileStatus.STALE for r in results)


def _find_stale_for_dir(
    dotfile_dir: Path,
    entries: list[DotfileEntry],
    profile: Profile,
) -> list[tuple[Path, DotfileEntry]]:
    """Find managed-but-stale symlinks for one source dir.

    Returns (symlink, synthesized DotfileEntry) tuples. The
    synthesized entry has its relative_path set to the path inside
    dotfile_dir that the stale link points to, so callers can
    package it as an OperationResult or unlink the symlink.
    """
    src_resolved = dotfile_dir.resolve()
    discovered_rels = {e.relative_path for e in entries}
    sources = {src_resolved: discovered_rels}
    scan_dirs = _scan_dirs_for_entries(entries, profile)

    stale: list[tuple[Path, DotfileEntry]] = []
    for symlink, _src, rel in _stale_managed_links(sources, scan_dirs):
        synth_entry = DotfileEntry(
            relative_path=rel,
            dotfile_dir=src_resolved,
            profile=profile,
        )
        stale.append((symlink, synth_entry))
    return stale


# =============================================================================
# SUBCOMMAND IMPLEMENTATIONS
# =============================================================================


# The do_* handlers resolve an invocation to a list of (source dir,
# profile) targets -- one per tracked record -- and hand off to these
# shared runners.


def _run_install(
    targets: list[tuple[Path, Profile]],
    *,
    dry_run: bool,
    force: bool,
    verbose: bool,
) -> None:
    """Sync each (source, profile) target: link new entries, prune the
    source's stale managed links, and raise on conflict.

    install is a sync operation: after it runs, each target tree
    reflects its source's current discovered set. Files removed from
    the source or newly matched by an ignore file have their managed
    symlinks pruned, scoped to the source being installed."""
    had_conflicts = False
    for src_dir, profile in targets:
        if not src_dir.is_dir():
            raise MissingDotfilesDirectory(
                f"Source directory does not exist: {src_dir}"
            )
        entries = discover_dotfiles(src_dir, profile=profile)
        results = _process_entries(
            entries, "install", dry_run=dry_run, force=force
        )
        for symlink, synth_entry in _find_stale_for_dir(
            src_dir, entries, profile
        ):
            if not dry_run:
                symlink.unlink()
                _cleanup_empty_parents(symlink.parent, profile)
            results.append(OperationResult(synth_entry, DotfileStatus.STALE))
        log_results(
            src_dir,
            results,
            verbose=verbose,
            problem_statuses=_INSTALL_PROBLEM_STATUSES,
        )
        if has_conflicts(results):
            had_conflicts = True
    if had_conflicts:
        raise ConflictsFound("Conflicts found during install")


def _run_audit(targets: list[tuple[Path, Profile]], *, verbose: bool) -> None:
    """Report each (source, profile) target's status plus any stale
    managed links; raise if anything diverges from the discovered
    set."""
    had_issues = False
    for src_dir, profile in targets:
        if not src_dir.exists():
            continue
        entries = discover_dotfiles(src_dir, profile=profile)
        results = _process_entries(entries, "audit")
        for _symlink, synth_entry in _find_stale_for_dir(
            src_dir, entries, profile
        ):
            results.append(OperationResult(synth_entry, DotfileStatus.STALE))
        log_results(
            src_dir,
            results,
            verbose=verbose,
            problem_statuses=_AUDIT_PROBLEM_STATUSES,
        )
        if has_conflicts(results) or has_missing(results) or has_stale(results):
            had_issues = True
    if had_issues:
        raise ConflictsFound(
            "Conflicts, missing entries, or stale links found during audit"
        )


def _run_remove(
    targets: list[tuple[Path, Profile]],
    *,
    dry_run: bool,
    verbose: bool,
    on_removed: Callable[[Path, Profile], None],
) -> None:
    """Remove each (source, profile) target's managed links, then
    untrack it via `on_removed` (skipped on a dry run). Only symlinks
    that point to the correct source are removed."""
    for src_dir, profile in targets:
        if not src_dir.exists():
            raise MissingDotfilesDirectory(
                f"Source directory does not exist: {src_dir}"
            )
        results = process_directory(
            src_dir, "remove", dry_run=dry_run, profile=profile
        )
        log_results(
            src_dir,
            results,
            verbose=verbose,
            problem_statuses=_REMOVE_PROBLEM_STATUSES,
        )
        if not dry_run:
            on_removed(src_dir, profile)


def do_install(
    directory: Path | None,
    dst: Path | None,
    *,
    dotfiles: bool,
    no_recurse: bool,
    dry_run: bool,
    force: bool,
    verbose: bool,
) -> None:
    """Install a source dir's entries into an explicit target dir
    (recording the install + its flags), or re-sync every tracked
    install when neither source nor target is given."""
    if directory is not None or dst is not None:
        if directory is None or dst is None:
            raise UsageError("install needs both a source and a target dir")
        src = directory.expanduser().resolve()
        target = dst.expanduser().resolve()
        if not src.is_dir():
            raise MissingDotfilesDirectory(
                f"Source directory does not exist: {src}"
            )
        record = LinkRecord(
            dst=target, src=src, dotfiles=dotfiles, no_recurse=no_recurse
        )
        if not dry_run:
            add_link_record(record)
        targets = [(src, record.profile())]
    else:
        targets = load_installed_entries()
        if not targets:
            logger.info("No installs tracked.")
            return
    _run_install(targets, dry_run=dry_run, force=force, verbose=verbose)


def _untrack_record(src_dir: Path, profile: Profile) -> None:
    """Drop the tracked record for (target, source)."""
    remove_link_record(profile.target_root(), src_dir)


def do_remove(
    directory: Path | None,
    dst: Path | None,
    *,
    dry_run: bool,
    verbose: bool,
) -> None:
    """Remove one tracked install's links (identified by its source and
    target dirs) and untrack it, or remove every tracked install when
    neither is given."""
    if directory is not None or dst is not None:
        if directory is None or dst is None:
            raise UsageError("remove needs both a source and a target dir")
        src = directory.expanduser().resolve()
        target = dst.expanduser().resolve()
        record = next(
            (
                r
                for r in load_link_records()
                if r.src == src and r.dst == target
            ),
            None,
        )
        if record is None:
            raise MissingDotfilesDirectory(
                f"No tracked install: {src} -> {target}"
            )
        targets = [(src, record.profile())]
    else:
        targets = load_installed_entries()
        if not targets:
            logger.info("No installs tracked.")
            return
    _run_remove(
        targets,
        dry_run=dry_run,
        verbose=verbose,
        on_removed=_untrack_record,
    )


def do_audit(*, verbose: bool) -> None:
    """Audit every tracked install (each under its own target root).

    Reports the status of each discovered entry plus any STALE managed
    symlinks -- symlinks under a target root that point into the audited
    source but whose relative path is no longer in the discovered set
    (file removed from the source, or matched by an ignore file)."""
    targets = load_installed_entries()
    if not targets:
        return
    _run_audit(targets, verbose=verbose)


def do_cleanup(*, dry_run: bool) -> None:
    """Remove dangling and stale managed symlinks from the
    directories the profile manages.

    A *dangling* symlink points to a target that no longer exists on
    disk and is removed regardless of where it points. A *stale
    managed* symlink resolves into one of the installed source
    directories but to a path that is no longer in that source's
    discovered set -- because the file was removed from the repo or
    now matches an ignore file. Symlinks that point outside every
    installed source directory and resolve to an existing file are
    foreign and left alone.

    The scan set spans every tracked record's target root plus the
    parent directory of every entry currently discovered across all
    tracked sources.

    Args:
        dry_run: If True, log what would be removed without removing it.
    """
    target_roots: set[Path] = set()
    scan_dirs: set[Path] = set()
    sources: dict[Path, set[Path]] = {}

    for src_dir, profile in load_installed_entries():
        if not src_dir.exists():
            continue
        root = profile.target_root()
        target_roots.add(root)
        scan_dirs.add(root)
        rels: set[Path] = set()
        for entry in discover_dotfiles(src_dir, profile=profile):
            rels.add(entry.relative_path)
            scan_dirs.add(entry.target_path.parent)
        # Union, not assignment: one source can be installed under more
        # than one record (e.g. into two targets, or with different
        # recurse flags). A link is current if its relative path is
        # delivered by any of them, so a valid link is never reclaimed
        # because a different record for the same source omits it.
        sources.setdefault(src_dir.resolve(), set()).update(rels)

    src_list = list(sources.keys())
    for scan_dir in sorted(scan_dirs):
        if not scan_dir.is_dir():
            continue
        for item in sorted(scan_dir.iterdir()):
            if not item.is_symlink():
                continue
            link = _link_source_dir(item, src_list)
            if link is not None:
                src, rel = link
                if rel in sources[src]:
                    continue
                logger.info("removing stale managed symlink: %s", item)
                if not dry_run:
                    item.unlink()
                    _prune_empty_dirs(item.parent, target_roots)
                continue
            if not item.exists():
                logger.info("removing dangling symlink: %s", item)
                if not dry_run:
                    item.unlink()


# =============================================================================
# ARGUMENT PARSER
# =============================================================================


def build_parser() -> StrictArgumentParser:
    """
    Build and return the argument parser.

    Returns:
        Configured ArgumentParser instance
    """
    parser = StrictArgumentParser(
        prog=LINKFILES_PROFILE.name,
        description=LINKFILES_PROFILE.description,
        epilog=ExitCode.epilog(),
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )
    subparsers = parser.add_command_subparsers(help="Subcommands")

    # Install subcommand
    install_parser = subparsers.add_parser(
        "install",
        help=(
            "Sync a source directory into a target: link new entries, "
            "prune stale managed links"
        ),
    )
    install_parser.add_argument(
        "--dry-run",
        action="store_true",
        help="Show what would be done without making changes",
    )
    install_parser.add_argument(
        "-f",
        "--force",
        action="store_true",
        help="Replace conflicting symlinks (not files)",
    )
    install_parser.add_argument(
        "-v",
        "--verbose",
        action="store_true",
        help="Print every entry; default suppresses ok lines",
    )
    install_parser.add_argument(
        "--dotfiles",
        action="store_true",
        help="Dot-prefix each top-level entry under the target",
    )
    install_parser.add_argument(
        "--no-recurse",
        action="store_true",
        help="Link only top-level entries; do not descend",
    )
    install_parser.add_argument(
        "directory",
        type=Path,
        nargs="?",
        help="Source directory to install entries from",
    )
    install_parser.add_argument(
        "dst",
        type=Path,
        nargs="?",
        help="Target directory to link the source's entries into",
    )

    # Remove subcommand
    remove_parser = subparsers.add_parser(
        "remove", help="Remove an installed source / target pair"
    )
    remove_parser.add_argument(
        "--dry-run",
        action="store_true",
        help="Show what would be done without making changes",
    )
    remove_parser.add_argument(
        "-v",
        "--verbose",
        action="store_true",
        help="Print every entry; default suppresses ok lines",
    )
    remove_parser.add_argument(
        "directory",
        type=Path,
        nargs="?",
        help="Source directory whose entries should be removed",
    )
    remove_parser.add_argument(
        "dst",
        type=Path,
        nargs="?",
        help="Target directory the install was linked into",
    )

    # Audit subcommand
    audit_parser = subparsers.add_parser(
        "audit",
        help=(
            "Report status of installed entries; fails on conflicts, "
            "missing entries, or stale managed links"
        ),
    )
    audit_parser.add_argument(
        "-v",
        "--verbose",
        action="store_true",
        help="Print every entry; default suppresses ok lines",
    )

    # Cleanup subcommand
    cleanup_parser = subparsers.add_parser(
        "cleanup",
        help="Remove dangling and stale managed symlinks",
    )
    cleanup_parser.add_argument(
        "--dry-run",
        action="store_true",
        help="Show what would be removed without removing it",
    )

    return parser


# =============================================================================
# COMMAND DISPATCH
# =============================================================================

COMMAND_CALLBACKS: dict[str, Callable[..., None]] = {
    "install": do_install,
    "remove": do_remove,
    "audit": do_audit,
    "cleanup": do_cleanup,
}


@cli_entrypoint
def cli() -> int:
    """CLI entry point with exception handling."""
    parser = build_parser()
    args_dict = vars(parser.parse_command())
    command = args_dict.pop("command")

    try:
        COMMAND_CALLBACKS[command](**args_dict)
    except KeyError:
        raise UsageError(f"Unknown command '{command}'") from None
    except DotfilesError as e:
        logger.error("ERROR: %s", e)
        return e.exit_code
    return ExitCode.SUCCESS


if __name__ == "__main__":
    raise SystemExit(cli())
