# =============================================================================
# TRACKING-FILE RECORDS
# =============================================================================
#
# Two tracking files share one on-disk format: one record per line, fields
# tab-separated and backslash-escaped so an arbitrary path (even one with a
# tab or newline) round-trips on a single line. ~/.linkfiles.installed holds
# one InstallRecord per install (`<tgt>\t<src>[\t<flags>]`);
# ~/.linkfiles.linked holds one LinkRecord per individual symlink
# (`<tgt>\t<src>`). `LineRecord` carries the shared escaping and line
# (de)serialization; each subclass only declares its field layout.

_FLAG_DOTFILES = "dotfiles"
_FLAG_NO_RECURSE = "no-recurse"


@dataclass(frozen=True)
class LineRecord(ABC):
    """Base for a record stored one per line in a tab-delimited,
    backslash-escaped tracking file. Subclasses declare their on-disk
    fields via `_fields` / `_from_fields`; field escaping and the
    `to_line` / `from_line` round-trip are shared here."""

    @staticmethod
    def encode(value: str) -> str:
        """Escape a single field: the escape char, the field separator
        (tab), and the record separator (newline)."""
        return (
            value.replace("\\", "\\\\")
            .replace("\t", "\\t")
            .replace("\n", "\\n")
        )

    @staticmethod
    def decode(value: str) -> str:
        """Inverse of `encode`."""
        out: list[str] = []
        i = 0
        while i < len(value):
            ch = value[i]
            if ch == "\\" and i + 1 < len(value):
                mapped = {"\\": "\\", "t": "\t", "n": "\n"}.get(value[i + 1])
                if mapped is not None:
                    out.append(mapped)
                    i += 2
                    continue
            out.append(ch)
            i += 1
        return "".join(out)

    @staticmethod
    def _split(line: str) -> list[str]:
        """Split a record line on unescaped tabs into still-escaped
        fields."""
        fields: list[str] = []
        cur: list[str] = []
        i = 0
        while i < len(line):
            ch = line[i]
            if ch == "\\" and i + 1 < len(line):
                cur.append(ch)
                cur.append(line[i + 1])
                i += 2
                continue
            if ch == "\t":
                fields.append("".join(cur))
                cur = []
                i += 1
                continue
            cur.append(ch)
            i += 1
        fields.append("".join(cur))
        return fields

    @abstractmethod
    def _fields(self) -> list[str]:
        """This record's fields, unescaped, in on-disk order."""

    @classmethod
    @abstractmethod
    def _from_fields(cls, fields: list[str]) -> Self | None:
        """Build a record from its split + unescaped fields, or None when
        the field list is malformed."""

    def to_line(self) -> str:
        return "\t".join(self.encode(f) for f in self._fields())

    @classmethod
    def from_line(cls, line: str) -> Self | None:
        return cls._from_fields([cls.decode(f) for f in cls._split(line)])


@dataclass(frozen=True)
class InstallRecord(LineRecord):
    """One tracked install: a source dir linked into a target dir, plus
    the flags that shaped the links. Identity is (tgt, src). Stored in
    ~/.linkfiles.installed."""

    tgt: Path
    src: Path
    dotfiles: bool
    no_recurse: bool

    def flag_tokens(self) -> list[str]:
        """The flags as their on-disk tokens, in a stable order."""
        tokens: list[str] = []
        if self.dotfiles:
            tokens.append(_FLAG_DOTFILES)
        if self.no_recurse:
            tokens.append(_FLAG_NO_RECURSE)
        return tokens

    def _fields(self) -> list[str]:
        fields = [str(self.tgt), str(self.src)]
        tokens = self.flag_tokens()
        if tokens:
            fields.append(",".join(tokens))
        return fields

    @classmethod
    def _from_fields(cls, fields: list[str]) -> InstallRecord | None:
        if len(fields) < 2:
            return None
        flags = set(fields[2].split(",")) if len(fields) > 2 else set()
        return cls(
            tgt=Path(fields[0]),
            src=Path(fields[1]),
            dotfiles=_FLAG_DOTFILES in flags,
            no_recurse=_FLAG_NO_RECURSE in flags,
        )


def _atomic_write(path: Path, content: str) -> None:
    """Write `content` to `path` atomically -- a temp file in the same
    directory, fsynced, then `os.replace`d over the target -- so an
    interrupted write never leaves a half-written tracking file."""
    path.parent.mkdir(parents=True, exist_ok=True)
    tmp = path.with_name(f"{path.name}.tmp")
    with open(tmp, "w", encoding="utf-8") as fh:
        fh.write(content)
        fh.flush()
        os.fsync(fh.fileno())
    os.replace(tmp, path)


def _serialize(records: Iterable[LineRecord]) -> str:
    """Render records to tracking-file content, one sorted line each."""
    return "".join(f"{line}\n" for line in sorted(r.to_line() for r in records))


def load_install_records() -> list[InstallRecord]:
    """Parse ~/.linkfiles.installed into InstallRecords. A malformed line
    (fewer than two fields) is skipped."""
    if not INSTALLED_FILE.exists():
        return []
    records: list[InstallRecord] = []
    for line in INSTALLED_FILE.read_text(encoding="utf-8").splitlines():
        if not line.strip():
            continue
        rec = InstallRecord.from_line(line)
        if rec is None:
            logger.warning("skipping malformed linkfiles record: %s", line)
            continue
        records.append(rec)
    return records


def save_install_records(records: list[InstallRecord]) -> None:
    """Write the install records to ~/.linkfiles.installed (atomic,
    sorted by line)."""
    _atomic_write(INSTALLED_FILE, _serialize(records))


# =============================================================================
# LINKED-FILE LEDGER (~/.linkfiles.linked)
# =============================================================================
#
# An internal record of every individual symlink linkfiles maintains:
# one `<tgt>\t<src>` line per link (tgt = the symlink, src = the source
# file it points to), with the same escaping and (tgt, src) sort as the
# install tracking file. It lets install/remove prune dangling links and
# tear down an install's links without re-discovering the source -- so
# cleanup works even when the source directory is gone. `WorldState.load`
# builds a `LinkPlan` from it (plus the source scan and the targets'
# on-disk state); the plan is executed and written back here.
#
# It is not part of the CLI surface (no --help flag reads or writes it);
# the man page / GFM doc note it in their FILES section. When the file is
# absent (a pre-ledger install), the links are seeded in memory from source
# discovery and written out on the next install.


@dataclass(frozen=True)
class LinkRecord(LineRecord):
    """One source-to-target link: `tgt` is the link path, `src` the source
    file it points to. Identity is (tgt, src); only those two serialize to
    ~/.linkfiles.linked. Carries the mechanics of the link (its on-disk
    status, and creating / removing it) plus, once categorized, the
    `install` it belongs to. `install` is None for a record freshly loaded
    from the ledger file -- it is stamped when the link is matched to an
    install while building world state -- and is excluded from identity."""

    tgt: Path
    src: Path

    # The install this link belongs to, stamped when the record is
    # categorized (a record loaded from the ledger has none until then).
    install: InstallRecord | None = field(default=None, compare=False)

    # The on-disk probe, cached per instance so status() (and the
    # create / remove that consult it) reads the target once. A record is
    # rebuilt each command and its status is read before the link it
    # describes is created or removed, so the cache is never observed
    # stale -- which a process-global cache could not promise.
    # compare=False keeps two equal records equal regardless of probe.
    _status: LinkStatus | None = field(
        default=None, init=False, compare=False, repr=False
    )

    @property
    def relative_path(self) -> Path:
        """The source path relative to the owning install's source dir,
        for display. Falls back to the basename when src isn't under it."""
        assert self.install is not None
        if self.src.is_relative_to(self.install.src):
            return self.src.relative_to(self.install.src)
        return Path(self.src.name)

    def _fields(self) -> list[str]:
        return [str(self.tgt), str(self.src)]

    @classmethod
    def _from_fields(cls, fields: list[str]) -> LinkRecord | None:
        if len(fields) < 2:
            return None
        return cls(tgt=Path(fields[0]), src=Path(fields[1]))

    def status(self) -> LinkStatus:
        """Classify what is at `tgt` relative to this record: OK (our
        symlink, possibly dangling), MISSING (nothing there),
        LINK_CONFLICT (a symlink elsewhere), NONLINK_CONFLICT (a real
        file/dir). `src` existence is judged separately, against the
        scanned source snapshot. The probe is cached after the first
        call."""
        cached = self._status
        if cached is None:
            cached = self._probe()
            object.__setattr__(self, "_status", cached)
        return cached

    def _probe(self) -> LinkStatus:
        if self.tgt.is_symlink():
            if _link_target(self.tgt) == self.src:
                return LinkStatus.OK
            return LinkStatus.LINK_CONFLICT
        if self.tgt.exists():
            return LinkStatus.NONLINK_CONFLICT
        return LinkStatus.MISSING

    def create(self, *, dry_run: bool) -> LinkStatus:
        """Create the symlink, returning the resulting status. An
        already-correct link stays OK; a missing target becomes INSTALLED.
        A foreign symlink in the way is replaced (the plan schedules a link
        for creation only once replacement is authorized); a real file/dir
        is never touched (NONLINK_CONFLICT)."""
        status = self.status()
        if status == LinkStatus.OK:
            return LinkStatus.OK
        if status == LinkStatus.NONLINK_CONFLICT:
            return LinkStatus.NONLINK_CONFLICT
        if status == LinkStatus.LINK_CONFLICT and not dry_run:
            self.tgt.unlink()
        if not dry_run:
            self.tgt.parent.mkdir(parents=True, exist_ok=True)
            rel = Path(os.path.relpath(self.src, self.tgt.parent))
            self.tgt.symlink_to(rel)
        return LinkStatus.INSTALLED

    def remove(self, *, dry_run: bool, target_root: Path) -> bool:
        """Remove the symlink if linkfiles still owns it, pruning empty
        parents up to `target_root`. Tolerant of drift -- a link already
        gone, replaced by the user, or unremovable -- which warns and is
        skipped without aborting. Returns True if the ledger entry should
        be dropped (removed, gone, or no longer ours)."""
        status = self.status()
        if status != LinkStatus.OK:
            if status == LinkStatus.MISSING:
                logger.warning("linked path already gone: %s", self.tgt)
            else:
                logger.warning(
                    "linked path is no longer linkfiles' link, leaving it: %s",
                    self.tgt,
                )
            return True
        if dry_run:
            return False
        try:
            self.tgt.unlink()
            _prune_empty_dirs(self.tgt.parent, {target_root})
        except OSError as exc:
            logger.warning("could not remove linked path %s: %s", self.tgt, exc)
            return False
        return True


class LinkPlan:
    """The categorized plan for one run, kept as a live model of the links.
    `WorldState.load` builds it from the recorded links (~/.linkfiles.linked),
    the current source scan, and each target's on-disk state. Executing a
    phase updates the buckets so the plan always resembles what a reload would
    produce: `install_links` creates each INSTALL link and moves it to KEEP;
    `remove_links` drops the links it unlinks and leaves any it could not in
    REMOVE. `write` persists every still-tracked link (keep + install +
    remove); conflict links are not ours and orphans were dropped at build
    time, so neither is written."""

    def __init__(self) -> None:
        # The buckets a link lands in, after the desired set (the source
        # scan) is matched against the recorded ledger and the target's
        # on-disk state:
        #   keep     -- wanted and already correctly linked; also carries an
        #               out-of-scope install's recorded links (added by
        #               WorldState.load), written back untouched and scoped
        #               out of reporting.
        #   install  -- wanted but not yet linked (new entry, hand-removed
        #               link, interrupted run, or a force-replaceable
        #               conflict).
        #   remove   -- recorded but no longer wanted (source file gone or
        #               now ignored).
        #   conflict -- wanted, but the target is occupied by something else
        #               (a foreign symlink, or a real file/dir).
        self.keep: list[LinkRecord] = []
        self.install: list[LinkRecord] = []
        self.remove: list[LinkRecord] = []
        self.conflict: list[LinkRecord] = []

    def preserve(self, link: LinkRecord) -> None:
        """Carry an out-of-scope install's already-correct link through to
        keep untouched. Used by `WorldState.load`; the link is written back
        and scoped out of reporting."""
        self.keep.append(link)

    def categorize(
        self,
        install: InstallRecord,
        recorded: list[LinkRecord],
        desired: list[LinkRecord],
        *,
        force_install: bool,
    ) -> None:
        """Bucket one in-scope install's links, reading each target's on-disk
        status exactly once. `desired` is what the source currently wants (one
        scan, ignores applied); `recorded` is the install's links already in
        the ledger. Each link is stamped with its owning install. A wanted
        target is keep (already linked), install (missing, or a foreign
        symlink when `force_install`), or conflict (blocked); a recorded
        target the source no longer wants is remove. `force_install` is
        consumed here -- the resulting plan already reflects which conflicts
        will be replaced."""
        recorded_by_tgt = {rec.tgt: rec for rec in recorded}
        wanted = {rec.tgt: rec for rec in desired}
        # Sorted so each bucket -- and the per-link report built from it --
        # is deterministic regardless of dict / set iteration order.
        for tgt in sorted(wanted.keys() | recorded_by_tgt.keys()):
            want = wanted.get(tgt)
            link = want if want is not None else recorded_by_tgt[tgt]
            # Stamp the owning install (a record loaded from the ledger has
            # none until matched here); for a discovered want it is a no-op.
            object.__setattr__(link, "install", install)
            status = link.status()
            if want is None:
                self.remove.append(link)
            elif status == LinkStatus.OK:
                self.keep.append(link)
            elif status == LinkStatus.MISSING or (
                status == LinkStatus.LINK_CONFLICT and force_install
            ):
                self.install.append(link)
            else:
                self.conflict.append(link)

    def keep_links(self) -> list[OperationResult]:
        """The keep links, each reported OK. Taken before `install_links`
        runs, so it is the already-correct links, not the freshly installed
        ones (which report via `install_links`)."""
        return [OperationResult(link, LinkStatus.OK) for link in self.keep]

    def conflict_links(self) -> list[OperationResult]:
        """The conflict links, each reporting its own link / nonlink kind.
        The bucket already excludes conflicts the plan will replace (those
        are in install), so this is exactly the conflicts that remain."""
        return [OperationResult(link, link.status()) for link in self.conflict]

    def remove_links(self, *, dry_run: bool) -> list[OperationResult]:
        """Unlink every remove link (pruning empty parents), reporting REMOVED
        when it was ours and is now gone or MISSING when it was already absent
        or no longer ours. A link that is unlinked leaves the bucket; one that
        could not be unlinked stays in remove, so it is written back and a
        later run of its still-tracked install retries it. A dry run reports
        without unlinking and leaves the bucket untouched. Used to prune stale
        links (install) and to tear an install down (remove)."""
        results: list[OperationResult] = []
        unremovable: list[LinkRecord] = []
        for link in self.remove:
            present = link.status() is LinkStatus.OK
            dropped = link.remove(
                dry_run=dry_run, target_root=_install_of(link).tgt
            )
            if not dropped:
                unremovable.append(link)
            results.append(
                OperationResult(
                    link,
                    LinkStatus.REMOVED if present else LinkStatus.MISSING,
                )
            )
        if not dry_run:
            self.remove = unremovable
        return results

    def install_links(self, *, dry_run: bool) -> list[OperationResult]:
        """Create every install link (replacing a foreign symlink, present in
        this bucket only because the plan authorized replacement), moving each
        into keep now that it is correctly linked, and report INSTALLED / OK
        per link. A dry run reports without creating and leaves the buckets
        untouched."""
        results: list[OperationResult] = []
        for link in self.install:
            results.append(OperationResult(link, link.create(dry_run=dry_run)))
            if not dry_run:
                self.keep.append(link)
        if not dry_run:
            self.install = []
        return results

    def describe(self) -> list[OperationResult]:
        """Per-link outcome for the whole plan without acting on it -- audit's
        read-only view. Each link reports its own on-disk status (a keep link
        probes OK, an install link MISSING, a conflict its link / nonlink
        kind), except a remove link, which is a recorded link the source no
        longer wants -- on disk a valid symlink (status OK), reported STALE so
        audit surfaces it as a divergence to prune."""
        return (
            [OperationResult(link, link.status()) for link in self.keep]
            + [OperationResult(link, link.status()) for link in self.install]
            + [OperationResult(link, LinkStatus.STALE) for link in self.remove]
            + [OperationResult(link, link.status()) for link in self.conflict]
        )

    def write(self) -> None:
        """Persist every still-tracked link to ~/.linkfiles.linked (atomic):
        the keep links (in-scope, out-of-scope, and -- after `install_links`
        -- freshly installed), any install links not yet created (recorded
        write-ahead so an interrupted run re-creates them), and any remove
        link a removal could not unlink. Conflict links are not ours, and
        orphans were dropped at build time, so neither is written."""
        records = self.keep + self.install + self.remove
        _atomic_write(LINKED_FILE, _serialize(records))


# =============================================================================
# ENTRY DISCOVERY
# =============================================================================


# Ignore file names to load patterns from. .linkfiles.ignore is the
# preferred way to keep something tracked in git but unlinked by install
# (e.g. tests/, README.md, .github/, pyproject.toml). The .gitignore /
# .hgignore reads cover the common case where a file you don't want
# tracked also shouldn't be linked (editor backups, build outputs). All
# modes read the whole set.
IGNORE_FILES = {
    ".gitignore",
    ".hgignore",
    ".linkfiles.ignore",
}

# Editor / swap / autosave patterns always excluded, even when no
# ignore file is reachable. Matched as fnmatch globs against filename
# and path components.
HARDCODED_IGNORE_PATTERNS: frozenset[str] = frozenset(
    {
        "*~",
        "*.swp",
        "*.swo",
        ".*.swp",
        "#*#",
    }
)


def _is_repo_root(path: Path) -> bool:
    """Return True if path looks like a git or hg repo root.

    Both '.git' and '.hg' may be a directory or, for git worktrees /
    submodules, a regular file containing a 'gitdir:' pointer --
    Path.exists() catches both shapes.
    """
    return (path / ".git").exists() or (path / ".hg").exists()


def _ignore_search_dirs(source_dir: Path) -> list[Path]:
    """Return source_dir plus ancestors up to the enclosing repo root.

    The walk consumes source_dir and continues upward until it hits
    (and includes) the first ancestor that contains a '.git' or '.hg'
    entry -- the enclosing git/hg repo root. This covers the
    motivating case ('binfiles install ~/utils/bin' needs to see
    '~/utils/.gitignore', which lives one level above bin) without
    pulling in the user's $HOME-level ignore files, where flat-merged
    patterns -- especially leading-/ anchored ones -- would be
    re-interpreted relative to source_dir and silently mismatch.

    If no enclosing repo root exists between source_dir and $HOME,
    the walk falls back to stopping at $HOME inclusive. A source_dir
    outside $HOME consults only source_dir itself.
    """
    abs_dir = source_dir.resolve()
    dirs = [abs_dir]
    try:
        home = Path.home().resolve()
    except (OSError, RuntimeError):
        return dirs
    if abs_dir == home:
        return dirs
    if home not in abs_dir.parents:
        return dirs
    if _is_repo_root(abs_dir):
        return dirs
    for parent in abs_dir.parents:
        dirs.append(parent)
        if _is_repo_root(parent):
            break
        if parent == home:
            break
    return dirs


def load_ignore_patterns(source_dir: Path) -> set[str]:
    """
    Load ignore patterns from each file in IGNORE_FILES.

    Patterns are collected from source_dir and each ancestor directory
    up to and including the enclosing repo root (see
    _ignore_search_dirs for the exact walk bound), plus a hardcoded
    set of editor / swap / autosave file patterns that always apply.

    .linkfiles.ignore is the preferred way to exclude something that is
    tracked in git but should not be linked into the target tree (tests/,
    README.md, project config). .gitignore / .hgignore covers the case
    where a file you don't want tracked also shouldn't be linked (editor
    backups, build outputs).

    Patterns are simple glob patterns (supports *, ?, []).
    Lines starting with # are comments.
    Empty lines are skipped.
    Negation patterns (!) are not supported.

    A leading '/' anchors the pattern to source_dir's root, matching
    gitignore semantics: '/CLAUDE.md' excludes only the root-level
    CLAUDE.md, leaving nested files like 'claude/CLAUDE.md' eligible
    for linking. The leading slash is preserved in the returned set
    and interpreted by matches_ignore_pattern.

    Note: anchored patterns collected from an ancestor ignore file
    (e.g. '/foo' in the repo root's '.gitignore' while source_dir
    is a subdir of the repo) anchor to source_dir, not to the
    ancestor directory the pattern was written in. This diverges
    from gitignore proper, which anchors each pattern at its own
    .gitignore's directory. The flat-merge collection here is the
    underlying cause; practical impact is bounded because the walk
    stops at the enclosing repo root (see _ignore_search_dirs).

    Returns:
        Set of glob patterns to ignore.
    """
    patterns: set[str] = set(HARDCODED_IGNORE_PATTERNS)

    for directory in _ignore_search_dirs(source_dir):
        for ignore_file in IGNORE_FILES:
            ignore_path = directory / ignore_file
            if not (ignore_path.exists() and ignore_path.is_file()):
                continue
            try:
                content = ignore_path.read_text(encoding="utf-8")
            except OSError:
                continue
            for line in content.splitlines():
                line = line.strip()
                if not line or line.startswith("#"):
                    continue
                if line.startswith("!"):
                    continue
                # gitignore patterns use '\X' to escape a literal X
                # anywhere in the pattern (git's wildmatch). fnmatch
                # treats '\' as a literal character with no escape
                # semantics, so unescape '\#' and '\!' before adding --
                # otherwise a real-world pattern like '\#*\#' (matching
                # emacs autosave files) would never fire.
                pattern = line.replace(r"\#", "#").replace(r"\!", "!")
                # gitignore convention suffixes directory patterns with
                # '/' (e.g. 'tests/'). fnmatch has no concept of
                # trailing slash; strip it so the path-component check
                # in matches_ignore_pattern does the right thing. A
                # leading '/' is kept as the anchored-pattern marker
                # consumed by matches_ignore_pattern.
                if pattern.endswith("/") and len(pattern) > 1:
                    pattern = pattern[:-1]
                patterns.add(pattern)

    return patterns


def matches_ignore_pattern(path: Path, patterns: set[str]) -> bool:
    """
    Check if a path matches any of the ignore patterns.

    Unanchored patterns are checked via fnmatch against the basename,
    the full relative path, and each path component -- so a bare
    'CLAUDE.md' excludes that file at any depth.

    Patterns with a leading '/' are anchored to the source_dir root,
    matching gitignore semantics. An anchored bare name like
    '/CLAUDE.md' matches only the first path component (root-level
    file or root-level directory by that name), leaving nested
    'claude/CLAUDE.md' eligible for linking. An anchored multi-segment
    pattern like '/foo/bar' matches the full relative path AND any
    descendant of it ('/foo/bar' excludes 'foo/bar' itself plus
    'foo/bar/baz') so it works as a directory exclusion the same way
    the bare-name branch does.

    Args:
        path: Relative path to check
        patterns: Set of glob patterns

    Returns:
        True if the path matches any pattern.
    """
    path_str = str(path)
    filename = path.name
    first_part = path.parts[0] if path.parts else ""

    for pattern in patterns:
        if pattern.startswith("/") and len(pattern) > 1:
            anchored = pattern[1:]
            if "/" in anchored:
                if fnmatch.fnmatch(path_str, anchored) or fnmatch.fnmatch(
                    path_str, anchored + "/*"
                ):
                    return True
            else:
                if fnmatch.fnmatch(first_part, anchored):
                    return True
            continue
        # Check if pattern matches the filename
        if fnmatch.fnmatch(filename, pattern):
            return True
        # Check if pattern matches the full relative path
        if fnmatch.fnmatch(path_str, pattern):
            return True
        # Check if pattern matches any path component
        for part in path.parts:
            if fnmatch.fnmatch(part, pattern):
                return True

    return False


def _target_path(install: InstallRecord, relative: Path) -> Path:
    """The link path for a source entry: its path relative to the source
    placed under the install's tgt, with the top-level component
    dot-prefixed under the dotfiles flag (`bashrc` -> `.bashrc`)."""
    parts = relative.parts
    first = ("." + parts[0]) if install.dotfiles else parts[0]
    return install.tgt / Path(first, *parts[1:])


def discover_entries(record: InstallRecord) -> list[LinkRecord]:
    """
    Discover the links an install wants from its source directory, one
    LinkRecord per discovered entry (with `install` set).

    Common rules:
    - Skip any dotfile -- an entry with a leading-'.' component at any
      depth (so .git / .hg / .github, the ignore files, and editor
      state never link).
    - Skip files matching patterns in .gitignore / .hgignore /
      .linkfiles.ignore from the source dir and each ancestor up to the
      enclosing repo root, plus a hardcoded set of editor / swap /
      autosave patterns.

    With the record's no_recurse flag, only top-level entries are
    considered; subdirectories are not descended into.

    Raises:
        LinkfilesError: If the directory doesn't exist or isn't valid.
    """
    source_dir = record.src
    if not source_dir.exists():
        raise LinkfilesError(f"Source directory does not exist: {source_dir}")
    if not source_dir.is_dir():
        raise LinkfilesError(f"Not a directory: {source_dir}")

    abs_source_dir = source_dir.resolve()
    links: list[LinkRecord] = []

    ignore_patterns = load_ignore_patterns(abs_source_dir)

    candidates: Iterator[Path]
    if record.no_recurse:
        candidates = abs_source_dir.iterdir()
    else:
        candidates = abs_source_dir.rglob("*")

    for item in candidates:
        # Include files and symlinks, but not directories
        # (symlinks are included even if they point to directories).
        if not (item.is_file() or item.is_symlink()):
            continue
        relative = item.relative_to(abs_source_dir)
        # Skip any dotfile -- a leading-'.' component at any depth. This
        # covers VCS / metadata dirs (.git, .hg, .github), the ignore
        # files themselves, and editor state, without linking them into
        # the target tree.
        if any(part.startswith(".") for part in relative.parts):
            continue
        if matches_ignore_pattern(relative, ignore_patterns):
            continue
        links.append(
            LinkRecord(
                tgt=_target_path(record, relative),
                src=item,
                install=record,
            )
        )

    links.sort(key=lambda link: str(link.src))
    return links


# =============================================================================
# ENTRY OPERATIONS
# =============================================================================


def _link_target(symlink: Path) -> Path | None:
    """Compute the symlink's immediate target as an absolute path.

    The symlink's parent directory is resolved (so paths like
    /tmp/... canonicalize to /private/tmp/... on macOS, matching the
    resolved source paths recorded in the ledger). The readlink value
    is appended literally and any '.'/'..' segments in the joined path
    are normalized -- but symlinks within the target are NOT followed.

    The non-following matters when the source dir contains internal
    symlinks: e.g. claude/DEVELOPMENT_SHARED.md -> ../_repo_shared/
    files/DEVELOPMENT_SHARED.md. A managed link
    ~/.claude/DEVELOPMENT_SHARED.md -> .../dotfiles/claude/
    DEVELOPMENT_SHARED.md must match the immediate
    claude/DEVELOPMENT_SHARED.md the ledger recorded, not the chain end
    at _repo_shared/files/... (which would make linkfiles disown its
    own link).

    Returns None if the symlink can't be read.
    """
    try:
        link_value = Path(os.readlink(symlink))
    except OSError:
        return None
    try:
        parent_resolved = symlink.parent.resolve(strict=False)
    except OSError:
        return None
    return Path(os.path.normpath(str(parent_resolved / link_value)))


def _prune_empty_dirs(directory: Path, stop_at: set[Path]) -> None:
    """Remove empty directories from `directory` upward, stopping
    before any path in `stop_at` -- the managed target roots, which
    must never be removed even when emptied."""
    current = directory
    while current not in stop_at and current.exists():
        try:
            current.rmdir()  # Only succeeds if empty
            current = current.parent
        except OSError:
            break


# =============================================================================
# RESULT REPORTING
# =============================================================================


# Per-operation classification of which LinkStatus values count
# as *problems* (anything else is either OK or a successful action).
# install / remove that complete cleanly may yield INSTALLED, REMOVED,
# or (for install) STALE-pruned entries -- those are state changes,
# not errors. audit, by contrast, doesn't fix anything, so any
# status that says the target tree diverges from the discovered set
# is a problem the user needs to see.
_INSTALL_PROBLEM_STATUSES: frozenset[LinkStatus] = frozenset(
    {LinkStatus.NONLINK_CONFLICT, LinkStatus.LINK_CONFLICT}
)
_REMOVE_PROBLEM_STATUSES: frozenset[LinkStatus] = frozenset(
    {LinkStatus.NONLINK_CONFLICT, LinkStatus.LINK_CONFLICT}
)
_AUDIT_PROBLEM_STATUSES: frozenset[LinkStatus] = frozenset(
    {
        LinkStatus.MISSING,
        LinkStatus.NONLINK_CONFLICT,
        LinkStatus.LINK_CONFLICT,
        LinkStatus.STALE,
    }
)


def _format_status(
    status: LinkStatus, problem_statuses: frozenset[LinkStatus]
) -> str:
    code = _ANSI_RED if status in problem_statuses else _ANSI_GREEN
    return _colorize(status.value, code)


def log_results(
    source_dir: Path,
    results: list[OperationResult],
    *,
    verbose: bool = False,
    problem_statuses: frozenset[LinkStatus] = frozenset(),
) -> None:
    """Log the results of processing a directory.

    Default mode collapses an all-ok run to a single '<dir>: ok'
    line. When some entries are non-ok (state changes like INSTALLED
    or actual problems like LINK_CONFLICT), those entries print
    under the dir header. The header itself reads ': error' only
    when at least one entry's status is in problem_statuses --
    successful state changes don't flip the header. Verbose mode
    prints every entry, ok included.

    problem_statuses is the per-operation classifier: install /
    remove flag only file/link conflicts (so INSTALLED, REMOVED,
    STALE-pruned all count as success), while audit flags anything
    that says the target tree diverges from the discovered set.

    On a color-capable TTY the header suffix and per-entry status
    text are colored: green for non-problem, red for problem.
    """
    has_problem = any(r.status in problem_statuses for r in results)
    if has_problem:
        header_suffix = _colorize("error", _ANSI_RED)
    else:
        header_suffix = _colorize("ok", _ANSI_GREEN)

    if verbose:
        logger.info("%s: %s", source_dir, header_suffix)
        for result in results:
            logger.info(
                "    %s: %s",
                result.record.relative_path,
                _format_status(result.status, problem_statuses),
            )
        return

    non_ok = [r for r in results if r.status != LinkStatus.OK]
    if not non_ok:
        logger.info("%s: %s", source_dir, header_suffix)
        return

    logger.info("%s: %s", source_dir, header_suffix)
    for result in non_ok:
        logger.info(
            "    %s: %s",
            result.record.relative_path,
            _format_status(result.status, problem_statuses),
        )


def _install_of(link: LinkRecord) -> InstallRecord:
    """The install a categorized link belongs to (stamped in categorize)."""
    assert link.install is not None
    return link.install


def _report(
    state: WorldState,
    results: list[OperationResult],
    problem_statuses: frozenset[LinkStatus],
    *,
    verbose: bool,
) -> None:
    """Log per-link outcomes under each in-scope install's source header,
    grouped by the install each link belongs to."""
    grouped: dict[InstallRecord, list[OperationResult]] = {}
    for result in results:
        grouped.setdefault(_install_of(result.record), []).append(result)
    for install in state.scope:
        log_results(
            install.src,
            grouped.get(install, []),
            verbose=verbose,
            problem_statuses=problem_statuses,
        )


# =============================================================================
# SUBCOMMAND IMPLEMENTATIONS
# =============================================================================


# The do_* handlers build the WorldState for an invocation -- resolving the
# tracked installs and the in-scope set, and categorizing the link plan --
# then hand off to these shared runners.


@dataclass
class WorldState:
    """The categorized world a subcommand acts on. `installs` is the set
    written back to ~/.linkfiles.installed when the command finishes (for
    install, every tracked install including a new one; for remove, the ones
    that survive); `scope` the installs whose links this command processes
    and reports; `plan` the categorized LinkPlan; `missing_sources` the
    in-scope installs whose source dir is gone (their desired set is empty,
    so their recorded links fall to REMOVE)."""

    installs: list[InstallRecord]
    scope: list[InstallRecord]
    plan: LinkPlan
    missing_sources: list[InstallRecord]

    @classmethod
    def load(
        cls,
        *,
        install: InstallRecord | None = None,
        remove: InstallRecord | None = None,
        remove_all: bool = False,
        force_install: bool = False,
    ) -> WorldState:
        """Resolve the tracked install set against ~/.linkfiles.installed and
        build the categorized plan. At most one of `install` / `remove` /
        `remove_all` selects the operation; none re-syncs (or audits) every
        tracked install:

        - `install`: add or update this install and put it in scope.
        - `remove`: drop this install from the tracked set, with its links in
          scope (categorized REMOVE, since a removed install wants nothing).
        - `remove_all`: every install leaves the tracked set; all in scope.
        - none: every tracked install is in scope, the tracked set unchanged.

        `force_install` is forwarded to categorization, so the returned plan
        already encodes which conflicts will be replaced."""
        installs = load_install_records()
        if install is not None:
            installs = [
                r
                for r in installs
                if not (r.tgt == install.tgt and r.src == install.src)
            ]
            installs.append(install)
            scope = [install]
        elif remove is not None:
            scope = [remove]
            installs = [r for r in installs if r != remove]
        elif remove_all:
            scope = installs
            installs = []
        else:
            scope = installs
        return cls._build(installs, scope, force_install=force_install)

    @classmethod
    def _build(
        cls,
        installs: list[InstallRecord],
        scope: list[InstallRecord],
        *,
        force_install: bool,
    ) -> WorldState:
        """Partition the recorded links against the tracked-and-scoped
        installs and categorize each in-scope install's links from one source
        scan (ignores applied) plus one stat per target. A link owned by an
        in-scope install feeds its categorization; one owned by a
        tracked-but-out-of-scope install goes straight to KEEP (carried
        through untouched, scoped out of reporting); one owned by no tracked
        install (an orphan) is dropped. The links seed from source discovery
        when ~/.linkfiles.linked is absent -- from `installs` plus any `scope`
        installs not in it, so a removed install (no longer in `installs`)
        still gets its links seeded and cleaned."""
        known = installs + [s for s in scope if s not in installs]
        recorded = cls.load_link_records()
        if not recorded and not LINKED_FILE.exists():
            recorded = cls._seed_links_from_sources(known)
        scope_set = set(scope)
        per_install: dict[InstallRecord, list[LinkRecord]] = {
            install: [] for install in scope
        }
        plan = LinkPlan()
        for link in recorded:
            owner = cls._owning_install(link, known)
            if owner in scope_set:
                per_install[owner].append(link)
            elif owner is not None:
                object.__setattr__(link, "install", owner)
                plan.preserve(link)
        installs_set = set(installs)
        missing: list[InstallRecord] = []
        for install in scope:
            # An in-scope install absent from the tracked-after set is being
            # removed: it wants nothing, so its recorded links all fall to
            # REMOVE. One that stays tracked is synced against its source.
            if install in installs_set:
                desired = _desired_links(install)
                if not install.src.is_dir():
                    missing.append(install)
            else:
                desired = []
            plan.categorize(
                install,
                per_install[install],
                desired,
                force_install=force_install,
            )
        return cls(
            installs=installs,
            scope=scope,
            plan=plan,
            missing_sources=missing,
        )

    def save(self) -> None:
        """Persist the run's result: the surviving install records to
        ~/.linkfiles.installed and the post-run link plan to
        ~/.linkfiles.linked."""
        save_install_records(self.installs)
        self.plan.write()

    @staticmethod
    def load_link_records() -> list[LinkRecord]:
        """Parse ~/.linkfiles.linked into LinkRecords (empty when the file
        is absent). A malformed line (fewer than two fields) is skipped."""
        if not LINKED_FILE.exists():
            return []
        records: list[LinkRecord] = []
        for line in LINKED_FILE.read_text(encoding="utf-8").splitlines():
            if not line.strip():
                continue
            rec = LinkRecord.from_line(line)
            if rec is None:
                logger.warning("skipping malformed linkfiles link: %s", line)
                continue
            records.append(rec)
        return records

    @staticmethod
    def _seed_links_from_sources(
        installs: list[InstallRecord],
    ) -> list[LinkRecord]:
        """Seed the link set from each install's expected links by
        discovering its source. Used once when ~/.linkfiles.linked is
        absent, so a pre-ledger install has a baseline before the file is
        first written. A source already gone at seed time leaves no record
        of the links it once created, so its dangling links can't be seeded
        (or cleaned) until the source returns and a later install re-seeds
        from it."""
        records: list[LinkRecord] = []
        for install in installs:
            if not install.src.is_dir():
                continue
            records.extend(discover_entries(install))
        return records

    @staticmethod
    def _owning_install(
        link: LinkRecord, installs: list[InstallRecord]
    ) -> InstallRecord | None:
        """The install a recorded link belongs to: its source under the
        install's src and its target under the install's tgt. Install
        sources are non-nested, so at most one install matches; a link
        matching none is an orphan no longer owned by any tracked install."""
        for install in installs:
            if link.src.is_relative_to(install.src) and link.tgt.is_relative_to(
                install.tgt
            ):
                return install
        return None


def _desired_links(record: InstallRecord) -> list[LinkRecord]:
    """The links a source currently wants (ignores already applied), or
    an empty list when the source dir is gone."""
    if not record.src.is_dir():
        return []
    return discover_entries(record)


def _run_install(state: WorldState, *, dry_run: bool, verbose: bool) -> None:
    """Apply the plan in an interruption-safe order: unlink every REMOVE
    link, persist the tracking files (.installed then .linked) recording the
    wanted links *before* they exist, then create them. A crash at any step
    leaves a state the next run reconciles. A CONFLICT is a hard error unless
    the plan already resolved it (a foreign symlink under --force, which the
    plan placed in INSTALL); a non-link is never touched. Raises
    ConflictsFound if any wanted link stays blocked."""
    plan = state.plan
    for install in state.missing_sources:
        logger.warning(
            "tracked source is missing, pruning its links: %s", install.src
        )
    # Take the keep report before install_links moves the freshly created
    # links into KEEP, so the two don't overlap.
    keep_results = plan.keep_links()
    remove_results = plan.remove_links(dry_run=dry_run)
    # Record the links we will own before creating them: .installed then
    # .linked, so an install interrupted partway is recovered (a
    # recorded-but-missing link is re-created on the next run).
    if not dry_run:
        state.save()
    install_results = plan.install_links(dry_run=dry_run)
    results = (
        keep_results + remove_results + install_results + plan.conflict_links()
    )
    _report(state, results, _INSTALL_PROBLEM_STATUSES, verbose=verbose)
    if any(r.status in _INSTALL_PROBLEM_STATUSES for r in results):
        raise ConflictsFound("Conflicts found during install")


def _run_audit(state: WorldState, *, verbose: bool) -> None:
    """Report, without changing anything, how each install diverges from
    its source -- straight from the plan's buckets, no further IO: install
    links would be created (missing), remove links pruned (stale), conflict
    links are blocked, keep links are fine. Raises if anything diverges."""
    for install in state.missing_sources:
        logger.warning("tracked source is missing: %s", install.src)
    results = state.plan.describe()
    _report(state, results, _AUDIT_PROBLEM_STATUSES, verbose=verbose)
    # A link in any non-keep bucket means the target tree diverges from what
    # the sources want.
    plan = state.plan
    if plan.install or plan.remove or plan.conflict:
        raise ConflictsFound(
            "Conflicts, missing entries, or stale links found during audit"
        )


def _run_remove(state: WorldState, *, dry_run: bool, verbose: bool) -> None:
    """Tear down every recorded link of each in-scope install -- live or
    dangling, even when the source or target dir is gone. A removed install
    wants nothing, so all its links are REMOVE; surviving installs' links are
    preserved untouched. A link no longer ours (a foreign file or symlink now
    at the path) is left in place with a warning; only its record is dropped.
    The teardown is recorded (the surviving installs to .installed, the
    dropped links to .linked) only after every link is gone, so an
    interrupted remove is completed, not undone."""
    results = state.plan.remove_links(dry_run=dry_run)
    if not dry_run:
        state.save()
    _report(state, results, _REMOVE_PROBLEM_STATUSES, verbose=verbose)


def do_install(
    source_dir: Path | None,
    target_dir: Path | None,
    *,
    dotfiles: bool,
    no_recurse: bool,
    dry_run: bool,
    force: bool,
    verbose: bool,
) -> ExitCode | None:
    """Install a source dir's entries into an explicit target dir
    (recording the install + its flags), or re-sync every tracked
    install when neither source nor target is given. An explicit but
    missing source is an error; a tracked source that has since gone
    missing has its dangling links pruned and returns WARNING (the
    install record is kept so a restored source is re-linked)."""
    if source_dir is not None:
        assert target_dir is not None  # the parser validates them together
        src = source_dir.expanduser().resolve()
        target = target_dir.expanduser().resolve()
        if not src.is_dir():
            raise LinkfilesError(f"Source directory does not exist: {src}")
        # Each install's source must be distinct and not nested within
        # another's: that keeps a recorded link's source under exactly one
        # install, so cleanup attributes it unambiguously. (Targets may
        # nest freely -- the source is the discriminator.)
        for other in load_install_records():
            if other.tgt == target and other.src == src:
                continue
            if src.is_relative_to(other.src) or other.src.is_relative_to(src):
                raise LinkfilesError(
                    f"source {src} nests with tracked install's source "
                    f"{other.src}; install sources must be distinct and "
                    "not nested within one another"
                )
        new = InstallRecord(
            tgt=target, src=src, dotfiles=dotfiles, no_recurse=no_recurse
        )
        state = WorldState.load(install=new, force_install=force)
    else:
        if not load_install_records():
            logger.info("No installs tracked.")
            return None
        state = WorldState.load(force_install=force)
    _run_install(state, dry_run=dry_run, verbose=verbose)
    return ExitCode.WARNING if state.missing_sources else None


def do_remove(
    source_dir: Path | None,
    target_dir: Path | None,
    *,
    all_installs: bool,
    dry_run: bool,
    verbose: bool,
) -> ExitCode | None:
    """Remove one tracked install's links (identified by its source and
    target dirs) and untrack it, or every tracked install with
    `all_installs`. Requiring one of the two -- rather than treating a
    bare `remove` as remove-everything -- guards against accidentally
    wiping every install. Removal is driven by the link ledger, so an
    install whose source or target dir has gone missing still has its
    links cleaned up and is untracked."""
    if source_dir is not None:
        assert target_dir is not None  # the parser validates them together
        src = source_dir.expanduser().resolve()
        target = target_dir.expanduser().resolve()
        record = next(
            (
                r
                for r in load_install_records()
                if r.src == src and r.tgt == target
            ),
            None,
        )
        if record is None:
            raise LinkfilesError(f"No tracked install: {src} -> {target}")
        state = WorldState.load(remove=record)
    else:
        assert all_installs  # parser: a bare remove (no pair, no --all) errors
        if not load_install_records():
            logger.info("No installs tracked.")
            return None
        state = WorldState.load(remove_all=True)
    _run_remove(state, dry_run=dry_run, verbose=verbose)
    return None


def do_audit(*, verbose: bool) -> ExitCode | None:
    """Audit every tracked install (each under its own target root),
    without changing anything.

    Reports each link `install` would create (a source entry not yet
    linked), any conflicts, and any dangling/stale link `install` would
    prune (a recorded link whose source file is gone or no longer
    wanted). Any divergence -- including the dangling links of a tracked
    source that has gone missing -- raises ConflictsFound. WARNING is
    returned only when a tracked source is missing but nothing diverges
    (its links were already pruned)."""
    if not load_install_records():
        return None
    state = WorldState.load()
    _run_audit(state, verbose=verbose)
    return ExitCode.WARNING if state.missing_sources else None


# =============================================================================
# ARGUMENT PARSER
# =============================================================================


def _validate_install(
    parser: argparse.ArgumentParser, args: argparse.Namespace
) -> None:
    """Reject an install that names only one of source / target."""
    if (args.source_dir is None) != (args.target_dir is None):
        parser.error("install needs both a source and a target dir")


def _validate_remove(
    parser: argparse.ArgumentParser, args: argparse.Namespace
) -> None:
    """Reject an ambiguous remove: a bare invocation (which would wipe
    every install), --all combined with a source/target pair, or a
    half-named pair."""
    has_pair = args.source_dir is not None or args.target_dir is not None
    if has_pair and args.all_installs:
        parser.error("--all cannot be combined with a source/target dir")
    if has_pair and (args.source_dir is None or args.target_dir is None):
        parser.error("remove needs both a source and a target dir")
    if not has_pair and not args.all_installs:
        parser.error(
            "remove needs a source and target dir, or --all to remove "
            "every tracked install"
        )


# The Description and Getting Started text appended to the `--help`
# epilog. _DESCRIPTION's first paragraph is written to stand alone so it can
# serve as a one-line summary of the tool on its own.
_DESCRIPTION = """\
linkfiles symlinks the contents of a source directory tree into a target
directory, recreating the tree there. Installations are tracked, so later
runs can add new links, audit existing ones, and clean up dangling links.
While linkfiles can be used to link
files from any source to any destination, its primary purpose is linking
repository files into $HOME/ (as dotfiles) and $HOME/.local/.

By default linkfiles descends into the source and links the leaf files,
recreating any subdirectories in the target; --no-recurse links each
top-level entry directly instead. --dotfiles dot-prefixes each top-level
entry in the target (`bashrc` becomes `.bashrc`). Files matched by an
ignore file (.gitignore, .hgignore, or .linkfiles.ignore, in or above the
source) are skipped, as are editor backup and swap files."""

_GETTING_STARTED = """\
To install files from repos in your $HOME you can do:

    linkfiles install --dotfiles .../files $HOME/
    linkfiles install .../bin $HOME/.local/bin
    linkfiles install .../share $HOME/.local/share

To update already installed link trees after the source directories are
updated run:

    linkfiles install"""


def _add_dry_run_argument(parser: argparse.ArgumentParser) -> None:
    """Add the shared `--dry-run` flag, so it is wired -- and its help
    reads -- identically wherever it appears, and documented once under
    COMMON ARGUMENTS."""
    add_argument_ext(
        parser,
        "--dry-run",
        action="store_true",
        common=True,
        help="Show what would be done without making changes.",
    )


def _add_verbose_argument(parser: argparse.ArgumentParser) -> None:
    """Add the shared `-v/--verbose` flag, so it is wired -- and its help
    reads -- identically wherever it appears, and documented once under
    COMMON ARGUMENTS."""
    add_argument_ext(
        parser,
        "-v",
        "--verbose",
        action="store_true",
        common=True,
        help="Print every entry; default suppresses ok lines.",
    )


def build_parser() -> StrictArgumentParser:
    """
    Build and return the argument parser.

    Returns:
        Configured ArgumentParser instance
    """
    parser = StrictArgumentParser(
        prog=LINKFILES_NAME,
        description=LINKFILES_DESCRIPTION,
        epilog=(
            f"{ExitCode.epilog()}\n\n"
            f"Description:\n{textwrap.indent(_DESCRIPTION, '  ')}\n\n"
            f"Getting Started:\n{textwrap.indent(_GETTING_STARTED, '  ')}"
        ),
        formatter_class=RawDescriptionDefaultsHelpFormatter,
    )
    subparsers = parser.add_command_subparsers(
        metavar="<command>",
        help="Subcommands.",
    )

    # Install subcommand
    install_parser = subparsers.add_parser(
        "install",
        help=(
            "Link a source directory's contents into a target, or re-sync "
            "every tracked install."
        ),
        description=(
            "Link the contents of source_dir into target_dir, recording "
            "the install and its flags so it can be audited and removed "
            "later. To install links from a new directory, both source_dir "
            "and target_dir are required. If neither are specified, re-sync "
            "all previously installed directories."
        ),
    )
    _add_dry_run_argument(install_parser)
    install_parser.add_argument(
        "-f",
        "--force",
        action="store_true",
        help="Replace conflicting symlinks (not files).",
    )
    _add_verbose_argument(install_parser)
    install_parser.add_argument(
        "--dotfiles",
        action="store_true",
        help="Dot-prefix each top-level entry under the target.",
    )
    install_parser.add_argument(
        "--no-recurse",
        action="store_true",
        help="Link only top-level entries; do not descend.",
    )
    install_parser.add_argument(
        "source_dir",
        type=Path,
        nargs="?",
        help="Source directory to install entries from.",
    )
    install_parser.add_argument(
        "target_dir",
        type=Path,
        nargs="?",
        help="Target directory to link the source's entries into.",
    )
    install_parser.add_validate_callback(_validate_install)

    # Remove subcommand
    remove_parser = subparsers.add_parser(
        "remove",
        help="Remove one tracked install's links, or all of them with --all.",
        description=(
            "Remove the links of one tracked install -- identified by its "
            "source_dir and target_dir, required together -- and untrack "
            "it. Pass --all instead to remove every tracked install."
        ),
    )
    remove_parser.add_argument(
        "--all",
        dest="all_installs",
        action="store_true",
        help="Remove every tracked install (instead of one source/target).",
    )
    _add_dry_run_argument(remove_parser)
    _add_verbose_argument(remove_parser)
    remove_parser.add_argument(
        "source_dir",
        type=Path,
        nargs="?",
        help="Source directory whose entries should be removed.",
    )
    remove_parser.add_argument(
        "target_dir",
        type=Path,
        nargs="?",
        help="Target directory the install was linked into.",
    )
    remove_parser.add_validate_callback(_validate_remove)

    # Audit subcommand
    audit_parser = subparsers.add_parser(
        "audit",
        help=(
            "Report the status of every tracked install; exits non-zero on "
            "conflicts, missing entries, or stale managed links."
        ),
    )
    _add_verbose_argument(audit_parser)

    return parser


# =============================================================================
# COMMAND DISPATCH
# =============================================================================

COMMAND_CALLBACKS: dict[str, Callable[..., ExitCode | None]] = {
    "install": do_install,
    "remove": do_remove,
    "audit": do_audit,
}


@cli_entrypoint
def cli() -> int:
    """CLI entry point with exception handling."""
    parser = build_parser()
    args_dict = vars(parser.parse_command())
    command = args_dict.pop("command")

    try:
        result = COMMAND_CALLBACKS[command](**args_dict)
    except LinkfilesError as e:
        logger.error("ERROR: %s", e)
        return e.exit_code
    # A callback returns an ExitCode to override the default (e.g. install
    # / audit return WARNING when a tracked source has gone missing);
    # otherwise the command succeeded.
    return result if isinstance(result, ExitCode) else ExitCode.SUCCESS


# Reference-doc spec discovered by scripts/render-docs.
MAN_SPEC = ManSpec(
    prog="linkfiles",
    section=1,
    build_parser=build_parser,
    name_description="symlink a source directory's contents into a target",
    description=_DESCRIPTION,
    pre_sections=[TextSection("GETTING STARTED", _GETTING_STARTED)],
    post_sections=[
        ItemsSection(
            "FILES",
            [
                (
                    "~/.linkfiles.installed",
                    "Tracks installed directory pairs (source + target) and "
                    "installation options.",
                ),
                (
                    "~/.linkfiles.linked",
                    "Tracks installed links (source + target pairs).",
                ),
                (
                    "$REPO/.linkfiles.ignore",
                    "A file containing gitignore style patterns used to "
                    "specify repo files that should be ignored by linkfiles. "
                    "Used when source_dir is $REPO or a child of $REPO.",
                ),
            ],
        ),
    ],
    exit_status=[
        (str(value), description) for value, description in ExitCode.entries()
    ],
)


if __name__ == "__main__":
    raise SystemExit(cli())
