class LinkStatus(StrEnum):
    """Status of an entry during operations. The value is the lowercased,
    hyphenated member name (NONLINK_CONFLICT -> "nonlink-conflict"), used
    verbatim as the status text in result output."""

    @staticmethod
    def _generate_next_value_(
        name: str, _start: int, _count: int, _last: list[str]
    ) -> str:
        return name.lower().replace("_", "-")

    NONLINK_CONFLICT = auto()
    LINK_CONFLICT = auto()
    OK = auto()
    MISSING = auto()
    INSTALLED = auto()
    REMOVED = auto()
