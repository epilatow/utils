# The argparse program identity.
LINKFILES_NAME = "linkfiles"
LINKFILES_DESCRIPTION = (
    "Symlink a source dir's contents into an explicit target"
)

# The tracking file (~/.linkfiles.installed). Tests monkeypatch this to
# point at a tmpdir.
INSTALLED_FILE: Path = Path.home() / ".linkfiles.installed"


# =============================================================================
# EXIT CODES
