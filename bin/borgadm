# -----------------------------------------------------------------------------
# Configuration schema
# -----------------------------------------------------------------------------
# CONFIG_FIELDS is the single source for every ~/.borgadm setting: the
# default Config falls back to, its description, and the value `config
# init` writes. A field with a template_value is written active
# (uncommented) in the generated config; the rest are written commented at
# their default. The test_config_fields_match_config gate asserts it
# covers exactly the settings Config reads.


@dataclasses.dataclass(frozen=True)
class ConfigField:
    name: str
    default: object
    description: str
    template_value: object | None = None
    # The user-facing "you must set this" label for the docs and the
    # generated config. Enforcement is separate and context-dependent
    # (BORG_REPO is checked always; BACKUP_SETS only when a backup is
    # about to run), so this flag is presentational, not a validation
    # driver.
    required: bool = False


# macOS paths auto-excluded on Darwin to prevent backup failures.
_MACOS_EXCLUDES: list[str] = [
    # iCloud -- causes deadlocks when borg reads during active sync
    "Library/Mobile Documents",
    # Contains root-owned files (a root-ownership problem, not a
    # Full Disk Access one)
    "Library/Google/GoogleSoftwareUpdate",
]

# Shared by the two example backup sets `config init` writes.
_EXAMPLE_EXCLUDES: list[str] = [
    "sh:**/.venv",
    "sh:**/node_modules",
    "sh:**/__pycache__",
    "sh:**/.pytest_cache",
    "sh:**/.mypy_cache",
    "sh:**/.ruff_cache",
]
_EXAMPLE_BACKUP_SETS: dict[str, dict[str, list[str]]] = {
    "local": {
        "excludes": _EXAMPLE_EXCLUDES,
        "paths": ["Documents/", "Projects/"],
    },
    "fuse": {
        "create_options": ["--noacls", "--noctime", "--noxattrs"],
        "excludes": _EXAMPLE_EXCLUDES,
        "paths": ["Shared/"],
    },
}

# Archive names emitted by `borgadm create` follow
#   {BACKUP_NAME}-{set_name}-YYYYMMDD_HHMMSS_NofM
# where M is the count of configured sets and N is the 1-based position of
# the set's name in sorted set-name order. When M has two or more digits,
# N is zero-padded to match (e.g. 01of11, ..., 11of11) so archive names
# sort correctly in alphabetical listings. The suffix is required: an
# archive whose name shares the BACKUP_NAME- prefix but does not parse
# into this shape is surfaced as "unknown" by list and removable via
# `prune --cleanup-unknown`.
#
# The NofM suffix is the source of truth for set completeness: a timestamp
# is "full" when every N in 1..M is present and "partial" otherwise.
# Adding, removing, or renaming a set changes which N future archives get
# but does NOT retroactively reclassify existing archives -- old archives
# keep their original NofM.
CONFIG_FIELDS: list[ConfigField] = [
    ConfigField(
        "BORG_REPO",
        "",
        "Path or ssh URL of the borg repository to manage",
        template_value="ssh://user@host/./path/to/repo",
        required=True,
    ),
    ConfigField(
        "BORG_REPO_HOSTKEY",
        "",
        "known_hosts entry for the remote repository host",
    ),
    ConfigField(
        "BORG_PASSPHRASE_FILE",
        "~/.borg_passphrase",
        "File holding the repository passphrase",
    ),
    ConfigField(
        "BORG_SSHKEY_FILE",
        "~/.ssh/id_borg.net",
        "SSH private key used to reach a remote repository",
    ),
    ConfigField(
        "BORG_REMOTE_PATH",
        "",
        "Path to the borg executable on the remote host",
    ),
    ConfigField(
        "BORG_CMD_TIMEOUT",
        4 * 3600,
        "Timeout for borg commands, in seconds",
    ),
    ConfigField(
        "CMD_TIMEOUT",
        60,
        "Timeout for non-borg commands, in seconds",
    ),
    ConfigField(
        "LOCK_CHECK_TIMEOUT",
        5,
        "Seconds to wait probing whether a borg lock is held",
    ),
    ConfigField(
        "BACKUP_NAME",
        "home",
        "Prefix for archive names",
    ),
    ConfigField(
        "BACKUP_ROOT",
        "~",
        "Directory `create` runs from and that backup-set paths are "
        "resolved against",
    ),
    ConfigField(
        "CHECK_AGE_SECONDS",
        24 * 3600,
        "Maximum age `check age` tolerates for the latest full backup, "
        "in seconds",
    ),
    ConfigField(
        "PRUNE_KEEP_HOURLY",
        24,
        "Hourly archives `prune` retains",
    ),
    ConfigField(
        "PRUNE_KEEP_DAILY",
        7,
        "Daily archives `prune` retains",
    ),
    ConfigField(
        "PRUNE_KEEP_WEEKLY",
        4,
        "Weekly archives `prune` retains",
    ),
    ConfigField(
        "PRUNE_KEEP_MONTHLY",
        12,
        "Monthly archives `prune` retains",
    ),
    ConfigField(
        "PRUNE_KEEP_YEARLY",
        2,
        "Yearly archives `prune` retains",
    ),
    ConfigField(
        "BACKUP_MOUNTS",
        [],
        "JSON list of paths (relative to BACKUP_ROOT) that must be "
        "mountpoints before `create` proceeds",
        template_value=["Shared"],
    ),
    ConfigField(
        "BACKUP_SETS",
        {},
        "JSON object mapping each backup-set name to its `paths`, "
        "optional `excludes`, and optional `create_options`; `create` "
        "writes one archive per set",
        template_value=_EXAMPLE_BACKUP_SETS,
        required=True,
    ),
]

_FIELDS: dict[str, ConfigField] = {f.name: f for f in CONFIG_FIELDS}


def _str_field(config: configparser.ConfigParser, name: str) -> str:
    return config.get(
        "default", name, fallback=cast(str, _FIELDS[name].default)
    )


def _path_field(config: configparser.ConfigParser, name: str) -> Path:
    return Path(os.path.expanduser(_str_field(config, name)))


def _int_field(config: configparser.ConfigParser, name: str) -> int:
    return config.getint(
        "default", name, fallback=cast(int, _FIELDS[name].default)
    )


def _json_field(config: configparser.ConfigParser, name: str) -> Any:
    return json.loads(
        config.get("default", name, fallback=json.dumps(_FIELDS[name].default))
    )


# -----------------------------------------------------------------------------
# Classes
# -----------------------------------------------------------------------------
class Config:
    def __init__(
        self,
        path: str,
        args: dict[str, Any],
        require_backup_sets: bool = False,
    ) -> None:
        self.path: Path = Path(path)
        try:
            with open(path) as f:
                content = f.read()
        except (
            FileNotFoundError,
            PermissionError,
            IsADirectoryError,
            OSError,
        ) as e:
            raise ConfigError(f"Failed to load config file {path}: {e}") from e

        config = configparser.ConfigParser()
        config_data = io.StringIO("[default]\n" + content)
        try:
            config.read_file(config_data)
        except configparser.ParsingError as e:
            raise ConfigError(f"Failed to parse config file {path}: {e}") from e

        self.BORG_PASSPHRASE_FILE: Path = _path_field(
            config, "BORG_PASSPHRASE_FILE"
        )
        self.BORG_SSHKEY_FILE: Path = _path_field(config, "BORG_SSHKEY_FILE")
        self.BORG_REMOTE_PATH: str = _str_field(config, "BORG_REMOTE_PATH")
        self.BORG_CMD_TIMEOUT: int = _int_field(config, "BORG_CMD_TIMEOUT")
        self.CMD_TIMEOUT: int = _int_field(config, "CMD_TIMEOUT")
        self.LOCK_CHECK_TIMEOUT: int = _int_field(config, "LOCK_CHECK_TIMEOUT")

        self.BACKUP_NAME: str = _str_field(config, "BACKUP_NAME")
        self.BACKUP_ROOT: Path = _path_field(config, "BACKUP_ROOT")

        # CHECK_AGE_SECONDS and the PRUNE_KEEP_* counts take an optional
        # per-run CLI override; absent that they come from the config (or
        # the field default).
        if (v := args.pop("seconds", None)) is not None:
            self.CHECK_AGE_SECONDS: int = v
        else:
            self.CHECK_AGE_SECONDS = _int_field(config, "CHECK_AGE_SECONDS")

        if (v := args.pop("keep_hourly", None)) is not None:
            self.PRUNE_KEEP_HOURLY: int = v
        else:
            self.PRUNE_KEEP_HOURLY = _int_field(config, "PRUNE_KEEP_HOURLY")
        if (v := args.pop("keep_daily", None)) is not None:
            self.PRUNE_KEEP_DAILY: int = v
        else:
            self.PRUNE_KEEP_DAILY = _int_field(config, "PRUNE_KEEP_DAILY")
        if (v := args.pop("keep_weekly", None)) is not None:
            self.PRUNE_KEEP_WEEKLY: int = v
        else:
            self.PRUNE_KEEP_WEEKLY = _int_field(config, "PRUNE_KEEP_WEEKLY")
        if (v := args.pop("keep_monthly", None)) is not None:
            self.PRUNE_KEEP_MONTHLY: int = v
        else:
            self.PRUNE_KEEP_MONTHLY = _int_field(config, "PRUNE_KEEP_MONTHLY")

        if (v := args.pop("keep_yearly", None)) is not None:
            self.PRUNE_KEEP_YEARLY: int = v
        else:
            self.PRUNE_KEEP_YEARLY = _int_field(config, "PRUNE_KEEP_YEARLY")

        self.BORG_REPO: str = _str_field(config, "BORG_REPO")
        self.BORG_REPO_HOSTKEY: str = _str_field(config, "BORG_REPO_HOSTKEY")
        self.BACKUP_MOUNTS: list[str] = _json_field(config, "BACKUP_MOUNTS")
        self.BACKUP_SETS: dict[str, dict[str, list[str]]] = _json_field(
            config, "BACKUP_SETS"
        )

        errors: list[str] = []
        if not self.BORG_REPO:
            errors.append(f"BORG_REPO not defined in config: {path}")
        # BACKUP_SETS is required to back anything up but is consumed only
        # by the create path, so most commands run without it. `validate`
        # opts into the stricter check so it can flag the gap before the
        # first backup rather than letting create fail later.
        if require_backup_sets and not self.BACKUP_SETS:
            errors.append(f"BACKUP_SETS not defined in config: {path}")
        if not any(
            [
                self.PRUNE_KEEP_HOURLY,
                self.PRUNE_KEEP_DAILY,
                self.PRUNE_KEEP_WEEKLY,
                self.PRUNE_KEEP_MONTHLY,
                self.PRUNE_KEEP_YEARLY,
            ]
        ):
            errors.append(
                "All PRUNE_KEEP intervals are 0; this would delete all backups"
            )
        if errors:
            detail = "\n  ".join(errors)
            raise ConfigError(f"Config validation failed:\n  {detail}")


class Interval(enum.Enum):
    HOUR = "hour"
    DAY = "day"
    WEEK = "week"
    MONTH = "month"
    YEAR = "year"

    def __str__(self) -> str:
        return self.value

    def timedelta(self) -> timedelta:
        if self == Interval.HOUR:
            return timedelta(hours=1)
        elif self == Interval.DAY:
            return timedelta(days=1)
        elif self == Interval.WEEK:
            return timedelta(weeks=1)
        elif self == Interval.MONTH:
            return timedelta(days=30)
        elif self == Interval.YEAR:
            return timedelta(days=365)
        else:
            raise ValueError(f"Unsupported timedelta interval: {self}")

    def keep(self) -> int:
        cfg = get_cfg()
        if self == Interval.HOUR:
            return cfg.PRUNE_KEEP_HOURLY
        elif self == Interval.DAY:
            return cfg.PRUNE_KEEP_DAILY
        elif self == Interval.WEEK:
            return cfg.PRUNE_KEEP_WEEKLY
        elif self == Interval.MONTH:
            return cfg.PRUNE_KEEP_MONTHLY
        elif self == Interval.YEAR:
            return cfg.PRUNE_KEEP_YEARLY
        else:
            raise ValueError(f"Unsupported keep interval: {self}")


# -----------------------------------------------------------------------------
# Utility Functions
# -----------------------------------------------------------------------------
def get_cfg() -> Config:
    assert CFG is not None, "CFG not initialized"
    return CFG


class InfoFilter(logging.Filter):
    def filter(self, record: logging.LogRecord) -> bool:
        return record.levelno == logging.INFO


class WarnOrWorseFilter(logging.Filter):
    def __init__(self, verbose: bool) -> None:
        self.verbose = verbose

    def filter(self, record: logging.LogRecord) -> bool:
        if self.verbose:
            # skip INFO messages
            return record.levelno != logging.INFO
        return record.levelno >= logging.WARNING


class BrokenPipeAwareStreamHandler(logging.StreamHandler[Any]):
    """StreamHandler that silently disables itself once its underlying
    stream is closed by a downstream pipe consumer (e.g., piping to
    `head`). The first BrokenPipeError swaps the stream for /dev/null,
    so subsequent records are absorbed without spamming "Logging error"
    tracebacks for every remaining log call."""

    def handleError(self, record: logging.LogRecord) -> None:
        # logging.StreamHandler.emit catches every non-RecursionError
        # exception and routes it here. If the underlying cause is a
        # closed pipe, swap to /dev/null so future emits no-op silently
        # rather than printing tracebacks to (possibly also-closed)
        # stderr.
        exc = sys.exc_info()[1]
        if isinstance(exc, BrokenPipeError):
            try:
                self.stream.close()
            except BrokenPipeError, OSError:
                pass
            self.stream = open(os.devnull, "w")
            return
        super().handleError(record)


# Sentinel attribute marking a logging.Handler as installed by
# initialize_logger().  Used to remove the previous generation of handlers
# from the root logger on re-init, so repeated calls (each test exercising
# cli(), or any long-running embedding that re-enters cli()) don't
# accumulate handlers and open file descriptors without bound.
_BORGADM_HANDLER_TAG = "_borgadm_handler"


def _install_handler(handler: logging.Handler) -> None:
    setattr(handler, _BORGADM_HANDLER_TAG, True)
    logger.addHandler(handler)


def initialize_logger(
    logfile_path: str | Path,
    verbose: bool = False,
    timestamp_messages: bool = False,
) -> None:
    for existing in list(logger.handlers):
        if getattr(existing, _BORGADM_HANDLER_TAG, False):
            logger.removeHandler(existing)
            existing.close()

    logger.setLevel(logging.DEBUG)  # Capture all logs for the file

    # File handler - all messages with full formatting
    file_handler = logging.FileHandler(logfile_path)
    file_handler.setLevel(logging.DEBUG)
    file_formatter = logging.Formatter(
        "%(asctime)s: PID %(process)d: %(levelname)s: %(message)s"
    )
    file_handler.setFormatter(file_formatter)
    _install_handler(file_handler)

    # Stdout handler for INFO messages only
    stdout_handler = BrokenPipeAwareStreamHandler(sys.stdout)
    stdout_handler.setLevel(logging.INFO)
    stdout_handler.addFilter(InfoFilter())
    stdout_fmt = (
        "%(asctime)s: %(message)s" if timestamp_messages else "%(message)s"
    )
    stdout_handler.setFormatter(logging.Formatter(stdout_fmt))
    _install_handler(stdout_handler)

    # Stderr handler for WARNING and worse (or DEBUG+ if verbose)
    stderr_handler = BrokenPipeAwareStreamHandler(sys.stderr)
    stderr_handler.setLevel(logging.DEBUG if verbose else logging.WARNING)
    stderr_handler.addFilter(WarnOrWorseFilter(verbose))
    stderr_fmt = (
        "%(asctime)s: %(levelname)s: %(message)s"
        if timestamp_messages
        else "%(levelname)s: %(message)s"
    )
    stderr_handler.setFormatter(logging.Formatter(stderr_fmt))
    _install_handler(stderr_handler)

    def log_exceptions(
        exc_type: type[BaseException],
        exc_value: BaseException,
        exc_traceback: Any,
    ) -> None:
        logger.critical(
            "Uncaught exception",
            exc_info=(exc_type, exc_value, exc_traceback),
        )

    sys.excepthook = log_exceptions


@functools.cache
def borg_cmd() -> list[str]:

    # Default to the version in PATH.
    if rv := shutil.which("borg"):
        return [rv]

    # Explicitly search common dirs.
    path_search = [os.environ["HOME"] + "/.local/bin", "/opt/local/bin"]
    for i in path_search:
        rv = os.path.join(i, "borg")
        if os.path.exists(rv):
            return [rv]

    # Run it via uvx if it's installed.
    if uvx := shutil.which("uvx"):
        return [uvx, "-q", "--from", "borgbackup", "borg"]

    raise BorgadmError("Can't find borg or uvx executables.")


def _is_remote_repo(repo: str) -> bool:
    """True if `repo` is an ssh-accessed borg repo URL.

    Borg accepts `ssh://user@host[:port]/path` and the abbreviated
    `user@host:path` form for remote repos; everything else is a local
    filesystem path. We follow borg's own heuristic for the abbreviated
    form -- a colon in the first path segment marks it as remote.
    Absolute local paths are immune (the segment before the first `/`
    is empty); a relative local path whose first directory contains a
    colon (e.g. `dir:name/repo`) would be misclassified as remote, but
    borg itself would reject the same input in the same way.
    """
    if repo.startswith("ssh://"):
        return True
    head, _, _ = repo.partition("/")
    return ":" in head


def initialize_borg_environment() -> None:
    cfg = get_cfg()

    global _borg_env_initialized
    if _borg_env_initialized:
        return

    if cfg.BORG_REMOTE_PATH:
        os.environ["BORG_REMOTE_PATH"] = cfg.BORG_REMOTE_PATH
        logger.debug(f"BORG_REMOTE_PATH={os.environ['BORG_REMOTE_PATH']}")
    os.environ["BORG_PASSPHRASE"] = load_passphrase()
    if _is_remote_repo(cfg.BORG_REPO):
        _hostkey_file.write(cfg.BORG_REPO_HOSTKEY)
        _hostkey_file.flush()
        # -F /dev/null ignores the user's ~/.ssh/config, whose settings
        # (like IdentityAgent) can conflict with our ssh-agent setup --
        # which also means our keepalive options below are the only ones
        # in effect. A `borg mount` of a remote repo holds its ssh
        # session open for the whole rsync (hours for a full set), with
        # idle gaps while rsync reads the other archive's mount or scans
        # the target. ServerAlive probes are answered by the remote sshd
        # (not the busy `borg serve`), so they keep NAT/firewall state
        # warm across those gaps; without them an evicted-but-undetected
        # connection leaves the FUSE mount returning ENOTCONN and every
        # subsequent read fails. CountMax x Interval bounds how long a
        # genuinely dead link hangs before ssh tears it down.
        os.environ["BORG_RSH"] = (
            f"ssh -F /dev/null "
            f"-o StrictHostKeyChecking=yes "
            f"-o ServerAliveInterval=15 "
            f"-o ServerAliveCountMax=30 "
            f"-o UserKnownHostsFile={_hostkey_file.name}"
        )
        logger.debug(f"BORG_RSH={os.environ['BORG_RSH']}")
        start_ssh_agent()
    _borg_env_initialized = True


def check_permissions(path: Path, name: str) -> None:
    try:
        st = os.stat(path)
        if (st.st_mode & (stat.S_IRWXG | stat.S_IRWXO)) != 0:
            raise ConfigError(f"Permissions on {name} ({path}) are too open.")
    except FileNotFoundError:
        raise ConfigError(f"{name} not found at: {path}") from None


def pump_stream(
    src: TextIO, sink: TextIO, acc: io.StringIO, allow_output: bool
) -> None:
    """Drain a subprocess stream into an accumulator and (optionally)
    a passthrough sink. If the sink's downstream consumer closes the
    pipe (e.g., `borgadm rsync --progress | head`), stop forwarding to
    the sink but keep draining the source so the subprocess doesn't
    block on a full pipe."""
    sink_broken = False
    while True:
        chunk = src.readline()
        if chunk == "":
            break
        acc.write(chunk)
        if allow_output and not sink_broken:
            try:
                sink.write(chunk)
                sink.flush()
            except BrokenPipeError:
                sink_broken = True


def run_cmd(
    cmd: list[str],
    sudo: bool = False,
    errok: bool = False,
    allow_output: bool = False,
    log_error: bool = True,
    track_warning: bool = True,
    **kwargs: Any,
) -> subprocess.CompletedProcess[Any]:
    slow = cmd[0] in borg_cmd() + ["rsync"]
    # Before CFG is loaded, fall back to the field defaults.
    timeout: int = cast(
        int, _FIELDS["BORG_CMD_TIMEOUT" if slow else "CMD_TIMEOUT"].default
    )
    if CFG:
        timeout = CFG.BORG_CMD_TIMEOUT if slow else CFG.CMD_TIMEOUT
    if sudo:
        cmd = ["sudo", "-n", "-E"] + cmd
    cmd_str = shlex.join(cmd)
    logger.debug(f"Running command: {cmd_str}")
    proc = subprocess.Popen(
        cmd,
        stdin=subprocess.DEVNULL,
        stdout=subprocess.PIPE,
        stderr=subprocess.PIPE,
        text=True,
        bufsize=1,
        **kwargs,
    )
    stdout_buf = io.StringIO()
    stderr_buf = io.StringIO()
    stdout = cast(TextIO, proc.stdout)
    stderr = cast(TextIO, proc.stderr)

    t_stdout = threading.Thread(
        target=pump_stream,
        args=(stdout, sys.stdout, stdout_buf, allow_output),
        daemon=True,
    )
    t_stdout.start()
    t_stderr = threading.Thread(
        target=pump_stream,
        args=(stderr, sys.stderr, stderr_buf, allow_output),
        daemon=True,
    )
    t_stderr.start()

    try:
        proc.wait(timeout=timeout)
    except subprocess.TimeoutExpired:
        proc.kill()
        proc.wait()

    t_stdout.join()
    t_stderr.join()

    stdout_str = stdout_buf.getvalue()
    stderr_str = stderr_buf.getvalue()

    if stderr_str:
        logger.debug(f"stderr:\n{stderr_str.strip()}")

    is_borg = "borg" in cmd[0] or "borg" in cmd
    if is_borg and proc.returncode == ExitCode.WARNING:
        # Borg exit code 1 means the operation completed with
        # non-fatal warnings (e.g., files changed during backup).
        # track_warning lets an advisory call (the lock probe) opt out
        # so its incidental warning neither logs nor promotes borgadm's
        # own exit code.
        if track_warning:
            logger.warning(
                "Command %s completed with warnings (exit code %s):\n%s",
                cmd_str,
                proc.returncode,
                stderr_str.strip(),
            )
            global _warning_occurred
            _warning_occurred = True
    elif proc.returncode != 0:
        if log_error:
            logger.error(
                "Command %s failed with exit code %s and stderr:\n%s",
                cmd_str,
                proc.returncode,
                stderr_str.strip(),
            )
        if not errok:
            raise SubprocessError(
                proc.returncode,
                cmd,
                output=stdout_str,
                stderr=stderr_str,
            )

    return subprocess.CompletedProcess(
        args=cmd,
        returncode=proc.returncode,
        stdout=stdout_str,
        stderr=stderr_str,
    )


def _is_lock_timeout(stderr: str) -> bool:
    """True if `stderr` is borg's LockTimeout (the lock is held by
    another borg process and our wait elapsed). Distinct from other
    borg errors (network, corruption) so callers can wait on a held
    lock while still surfacing real failures."""
    s = stderr.lower()
    return "failed to create/acquire the lock" in s and "timeout" in s


def borg_locks_held() -> bool:
    """Probe whether a borg lock that would block a normal read is
    currently held, waiting at most `LOCK_CHECK_TIMEOUT` seconds. borg
    takes both a repository lock and a local cache lock, and a blocking
    read waits on whichever is held; this probe runs the same kind of
    non-bypassing read, so it contends on the same locks and predicts
    that wait. Advisory only: it lets a blocking operation warn the user
    before it waits for what could be a full backup's duration. A
    non-lock failure (network, etc.) is reported as not-held so the real
    operation surfaces it."""
    cfg = get_cfg()
    proc = run_cmd(
        borg_cmd()
        + [
            "list",
            "--short",
            "--lock-wait",
            str(cfg.LOCK_CHECK_TIMEOUT),
            cfg.BORG_REPO,
        ],
        errok=True,
        log_error=False,
        track_warning=False,
    )
    if proc.returncode == 0:
        return False
    return _is_lock_timeout(proc.stderr)


def run_borg(
    cmd: list[str],
    *,
    repo_write: bool,
    bypass_lock: bool = False,
    **kwargs: Any,
) -> subprocess.CompletedProcess[Any]:
    """Run a borg `cmd` (a full argv built from `borg_cmd()`) with
    locking handled.

    By default the operation blocks on the lock: if the lock is already
    held it logs that it is waiting (probing via `borg_locks_held`), then
    runs with a `BORG_CMD_TIMEOUT` lock-wait so it proceeds once the
    holder releases. With `bypass_lock` it skips the wait entirely
    (`--bypass-lock` plus throwaway cache and security dirs so it
    contends on neither the repository nor the cache lock), trading the
    wait for the risk of racing a concurrent writer -- only read-only
    commands expose that choice.

    `repo_write` must be True for any operation that mutates the repo;
    such an operation may never bypass the lock, and the assert makes
    that unrepresentable rather than relying on call sites to remember."""
    assert not (repo_write and bypass_lock), (
        f"repo-writing borg op must never bypass the lock: {shlex.join(cmd)}"
    )

    def with_flags(flags: list[str]) -> list[str]:
        # Lock flags go right after the borg subcommand verb -- the one
        # position valid for every borg command, regardless of how many
        # positionals (paths, mountpoint) trail it. cmd is built as
        # `borg_cmd() + [verb, ...]`, so the verb sits at index
        # len(borg_cmd()).
        verb_idx = len(borg_cmd()) + 1
        return [*cmd[:verb_idx], *flags, *cmd[verb_idx:]]

    if bypass_lock:
        # borg's --bypass-lock skips only the repository lock, not the
        # local cache and security-dir locks. A read-only command still
        # opens the cache, so a concurrent create holding the cache lock
        # would block the read to a lock timeout -- the very wait the
        # caller asked to skip. Point the cache and security dirs at a
        # throwaway location so the read contends on neither lock and is
        # immune to the "Cache newer than repository" anti-rollback abort
        # a mid-write repo would otherwise trip. A read-only command needs
        # no persistent cache, so the fresh dirs add no meaningful cost.
        base_env = kwargs.pop("env", os.environ)
        with tempfile.TemporaryDirectory(
            prefix="borgadm-bypass-", ignore_cleanup_errors=True
        ) as td:
            cache_dir = os.path.join(td, "cache")
            security_dir = os.path.join(td, "security")
            env = {
                **base_env,
                "BORG_CACHE_DIR": cache_dir,
                "BORG_SECURITY_DIR": security_dir,
            }
            try:
                return run_cmd(with_flags(["--bypass-lock"]), env=env, **kwargs)
            finally:
                # A sudo'd borg creates the throwaway dirs root-owned,
                # which the unprivileged TemporaryDirectory cleanup cannot
                # remove -- clear them with sudo first. Cleanup failures
                # (errok, ignore_cleanup_errors) degrade to a leaked tmp
                # dir rather than an exception that would mask the borg
                # result.
                if kwargs.get("sudo"):
                    run_cmd(
                        ["rm", "-rf", cache_dir, security_dir],
                        sudo=True,
                        errok=True,
                    )
    cfg = get_cfg()
    if borg_locks_held():
        logger.info(
            "A borg lock is held, waiting up to %ss for it to release.",
            cfg.BORG_CMD_TIMEOUT,
        )
    return run_cmd(
        with_flags(["--lock-wait", str(cfg.BORG_CMD_TIMEOUT)]), **kwargs
    )


def start_ssh_agent() -> None:
    cfg = get_cfg()

    global _ssh_agent_pid
    logger.debug("Initializing SSH agent.")
    check_permissions(cfg.BORG_SSHKEY_FILE, "SSH private key")
    result = run_cmd(["ssh-agent", "-s"])
    for line in result.stdout.splitlines():
        line = line.split(";")[0].strip()
        if line.startswith(("SSH_AUTH_SOCK=", "SSH_AGENT_PID=")):
            key, value = line.split("=")
            os.environ[key] = value
            if key == "SSH_AGENT_PID":
                _ssh_agent_pid = value
    result = run_cmd(["ssh-add", "-q", cfg.BORG_SSHKEY_FILE.as_posix()])
    atexit.register(stop_ssh_agent)


def stop_ssh_agent() -> None:
    global _ssh_agent_pid
    if _ssh_agent_pid:
        logger.debug("Stopping SSH agent.")
        try:
            run_cmd(["kill", _ssh_agent_pid])
        except Exception as e:
            logger.warning(f"Failed to kill SSH agent: {e}")
        _ssh_agent_pid = None


def load_passphrase() -> str:
    cfg = get_cfg()

    check_permissions(cfg.BORG_PASSPHRASE_FILE, "BORG_PASSPHRASE file")
    with open(cfg.BORG_PASSPHRASE_FILE) as f:
        return f.read().strip()


@functools.cache
def list_backups_raw(
    bypass_lock: bool = False,
) -> subprocess.CompletedProcess[Any]:
    cfg = get_cfg()

    return run_borg(
        borg_cmd() + ["list", "--short", cfg.BORG_REPO],
        repo_write=False,
        bypass_lock=bypass_lock,
    )


@dataclasses.dataclass(frozen=True)
class _ArchiveName:
    """A borg archive name, parsed into its components.

    The string form is `{backup_name}-{set_name}-YYYYMMDD_HHMMSS_NofM`
    -- the part after `::` in a full `repo::archive` reference.
    `str()` renders the name and `from_str()` parses one back, so
    do_create (emitting names) and list_backups (reading them) share
    exactly one definition of the shape.
    """

    backup_name: str
    set_name: str
    timestamp: str
    n: int
    m: int

    def __str__(self) -> str:
        """Render the archive name. Zero-pads N to M's digit count
        so archive names sort correctly when M >= 10 (e.g. 01of11
        rather than 1of11)."""
        base = f"{self.backup_name}-{self.set_name}-{self.timestamp}"
        width = len(str(self.m))
        return f"{base}_{self.n:0{width}d}of{self.m}"

    def __lt__(self, other: _ArchiveName) -> bool:
        """Total order over archive names: by backup_name, then
        timestamp, then ascending N (mirroring do_create's emission
        order), then set_name, then M."""
        if not isinstance(other, _ArchiveName):
            return NotImplemented
        return self._order_key() < other._order_key()

    def _order_key(self) -> tuple[str, str, int, str, int]:
        return (
            self.backup_name,
            self.timestamp,
            self.n,
            self.set_name,
            self.m,
        )

    @classmethod
    def from_str(cls, backup_name: str, name: str) -> _ArchiveName | None:
        """Parse a borg archive name into an _ArchiveName.

        Returns None when `name` does not match the expected
        `{backup_name}-{set_name}-YYYYMMDD_HHMMSS_NofM` shape -- the
        normal outcome for non-borgadm archives a user may have in
        the repo. Set-name is captured as the literal token between
        backup_name and the timestamp; it carries no semantic weight
        beyond display ordering.
        """
        pattern = re.escape(backup_name) + r"-(.+)-(\d{8}_\d{6})_(\d+)of(\d+)$"
        match = re.match(pattern, name)
        if match is None:
            return None
        set_name, ts, n_str, m_str = match.groups()
        return cls(
            backup_name=backup_name,
            set_name=set_name,
            timestamp=ts,
            n=int(n_str),
            m=int(m_str),
        )


def _archive_entries_are_complete(entries: list[_ArchiveName]) -> bool:
    """Decide whether `entries` form a complete backup set.

    Caller contract: `entries` are the members of a single set --
    they share one backup_name and one timestamp, and every set_name
    is distinct. The function asserts all three rather than
    soft-failing; a violation means the caller failed to group
    archives correctly, and surfacing the bug beats returning a
    misleading classification.

    Completeness requires a single consistent M across the entries
    and N values that cover 1..M exactly. Inconsistent Ms or a
    missing N is incomplete.
    """
    backup_names = {e.backup_name for e in entries}
    assert len(backup_names) == 1, (
        f"entries must share a backup_name; got {sorted(backup_names)}"
    )
    timestamps = {e.timestamp for e in entries}
    assert len(timestamps) == 1, (
        f"entries must share a timestamp; got {sorted(timestamps)}"
    )
    set_names = [e.set_name for e in entries]
    assert len(set_names) == len(set(set_names)), (
        f"entries must have distinct set names; got {sorted(set_names)}"
    )
    m_values = {e.m for e in entries}
    if len(m_values) != 1:
        return False
    (m,) = m_values
    n_values = {e.n for e in entries}
    return n_values == set(range(1, m + 1))


def list_backups(
    latest: bool = False,
    partial: bool = False,
    bypass_lock: bool = False,
) -> dict[str, list[str]]:
    cfg = get_cfg()

    result = list_backups_raw(bypass_lock)

    archives_by_ts: dict[str, list[_ArchiveName]] = {}
    for line in result.stdout.strip().splitlines():
        entry = _ArchiveName.from_str(cfg.BACKUP_NAME, line.strip())
        if entry is None:
            continue
        archives_by_ts.setdefault(entry.timestamp, []).append(entry)

    rv: dict[str, list[str]] = {}
    for ts in sorted(archives_by_ts.keys(), reverse=True):
        entries = archives_by_ts[ts]
        is_full = _archive_entries_are_complete(entries)
        if not ((not partial and is_full) or (partial and not is_full)):
            continue
        rv[ts] = [f"{cfg.BORG_REPO}::{name}" for name in sorted(entries)]
        if latest:
            break

    return rv


# Matches borg's checkpoint archives -- intermediate state from
# interrupted backups. borg prune cleans them up itself, so borgadm
# leaves them alone rather than surface them as "unknown". The full
# archive shape (timestamp + NofM) is required so a malformed name
# like `{BACKUP_NAME}-foo.checkpoint` or a checkpoint of a
# suffix-less archive still surfaces as unknown rather than getting
# filtered.
_BORG_CHECKPOINT_RE = re.compile(
    r"-\d{8}_\d{6}_\d+of\d+\.checkpoint(?:\.\d+)?$"
)


def list_unknown_archives(bypass_lock: bool = False) -> list[str]:
    """Return archive names that look like borgadm's own but don't
    parse into the expected shape.

    "Looks like borgadm's own" = starts with f"{cfg.BACKUP_NAME}-".
    Names with a foreign prefix stay silent (a user may keep other
    archives in the same repo). Names matching borg's `.checkpoint`
    / `.checkpoint.N` shape are filtered out for the same reason.
    """
    cfg = get_cfg()
    result = list_backups_raw(bypass_lock)
    prefix = f"{cfg.BACKUP_NAME}-"
    unknown: list[str] = []
    for line in result.stdout.strip().splitlines():
        name = line.strip()
        if not name.startswith(prefix):
            continue
        if _BORG_CHECKPOINT_RE.search(name):
            continue
        if _ArchiveName.from_str(cfg.BACKUP_NAME, name) is None:
            unknown.append(name)
    return sorted(unknown)


def is_mountpoint(path: Path) -> bool:
    try:
        output = subprocess.check_output(["mount"], text=True)
        for line in output.splitlines():
            if f" on {path} " in line:
                return True
    except subprocess.CalledProcessError:
        pass
    return False


def _mounts_under(root: Path) -> list[tuple[Path, str]]:
    """Return (mountpoint, fstype) for every mount at or under `root`.

    Parses `mount` output rather than /proc/mounts: the borgadm user
    inside the extract container may lack read permission on the latter.
    Runs as part of cleanup, so an unusable `mount` (failed or absent)
    yields an empty list rather than an exception.
    """
    try:
        output = subprocess.check_output(["mount"], text=True)
    except FileNotFoundError, subprocess.CalledProcessError:
        return []
    root_str = root.as_posix()
    found: list[tuple[Path, str]] = []
    for line in output.splitlines():
        m = re.match(r"\S+ on (.+) type (\S+)", line)
        if not m:
            continue
        mp = m.group(1)
        if mp == root_str or mp.startswith(root_str + "/"):
            found.append((Path(mp), m.group(2)))
    return found


def _umount_tree(root: Path) -> None:
    """Force-unmount every mount at or under `root`, overlay mounts first.

    A rsync run's overlay 'merged' mount stacks on the per-archive fuse
    mounts, so it has to come down before them or the fuse umount is
    blocked.
    """
    mounts = _mounts_under(root)
    mounts.sort(key=lambda mt: 0 if mt[1] == "overlay" else 1)
    for mp, _fstype in mounts:
        run_cmd(["umount", "-f", mp.as_posix()], sudo=True, errok=True)


def _reclaim_stale_run_dirs(parent: Path, prefix: str, keep: Path) -> None:
    """Unmount and remove tmp dirs left by dead rsync runs.

    A run killed by SIGKILL (e.g. the extract container restarting) never
    reaches its cleanup, leaking its tmp dir and any mounts beneath it.
    Both the tmp-dir prefix and the lockfile are derived from the target
    basename and live in the target's parent, and the caller holds the
    per-target flock -- so every sibling matching `prefix` other than the
    live `keep` dir belongs to a dead run of this same target and is safe
    to reclaim. Runs against other targets use a different prefix and/or
    parent, so they are never touched.
    """
    keep_str = keep.as_posix()
    for entry in sorted(parent.glob(prefix + "*")):
        if not entry.is_dir() or entry.as_posix() == keep_str:
            continue
        logger.info(f"Reclaiming stale rsync dir: {entry}")
        _umount_tree(entry)
        run_cmd(["rm", "-rf", entry.as_posix()], sudo=True, errok=True)


def check_sudo() -> bool:
    cfg = get_cfg()

    try:
        subprocess.run(
            ["sudo", "-n", "-E", "true"],
            check=True,
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL,
            timeout=cfg.CMD_TIMEOUT,
        )
        return True
    except subprocess.CalledProcessError:
        return False
    except FileNotFoundError:
        # sudo not installed
        return False


def backup_set_paths(
    set_name: str | None = None,
) -> tuple[set[Path], set[Path]]:
    """
    Return sets of directories and files from BACKUP_SETS paths.
    Directories end in a "/", all other entries are considered files.
    """
    cfg = get_cfg()

    paths: set[str] = {
        k
        for i, j in cfg.BACKUP_SETS.items()
        if set_name is None or i == set_name
        for k in j["paths"]
    }
    dirs: set[Path] = {Path(i) for i in paths if i.endswith("/")}
    files: set[Path] = {Path(i) for i in paths if not i.endswith("/")}
    return (dirs, files)


def delete_paths(
    root: Path, relative_paths: set[Path], dry_run: bool = True
) -> None:
    """
    Delete paths under root. Does not follow symlinks.
    """
    logger.info(f"Deleting {len(relative_paths)} paths in: {root}")
    for rel in sorted(
        relative_paths, key=lambda p: -len(p.parts)
    ):  # deepest first
        abs_path = root / rel
        if abs_path.is_dir():
            logger.debug(f"Deleting directory: {abs_path}")
            if not dry_run:
                shutil.rmtree(abs_path)
        else:
            logger.debug(f"Deleting: {abs_path}")
            if not dry_run:
                abs_path.unlink()


def ts_to_keep(timestamps: set[str]) -> OrderedDict[str, str]:
    """
    Given a list of timestamps, return a ordered dictionary (sorted by
    timestamp) of which ones to keep, implementing a retention GFS
    (Grandfather-father-son) retention policy. This duplicates the retention
    policy implemented by borg itself. We do this to enable testing of the
    policy, and because we borg doesn't support grouping of backups into
    sets like we do.
    """
    if not timestamps:
        return collections.OrderedDict()
    ts_keep: OrderedDict[str, str] = collections.OrderedDict()

    def keep_by_interval(interval: Interval) -> None:
        last: datetime | None = None
        ts: str | None = None
        ts_keep_new: OrderedDict[str, str] = collections.OrderedDict()
        for ts in sorted(timestamps - set(ts_keep.keys())):
            assert ts not in ts_keep
            dt: datetime = datetime.strptime(ts, "%Y%m%d_%H%M%S")
            if last is None or (dt - last) >= interval.timedelta():
                last = dt
                ts_keep_new[ts] = str(interval)
        ts_latest = ts

        i: int = 0
        for ts in sorted(ts_keep_new.keys(), reverse=True):
            ts_keep_new[ts] = ts_keep_new[ts] + f"-{i}"
            i += 1

        logger.debug(
            "interval=%s, keep=%s, len=%s, ts=%s",
            interval,
            interval.keep(),
            len(ts_keep_new),
            ts,
        )

        if (
            len(ts_keep_new) < interval.keep()
            and ts_latest is not None
            and ts_latest not in ts_keep_new
        ):
            ts_keep_new[ts_latest] = str(interval) + "-next"

        if interval.keep() > 0:
            for k in list(ts_keep_new.keys())[-interval.keep() :]:
                ts_keep[k] = ts_keep_new[k]

    keep_by_interval(Interval.HOUR)
    keep_by_interval(Interval.DAY)
    keep_by_interval(Interval.WEEK)
    keep_by_interval(Interval.MONTH)
    keep_by_interval(Interval.YEAR)

    # Sort the results by timestamp
    ts_keep = collections.OrderedDict(
        [(k, ts_keep[k]) for k in sorted(ts_keep.keys(), reverse=True)]
    )
    return ts_keep


def report_runtime() -> None:
    elapsed_time = time.perf_counter() - _start_time
    elapsed_time_str = str(timedelta(seconds=int(elapsed_time)))
    logger.debug(f"Execution time (hh:mm:ss): {elapsed_time_str}")


# -----------------------------------------------------------------------------
# Subcommands
# -----------------------------------------------------------------------------
def _repo_root() -> Path:
    """Return the borgadm repo root.

    Resolves symlinks so paths derived from this work when borgadm is
    invoked through a symlinked launcher; without the resolve, the
    launcher's parent dir would be returned instead of the repo
    checkout.
    """
    return Path(__file__).resolve().parent.parent


def _automate_require_crony() -> None:
    # Precondition for the automate subcommand: ensure the sibling crony
    # tool is usable so apply / status / destroy fail clearly rather
    # than mid-subprocess. automate drives crony, which owns the
    # scheduler side (launchd on macOS, systemd on Linux).
    _crony_path()


# Name of the crony bundle borgadm owns: drop-in file `borgadm.toml`,
# jobs namespaced `borgadm.<op>`.
_CRONY_BUNDLE = "borgadm"

# Fixed namespace so each operation's crony-job UUID is stable across
# apply / destroy / apply cycles -- seeded by bundle + operation name
# (e.g. "borgadm-create") rather than hard-coded per job.
_CRONY_UUID_NAMESPACE = uuid.uuid5(
    uuid.NAMESPACE_URL, "https://github.com/epilatow/utils#borgadm-crony"
)


def _borgadm_script_path() -> str:
    """Return the path to borgadm itself, for a crony job's command.

    Resolves symlinks so the command points at the real script in the
    repo rather than a launcher symlink that could later move.
    """
    return str(Path(__file__).resolve())


def _crony_path() -> str:
    """Path to the sibling crony tool that owns the schedule.

    Raises if it isn't a usable executable so apply / status /
    destroy fail clearly rather than mid-subprocess.
    """
    crony = _repo_root() / "bin" / "crony"
    if not crony.is_file() or not os.access(crony, os.X_OK):
        raise BorgadmError(f"crony not found or not executable: {crony}")
    return str(crony)


def _crony_dropin_dir() -> Path:
    """crony's drop-in config dir, resolved exactly as crony resolves
    it (its CRONY_CONFIG_DROPIN_DIR / CRONY_CONFIG_DIR env vars, else
    the ~/.config/crony/config default) so the bundle lands where
    crony reads it.

    crony derives that default from its own script basename, so the
    hardcoded "crony" here holds only while the sibling tool keeps that
    name; _crony_path() resolves the same basename.
    """
    dropin = os.environ.get("CRONY_CONFIG_DROPIN_DIR")
    if dropin:
        return Path(dropin)
    config_dir = os.environ.get("CRONY_CONFIG_DIR") or os.path.expanduser(
        "~/.config/crony"
    )
    return Path(config_dir) / "config"


def _current_host() -> str:
    """Short hostname for the bundle's `[target.host.<name>]`.

    Must match crony's own `current_host()` (short name, everything
    before the first dot) so the host target crony renders selects on
    the machine where `automate apply` ran.
    """
    return socket.gethostname().split(".")[0]


def _crony_bundle_path() -> Path:
    return _crony_dropin_dir() / f"{_CRONY_BUNDLE}.toml"


def _crony_job_uuid(op: str) -> str:
    """Deterministic UUID for a crony job, stable across re-applies."""
    return str(uuid.uuid5(_CRONY_UUID_NAMESPACE, f"{_CRONY_BUNDLE}-{op}"))


def _crony_jobs() -> list[tuple[str, str, str]]:
    """Return (job-name, command, interval) for each automated job.

    Every job runs borgadm directly. `create` reads user files; on macOS
    that needs Full Disk Access, so there its crony job carries the
    `full-disk-access` flag (set in `_render_crony_bundle`) and crony
    routes it through Crony.app for the grant. On Linux a user systemd
    job already reads everything the user owns, so no such flag is added.
    The `check` commands read only repo metadata and need none on any
    platform. Each command is a single `/bin/sh -c` string (how crony
    runs a job's `command`), with paths shell-quoted.
    """
    script = _borgadm_script_path()

    def check(op: str) -> str:
        return f"{shlex.quote(script)} check {op} --timestamp-messages"

    return [
        (
            "create",
            f"{shlex.quote(script)} create --timestamp-messages",
            "1h",
        ),
        ("check-age", check("age"), "1d"),
        ("check-prune", check("prune"), "1d"),
        ("check-full", check("full"), "7d"),
    ]


def _render_crony_bundle() -> str:
    """Render the crony bundle TOML borgadm installs.

    priority, the keep-awake flag, env, and the wallclock cap are
    identical for every job, so they live in `[defaults]` (no job
    overrides them) rather than being repeated per job. The defaults run
    all jobs un-throttled (`priority = high`), hold the machine awake
    (`flags = ["keep-awake"]`), and extend PATH with ~/.local/bin
    (`env`) so borgadm's `uv` shebang resolves under the scheduler's
    minimal PATH. Only `create` reads protected user files, and only on
    macOS does that need a grant, so on macOS it alone adds
    `full-disk-access` to its flags (composing with the inherited
    keep-awake) and crony routes it through Crony.app for the grant; on
    Linux a user systemd job already reads everything the user owns, so
    the flag is omitted and create runs without it.
    The bundle default `notify-channels` is ["default"], plus
    "dialog-popup" on macOS only (a desktop dialog, undeliverable on
    Linux), so a failing check notifies through the user's default crony
    bundle and, on macOS, also pops a desktop dialog. `create`
    overrides with `notify-channels = []` (silent) and treats borg's
    transient-warning exit (`success-exit-codes = [1]`) as success -- it
    runs hourly and a file changing or vanishing mid-read is noise, not
    a failed backup -- while the checks omit notify-channels to take the
    bundle default and keep the default exit handling (a check warning
    is a real signal). The default `job-timeout-sec = 0` disables
    crony's wallclock cap for every job: borgadm caps each borg command
    itself (BORG_CMD_TIMEOUT, default 4h), so crony's shorter default
    cap would only preempt a legitimately long backup or check.

    The target keys on this host (`[target.host.<this-host>]`); the
    repo and backup paths it runs against come from this machine's
    `~/.borgadm`.
    """
    jobs: dict[str, Any] = {}
    for name, command, interval in _crony_jobs():
        job: dict[str, Any] = {
            "uuid": _crony_job_uuid(name),
            "command": command,
            "interval": interval,
        }
        if name == "create":
            job["notify-channels"] = []
            job["success-exit-codes"] = [1]
            # create reads protected user files; only macOS gates that
            # behind Full Disk Access, so the flag (which makes crony
            # route the job through Crony.app) is added only there. On
            # Linux the user systemd job already has the access.
            if platform.system() == "Darwin":
                job["flags"] = ["full-disk-access"]
        jobs[name] = job
    # dialog-popup pops a macOS desktop dialog; it is undeliverable on
    # Linux, so the bundle default carries it only on macOS. On Linux a
    # failing check notifies through the user's default channels alone.
    default_channels = ["default"]
    if platform.system() == "Darwin":
        default_channels.append("dialog-popup")
    doc: dict[str, Any] = {
        "defaults": {
            "notify-channels": default_channels,
            "job-timeout-sec": 0,
            "priority": "high",
            "flags": ["keep-awake"],
            "env": {"PATH": "$HOME/.local/bin:$PATH"},
        },
        "job": jobs,
        "target": {
            "host": {
                _current_host(): {"jobs": [n for n, _, _ in _crony_jobs()]}
            }
        },
    }
    header = (
        "# Generated by `borgadm automate apply` -- edits are\n"
        "# overwritten on the next apply.\n\n"
    )
    return header + tomlkit.dumps(doc)


def do_log_files() -> None:
    log_paths: list[str] = [str(LOGFILE)]
    for lp in _crony_log_paths():
        if lp not in log_paths:
            log_paths.append(lp)
    for lp in log_paths:
        logger.info(lp)


def _crony_log_paths() -> list[str]:
    """Return each automated job's crony run-log path when crony is
    managing the bundle. Empty when crony is missing or when the bundle
    isn't installed. Each path comes from `crony logs <job> -p`, which
    resolves structurally from the bundle config (no run required yet).
    """
    if not _crony_bundle_path().exists():
        return []
    try:
        crony = _crony_path()
    except BorgadmError:
        return []
    paths: list[str] = []
    for name, _command, _interval in _crony_jobs():
        proc = run_cmd(
            [crony, "logs", f"{_CRONY_BUNDLE}.{name}", "-p"], errok=True
        )
        lp = proc.stdout.strip()
        if proc.returncode == 0 and lp:
            paths.append(lp)
    return paths


def do_automate_status() -> None:
    _automate_require_crony()
    crony = _crony_path()
    # Without the bundle file crony has no addressable borgadm bundle and
    # would just error; report the cleaner not-enabled state directly.
    if not _crony_bundle_path().exists():
        logger.info("Automation is not enabled (run 'borgadm automate apply').")
        return
    # crony owns the per-job state (on macOS that includes the Crony.app
    # wrapper health for the full-disk-access create job); show its
    # table.
    run_cmd(
        [crony, "status", "-b", _CRONY_BUNDLE], allow_output=True, errok=True
    )


def do_automate_destroy() -> None:
    _automate_require_crony()
    crony = _crony_path()
    bundle = _crony_bundle_path()
    # `crony destroy` works off crony's on-disk state, so it removes the
    # units and logs even when the bundle file is already gone. Tolerate
    # its failure (errok) so destroying already-destroyed automation --
    # where crony has no addressable bundle and exits nonzero -- is a
    # no-op rather than an error. But a present bundle file means the
    # bundle is installed, so a nonzero exit is a real failure (e.g. a
    # running job holds the lock) and gets surfaced rather than silently
    # swallowed.
    proc = run_cmd(
        [crony, "destroy", "-b", _CRONY_BUNDLE],
        allow_output=True,
        errok=True,
    )
    if proc.returncode != 0 and bundle.exists():
        raise BorgadmError(
            f"crony destroy failed (exit {proc.returncode}); "
            "is a borgadm job currently running?"
        )
    if bundle.exists():
        logger.info(f"Removing crony bundle: {bundle}")
        bundle.unlink()


def do_automate_apply() -> None:
    _automate_require_crony()
    crony = _crony_path()

    bundle = _crony_bundle_path()
    bundle.parent.mkdir(parents=True, exist_ok=True)
    bundle.write_text(_render_crony_bundle())
    logger.info(f"Wrote crony bundle: {bundle}")
    # crony apply reconciles idempotently (deterministic UUIDs), so a
    # re-apply is a no-op update rather than a delete + re-add. On macOS
    # the create job's full-disk-access flag makes crony build Crony.app
    # and print the Full Disk Access grant instructions itself (forwarded
    # here via allow_output), so borgadm prints no FDA guidance of its
    # own; on Linux the job needs no grant.
    run_cmd([crony, "apply", "-b", _CRONY_BUNDLE], allow_output=True)


def do_break_lock() -> None:
    cfg = get_cfg()

    logger.info(f"Breaking repo lock: {cfg.BORG_REPO}")
    run_cmd(
        borg_cmd()
        + [
            "break-lock",
            cfg.BORG_REPO,
        ]
    )


def do_check_age(bypass_lock: bool) -> None:
    cfg = get_cfg()
    seconds = cfg.CHECK_AGE_SECONDS
    backups = list_backups(latest=True, bypass_lock=bypass_lock)
    if not backups:
        raise CheckNoBackupsError("No full backups found.")
    assert len(backups.keys()) == 1, backups
    latest = list(backups.keys())[0]

    ts = datetime.strptime(latest, "%Y%m%d_%H%M%S")
    age = int((datetime.now() - ts).total_seconds())
    if age > seconds:
        raise CheckAgeError(
            f"Latest full backup ({latest}) is too old:"
            f" {age}s; limit is: {seconds}s"
        )

    logger.info(
        "Latest full backup (%s) age is: %s seconds; limit is: %s seconds",
        latest,
        age,
        seconds,
    )


def _borg_check_cmd(
    target: str,
    *,
    progress: bool,
    repository_only: bool = False,
    archives_only: bool = False,
    repair: bool = False,
) -> list[str]:
    """Build a `borg check` argv for one target.

    `repository_only` and `archives_only` select borg's two check phases
    (segment/index vs. archive metadata) and are mutually exclusive;
    passing neither runs both. `repair` adds --repair -- the parser
    requires --yes before any --repair caller runs, and the caller sets
    the BORG_CHECK_I_KNOW_WHAT_I_AM_DOING env borg requires for
    non-interactive repair.
    """
    assert not (repository_only and archives_only), (
        "repository_only and archives_only are mutually exclusive"
    )
    args = borg_cmd() + ["check"]
    if repair:
        args.append("--repair")
    if repository_only:
        args.append("--repository-only")
    if archives_only:
        args.append("--archives-only")
    if progress:
        args.append("--progress")
    args.append(target)
    return args


def _check_archive_targets(
    targets: list[str], progress: bool, bypass_lock: bool
) -> None:
    for target in targets:
        logger.info(f"Checking archive metadata: {target}")
        cmd = _borg_check_cmd(target, progress=progress)
        try:
            run_borg(
                cmd,
                repo_write=False,
                bypass_lock=bypass_lock,
                allow_output=progress,
            )
        except SubprocessError as e:
            raise CheckArchivesError(
                f"Archive metadata check failed: {target}"
            ) from e


def _resolve_archives(
    selectors: list[str], bypass_lock: bool = False
) -> list[str]:
    """Resolve archive selectors to full archive names. Each selector is a
    full archive name (verified to exist) or a YYYYMMDD_HHMMSS timestamp
    standing for every archive at that time (partials included). Shared by
    `delete` and `check archives` so the two read the argument the same
    way."""
    cfg = get_cfg()
    ts_pattern = re.compile(r"^\d{8}_\d{6}$")
    # Resolved lazily so a name-only or timestamp-only call makes only the
    # borg list it needs.
    by_timestamp: dict[str, list[str]] | None = None
    raw_names: list[str] | None = None
    resolved: list[str] = []
    for selector in selectors:
        if ts_pattern.match(selector):
            if by_timestamp is None:
                by_timestamp = list_backups(bypass_lock=bypass_lock)
                by_timestamp |= list_backups(
                    partial=True, bypass_lock=bypass_lock
                )
            if selector not in by_timestamp:
                raise BorgadmError(
                    f"No archives found for timestamp: {selector}"
                )
            resolved += [
                a.removeprefix(f"{cfg.BORG_REPO}::")
                for a in by_timestamp[selector]
            ]
        else:
            if raw_names is None:
                raw_names = (
                    list_backups_raw(bypass_lock).stdout.strip().splitlines()
                )
            if selector not in raw_names:
                raise BorgadmError(f"Archive not found: {selector}")
            resolved.append(selector)
    return resolved


def do_check_archives(
    progress: bool, latest: bool, archive: list[str], bypass_lock: bool
) -> None:
    cfg = get_cfg()
    assert not (latest and archive), "latest and archive are mutually exclusive"
    if archive:
        names = _resolve_archives(archive, bypass_lock=bypass_lock)
        targets = [f"{cfg.BORG_REPO}::{name}" for name in names]
        _check_archive_targets(targets, progress, bypass_lock)
    elif latest:
        backups = list_backups(latest=True, bypass_lock=bypass_lock)
        if not backups:
            raise CheckNoBackupsError("No full backups found.")
        assert len(backups.keys()) == 1
        _check_archive_targets(list(backups.values())[0], progress, bypass_lock)
    else:
        logger.info("Checking archive metadata.")
        cmd = _borg_check_cmd(
            cfg.BORG_REPO, progress=progress, archives_only=True
        )
        try:
            run_borg(
                cmd,
                repo_write=False,
                bypass_lock=bypass_lock,
                allow_output=progress,
            )
        except SubprocessError as e:
            raise CheckArchivesError("Archive metadata check failed.") from e


def do_check_prune(bypass_lock: bool) -> None:
    cfg = get_cfg()
    problems: list[str] = []

    partial_backups = list_backups(partial=True, bypass_lock=bypass_lock)
    if partial_backups:
        for _ts, archives in partial_backups.items():
            names = [a.removeprefix(f"{cfg.BORG_REPO}::") for a in archives]
            problems.append(f"Partial archive(s): {', '.join(names)}")

    full_backups = list_backups(bypass_lock=bypass_lock)
    ts_keep = ts_to_keep(set(full_backups.keys()))
    ts_prune = full_backups.keys() - ts_keep.keys()
    if ts_prune:
        pruning = sorted(ts_prune, reverse=True)
        problems.append(f"Unpruned backups: {', '.join(pruning)}")

    if problems:
        detail = "\n  ".join(problems)
        raise CheckPruneError(f"Prune check failed:\n  {detail}")

    logger.info("No unpruned archives found.")


def do_check_repo(progress: bool, bypass_lock: bool) -> None:
    cfg = get_cfg()
    logger.info("Checking repo metadata.")
    cmd = _borg_check_cmd(
        cfg.BORG_REPO, progress=progress, repository_only=True
    )
    try:
        run_borg(
            cmd,
            repo_write=False,
            bypass_lock=bypass_lock,
            allow_output=progress,
        )
    except SubprocessError as e:
        raise CheckRepoError("Repo metadata check failed.") from e


def do_check_full(progress: bool, bypass_lock: bool) -> None:
    cfg = get_cfg()
    logger.info("Checking full repo and archive metadata.")
    cmd = _borg_check_cmd(cfg.BORG_REPO, progress=progress)
    try:
        run_borg(
            cmd,
            repo_write=False,
            bypass_lock=bypass_lock,
            allow_output=progress,
        )
    except SubprocessError as e:
        raise CheckFullError(
            "Full repo and archive metadata check failed."
        ) from e


def do_compact(progress: bool) -> None:
    cfg = get_cfg()
    logger.info(f"Compacting repo: {cfg.BORG_REPO}")
    args = ["compact", *(["--progress"] if progress else []), cfg.BORG_REPO]
    run_borg(borg_cmd() + args, repo_write=True, allow_output=progress)


def do_create(dry_run: bool, progress: bool, no_prune: bool) -> None:
    cfg = get_cfg()
    # do_create is the one subcommand that requires BACKUP_SETS to be
    # non-empty -- the others read whatever the repo already contains
    # via list_backups, which is config-set-name-agnostic.
    if not cfg.BACKUP_SETS:
        raise ConfigError(f"BACKUP_SETS not defined in config: {CONFIG}")

    def backup_set_tests(set_name: str) -> None:
        error: bool = False
        dirs, files = backup_set_paths(set_name)
        for d in dirs:
            full_path = cfg.BACKUP_ROOT / d
            if not os.path.isdir(full_path):
                logger.error(
                    f"Missing backup dir (set: '{set_name}'): {full_path}"
                )
                error = True
            elif not os.listdir(full_path):
                logger.error(
                    f"Empty backup dir (set: '{set_name}'): {full_path}"
                )
                error = True
        for f in files:
            full_path = cfg.BACKUP_ROOT / f
            if os.path.isdir(full_path):
                logger.error(
                    "Missing trailing slash for backup directory in config "
                    "(set: '%s'): %s",
                    set_name,
                    full_path,
                )
                error = True
            if not os.path.exists(full_path):
                logger.error(
                    f"Missing backup path (set: '{set_name}'): {full_path}"
                )
                error = True
        if error:
            raise BorgadmError(f"Backup set '{set_name}' validation failed")

    # Run all tests before backups to fail-fast in case of errors
    for set_name in cfg.BACKUP_SETS:
        backup_set_tests(set_name)

    timestamp = datetime.now().strftime("%Y%m%d_%H%M%S")
    # NofM suffix: M is the count of configured sets; N is the 1-based
    # position of the current set among the sorted dict keys. Sorting
    # the keys means two configs with the same set names produce
    # identical archive names regardless of how the user edits the
    # dict; reordering the dict literally cannot change archive names.
    sorted_set_names = sorted(cfg.BACKUP_SETS.keys())
    suffix_count = len(sorted_set_names)
    for suffix_pos, set_name in enumerate(sorted_set_names, start=1):
        set_cfg = cfg.BACKUP_SETS[set_name]
        # Backups can take a while, so re-run tests before each backup
        backup_set_tests(set_name)
        for path in cfg.BACKUP_MOUNTS:
            full_path = cfg.BACKUP_ROOT / path
            if not is_mountpoint(full_path):
                raise BorgadmError(f"Missing backup mount: {full_path}")
        create_args = set_cfg.get("create_options", [])
        create_args += ["--progress"] if progress else []
        create_args += ["--dry-run"] if dry_run else ["--stats"]
        excludes = list(set_cfg.get("excludes", []))
        if platform.system() == "Darwin":
            backup_paths = [Path(p.rstrip("/")) for p in set_cfg["paths"]]

            def is_under_backup_path(
                exclude: str, backup_paths: list[Path] = backup_paths
            ) -> bool:
                exc_path = Path(exclude)
                return any(exc_path.is_relative_to(bp) for bp in backup_paths)

            auto_excludes = [
                e
                for e in _MACOS_EXCLUDES
                if e not in excludes and is_under_backup_path(e)
            ]
            if auto_excludes:
                logger.debug(
                    f"Auto-excluding {len(auto_excludes)} macOS paths"
                    f" for set '{set_name}'"
                )
                excludes.extend(auto_excludes)
        for e in excludes:
            create_args += ["--exclude", e]
        archive_name = _ArchiveName(
            backup_name=cfg.BACKUP_NAME,
            set_name=set_name,
            timestamp=timestamp,
            n=suffix_pos,
            m=suffix_count,
        )
        archive = f"{cfg.BORG_REPO}::{archive_name}"
        dry = " (dry-run)" if dry_run else ""
        logger.info(f"Create archive, start: {archive}{dry})")
        cmd = (
            borg_cmd()
            + ["create"]
            + create_args
            + [archive]
            + [os.path.expanduser(p) for p in set_cfg["paths"]]
        )
        run_borg(
            cmd,
            repo_write=True,
            cwd=cfg.BACKUP_ROOT,
            allow_output=progress,
        )
        logger.info(f"Create archive, finish: {archive}{dry})")

    if not no_prune:
        do_prune(dry_run=dry_run, progress=progress, cleanup_unknown=False)


def do_delete(
    archive: str | None,
    dry_run: bool,
    latest: bool,
    progress: bool,
) -> None:
    cfg = get_cfg()

    assert not (latest and archive), "latest and archive are mutually exclusive"
    assert latest or archive, "one of latest or archive is required"

    if latest:
        backups = list_backups(latest=True)
        if not backups:
            raise BorgadmError("No full backups found.")
        ts = list(backups.keys())[0]
        archives_to_delete = [
            a.removeprefix(f"{cfg.BORG_REPO}::") for a in backups[ts]
        ]
        logger.info(
            f"Deleting {len(archives_to_delete)} archive(s) at the latest "
            f"full backup ({ts})"
        )
    else:
        assert archive is not None
        archives_to_delete = _resolve_archives([archive])
        logger.info(f"Deleting {len(archives_to_delete)} archive(s): {archive}")

    cmd = borg_cmd() + ["delete"]
    cmd += ["--progress"] if progress else []
    if dry_run:
        cmd.append("--dry-run")
    else:
        cmd.append("--stats")
    cmd.append(cfg.BORG_REPO)
    cmd += archives_to_delete
    run_borg(cmd, repo_write=True, allow_output=progress or dry_run)


def do_extract(
    target_dir: Path,
    patterns: list[str],
    dry_run: bool,
    delete: bool,
    progress: bool,
    bypass_lock: bool,
) -> None:
    backups = list_backups(latest=True, bypass_lock=bypass_lock)
    if not backups:
        raise BorgadmError("No full backups found.")
    assert len(backups.keys()) == 1
    archives = list(backups.values())[0]

    target_dir = target_dir.resolve()
    if not os.path.isdir(target_dir):
        raise BorgadmError(f"Invalid extraction dirctory: {target_dir}")

    logger.info(f"Extract target dirctory: {target_dir}")

    cleanup_paths: set[Path] = set()
    if delete:
        # archive_paths is every entry in the archives; archive_dirs is
        # the subset that are directories. The "{type} {path}" format
        # puts a single type char ('d' for a directory) then a space
        # then the path, so the path starts at index 2 and may itself
        # contain spaces.
        archive_paths: set[Path] = set()
        archive_dirs: set[Path] = set()
        for archive in archives:
            logger.info(f"Getting archive contents: {archive}")
            cmd = borg_cmd() + ["list", "--format", "{type} {path}{NL}"]
            for pattern in patterns:
                cmd += ["--pattern", pattern]
            cmd.append(archive)
            proc = run_borg(cmd, repo_write=False, bypass_lock=bypass_lock)
            for line in proc.stdout.splitlines():
                if not line:
                    continue
                entry_path = Path(line[2:])
                archive_paths.add(entry_path)
                if line[0] == "d":
                    archive_dirs.add(entry_path)

        logger.info(f"Getting target-path contents: {target_dir}")
        local_paths: set[Path] = set()
        for walk_root, walk_dirs, walk_files in os.walk(target_dir):
            root_path = Path(walk_root)
            for name in walk_files + walk_dirs:
                full_path = root_path / name
                rel_path = full_path.relative_to(target_dir)
                local_paths.add(rel_path)

        logger.info(
            "Filtering local contents against backup paths and archive contents"
        )
        # Derive "managed" path roots from the archives being extracted
        # rather than from cfg.BACKUP_SETS. If the config has drifted
        # since these archives were created (a backup set was added,
        # removed, or renamed), reading cfg would over-delete or
        # under-delete in target_dir. The archives are the
        # authoritative statement of what this restore covers.
        #
        # The root of a backed-up tree is the topmost archive entry
        # (no proper ancestor in archive_paths). This handles
        # multi-component cfg-relative backup paths like
        # "Pictures/Family/" -- borg create writes a directory entry
        # for the explicitly-specified path but no entries for its
        # parents, so the root may live at any depth. A directory
        # topmost entry IS its own managed root; a file topmost entry
        # (a bare-file backup set) contributes its parent directory,
        # so --delete still reconciles the file's siblings. A
        # root-level file therefore makes target_dir itself a managed
        # root.
        managed_roots: set[Path] = set()
        # Sort by depth then lexicographically by path string so the
        # outcome is deterministic even when two entries share a
        # depth (e.g. a root-level file and a root-level directory).
        for p in sorted(archive_paths, key=lambda x: (len(x.parts), str(x))):
            if any(p.is_relative_to(r) and p != r for r in managed_roots):
                continue
            managed_roots.add(p if p in archive_dirs else p.parent)

        def archive_managed(path: Path) -> bool:
            # Path.is_relative_to(self) is True, so a single
            # is_relative_to check covers the exact-match case too.
            return any(path.is_relative_to(r) for r in managed_roots)

        # An archive entry's ancestor directories must survive the
        # delete pass even when they aren't archive entries themselves
        # -- borg omits the parents above a backed-up path, so a
        # "Pictures/Family/" set leaves Pictures/ with no entry.
        # Deleting it would only force a re-extract.
        archive_ancestors = {
            parent for p in archive_paths for parent in p.parents
        }
        local_paths = set(filter(archive_managed, local_paths))
        extras = sorted(
            local_paths - archive_paths - archive_ancestors,
            key=lambda x: len(x.parts),
        )  # shallowest first
        for path in extras:
            if not any(path.is_relative_to(p) for p in cleanup_paths):
                cleanup_paths.add(path)

        logger.info(
            f"Found {len(cleanup_paths)} paths to delete after extraction."
        )

    tdir_dirname = target_dir.parent
    tdir_basename = target_dir.name
    lockfile = tdir_dirname / f".{BASENAME}_{tdir_basename}.lock"
    with open(lockfile, "w") as lf:
        try:
            fcntl.flock(lf, fcntl.LOCK_EX | fcntl.LOCK_NB)
        except BlockingIOError:
            raise BorgadmError(
                "Another extract process is already running for this path."
            ) from None

        for archive in archives:
            logger.info(f"Extracting: {archive} to {target_dir}")

            cmd = borg_cmd() + ["extract"]
            cmd += ["--progress"] if progress else []
            if dry_run:
                cmd.append("--dry-run")
            for pattern in patterns:
                cmd += ["--pattern", pattern]
            cmd.append(archive)
            run_borg(
                cmd,
                repo_write=False,
                bypass_lock=bypass_lock,
                cwd=target_dir,
                allow_output=progress,
            )

    if cleanup_paths:
        delete_paths(target_dir, cleanup_paths, dry_run=dry_run)


def do_list(
    latest: bool,
    full_names: bool,
    include_partial: bool,
    only_partial: bool,
    keep_tags: bool,
    bypass_lock: bool,
) -> None:
    full_backups: dict[str, list[str]] = {}
    partial_backups: dict[str, list[str]] = {}
    if not only_partial:
        full_backups = list_backups(latest=latest, bypass_lock=bypass_lock)
    if include_partial or only_partial:
        partial_backups = list_backups(
            latest=latest, partial=True, bypass_lock=bypass_lock
        )
    backups = full_backups | partial_backups

    ts_keep: OrderedDict[str, str] = collections.OrderedDict()
    if keep_tags:
        ts_keep = ts_to_keep(set(full_backups.keys()))

    def get_keep_tag(ts: str) -> str:
        if not keep_tags:
            return ""
        if ts not in ts_keep:
            tag = "prune"
        else:
            tag = ts_keep[ts]
        return f" ({tag})"

    for ts, archives in backups.items():
        keep_tag = get_keep_tag(ts)
        if full_names:
            for archive in archives:
                logger.info(f"{archive}{keep_tag}")
        else:
            logger.info(f"{ts}{keep_tag}")

    for name in list_unknown_archives(bypass_lock):
        logger.warning(f"Unknown archive in repo: {name}")


def do_prune(dry_run: bool, progress: bool, cleanup_unknown: bool) -> None:
    cfg = get_cfg()

    unknown = list_unknown_archives()
    if unknown and cleanup_unknown:
        logger.info(f"Pruning unknown archives: {unknown}")
        cmd = borg_cmd() + ["delete"]
        cmd += ["--progress"] if progress else []
        if dry_run:
            cmd.append("--dry-run")
        else:
            cmd.append("--stats")
        cmd.append(cfg.BORG_REPO)
        cmd += unknown
        run_borg(cmd, repo_write=True, allow_output=progress)
    elif unknown:
        for name in unknown:
            logger.warning(
                f"Unknown archive left in repo: {name}"
                " (pass --cleanup-unknown to remove)"
            )

    partial_archives = [
        a.removeprefix(f"{cfg.BORG_REPO}::")
        for archives in list_backups(partial=True).values()
        for a in archives
    ]
    if partial_archives:
        logger.info(f"Pruning partial archives: {partial_archives}")
        cmd = borg_cmd() + ["delete"]
        cmd += ["--progress"] if progress else []
        if dry_run:
            cmd.append("--dry-run")
        else:
            cmd.append("--stats")
        cmd.append(cfg.BORG_REPO)
        cmd += partial_archives
        run_borg(cmd, repo_write=True, allow_output=progress)

    archives = list_backups()
    ts_keep = ts_to_keep(set(archives.keys()))
    ts_prune = archives.keys() - ts_keep.keys()
    prune_archives = [
        a.removeprefix(f"{cfg.BORG_REPO}::")
        for ts in ts_prune
        for a in archives[ts]
    ]
    logger.info(f"Keeping {len(ts_keep)} and pruning {len(ts_prune)} backups.")
    for k, v in ts_keep.items():
        logger.info(f"Keeping backup: {k} ({v})")
    pruning = [f"{i}" for i in sorted(ts_prune, reverse=True)]
    logger.info(f"Pruning backups: {', '.join(pruning)}")
    if prune_archives:
        cmd = borg_cmd() + ["delete"]
        cmd += ["--progress"] if progress else []
        if dry_run:
            cmd.append("--dry-run")
        else:
            cmd.append("--stats")
        cmd.append(cfg.BORG_REPO)
        cmd += prune_archives
        run_borg(cmd, repo_write=True, allow_output=progress)

    do_compact(progress)


def do_rsync(
    target_dir: Path,
    dry_run: bool,
    delete: bool,
    progress: bool,
    bypass_lock: bool,
) -> None:
    if platform.system() != "Linux":
        raise BorgadmError("Rsync subcommand is only supported on linux")

    if not check_sudo():
        raise BorgadmError(
            "Rsync subcommand requires non-interractive sudo"
            " support with the ability to set environment"
            " variables."
        )

    backups = list_backups(latest=True, bypass_lock=bypass_lock)
    if not backups:
        raise BorgadmError("No full backups found.")
    assert len(backups.keys()) == 1
    ts = list(backups.keys())[0]
    archives = list(backups.values())[0]

    target_dir = target_dir.resolve()
    if not os.path.isdir(target_dir):
        raise BorgadmError(f"Invalid extraction dirctory: {target_dir}")

    logger.info(f"Rsync target dirctory: {target_dir}")
    tdir_dirname = target_dir.parent
    tdir_basename = target_dir.name
    lockfile = tdir_dirname / f".{BASENAME}_{tdir_basename}.lock"
    tmpdir_prefix = f".{BASENAME}_{tdir_basename}.tmp."
    with open(lockfile, "w") as lf:
        try:
            fcntl.flock(lf, fcntl.LOCK_EX | fcntl.LOCK_NB)
        except BlockingIOError:
            raise BorgadmError(
                "Another extract process is already running for this path."
            ) from None

        # Create the workspace only once the flock is held: a concurrent
        # loser for this same target must not leave a tmp dir on disk for
        # the lock holder's reclaim to glob and remove. A cleanup failure
        # (e.g. a busy mount that survived umount -f) degrades to a leaked
        # dir the next run's reclaim sweeps, rather than an exception that
        # would mask the run's real error.
        tmpdir_ctx = tempfile.TemporaryDirectory(
            dir=tdir_dirname, prefix=tmpdir_prefix, ignore_cleanup_errors=True
        )
        tmpdir = Path(tmpdir_ctx.name)
        try:
            # Reclaim tmp dirs orphaned by a previously SIGKILLed run of
            # this same target.
            _reclaim_stale_run_dirs(tdir_dirname, tmpdir_prefix, tmpdir)

            archive_mounts: list[Path] = []
            for archive in archives:
                archive_name = archive.split("::", 1)[1]
                mount_dir = tmpdir / archive_name

                os.makedirs(mount_dir)
                cmd = borg_cmd() + [
                    "mount",
                    "-o",
                    "allow_other",
                    archive,
                    mount_dir.as_posix(),
                ]
                logger.info(f"Mounting {archive} to: {mount_dir}")
                run_borg(
                    cmd,
                    repo_write=False,
                    bypass_lock=bypass_lock,
                    sudo=True,
                )
                archive_mounts.append(mount_dir)

                if not os.listdir(mount_dir):
                    raise BorgadmError(f"Empty archive mount: {archive}")

            lowerdir = ":".join([i.as_posix() for i in archive_mounts])
            upperdir = tmpdir / "upperdir"
            workdir = tmpdir / "workdir"
            merged = tmpdir / "merged"
            os.makedirs(upperdir)
            os.makedirs(workdir)
            os.makedirs(merged)
            cmd = [
                "mount",
                "-t",
                "overlay",
                "overlay",
                "-o",
                f"lowerdir={lowerdir},upperdir={upperdir},workdir={workdir}",
                merged.as_posix(),
            ]
            logger.info(f"Merging archives with overlayfs: {merged}")
            run_cmd(cmd, sudo=True)
            if not os.listdir(merged):
                raise BorgadmError(f"Empty overlayfs mount: {merged}")

            logger.info(f"Starting rsync to: {target_dir}")
            cmd = [
                "rsync",
                "-a",
                "--stats",
                "--human-readable",
            ]
            cmd += ["--progress"] if progress else []
            cmd += ["--delete"] if delete else []
            cmd += ["--dry-run"] if dry_run else []
            cmd += [merged.as_posix() + "/", target_dir.as_posix() + "/"]
            run_cmd(cmd, allow_output=progress, sudo=True)

            # Record the version we extraced
            (tdir_dirname / f".{BASENAME}_{tdir_basename}.ts").write_text(
                f"{ts}"
            )

            logger.info(f"Finished rsync to: {target_dir}")
        finally:
            # Cleanup root owned resources. The mount table, not
            # bookkeeping, decides what comes down, so a mount stranded by
            # a failure between mounting and any later step is still torn
            # down before the TemporaryDirectory cleanup walks the tree.
            # The overlay workdir is root-owned and must be removed with
            # sudo before that cleanup can clear the rest.
            _umount_tree(tmpdir)
            run_cmd(
                ["rm", "-rf", (tmpdir / "workdir").as_posix()],
                sudo=True,
                errok=True,
            )
            tmpdir_ctx.cleanup()


def do_repair_delete_cache() -> None:
    cfg = get_cfg()
    logger.info(f"Deleting local cache for: {cfg.BORG_REPO}")
    run_cmd(
        borg_cmd()
        + [
            "delete",
            "--cache-only",
            cfg.BORG_REPO,
        ]
    )
    logger.info("Cache deleted successfully.")


def _repair_check(
    *,
    progress: bool,
    repository_only: bool = False,
    archives_only: bool = False,
) -> None:
    """Run `borg check --repair` over the whole repo.

    `repository_only` / `archives_only` scope the repair to one of
    borg's two check phases (see `_borg_check_cmd`); passing neither
    repairs both. Repair is potentially lossy for corruption borg
    cannot fully resolve, so the parser requires `--yes` before any of
    these run.
    """
    cfg = get_cfg()
    logger.info(f"Repairing repo: {cfg.BORG_REPO}")
    cmd = _borg_check_cmd(
        cfg.BORG_REPO,
        progress=progress,
        repository_only=repository_only,
        archives_only=archives_only,
        repair=True,
    )
    env = {
        **os.environ,
        "BORG_CHECK_I_KNOW_WHAT_I_AM_DOING": "YES",
    }
    run_borg(cmd, repo_write=True, allow_output=True, env=env)
    logger.info("Repo repair completed.")


def do_repair_repo(progress: bool) -> None:
    _repair_check(progress=progress, repository_only=True)


def do_repair_archives(progress: bool) -> None:
    _repair_check(progress=progress, archives_only=True)


def do_repair_full(progress: bool) -> None:
    _repair_check(progress=progress)


def do_environment() -> None:
    cfg = get_cfg()
    if _is_remote_repo(cfg.BORG_REPO):
        logger.info(f"ssh-add -q {cfg.BORG_SSHKEY_FILE}")
    logger.info(f"export BORG_PASSPHRASE=$(cat {cfg.BORG_PASSPHRASE_FILE})")
    logger.info(f"export BORG_REPO={cfg.BORG_REPO}")
    if cfg.BORG_REMOTE_PATH:
        logger.info(f"export BORG_REMOTE_PATH={cfg.BORG_REMOTE_PATH}")


_CONFIG_HEADER = """\
# borgadm configuration file (~/.borgadm)
#
# INI-style "key = value" settings read by borgadm. Edit BORG_REPO and
# BACKUP_SETS below, then uncomment any other key whose default you want
# to override. Regenerate this template with `borgadm config init`.
"""


def _fmt_ini_value(value: object) -> str:
    """Render a field value as it appears after `KEY = ` in the config.

    A non-empty object is pretty-printed and every continuation line
    indented so configparser reads the whole block as one multi-line
    value; everything else is a single token.
    """
    if isinstance(value, int):
        return str(value)
    if isinstance(value, dict) and value:
        head, *rest = json.dumps(value, indent=4).split("\n")
        return "\n".join([head, *(f"    {line}" for line in rest)])
    if isinstance(value, (list, dict)):
        return json.dumps(value)
    return str(value)


def _render_default_config() -> str:
    """Render the starter config from CONFIG_FIELDS: the authored header,
    then each field as a wrapped description comment followed by an active
    `KEY = template_value` (when the field carries one) or a commented
    `# KEY = default`."""
    lines = [_CONFIG_HEADER.rstrip("\n")]
    for field in CONFIG_FIELDS:
        suffix = " (required)" if field.required else ""
        lines.append("")
        for line in textwrap.wrap(f"{field.description}{suffix}.", width=76):
            lines.append(f"# {line}")
        if field.template_value is not None:
            lines.append(
                f"{field.name} = {_fmt_ini_value(field.template_value)}"
            )
        else:
            lines.append(f"# {field.name} = {_fmt_ini_value(field.default)}")
    # An empty value leaves a trailing "= "; strip per physical line.
    body = "\n".join(lines)
    return "\n".join(line.rstrip() for line in body.split("\n")) + "\n"


def do_config_init(config: str, force: bool) -> None:
    """Write a generated starter config to `config` (the --config path,
    default ~/.borgadm)."""
    dest = Path(config)
    if dest.exists() and not force:
        raise ConfigError(
            f"Config file already exists: {dest} (pass --force to overwrite)"
        )
    try:
        dest.write_text(_render_default_config(), encoding="utf-8")
    except OSError as e:
        raise ConfigError(f"Failed to write config file {dest}: {e}") from e
    logger.info(f"Wrote config template to {dest}")


def do_config_validate(config: str) -> None:
    """Load the config at `config` and report whether it is structurally
    valid.

    Construction IS the validation: a malformed or incomplete config
    (including a missing BACKUP_SETS, which create requires) raises
    ConfigError before this returns.
    """
    cfg = Config(config, {}, require_backup_sets=True)
    logger.info(f"config valid: {cfg.path}")


# -----------------------------------------------------------------------------
# Argument Parsing
# -----------------------------------------------------------------------------
def _validate_repair(
    parser: argparse.ArgumentParser, args: argparse.Namespace
) -> None:
    """Require `--yes` for a `repair` check, then drop it from the
    namespace. Repair is potentially lossy, so the confirmation is
    enforced at parse time (exit 2 with the usage line) and the repair
    handlers take no `yes`."""
    if not args.yes:
        parser.error(
            "This is a potentially dangerous function.\n"
            "check --repair might lead to data loss (for kinds"
            " of corruption it is not\n"
            "capable of dealing with). BE VERY CAREFUL!\n"
            "\n"
            "Pass --yes to confirm you understand the risks."
        )
    del args.yes


# The Description and Getting Started text appended to the `--help`
# epilog and rendered into the man page / GFM doc via MAN_SPEC.
# _DESCRIPTION's first paragraph is written to stand alone so it can serve
# as a one-line summary of the tool on its own (the README blurb).
_DESCRIPTION = """\
borgadm is a wrapper around borgbackup designed to manage backup sets,
where a set is a group of separate borg backups (archives) created with
different create options. It creates backups from the named sets,
verifies repository and archive integrity, prunes old and partial
archives by retention policy, and restores archives via extract or rsync.
A passphrase- and SSH-key-based workflow handles authentication to local
and remote repositories, and it can schedule unattended backups and
checks through crony(1) on macOS (launchd) and Linux (systemd).

The sets are defined in the config file; each `create` run writes one
archive per set, named {BACKUP_NAME}-{set_name}-YYYYMMDD_HHMMSS_NofM. The
NofM suffix records a set's position so a timestamp is "full" only when
every configured set is present and "partial" otherwise. The list, check,
prune, and restore subcommands operate on these timestamps, and prune can
also clean up partial or unrecognized ("unknown") archives.

Configuration lives in ~/.borgadm, an INI-style file naming the
repository, the backup sets, retention counts, credential file paths, and
check thresholds. The `automate` subcommand deploys borgadm's scheduled
create and check jobs through crony(1) (launchd on macOS, systemd on Linux);
`environment` prints the shell exports needed to run the borg CLI
directly against the configured repository."""

_GETTING_STARTED = """\
Generate a starter config at ~/.borgadm, then edit it to set at least
BORG_REPO and your BACKUP_SETS (see CONFIGURATION):

    borgadm config init

Check the config parses and is complete before the first backup:

    borgadm config validate

To create a backup of every configured set and prune old archives run:

    borgadm create

To inspect what is in the repository and verify its integrity:

    borgadm list
    borgadm check full

To restore the latest full backup into a directory:

    borgadm extract /path/to/restore

To schedule unattended backups and checks via crony(1) run:

    borgadm automate apply"""


def args_parser() -> StrictArgumentParser:
    parser = StrictArgumentParser(
        description="Borg backup manager",
        formatter_class=RawDescriptionDefaultsHelpFormatter,
        epilog=(
            f"{ExitCode.epilog()}\n\n"
            f"Description:\n{textwrap.indent(_DESCRIPTION, '  ')}\n\n"
            f"Getting Started:\n{textwrap.indent(_GETTING_STARTED, '  ')}"
        ),
    )
    subparsers = parser.add_command_subparsers(metavar="<command>")

    # Always set formatter_class so that we display default values. Leaf
    # subcommands carry plain-prose descriptions, so the wrapping
    # DefaultsHelpFormatter is used (it reflows description text to the
    # terminal width while still appending each option's default); only
    # the top-level parser needs the raw variant for its preformatted
    # epilog.
    def add_parser(name: str, **kwargs: Any) -> StrictArgumentParser:
        kwargs["formatter_class"] = DefaultsHelpFormatter
        return subparsers.add_parser(name, **kwargs)

    def add_delete(parser: argparse.ArgumentParser) -> None:
        parser.add_argument(
            "--delete",
            action="store_true",
            help="Delete files in destination not in backup",
        )

    def add_dry_run(parser: argparse.ArgumentParser) -> None:
        add_argument_ext(
            parser,
            "--dry-run",
            action="store_true",
            help="don't make any changes",
            common=True,
            extended_help=(
                "Report what the operation would do without changing anything."
            ),
        )

    def add_progress(parser: argparse.ArgumentParser) -> None:
        add_argument_ext(
            parser,
            "--progress",
            action="store_true",
            help="show progress information",
            common=True,
            extended_help=(
                "Show borg's progress output while the operation runs."
            ),
        )

    def add_bypass_lock(
        parser: argparse.ArgumentParser, *, default: bool
    ) -> None:
        # Read-only commands only: a bypassing read skips waiting on any
        # lock (fast, but may race a concurrent writer); the blocking form
        # waits for the lock. Writers never bypass, so they omit this.
        parser.add_argument(
            "--bypass-lock",
            action=argparse.BooleanOptionalAction,
            default=default,
            help=(
                "skip waiting for any locks (faster, but may race a "
                "concurrent backup)"
            ),
        )

    def add_prune_args(parser: argparse.ArgumentParser) -> None:
        # Override the configured PRUNE_KEEP_* retention counts for this
        # run; the same flags document once in COMMON ARGUMENTS.
        for unit in ("hourly", "daily", "weekly", "monthly", "yearly"):
            add_argument_ext(
                parser,
                f"--keep-{unit}",
                type=int,
                help=f"Number of {unit} backups to keep",
                common=True,
                extended_help=(
                    f"Number of {unit} backups to keep, overriding the "
                    f"PRUNE_KEEP_{unit.upper()} config value for this run."
                ),
            )

    def add_seconds(parser: argparse.ArgumentParser) -> None:
        parser.add_argument(
            "seconds",
            type=int,
            nargs="?",
            help="Maximum backup age, in seconds",
        )

    def add_target_dir(parser: argparse.ArgumentParser) -> None:
        parser.add_argument(
            "target_dir",
            type=Path,
            help="Target directory for extracted backup",
        )

    def add_archive(
        container: argparse._ActionsContainer,
        *,
        nargs: str,
        default: list[str] | None,
    ) -> None:
        # The `archive` positional is shared by `check archives` and
        # `delete`, which read it the same way (a name or an expanded
        # timestamp, via _resolve_archives), so its format is documented
        # once here. Arity differs per subcommand and shows in each
        # synopsis, so it stays out of the shared help.
        add_argument_ext(
            container,
            "archive",
            nargs=nargs,
            default=default,
            help="Full archive name or timestamp.",
            common=True,
            extended_help=(
                "A full archive name as shown by `borgadm list`, or a "
                "YYYYMMDD_HHMMSS timestamp standing for every archive at "
                "that time."
            ),
        )

    def add_latest(container: argparse._ActionsContainer) -> None:
        # Shared by check archives, delete, and list, so COMMON ARGUMENTS
        # documents it once; the per-verb meaning comes from each
        # subcommand.
        add_argument_ext(
            container,
            "--latest",
            action="store_true",
            help="operate only on the latest full backup set",
            common=True,
            extended_help=(
                "Restrict the operation to the latest full backup set "
                "(the newest timestamp with every configured set present)."
            ),
        )

    automate = add_parser(
        "automate",
        help="Manage automated backups and checks (apply/status/destroy)",
    )
    automate_subparsers = automate.add_command_subparsers(metavar="<command>")
    automate_subparsers.add_parser(
        "apply",
        help="Deploy automated backup creation and checks",
        description=(
            "Write borgadm's crony(1) bundle and deploy the scheduled "
            "backup-creation and check jobs (via launchd on macOS, "
            "systemd on Linux). On macOS the create job runs with Full "
            "Disk Access permissions."
        ),
        formatter_class=DefaultsHelpFormatter,
    )
    automate_subparsers.add_parser(
        "destroy",
        help="Tear down automated backup creation and checks",
        description=(
            "Tear down borgadm's scheduled backup and check jobs and remove "
            "its crony(1) bundle."
        ),
        formatter_class=DefaultsHelpFormatter,
    )
    automate_subparsers.add_parser(
        "status",
        help="Show automation status (via crony(1))",
        description=(
            "Report whether automated backups and checks are deployed, "
            "querying crony(1) for their status."
        ),
        formatter_class=DefaultsHelpFormatter,
    )

    add_parser(
        "break-lock",
        help="Break repo lock",
        description=(
            "Forcibly release a stale lock left on the repository by an "
            "interrupted borg run."
        ),
    )

    check = add_parser("check", help="Run backup checks")
    check_subparsers = check.add_command_subparsers(metavar="<command>")

    check_age = check_subparsers.add_parser(
        "age",
        help="Check full backup age",
        description=(
            "Verify that the latest full backup is no older than the "
            "configured (or given) maximum age."
        ),
        formatter_class=DefaultsHelpFormatter,
    )
    add_seconds(check_age)
    add_bypass_lock(check_age, default=False)

    check_archives = check_subparsers.add_parser(
        "archives",
        help="Check archive metadata (borg check --archives-only)",
        description=(
            "Verify archive metadata with borg check --archives-only, over "
            "the given archives, the latest full set (--latest), or every "
            "archive in the repository."
        ),
        formatter_class=DefaultsHelpFormatter,
    )
    check_archives_target = check_archives.add_mutually_exclusive_group()
    add_archive(check_archives_target, nargs="*", default=[])
    add_latest(check_archives_target)
    add_progress(check_archives)
    add_bypass_lock(check_archives, default=False)

    check_prune = check_subparsers.add_parser(
        "prune",
        help="Check for unpruned archives",
        description=(
            "Report any partial or unpruned archives left in the repository."
        ),
        formatter_class=DefaultsHelpFormatter,
    )
    add_bypass_lock(check_prune, default=False)

    check_repo = check_subparsers.add_parser(
        "repo",
        help="Check repo metadata (borg check --repository-only)",
        description=(
            "Verify repository metadata with borg check --repository-only."
        ),
        formatter_class=DefaultsHelpFormatter,
    )
    add_progress(check_repo)
    add_bypass_lock(check_repo, default=False)

    check_full = check_subparsers.add_parser(
        "full",
        help="Check repo + archive metadata (borg check)",
        description=(
            "Verify both repository and archive metadata with a full "
            "borg check."
        ),
        formatter_class=DefaultsHelpFormatter,
    )
    add_progress(check_full)
    add_bypass_lock(check_full, default=False)

    compact = add_parser(
        "compact",
        help="Compact the repository to reclaim freed space",
        description=(
            "Compact the repository to reclaim space left behind by deleted "
            "archives."
        ),
    )
    add_progress(compact)

    config = add_parser(
        "config",
        help="Create or validate the config file",
    )
    config_subparsers = config.add_command_subparsers(metavar="<command>")
    config_init = config_subparsers.add_parser(
        "init",
        help="Write a starter config file",
        description=(
            "Write the shipped example config to ~/.borgadm, refusing to "
            "overwrite an existing file unless --force is given."
        ),
        formatter_class=DefaultsHelpFormatter,
    )
    config_init.add_argument(
        "--force",
        action="store_true",
        help="Overwrite an existing config file",
    )
    config_subparsers.add_parser(
        "validate",
        help="Validate the config file",
        description=(
            "Load the config file (see --config) and report whether it is "
            "structurally valid, listing any errors. Does not connect to "
            "the repository."
        ),
        formatter_class=DefaultsHelpFormatter,
    )

    delete_cmd = add_parser(
        "delete",
        help="Delete archives by timestamp or name",
        description=(
            "Delete the given archive, or the latest full backup set "
            "(--latest)."
        ),
    )
    # Exactly one of an explicit archive or --latest is required, so a
    # bare `delete` cannot silently target the whole repo.
    delete_target = delete_cmd.add_mutually_exclusive_group(required=True)
    add_archive(delete_target, nargs="?", default=None)
    add_latest(delete_target)
    add_dry_run(delete_cmd)
    add_progress(delete_cmd)

    create = add_parser(
        "create",
        help="Create full backup",
        description=(
            "Create a full backup, writing one archive per configured backup "
            "set, then prune old archives unless --no-prune is given."
        ),
    )
    create.add_argument(
        "--no-prune", action="store_true", help="Skip backup pruning"
    )
    add_dry_run(create)
    add_progress(create)
    add_prune_args(create)

    extract = add_parser(
        "extract",
        help="Extract latest full backup",
        description=(
            "Extract the latest full backup into a target directory, "
            "optionally filtered by include/exclude patterns."
        ),
    )
    add_target_dir(extract)
    extract.add_argument(
        "patterns",
        nargs="*",
        help=(
            "include/exclude paths matching PATTERN, "
            "see 'borg help patterns' for details"
        ),
    )
    add_delete(extract)
    add_dry_run(extract)
    add_progress(extract)
    add_bypass_lock(extract, default=True)

    list_cmd = add_parser(
        "list",
        help="List backups",
        description=(
            "List backups grouped by timestamp, distinguishing full from "
            "partial sets and showing prune keep tags."
        ),
    )
    add_latest(list_cmd)
    list_cmd.add_argument(
        "--full-names",
        action="store_true",
        help="List full names of backups (instead of just timestamps)",
    )
    list_cmd.add_argument(
        "--keep-tags",
        action=argparse.BooleanOptionalAction,
        default=True,
        help=(
            "Include keep tags (indicating what would be kept and "
            "deleted during a prune)"
        ),
    )
    add_prune_args(list_cmd)
    group = list_cmd.add_mutually_exclusive_group()
    group.add_argument(
        "--include-partial",
        action=argparse.BooleanOptionalAction,
        default=True,
        help="Include partial backups",
    )
    group.add_argument(
        "--only-partial",
        action="store_true",
        help="Only list partial",
    )
    add_bypass_lock(list_cmd, default=False)

    add_parser(
        "log-files",
        help="Show borgadm log file paths (default and deployed automations)",
        description=(
            "Print the borgadm log file paths, including those of any "
            "deployed automations."
        ),
    )

    repair = add_parser(
        "repair",
        help="Repair operations for the borg repository",
    )
    repair_subparsers = repair.add_command_subparsers(metavar="<command>")
    repair_subparsers.add_parser(
        "delete-cache",
        help="Delete the local borg cache for the repository",
        description=(
            "Delete the local borg cache for the repository, forcing it to be "
            "rebuilt on the next access."
        ),
        formatter_class=DefaultsHelpFormatter,
    )

    def add_repair_check(name: str, help_text: str, description: str) -> None:
        sub = repair_subparsers.add_parser(
            name,
            help=help_text,
            description=description,
            formatter_class=DefaultsHelpFormatter,
        )
        add_progress(sub)
        sub.add_argument(
            "--yes",
            action="store_true",
            help="confirm you understand the risks of --repair",
        )
        sub.add_validate_callback(_validate_repair)

    add_repair_check(
        "repo",
        "Repair repo metadata (borg check --repair --repository-only)",
        "Repair repository metadata with borg check --repair "
        "--repository-only; requires --yes.",
    )
    add_repair_check(
        "archives",
        "Repair archive metadata (borg check --repair --archives-only)",
        "Repair archive metadata with borg check --repair --archives-only; "
        "requires --yes.",
    )
    add_repair_check(
        "full",
        "Repair repo + archive metadata (borg check --repair)",
        "Repair both repository and archive metadata with borg check "
        "--repair; requires --yes.",
    )

    prune = add_parser(
        "prune",
        help="Prune partial and old backups",
        description=(
            "Prune partial and aged-out archives according to the configured "
            "retention policy, optionally removing unknown archives."
        ),
    )
    add_dry_run(prune)
    add_progress(prune)
    add_prune_args(prune)
    prune.add_argument(
        "--cleanup-unknown",
        action="store_true",
        help=(
            "Delete archives whose names start with the configured"
            " BACKUP_NAME prefix but don't match the expected"
            " {BACKUP_NAME}-{set_name}-YYYYMMDD_HHMMSS_NofM shape."
            " Default: warn but leave in place. Either way, an"
            " unknown archive in the repo causes list and prune to"
            " exit with the WARNING status."
        ),
    )

    rsync = add_parser(
        "rsync",
        help="Rsync latest archive",
        description=(
            "Mirror the contents of the latest archive to a target directory "
            "with rsync (Linux only)."
        ),
    )
    add_target_dir(rsync)
    add_delete(rsync)
    add_dry_run(rsync)
    add_progress(rsync)
    add_bypass_lock(rsync, default=True)

    add_parser(
        "environment",
        help="Display environment settings to run borg cli",
        description=(
            "Print the shell commands needed to run the borg CLI directly "
            "against the configured repository."
        ),
    )

    def add_common_args(p: argparse.ArgumentParser) -> None:
        add_argument_ext(
            p,
            "--config",
            type=str,
            default=CONFIG,
            help="borgadm config file",
            common=True,
            extended_help="Path to the borgadm config file to read.",
        )
        add_argument_ext(
            p,
            "--verbose",
            action="store_true",
            help="Enable verbose output",
            common=True,
            extended_help="Log informational messages, not just warnings.",
        )
        add_argument_ext(
            p,
            "--timestamp-messages",
            action="store_true",
            help="Add timestamps to stdout/stderr messages",
            common=True,
            extended_help=(
                "Prefix each stdout/stderr message with a timestamp."
            ),
        )

    for subparser in subparsers.choices.values():
        has_actions = any(
            isinstance(a, argparse._SubParsersAction)
            for a in subparser._actions
        )
        if has_actions:
            # Only add to action-level parsers so that e.g.
            # "borgadm check age --verbose" works but
            # "borgadm check --verbose age" does not.
            for action in subparser._actions:
                if isinstance(action, argparse._SubParsersAction):
                    for nested in action.choices.values():
                        add_common_args(nested)
        else:
            add_common_args(subparser)

    return parser


# -----------------------------------------------------------------------------
# Main
# -----------------------------------------------------------------------------
# Dispatch table mapping CLI commands to handler functions.
# Handler signatures must not use default argument values;
# defaults are owned by the argument parser so they stay in
# one place and argparse help text stays accurate.
COMMAND_CALLBACKS: dict[str, Callable[..., Any]] = {
    "automate apply": do_automate_apply,
    "automate destroy": do_automate_destroy,
    "automate status": do_automate_status,
    "break-lock": do_break_lock,
    "check age": do_check_age,
    "check archives": do_check_archives,
    "check full": do_check_full,
    "check prune": do_check_prune,
    "check repo": do_check_repo,
    "compact": do_compact,
    "config init": do_config_init,
    "config validate": do_config_validate,
    "create": do_create,
    "delete": do_delete,
    "environment": do_environment,
    "extract": do_extract,
    "list": do_list,
    "log-files": do_log_files,
    "prune": do_prune,
    "repair archives": do_repair_archives,
    "repair delete-cache": do_repair_delete_cache,
    "repair full": do_repair_full,
    "repair repo": do_repair_repo,
    "rsync": do_rsync,
}


def main(
    command: str,
    config: str,
    verbose: bool,
    timestamp_messages: bool,
    args_dict: dict[str, Any],
) -> None:
    # ``command`` is the full path (e.g. "automate apply"); the timing
    # and backup-set checks key off the top-level word.
    top_command = command.split(" ", 1)[0]
    quick_commands = {
        "automate",
        "config",
        "environment",
        "list",
        "log-files",
    }
    timed = top_command not in quick_commands
    cmd_start = time.perf_counter()
    cmd_label = command

    try:
        initialize_logger(LOGFILE, verbose, timestamp_messages)

        invocation = " ".join(shlex.quote(arg) for arg in sys.argv)
        logger.debug(f"Invocation: {invocation}")
        atexit.register(report_runtime)

        global CFG
        # `config` subcommands operate on the config file itself, so they
        # skip the usual load + borg-env setup: init writes a starter file
        # before any config exists, and validate builds and checks the
        # Config on its own. They still need the --config path, so it
        # rejoins the dispatch kwargs; every other command gets a loaded
        # CFG and a ready borg environment first.
        if top_command == "config":
            args_dict["config"] = config
        else:
            CFG = Config(config, args_dict)
            initialize_borg_environment()

            backup_set_commands = {
                "check",
                "create",
                "delete",
                "extract",
                "list",
                "prune",
                "rsync",
            }
            if top_command in backup_set_commands:
                logger.debug(f"BACKUP_SETS={CFG.BACKUP_SETS}")

        if timed:
            logger.info(f"borgadm {cmd_label}: started")

        COMMAND_CALLBACKS[cmd_label](**args_dict)
    except Exception as e:
        logger.error("%s", e)
        raise
    finally:
        if timed:
            elapsed = timedelta(seconds=int(time.perf_counter() - cmd_start))
            logger.info(f"borgadm {cmd_label}: finished (elapsed: {elapsed})")


@cli_entrypoint
def cli() -> int:
    parser = args_parser()
    args = parser.parse_command()
    args_dict = vars(args).copy()
    command = args_dict.pop("command")

    config = args_dict.pop("config")
    verbose = args_dict.pop("verbose")
    timestamp_messages = args_dict.pop("timestamp_messages")

    try:
        main(
            command,
            config,
            verbose,
            timestamp_messages,
            args_dict,
        )
    except BorgadmError as e:
        return e.exit_code

    if _warning_occurred:
        return ExitCode.WARNING

    return ExitCode.SUCCESS


def _config_doc_items() -> list[tuple[str, str]]:
    """The CONFIGURATION reference, rendered from CONFIG_FIELDS: each
    field's name and description with `(required)` or `(default: X)`
    appended (the latter omitted for empty defaults)."""
    items: list[tuple[str, str]] = []
    for field in CONFIG_FIELDS:
        if field.required:
            suffix = " (required)"
        elif field.default in ("", [], {}):
            suffix = ""
        else:
            suffix = f" (default: {field.default})"
        items.append((field.name, f"{field.description}{suffix}."))
    return items


def _files_doc_items() -> list[tuple[str, str]]:
    """The FILES reference, sourced from BASENAME and the CONFIG_FIELDS
    defaults so the paths can't drift from the code that defines them."""
    return [
        (
            f"~/.{BASENAME}",
            "INI-style configuration file (see CONFIGURATION).",
        ),
        (
            str(_FIELDS["BORG_PASSPHRASE_FILE"].default),
            "Default repository passphrase file (BORG_PASSPHRASE_FILE).",
        ),
        (
            str(_FIELDS["BORG_SSHKEY_FILE"].default),
            "Default SSH key for a remote repository (BORG_SSHKEY_FILE).",
        ),
        (
            f"$TMPDIR/{BASENAME}.log",
            "Run log written on every invocation.",
        ),
    ]


MAN_SPEC = ManSpec(
    prog="borgadm",
    section=1,
    build_parser=args_parser,
    name_description="manage borg backup repositories and scheduled backups",
    description=_DESCRIPTION,
    pre_sections=[TextSection("GETTING STARTED", _GETTING_STARTED)],
    post_sections=[
        ItemsSection("CONFIGURATION", _config_doc_items()),
        ItemsSection("FILES", _files_doc_items()),
    ],
    exit_status=[
        (str(value), description) for value, description in ExitCode.entries()
    ],
)


if __name__ == "__main__":
    raise SystemExit(cli())
