#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.14"
# ///
# This is AI generated code
#
# IMPORTANT: This script has tests in tests/test_darwin_tz_watchdog.py
# Always run the test suite after making modifications.

"""Restart macOS UserEventAgent-Aqua when its cached timezone is stale.

UserEventAgent-Aqua monitors `StartCalendarInterval` triggers for
user-mode LaunchAgents. The process caches the timezone at start
and does not re-read it when `/etc/localtime` changes. After a
timezone switch (e.g. travel), calendar intervals continue to
fire against the old timezone -- a job scheduled for `02:30` in
the new local zone fires at 02:30 in the *old* zone, which can
be several hours off.

This watchdog compares the symlink mtime of `/etc/localtime`
(updated when the system timezone changes) to the start time of
UserEventAgent-Aqua. If the timezone link is newer, the agent is
restarted by sending SIGTERM to its pid; launchd's KeepAlive
respawns it and the new instance reads the current zone.

`launchctl kickstart -k` would be the clean way to do this, but
SIP blocks user-level launchctl operations on Apple-provided
agents (exit 150, "Operation not permitted while System
Integrity Protection is engaged"). Killing the pid we own
sidesteps the launchctl restriction.

On non-darwin platforms the script does nothing (systemd timers
on linux re-read the zone on each evaluation and don't have this
bug, so there's nothing to watch); it still parses its arguments
first, so --help behaves the same everywhere.
"""

import argparse
import datetime
import logging
import os as os  # noqa: PLC0414  re-exported for tests
import platform as platform  # noqa: PLC0414  re-exported for tests
import signal as signal  # noqa: PLC0414  re-exported for tests
import subprocess as subprocess  # noqa: PLC0414  re-exported for tests
import sys
import textwrap
from pathlib import Path

sys.path.insert(0, str(Path(__file__).resolve().parent.parent / "src"))

from common.argparse_ext import (  # noqa: E402
    RawDescriptionDefaultsHelpFormatter,
)
from common.cli import cli_entrypoint  # noqa: E402
from common.docspec import ManSpec, TextSection  # noqa: E402
from common.exitcodes import CommonExitCode, ExitCodeBase  # noqa: E402

# Configure logging to stderr so notification output (decision /
# action) stays in stdout when piped.
logging.basicConfig(
    format="%(message)s",
    level=logging.INFO,
    stream=sys.stderr,
)
logger = logging.getLogger(__name__)


# =============================================================================
# Constants
# =============================================================================

UEA_AQUA_LABEL = "com.apple.UserEventAgent-Aqua"
TZ_SYMLINK = Path("/etc/localtime")

# ps -o lstart= prints e.g. "Fri Apr 10 08:07:23 2026" -- abbreviated
# weekday, abbreviated month, day-of-month (space-padded), HH:MM:SS,
# 4-digit year. `%c` is locale-dependent so we spell the format out.
PS_LSTART_FORMAT = "%a %b %d %H:%M:%S %Y"


# =============================================================================
# Exit codes
# =============================================================================


class ExitCode(ExitCodeBase):
    SUCCESS = CommonExitCode.SUCCESS
    ERROR = CommonExitCode.ERROR
    CRASHED = CommonExitCode.CRASHED


# =============================================================================
# Errors
# =============================================================================


class WatchdogError(Exception):
    """Watchdog failed to perform a required step."""


# =============================================================================
# OS probes
# =============================================================================


def _tz_mtime(path: Path = TZ_SYMLINK) -> float:
    """Return mtime (epoch seconds) of the timezone symlink itself.

    `lstat` -- not `stat` -- is intentional: `/etc/localtime` is a
    symlink, and switching timezones updates the symlink (bumping
    *its* mtime) while leaving the underlying zone-data file
    alone. Following the symlink would miss every TZ switch.
    """
    return path.lstat().st_mtime


def _uea_aqua_pid() -> int | None:
    """Return the PID of UserEventAgent-Aqua, or None if not loaded.

    Resolves via `launchctl print gui/<uid>/<label>` rather than
    pgrep so the lookup is keyed to the launchd service identity
    (stable across macOS versions) instead of a process-name
    substring match.
    """
    proc = subprocess.run(
        [
            "launchctl",
            "print",
            f"gui/{os.getuid()}/{UEA_AQUA_LABEL}",
        ],
        capture_output=True,
        text=True,
    )
    if proc.returncode != 0:
        return None
    for line in proc.stdout.splitlines():
        stripped = line.strip()
        if stripped.startswith("pid ="):
            try:
                return int(stripped.split("=", 1)[1].strip())
            except ValueError:
                return None
    return None


def _process_start_epoch(pid: int) -> float:
    """Return start time (epoch seconds) of `pid` via `ps -o lstart=`.

    `ps` prints lstart in the *current* local timezone. The
    returned naive datetime is then converted with `.timestamp()`,
    which interprets it in the current local zone -- so the
    round-trip gives an epoch consistent with `_tz_mtime`.
    """
    proc = subprocess.run(
        ["ps", "-p", str(pid), "-o", "lstart="],
        capture_output=True,
        text=True,
    )
    if proc.returncode != 0:
        raise WatchdogError(f"ps failed for pid {pid}: {proc.stderr.strip()!r}")
    line = proc.stdout.strip()
    if not line:
        raise WatchdogError(f"ps returned no lstart for pid {pid}")
    try:
        naive = datetime.datetime.strptime(line, PS_LSTART_FORMAT)
    except ValueError as exc:
        raise WatchdogError(
            f"unrecognised lstart format {line!r}: {exc}"
        ) from exc
    return naive.timestamp()


def _restart_uea_aqua(pid: int) -> None:
    """Send SIGTERM to UEA-Aqua so launchd respawns a fresh instance.

    The respawned process re-reads the current timezone on
    startup, which is the whole point of the restart. Plain kill
    -- rather than `launchctl kickstart -k` -- because SIP blocks
    user-level launchctl operations on Apple-provided agents
    (exit 150). The signaled process is owned by the current
    user, so `os.kill` is not SIP-restricted.

    A "no such process" ESRCH between detection and signaling is
    benign: launchd already restarted the agent for some other
    reason, and a fresh instance reads the current zone anyway.
    """
    try:
        os.kill(pid, signal.SIGTERM)
    except ProcessLookupError:
        return
    except PermissionError as exc:
        raise WatchdogError(f"kill({pid}, SIGTERM) refused: {exc}") from exc


# =============================================================================
# Decision
# =============================================================================


def _format_epoch(epoch: float) -> str:
    """Format an epoch as local time for human-readable diagnostics."""
    return (
        datetime.datetime.fromtimestamp(epoch)
        .strftime("%Y-%m-%d %H:%M:%S %Z")
        .rstrip()
    )


def check_and_restart(*, dry_run: bool, verbose: bool) -> int:
    """Detect stale UEA-Aqua and (unless dry-run) restart it.

    Returns an exit code suitable for `sys.exit`. The "nothing to
    do" path (fresh enough agent, or UEA-Aqua not loaded) returns
    0 silently so the watchdog is cheap to schedule -- only the
    action path or an error produces stdout / stderr.
    """
    pid = _uea_aqua_pid()
    if pid is None:
        # Not loaded means there's nothing stale to restart. A
        # later login session will spawn a fresh instance that
        # reads the current zone, so the bug can't manifest in
        # this state.
        if verbose:
            print(f"noop: {UEA_AQUA_LABEL} not loaded")
        return ExitCode.SUCCESS

    tz_mtime = _tz_mtime()
    start_epoch = _process_start_epoch(pid)
    is_stale = tz_mtime > start_epoch

    if verbose:
        print(f"pid:         {pid}")
        print(f"agent start: {_format_epoch(start_epoch)}")
        print(f"tz mtime:    {_format_epoch(tz_mtime)}")
        print(f"stale:       {is_stale}")

    if not is_stale:
        return ExitCode.SUCCESS

    if dry_run:
        print(
            f"would restart {UEA_AQUA_LABEL} "
            f"(tz mtime newer than process start)"
        )
        return ExitCode.SUCCESS

    _restart_uea_aqua(pid)
    print(
        f"restarted {UEA_AQUA_LABEL} pid={pid} "
        f"(was started {_format_epoch(start_epoch)}, "
        f"tz updated {_format_epoch(tz_mtime)})"
    )
    return ExitCode.SUCCESS


# =============================================================================
# CLI
# =============================================================================

# The overview shown in `--help` (appended to the epilog) and rendered as
# the DESCRIPTION of the generated man page / GFM doc via MAN_SPEC.
# _DESCRIPTION's first paragraph stands alone so it can also serve as the
# tool's one-line blurb in the repo README.
_DESCRIPTION = """\
darwin-tz-watchdog restarts macOS UserEventAgent-Aqua when its cached
timezone has gone stale. UserEventAgent-Aqua dispatches user-level launchd
StartCalendarInterval triggers, but it reads the timezone once at startup
and never re-reads it when /etc/localtime changes. After a timezone switch
(e.g. travel) calendar-interval jobs keep firing against the stale cached
zone -- a job set for 02:30 local fires at 02:30 in the previously cached
zone, potentially hours off -- until the agent is restarted. This watchdog
detects that condition and restarts the agent so it picks up the current
zone.

It compares the mtime of the /etc/localtime symlink (bumped whenever the
system timezone changes) against UserEventAgent-Aqua's start time; if the
timezone link is newer the agent is stale and is restarted by signaling
the process this user owns, which launchd then respawns against the
current zone. With nothing stale to act on it exits silently, so it is
cheap to run periodically from a scheduler. Use --dry-run to report what
would happen without touching the agent, and -v to print the decision
inputs (pid, times, staleness)."""

_GETTING_STARTED = """\
Schedule darwin-tz-watchdog with crony(1) so it runs automatically --
e.g. a daily, darwin-only job:

    mkdir -p ~/.config/crony/config/
    cat > ~/.config/crony/config/darwin-tz-watchdog.toml <<-EOF
    [defaults]
    notify-channels = ["default"]

    [job.doit]
    command   = "darwin-tz-watchdog"
    env.PATH  = "\\$PATH:\\$HOME/.local/bin"
    interval = "1d"
    uuid = "$(crony config generate-uuid)"

    [target.darwin]
    jobs = ["doit"]
    EOF
    crony apply -b darwin-tz-watchdog
"""


_PLATFORM_SPECIFICS = """\
darwin-tz-watchdog targets a macOS-only bug, so it does real work only on
macOS/darwin. On every other platform it still parses its arguments (so
--help behaves identically everywhere) and then exits successfully without
doing anything, which lets a cross-platform scheduler invoke it
unconditionally."""


def _build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(
        prog="darwin-tz-watchdog",
        description=(
            "Restart macOS UserEventAgent-Aqua when its cached\n"
            "timezone is stale relative to /etc/localtime."
        ),
        epilog=(
            f"{ExitCode.epilog()}\n\n"
            f"Description:\n{textwrap.indent(_DESCRIPTION, '  ')}\n\n"
            f"Getting Started:\n{textwrap.indent(_GETTING_STARTED, '  ')}"
        ),
        formatter_class=RawDescriptionDefaultsHelpFormatter,
    )
    parser.add_argument(
        "-v",
        "--verbose",
        action="store_true",
        help="Print decision diagnostics (pid, times, staleness).",
    )
    parser.add_argument(
        "--dry-run",
        action="store_true",
        help="Report what would happen without signaling the agent.",
    )
    return parser


@cli_entrypoint
def main(argv: list[str] | None = None) -> int:
    # Parse first so --help/-h and argument validation behave
    # identically on every platform, before the non-darwin no-op
    # short-circuit. On non-darwin the watchdog then no-ops -- there
    # is nothing to restart -- so a cross-platform scheduler can still
    # invoke it unconditionally.
    args = _build_parser().parse_args(argv)
    if platform.system() != "Darwin":
        return ExitCode.SUCCESS
    try:
        return check_and_restart(
            dry_run=args.dry_run,
            verbose=args.verbose,
        )
    except WatchdogError as exc:
        logger.error("tz-agent-watchdog: %s", exc)
        return ExitCode.ERROR


MAN_SPEC = ManSpec(
    prog="darwin-tz-watchdog",
    section=1,
    build_parser=_build_parser,
    name_description=("restart macOS UserEventAgent-Aqua on a stale timezone"),
    description=_DESCRIPTION,
    pre_sections=[
        TextSection("GETTING STARTED", _GETTING_STARTED),
        TextSection("PLATFORM SPECIFICS", _PLATFORM_SPECIFICS),
    ],
    exit_status=[
        (str(value), description) for value, description in ExitCode.entries()
    ],
)


if __name__ == "__main__":
    sys.exit(main())
