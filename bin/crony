logger = logging.getLogger(__name__)


class BrokenPipeAwareStreamHandler(logging.StreamHandler):
    """StreamHandler that silently disables itself once its downstream
    pipe consumer closes (e.g., piping to `head`). The first
    BrokenPipeError swaps the stream for /dev/null so subsequent log
    records are absorbed without spamming tracebacks.
    """

    def handleError(self, record: logging.LogRecord) -> None:
        exc = sys.exc_info()[1]
        if isinstance(exc, BrokenPipeError):
            try:
                self.stream.close()
            except (BrokenPipeError, OSError):
                pass
            self.stream = open(os.devnull, "w")
            return
        super().handleError(record)


def _initialize_logger() -> None:
    """Configure root logger with a broken-pipe-aware handler."""
    handler = BrokenPipeAwareStreamHandler(sys.stderr)
    handler.setFormatter(logging.Formatter("%(message)s"))
    logging.basicConfig(level=logging.INFO, handlers=[handler])


_initialize_logger()


# =============================================================================
# DEFAULT CONFIG TEMPLATE
# =============================================================================
# Emitted by `crony init`. Every section is commented out so a user can
# uncomment the bits they want without touching the explanatory prose.

_DEFAULT_CONFIG_TEMPLATE: str = """\
# ============================================================================
# crony config bundle
# ============================================================================
# crony reads bundles from:
#   ~/.config/crony/config.toml      -> bundle name "default"
#   ~/.config/crony/config/<x>.toml  -> bundle name "<x>"
#                                       (filename stem matches
#                                       [A-Za-z0-9][A-Za-z0-9_-]*)
# Each bundle is independent: its [defaults], targets, groups, and
# notify config apply only to the jobs defined in the same file.
# Job and group names are namespaced as <bundle>.<short>; on the
# CLI, a bare name (`crony run foo`) is shorthand for
# `default.foo` and never falls through to other bundles.
#
# Schedules use systemd OnCalendar syntax; intervals use systemd
# time-span syntax. See:
#   https://www.freedesktop.org/software/systemd/man/systemd.time.html
# ============================================================================


# ----------------------------------------------------------------------------
# defaults section
# ----------------------------------------------------------------------------
# Settings cascaded to every job in THIS bundle. Per-job and
# per-target settings can override anything here. Defaults from
# other bundles never apply -- each bundle has its own.

# [defaults]
# notify_channels      = []           # subset of ["email", "ntfy"]
# notify_attach_log    = true
# notify_attach_max_kb = 256
# timeout_sec          = 1800         # 30 min default per-job wallclock cap
# log_keep_runs        = 30

# Embedded SMTP channel (used when "email" is in notify_channels).
# [defaults.notify.email]
# to                 = "you@example.com"
# from               = "crony@example.com"
# smtp_host          = "smtp.gmail.com"
# smtp_port          = 587
# smtp_user          = "you@gmail.com"
# smtp_starttls              = true
# # Password retrieval -- first match wins. On macOS prefer the
# # keychain item (the optional _account narrows the lookup when
# # multiple items share a service name); on Linux fall back to a
# # 0600 secrets file.
# smtp_pass_keychain_service = "crony-smtp"
# smtp_pass_keychain_account = "you@gmail.com"   # optional
# smtp_pass_file             = "~/.config/crony/secrets/smtp-password"

# ntfy channel (used when "ntfy" is in notify_channels).
# [defaults.notify.ntfy]
# url                    = "https://ntfy.example.com/automation"
# token_keychain_service = "ntfy-automation"
# token_keychain_account = "edp"                 # optional
# token_file             = "~/.config/crony/secrets/ntfy-token"


# ----------------------------------------------------------------------------
# job sections
# ----------------------------------------------------------------------------
# A schedulable unit of work. Either `command` (one-line shell) or
# `script` (path under the dotfiles repo) is required. A job with
# no schedule/interval is valid only if some [job-group.*] references
# it (otherwise it can never fire).

# [job.brew-update]
# command   = "brew update && brew upgrade && brew cleanup"
# platforms = ["darwin"]               # applicability filter
# schedule  = "*-*-* 03:15"            # OnCalendar; daily at 03:15
# gate      = "command -v brew"        # skip benignly if absent
# # Optional per-job overrides of [defaults]:
# # notify_channels = ["email"]
# # timeout_sec     = 7200
# # env supports $VAR / ${VAR} expansion against the running env, so
# # `PATH = "$HOME/.local/bin:$PATH"` extends the inherited PATH.
# # Unresolved vars stay literal; `$$` is a literal `$`.
# # env             = { "PATH" = "$HOME/.local/bin:$PATH", "RUST_BACKTRACE" = "1" }

# [job.git-pull-utils]
# script   = "scripts/git-pull.sh"     # path under the dotfiles repo
# args     = ["~/utils"]               # ~ expanded
# interval = "30min"                   # 30 min after each completion

# Group-only job: no schedule, only fires via [job-group.*].
# [job.uv-update]
# command = "uv self update && uv tool upgrade --all"
# gate    = "command -v uv"


# ----------------------------------------------------------------------------
# job-group sections
# ----------------------------------------------------------------------------
# A scheduled sequencer that fires named jobs in order. Has its own
# schedule but no command/script of its own.

# [job-group.daily-updates]
# schedule = "*-*-* 03:00"
# jobs     = ["brew-update", "uv-update", "git-pull-utils"]


# ----------------------------------------------------------------------------
# target sections
# ----------------------------------------------------------------------------
# Selects which jobs and groups install on which hosts. A host
# target replaces the platform target when both apply; the explicit
# `jobs` list IS the selection (no inherits / exclude / add).

# [target.darwin]
# jobs            = ["brew-update", "git-pull-utils", "daily-updates"]
# notify_channels = ["email"]

# [target.linux]
# jobs            = ["git-pull-utils"]
# notify_channels = ["ntfy"]

# [target.host.work-laptop]
# jobs            = ["brew-update", "git-pull-utils"]
# notify_channels = []   # no external dispatch (run.log + last-run.json only)
"""


# =============================================================================
# EXIT CODES
# =============================================================================


class ExitCode(enum.IntEnum):
    SUCCESS = 0, "Success"
    WARNING = 1, "Warning (non-fatal issues)"
    USAGE = 2, "Usage/argument error"
    CONFIG = 3, "Configuration error"
    ERROR = 4, "General error"
    SUBPROCESS = 5, "Subprocess command failed"
    AUDIT_FAILED = 6, "audit found jobs in a bad state"
    LOCK_BUSY = 7, "run.lock held by another instance"
    PRECONDITION = 8, "run precondition failed before exec"
    TIMEOUT = 9, "run killed wrapped command on timeout"

    def __new__(cls, value: int, description: str = "") -> ExitCode:
        obj = int.__new__(cls, value)
        obj._value_ = value
        obj.description = description  # type: ignore[attr-defined]
        return obj

    @classmethod
    def epilog(cls) -> str:
        lines = ["exit codes:"]
        for member in cls:
            lines.append(
                f"  {member.value}  {member.description}"  # type: ignore[attr-defined]
            )
        return "\n".join(lines)


# =============================================================================
# EXCEPTIONS
# =============================================================================


class CronyError(RuntimeError):
    """Base exception for crony errors."""

    exit_code: ExitCode = ExitCode.ERROR


class UsageError(CronyError):
    """Bad argument or unknown subcommand."""

    exit_code = ExitCode.USAGE


class ConfigError(CronyError):
    """Unparseable or invalid config."""

    exit_code = ExitCode.CONFIG


class SubprocessError(subprocess.CalledProcessError, CronyError):
    """Subprocess (launchctl, systemctl, etc) failed."""

    exit_code = ExitCode.SUBPROCESS


class AuditFailedError(CronyError):
    """`crony audit` found jobs in a bad state."""

    exit_code = ExitCode.AUDIT_FAILED


class LockBusyError(CronyError):
    """`crony run` could not acquire the per-job lock."""

    exit_code = ExitCode.LOCK_BUSY


class PreconditionError(CronyError):
    """`crony run` precondition failed before exec."""

    exit_code = ExitCode.PRECONDITION


class JobTimeoutError(CronyError):
    """`crony run` killed the wrapped command on timeout."""

    exit_code = ExitCode.TIMEOUT


