# External notification channels. log-only is no longer a value here:
# crony always writes run.log + last-run.json regardless, so an empty
# notify_channels list expresses "no external dispatch" without needing
# a special sentinel.
_VALID_NOTIFY_CHANNELS: frozenset[str] = frozenset(
    {
        "email",
        "ntfy",
    }
)

_VALID_PLATFORMS: frozenset[str] = frozenset({"darwin", "linux"})


def _reject_unknown_keys(
    raw: dict[str, Any], known: frozenset[str], where: str
) -> None:
    """Raise ConfigError if raw has keys not in `known`."""
    unknown = set(raw.keys()) - known
    if unknown:
        raise ConfigError(f"{where}: unknown key(s) {sorted(unknown)}")


def _typed_field(
    raw: dict[str, Any],
    key: str,
    expected: type,
    where: str,
    *,
    default: Any = None,
) -> Any:
    """Extract `key` from `raw` with a type check. Returns `default` if absent.

    `bool` and `int` are distinct here, even though `isinstance(True, int)`
    is True in Python -- we explicitly reject booleans for int-typed fields
    so `timeout_sec = true` raises clearly rather than silently meaning 1.
    """
    if key not in raw:
        return default
    val = raw[key]
    # bool is a subclass of int; require strict separation here.
    if expected is int and isinstance(val, bool):
        raise ConfigError(f"{where}: '{key}' must be int, got bool")
    if expected is bool and not isinstance(val, bool):
        raise ConfigError(
            f"{where}: '{key}' must be bool, got {type(val).__name__}"
        )
    if not isinstance(val, expected):
        raise ConfigError(
            f"{where}: '{key}' must be {expected.__name__}, "
            f"got {type(val).__name__}"
        )
    return val


# Short job/group/host names appear inside a single bundle's TOML.
# They become part of filesystem paths (alongside the bundle name)
# and platform unit labels, so they must be safe filename characters.
# Dots are allowed: a job written as `[job."foo.bar"]` still maps
# cleanly into `<bundle>.foo.bar` on disk.
_NAME_RE: re.Pattern[str] = re.compile(r"^[A-Za-z0-9][A-Za-z0-9._-]*$")

# Bundle names come from filenames (config.toml -> "default";
# config/<x>.toml -> "x"). The dot is reserved as the namespace
# separator between bundle and short name, so bundle names cannot
# themselves contain dots.
_BUNDLE_NAME_RE: re.Pattern[str] = re.compile(r"^[A-Za-z0-9][A-Za-z0-9_-]*$")

# Names that collide with crony's own state-dir layout. A job named
# "installed" would be wiped by `destroy --purge-state` (which removes
# STATE_DIR/<name>/), taking the hash registry with it.
_RESERVED_NAMES: frozenset[str] = frozenset({"installed"})


def _validate_name(name: str, where: str) -> None:
    """Reject names that would break filesystem paths or unit labels."""
    if not _NAME_RE.match(name):
        raise ConfigError(
            f"{where}: name {name!r} must match "
            f"[A-Za-z0-9][A-Za-z0-9._-]* (no slashes, spaces, "
            f"empty, or leading punctuation)"
        )
    if name in _RESERVED_NAMES:
        raise ConfigError(f"{where}: name {name!r} is reserved by crony")


def _validate_bundle_name(name: str, where: str) -> None:
    """Reject filenames whose stem can't be a bundle name."""
    if not _BUNDLE_NAME_RE.match(name):
        raise ConfigError(
            f"{where}: bundle name {name!r} must match "
            f"[A-Za-z0-9][A-Za-z0-9_-]* (no dots -- the dot is "
            f"reserved as the bundle/job-name separator)"
        )


def parse_full_name(arg: str) -> tuple[str, str]:
    """Parse a CLI job/group reference into (bundle_name, short).

    Bare 'foo' -> ('default', 'foo') -- bare input only ever
    selects the default bundle, never falls through to others.
    'borgadm.foo' -> ('borgadm', 'foo'). Multi-dot forms split on
    the first dot, so '<bundle>.<short>' where short itself
    contains dots stays intact.
    """
    if "." not in arg:
        return (DEFAULT_BUNDLE_NAME, arg)
    bundle, _, short = arg.partition(".")
    if not bundle or not short:
        raise UsageError(f"invalid job reference: {arg!r}")
    return (bundle, short)


def _string_list(raw: dict[str, Any], key: str, where: str) -> list[str]:
    """Extract a list-of-strings field, defaulting to []."""
    val = raw.get(key)
    if val is None:
        return []
    if not isinstance(val, list) or not all(isinstance(x, str) for x in val):
        raise ConfigError(f"{where}: '{key}' must be a list of strings")
    return list(val)


def _string_dict(raw: dict[str, Any], key: str, where: str) -> dict[str, str]:
    """Extract a dict-of-string-to-string field, defaulting to {}."""
    val = raw.get(key)
    if val is None:
        return {}
    if not isinstance(val, dict):
        raise ConfigError(f"{where}: '{key}' must be a table (dict)")
    out: dict[str, str] = {}
    for k, v in val.items():
        if not isinstance(k, str) or not isinstance(v, str):
            raise ConfigError(
                f"{where}: '{key}' values must be string -> string"
            )
        out[k] = v
    return out


def _parse_notify_email(raw: dict[str, Any]) -> NotifyEmail:
    """Parse [defaults.notify.email]."""
    where = "[defaults.notify.email]"
    _reject_unknown_keys(raw, _KNOWN_NOTIFY_EMAIL, where)
    to = _typed_field(raw, "to", str, where)
    smtp_host = _typed_field(raw, "smtp_host", str, where)
    smtp_user = _typed_field(raw, "smtp_user", str, where)
    smtp_port = _typed_field(raw, "smtp_port", int, where, default=587)
    if to is None or smtp_host is None or smtp_user is None:
        raise ConfigError(
            f"{where}: 'to', 'smtp_host', 'smtp_user' are required"
        )
    return NotifyEmail(
        to=to,
        from_addr=_typed_field(raw, "from", str, where),
        smtp_host=smtp_host,
        smtp_port=smtp_port,
        smtp_user=smtp_user,
        smtp_starttls=_typed_field(
            raw, "smtp_starttls", bool, where, default=True
        ),
        smtp_pass_keychain_service=_typed_field(
            raw, "smtp_pass_keychain_service", str, where
        ),
        smtp_pass_keychain_account=_typed_field(
            raw, "smtp_pass_keychain_account", str, where
        ),
        smtp_pass_file=_typed_field(raw, "smtp_pass_file", str, where),
    )


def _parse_notify_ntfy(raw: dict[str, Any]) -> NotifyNtfy:
    """Parse [defaults.notify.ntfy]."""
    where = "[defaults.notify.ntfy]"
    _reject_unknown_keys(raw, _KNOWN_NOTIFY_NTFY, where)
    url = _typed_field(raw, "url", str, where)
    if url is None:
        raise ConfigError(f"{where}: 'url' is required")
    return NotifyNtfy(
        url=url,
        token_keychain_service=_typed_field(
            raw, "token_keychain_service", str, where
        ),
        token_keychain_account=_typed_field(
            raw, "token_keychain_account", str, where
        ),
        token_file=_typed_field(raw, "token_file", str, where),
    )


def _positive_int(
    raw: dict[str, Any], key: str, where: str, default: int
) -> int:
    """Read a positive int defaulting to `default`. Reject 0 / negative."""
    val: int = _typed_field(raw, key, int, where, default=default)
    if val <= 0:
        raise ConfigError(f"{where}: '{key}' must be positive, got {val}")
    return val


def _parse_notify_channels(
    raw: dict[str, Any], where: str, *, required: bool
) -> list[str] | None:
    """Parse a `notify_channels` list with channel-name validation.

    `required=True` (Defaults) returns [] when the key is absent.
    `required=False` (Job/Target) returns None when absent so the
    cascade can inherit from a layer below. Duplicate entries and
    non-string / unknown channel names raise.
    """
    if "notify_channels" not in raw:
        return [] if required else None
    val = raw["notify_channels"]
    if not isinstance(val, list) or not all(isinstance(x, str) for x in val):
        raise ConfigError(
            f"{where}: 'notify_channels' must be a list of strings"
        )
    seen: set[str] = set()
    out: list[str] = []
    for ch in val:
        if ch not in _VALID_NOTIFY_CHANNELS:
            raise ConfigError(
                f"{where}: notify_channels entry {ch!r} not in "
                f"{sorted(_VALID_NOTIFY_CHANNELS)}"
            )
        if ch in seen:
            raise ConfigError(
                f"{where}: notify_channels entry {ch!r} listed twice"
            )
        seen.add(ch)
        out.append(ch)
    return out


def _parse_defaults(raw: dict[str, Any]) -> Defaults:
    """Parse [defaults]."""
    where = "[defaults]"
    _reject_unknown_keys(raw, _KNOWN_DEFAULTS, where)
    channels = _parse_notify_channels(raw, where, required=True)
    notify_email = None
    notify_ntfy = None
    nested = raw.get("notify", {})
    if not isinstance(nested, dict):
        raise ConfigError(f"{where}.notify must be a table (dict)")
    for sub_key, sub_body in nested.items():
        if sub_key == "email":
            notify_email = _parse_notify_email(sub_body)
        elif sub_key == "ntfy":
            notify_ntfy = _parse_notify_ntfy(sub_body)
        else:
            raise ConfigError(
                f"[defaults.notify.{sub_key}] is not a known channel"
            )
    return Defaults(
        notify_channels=channels or [],
        notify_attach_log=_typed_field(
            raw, "notify_attach_log", bool, where, default=True
        ),
        notify_attach_max_kb=_positive_int(
            raw, "notify_attach_max_kb", where, default=256
        ),
        timeout_sec=_positive_int(raw, "timeout_sec", where, default=1800),
        log_keep_runs=_positive_int(raw, "log_keep_runs", where, default=30),
        notify_email=notify_email,
        notify_ntfy=notify_ntfy,
    )


def _parse_job(name: str, raw: dict[str, Any]) -> Job:
    """Parse [job.<name>]."""
    _validate_name(name, f"[job.{name}]")
    where = f"[job.{name}]"
    _reject_unknown_keys(raw, _KNOWN_JOB, where)
    command = _typed_field(raw, "command", str, where)
    script = _typed_field(raw, "script", str, where)
    if (command is None) == (script is None):
        raise ConfigError(
            f"{where}: must have exactly one of 'command' or 'script'"
        )
    args = _string_list(raw, "args", where)
    if args and command is not None:
        raise ConfigError(
            f"{where}: 'args' is only valid with 'script', not 'command'"
        )
    gate = _typed_field(raw, "gate", str, where)
    gate_script = _typed_field(raw, "gate_script", str, where)
    if gate is not None and gate_script is not None:
        raise ConfigError(
            f"{where}: 'gate' and 'gate_script' are mutually exclusive"
        )
    gate_args = _string_list(raw, "gate_args", where)
    if gate_args and gate_script is None:
        raise ConfigError(
            f"{where}: 'gate_args' is only valid with 'gate_script'"
        )
    schedule = _typed_field(raw, "schedule", str, where)
    interval = _typed_field(raw, "interval", str, where)
    if schedule is not None and interval is not None:
        raise ConfigError(
            f"{where}: 'schedule' and 'interval' are mutually exclusive"
        )
    if schedule is not None:
        validate_schedule(schedule)
    if interval is not None:
        parse_interval_seconds(interval)
    platforms = _string_list(raw, "platforms", where)
    for p in platforms:
        if p not in _VALID_PLATFORMS:
            raise ConfigError(
                f"{where}: platforms entry {p!r} not in "
                f"{sorted(_VALID_PLATFORMS)}"
            )
    channels = _parse_notify_channels(raw, where, required=False)
    timeout_sec = _typed_field(raw, "timeout_sec", int, where)
    if timeout_sec is not None and timeout_sec <= 0:
        raise ConfigError(f"{where}: timeout_sec must be positive")
    return Job(
        name=name,
        command=command,
        script=script,
        args=args,
        gate=gate,
        gate_script=gate_script,
        gate_args=gate_args,
        schedule=schedule,
        interval=interval,
        platforms=platforms,
        timeout_sec=timeout_sec,
        notify_channels=channels,
        env=_string_dict(raw, "env", where),
    )


def _parse_job_group(name: str, raw: dict[str, Any]) -> JobGroup:
    """Parse [job-group.<name>]."""
    _validate_name(name, f"[job-group.{name}]")
    where = f"[job-group.{name}]"
    _reject_unknown_keys(raw, _KNOWN_JOB_GROUP, where)
    jobs = _string_list(raw, "jobs", where)
    if not jobs:
        raise ConfigError(f"{where}: 'jobs' must be a non-empty list")
    schedule = _typed_field(raw, "schedule", str, where)
    interval = _typed_field(raw, "interval", str, where)
    if schedule is not None and interval is not None:
        raise ConfigError(
            f"{where}: 'schedule' and 'interval' are mutually exclusive"
        )
    if schedule is None and interval is None:
        raise ConfigError(
            f"{where}: must define exactly one of 'schedule' or 'interval'"
        )
    if schedule is not None:
        validate_schedule(schedule)
    if interval is not None:
        parse_interval_seconds(interval)
    timeout_sec = _typed_field(raw, "timeout_sec", int, where)
    if timeout_sec is not None and timeout_sec <= 0:
        raise ConfigError(f"{where}: timeout_sec must be positive")
    return JobGroup(
        name=name,
        jobs=jobs,
        schedule=schedule,
        interval=interval,
        timeout_sec=timeout_sec,
    )


def _parse_target(name: str, kind: str, raw: dict[str, Any]) -> Target:
    """Parse [target.<platform>] or [target.host.<name>]."""
    where = (
        f"[target.{name}]" if kind == "platform" else f"[target.host.{name}]"
    )
    if kind == "host":
        _validate_name(name, where)
    _reject_unknown_keys(raw, _KNOWN_TARGET, where)
    jobs = _string_list(raw, "jobs", where)
    channels = _parse_notify_channels(raw, where, required=False)
    timeout_sec = _typed_field(raw, "timeout_sec", int, where)
    if timeout_sec is not None and timeout_sec <= 0:
        raise ConfigError(f"{where}: timeout_sec must be positive")
    return Target(
        name=name,
        kind=kind,
        jobs=jobs,
        notify_channels=channels,
        timeout_sec=timeout_sec,
    )


def _validate_config(config: Config) -> None:
    """Cross-cutting validation: name collisions, references, applicability."""
    # Job/group name collision
    overlap = set(config.jobs) & set(config.job_groups)
    if overlap:
        raise ConfigError(
            f"name collision: {sorted(overlap)} appear as both "
            f"[job.*] and [job-group.*]"
        )
    all_names = set(config.jobs) | set(config.job_groups)
    # Group children must reference defined jobs (not other groups in v1)
    for gname, group in config.job_groups.items():
        for child in group.jobs:
            if child not in config.jobs:
                if child in config.job_groups:
                    raise ConfigError(
                        f"[job-group.{gname}]: 'jobs' references "
                        f"another group {child!r} (nested groups "
                        f"are not supported in v1)"
                    )
                raise ConfigError(
                    f"[job-group.{gname}]: 'jobs' references "
                    f"undefined job {child!r}"
                )
    # Targets reference defined jobs or groups
    for tname, target in config.platform_targets.items():
        for ref in target.jobs:
            if ref not in all_names:
                raise ConfigError(
                    f"[target.{tname}]: 'jobs' references "
                    f"undefined name {ref!r}"
                )
        if tname not in _VALID_PLATFORMS:
            raise ConfigError(
                f"[target.{tname}]: platform must be one of "
                f"{sorted(_VALID_PLATFORMS)}"
            )
    for hname, target in config.host_targets.items():
        for ref in target.jobs:
            if ref not in all_names:
                raise ConfigError(
                    f"[target.host.{hname}]: 'jobs' references "
                    f"undefined name {ref!r}"
                )
    # Job platform applicability for targets that reference them
    for tname, target in config.platform_targets.items():
        for ref in target.jobs:
            if ref in config.jobs:
                job = config.jobs[ref]
                if job.platforms and tname not in job.platforms:
                    raise ConfigError(
                        f"[target.{tname}] references job {ref!r} "
                        f"whose platforms={job.platforms!r} excludes "
                        f"{tname}"
                    )
    # A job with no schedule and no interval must be referenced by some
    # group (otherwise it can never fire).
    referenced_by_group: set[str] = set()
    for group in config.job_groups.values():
        referenced_by_group.update(group.jobs)
    for jname, job in config.jobs.items():
        if (
            job.schedule is None
            and job.interval is None
            and jname not in referenced_by_group
        ):
            raise ConfigError(
                f"[job.{jname}]: has no schedule/interval and is "
                f"not referenced by any [job-group.*] (would never "
                f"fire)"
            )


def _load_one_bundle(name: str, path: Path) -> Bundle:
    """Parse a single bundle file and validate it. Raises ConfigError
    on parse / schema failure, naming the source path for context.
    """
    try:
        raw = tomllib.loads(path.read_text(encoding="utf-8"))
    except tomllib.TOMLDecodeError as e:
        raise ConfigError(f"TOML parse error in {path}: {e}") from e
    try:
        config = parse_config(raw)
    except ConfigError as e:
        raise ConfigError(f"{path}: {e}") from e
    return Bundle(name=name, source=path, config=config)


def load_all_bundles() -> Bundles:
    """Load every bundle: `config.toml` (-> bundle 'default') plus
    `config/*.toml` (each -> bundle named after its filename stem).

    Per-bundle failures are isolated: a bundle that fails to parse,
    fails schema validation, or has an invalid filename is dropped
    with a CONFIG-level error logged for that source. Subsequent
    bundles continue loading. The returned Bundles contains only
    the bundles that loaded successfully.

    It is an error if no bundles load -- either every config file is
    broken or no config files exist at all.
    """
    bundles = Bundles()
    errors: list[str] = []
    seen_names: set[str] = set()

    candidates: list[tuple[str, Path]] = []
    if CONFIG_FILE.exists():
        candidates.append((DEFAULT_BUNDLE_NAME, CONFIG_FILE))
    if CONFIG_DROPIN_DIR.exists():
        for path in sorted(CONFIG_DROPIN_DIR.glob("*.toml")):
            candidates.append((path.stem, path))

    if not candidates:
        raise ConfigError(
            f"no config: expected {CONFIG_FILE} or {CONFIG_DROPIN_DIR}/*.toml"
        )

    for bundle_name, path in candidates:
        try:
            _validate_bundle_name(bundle_name, str(path))
        except ConfigError as e:
            errors.append(str(e))
            continue
        if bundle_name in seen_names:
            errors.append(
                f"{path}: bundle name {bundle_name!r} collides with "
                f"already-loaded bundle; this file will not load"
            )
            continue
        try:
            bundle = _load_one_bundle(bundle_name, path)
        except ConfigError as e:
            errors.append(str(e))
            continue
        bundles.bundles.append(bundle)
        seen_names.add(bundle_name)

    if errors:
        for msg in errors:
            logger.error("%s", msg)
    if not bundles.bundles:
        raise ConfigError("no bundles loaded successfully")
    return bundles


def load_config(path: Path | None = None) -> Config:
    """Load a single config file as a `Config`. Used by tests and
    callers that want the legacy single-bundle shape.

    Most production code should use `load_all_bundles()` instead.
    """
    if path is None:
        path = CONFIG_FILE
    if not path.exists():
        raise ConfigError(f"config not found: {path}")
    try:
        raw = tomllib.loads(path.read_text(encoding="utf-8"))
    except tomllib.TOMLDecodeError as e:
        raise ConfigError(f"TOML parse error in {path}: {e}") from e
    return parse_config(raw)


def parse_config(raw: dict[str, Any]) -> Config:
    """Parse a top-level config dict into a validated Config."""
    _reject_unknown_keys(raw, _KNOWN_TOPLEVEL, "(top level)")

    config = Config()

    if "defaults" in raw:
        if not isinstance(raw["defaults"], dict):
            raise ConfigError("[defaults] must be a table")
        config.defaults = _parse_defaults(raw["defaults"])

    job_section = raw.get("job", {})
    if not isinstance(job_section, dict):
        raise ConfigError("[job] must be a table")
    for name, body in job_section.items():
        if not isinstance(body, dict):
            raise ConfigError(f"[job.{name}] must be a table")
        config.jobs[name] = _parse_job(name, body)

    group_section = raw.get("job-group", {})
    if not isinstance(group_section, dict):
        raise ConfigError("[job-group] must be a table")
    for name, body in group_section.items():
        if not isinstance(body, dict):
            raise ConfigError(f"[job-group.{name}] must be a table")
        config.job_groups[name] = _parse_job_group(name, body)

    target_section = raw.get("target", {})
    if not isinstance(target_section, dict):
        raise ConfigError("[target] must be a table")
    for name, body in target_section.items():
        if name == "host":
            # [target.host.<host>] entries
            if not isinstance(body, dict):
                raise ConfigError("[target.host] must be a table")
            for hostname, hostbody in body.items():
                if not isinstance(hostbody, dict):
                    raise ConfigError(
                        f"[target.host.{hostname}] must be a table"
                    )
                config.host_targets[hostname] = _parse_target(
                    hostname, "host", hostbody
                )
        else:
            # [target.<platform>] entry
            if not isinstance(body, dict):
                raise ConfigError(f"[target.{name}] must be a table")
            config.platform_targets[name] = _parse_target(
                name, "platform", body
            )

    _validate_config(config)
    return config


# =============================================================================
# RESOLUTION
# =============================================================================


def resolve_target(config: Config, host: str, platform: str) -> Target | None:
    """Pick the effective target for (host, platform).

    Host target wins; otherwise the platform target; otherwise None
    (nothing selected on this host).
    """
    if host in config.host_targets:
        return config.host_targets[host]
    if platform in config.platform_targets:
        return config.platform_targets[platform]
    return None


def selected_jobs_and_groups(
    config: Config, target: Target | None
) -> tuple[set[str], set[str]]:
    """Compute the set of job names and group names selected by target.

    Naming a group implicitly selects its constituent jobs, so they
    don't appear as orphans on this host even though they have no
    platform unit.
    """
    jobs: set[str] = set()
    groups: set[str] = set()
    if target is None:
        return jobs, groups
    for name in target.jobs:
        if name in config.jobs:
            jobs.add(name)
        elif name in config.job_groups:
            groups.add(name)
            for child in config.job_groups[name].jobs:
                jobs.add(child)
    return jobs, groups


def resolved_notify_channels(
    config: Config, target: Target | None, job: Job
) -> list[str]:
    """Cascade notify_channels: target > job > defaults.

    Each layer's value is either None ("inherit from below") or a
    list ("override; this is the value for this layer"). An empty
    list at any layer is a deliberate "no external dispatch" choice
    that wins over lower layers. The bottom-most fallback is the
    defaults' list, which may itself be empty.
    """
    if target is not None and target.notify_channels is not None:
        return list(target.notify_channels)
    if job.notify_channels is not None:
        return list(job.notify_channels)
    return list(config.defaults.notify_channels)


def resolved_timeout_sec(
    config: Config, target: Target | None, job: Job
) -> int:
    """Cascade timeout_sec: target > job > defaults."""
    if target is not None and target.timeout_sec is not None:
        return target.timeout_sec
    if job.timeout_sec is not None:
        return job.timeout_sec
    return config.defaults.timeout_sec


# =============================================================================
# RUNNER
# =============================================================================
# `crony run <name>` dispatches to the per-job pipeline or the group
# pipeline depending on whether <name> is a job or a job-group. The
# per-job pipeline acquires a per-job flock, runs the optional gate,
# execs the main command with a wallclock cap, writes a structured
# last-run.json record, and dispatches a notification on non-ok exits
# exits via the configured channel (log-only, email, or ntfy). The
# group pipeline acquires a group-level lock and re-invokes
# `crony run <child>` for each named child in order; per-job
# notifications happen inside each child's own run.


@dataclass
class JobRunResult:
    """Recorded as last-run.json for each completed job run."""

    job: str
    host: str
    platform: str
    started_at: str
    ended_at: str
    duration_sec: float
    exit_class: str
    exit_code: int | None
    signal: int | None
    # "none" if no gate ran (no config, or --skip-gate), "passed" on
    # exit 0, "failed" on any non-zero or timeout. The numeric exit
    # code stays in run.log for diagnosis; this field is the binary
    # answer "did the gate let the job run?".
    gate: str
    log_path: str
    log_bytes_this_run: int
    # Per-channel outcomes. Keys are channel names that were
    # attempted (e.g. "email", "ntfy"); values are NotificationResult
    # records. Empty dict means no external dispatch was attempted
    # (notify_channels resolved to []).
    notifications: dict[str, NotificationResult] = field(default_factory=dict)


@dataclass
class GroupChildResult:
    """One child's outcome inside a group run."""

    name: str
    exit_class: str
    exit_code: int


@dataclass
class GroupRunResult:
    """Recorded as last-run.json for each completed group run."""

    group: str
    host: str
    platform: str
    started_at: str
    ended_at: str
    duration_sec: float
    log_path: str
    jobs_run: list[GroupChildResult]


def _state_dir_for(name: str) -> Path:
    """State directory for a named job or group, created on demand."""
    d = STATE_DIR / name
    d.mkdir(parents=True, exist_ok=True)
    return d


def _now_iso() -> str:
    """Current local time in ISO 8601 format with timezone offset."""
    return (
        datetime.datetime.now(datetime.timezone.utc)
        .astimezone()
        .isoformat(timespec="seconds")
    )


@contextlib.contextmanager
def _acquire_lock(lock_path: Path) -> Iterator[None]:
    """Hold an exclusive non-blocking flock on lock_path.

    Raises LockBusyError if another holder has the lock. The lock
    file is left in place across runs; flock guards mutual exclusion.
    """
    fd = open(lock_path, "w")
    try:
        try:
            fcntl.flock(fd, fcntl.LOCK_EX | fcntl.LOCK_NB)
        except BlockingIOError as e:
            raise LockBusyError(
                f"another instance of {lock_path.parent.name} is running"
            ) from e
        try:
            yield
        finally:
            fcntl.flock(fd, fcntl.LOCK_UN)
    finally:
        fd.close()


def _expand_env_value(raw: str, env: dict[str, str]) -> str:
    """Expand `$VAR` / `${VAR}` references in `raw` against `env`.

    Uses `string.Template.safe_substitute` so unresolved references
    stay literal (shell-like behavior: `$NOTHING` becomes the string
    `"$NOTHING"`, not an error). `$$` escapes to a literal `$`. The
    expansion is single-pass: a value that contains another expanded
    value's reference resolves once, not recursively.
    """
    return string.Template(raw).safe_substitute(env)


def _runtime_env(job: Job) -> dict[str, str]:
    """Build the env dict passed to the wrapped command.

    Carries forward the small set of shell-essential vars from the
    invoking process and overlays the job's `env` dict so users can
    inject custom settings without leaking the full parent env.
    SSH_AUTH_SOCK is included so jobs that need to ssh out (e.g.
    a remote backup or a git pull from a private repo) can talk to
    the user's running ssh-agent without the user having to wire it
    up per-job. Each `env` value is expanded against the running
    merged env, so a job can write `PATH = "/extra:$PATH"` and have
    $PATH resolve to the inherited PATH (or to a value an earlier
    job-env key set).
    """
    env: dict[str, str] = {}
    for k in (
        "HOME",
        "PATH",
        "LANG",
        "LC_ALL",
        "TZ",
        "USER",
        "LOGNAME",
        "SSH_AUTH_SOCK",
    ):
        v = os.environ.get(k)
        if v is not None:
            env[k] = v
    for k, raw in job.env.items():
        env[k] = _expand_env_value(raw, env)
    return env


def _resolve_script(script: str) -> Path:
    """Resolve a `script` field to an absolute path."""
    p = Path(os.path.expanduser(script))
    if not p.is_absolute():
        p = (CONFIG_DIR / p).resolve()
    return p


def _command_argv(job: Job) -> list[str]:
    """argv for the job's main command."""
    if job.command is not None:
        return ["/bin/sh", "-c", job.command]
    assert job.script is not None
    return [
        str(_resolve_script(job.script)),
        *(os.path.expanduser(a) for a in job.args),
    ]


def _gate_argv(job: Job) -> list[str] | None:
    """argv for the job's gate, or None if no gate is configured."""
    if job.gate is not None:
        return ["/bin/sh", "-c", job.gate]
    if job.gate_script is not None:
        return [
            str(_resolve_script(job.gate_script)),
            *(os.path.expanduser(a) for a in job.gate_args),
        ]
    return None


def _crony_executable() -> str:
    """Absolute path to bin/crony for re-invocation by groups.

    Uses `__file__` rather than `sys.argv[0]` so the subprocess
    re-invocation reaches the right binary even when crony has
    been imported as a module (e.g. by the test suite, where
    sys.argv[0] is pytest, not crony).
    """
    return str(Path(__file__).resolve())


class ExitOutcome(NamedTuple):
    """Outcome of a wrapped subprocess invocation.

    `signal` is set to the killing signal number when the process was
    terminated by a signal, and None when it exited normally. `rc` is
    0 in the signal case and the process's own exit code otherwise.
    """

    rc: int
    signal: int | None


def _exec_with_timeout(
    argv: list[str],
    *,
    env: dict[str, str],
    timeout_sec: int,
    log_file: IO[bytes],
) -> ExitOutcome:
    """Exec argv, piping stdout+stderr into log_file.

    On timeout, sends SIGTERM, then SIGKILL after a grace window, and
    re-raises subprocess.TimeoutExpired.
    """
    proc = subprocess.Popen(
        argv,
        stdout=log_file,
        stderr=subprocess.STDOUT,
        env=env,
    )
    try:
        rc = proc.wait(timeout=timeout_sec)
    except subprocess.TimeoutExpired:
        proc.terminate()
        try:
            proc.wait(timeout=10)
        except subprocess.TimeoutExpired:
            proc.kill()
            proc.wait()
        raise
    if rc < 0:
        return ExitOutcome(rc=0, signal=-rc)
    return ExitOutcome(rc=rc, signal=None)


def _write_last_run(path: Path, payload: dict[str, Any]) -> None:
    """Atomically write last-run.json so partial writes can't corrupt it.

    Insertion order is preserved (no `sort_keys=True`): top-level keys
    follow dataclass field order, and `notifications` keeps the
    configured channel order so the on-disk record matches what the
    user wrote in the toml.
    """
    tmp = path.with_suffix(".json.tmp")
    tmp.write_text(json.dumps(payload, indent=2))
    tmp.replace(path)


_NOTIFY_TIMEOUT_SEC: int = 15


def _retrieve_secret(
    *,
    keychain_service: str | None,
    keychain_account: str | None = None,
    file_path: str | None,
) -> str | None:
    """Look up a secret value from macOS Keychain or a 0600 file.

    Tries `security find-generic-password` first when a keychain
    service is configured and the host is darwin; falls back to
    reading file_path if the file exists. `keychain_account` is
    optional and disambiguates when multiple keychain items share the
    same service name (the (service, account) pair is the keychain's
    composite identity for generic-password items). Returns None if
    no source is configured or the keychain lookup fails on a darwin
    host. Raises PreconditionError if a secrets file exists but its
    mode allows group / world access -- a config-time check that
    surfaces leaked-credential risk before the runtime path tries to
    use it.
    """
    if keychain_service is not None and sys.platform == "darwin":
        argv = [
            "security",
            "find-generic-password",
            "-s",
            keychain_service,
        ]
        if keychain_account is not None:
            argv.extend(["-a", keychain_account])
        argv.append("-w")
        try:
            r = subprocess.run(
                argv,
                capture_output=True,
                text=True,
                timeout=5,
            )
            if r.returncode == 0:
                return r.stdout.rstrip("\n")
        except (FileNotFoundError, subprocess.TimeoutExpired):
            pass
    if file_path is not None:
        p = Path(os.path.expanduser(file_path))
        if p.exists():
            # Parent directory: require no group / world bits. A
            # 0700 (or 0500) parent prevents leaks of file names /
            # mtimes / sibling presence even when the secret file
            # itself is locked down to 0600.
            parent = p.parent
            parent_mode = parent.stat().st_mode & 0o777
            if parent_mode & 0o077:
                raise PreconditionError(
                    f"secret directory {parent} is mode "
                    f"0o{parent_mode:o}; require no group / world "
                    f"bits (e.g. 0700)"
                )
            mode = p.stat().st_mode & 0o777
            if mode & 0o077:
                raise PreconditionError(
                    f"secret file {p} is mode 0o{mode:o}; require 0600 "
                    f"(group / world readable secrets are unsafe)"
                )
            return p.read_text(encoding="utf-8").rstrip("\n")
    return None


def _format_summary(result: JobRunResult) -> str:
    """One-line-per-field human summary for notification bodies."""
    return (
        f"Job:        {result.job}\n"
        f"Host:       {result.host}\n"
        f"Platform:   {result.platform}\n"
        f"Started:    {result.started_at}\n"
        f"Ended:      {result.ended_at}\n"
        f"Duration:   {result.duration_sec:.1f}s\n"
        f"Exit class: {result.exit_class}\n"
        f"Exit code:  {result.exit_code}\n"
        f"Signal:     {result.signal}\n"
        f"Gate:       {result.gate}\n"
        f"Log path:   {result.log_path}\n"
    )


def _truncate_log(log_text: str, max_kb: int) -> tuple[str, bool]:
    """Tail a log to at most max_kb KB, returning (text, truncated)."""
    max_bytes = max_kb * 1024
    if len(log_text) <= max_bytes:
        return log_text, False
    return log_text[-max_bytes:], True


def _build_email_message(
    result: JobRunResult,
    log_text: str,
    cfg: NotifyEmail,
    attach_log: bool,
    attach_max_kb: int,
) -> EmailMessage:
    """Construct the RFC822 EmailMessage for a job failure."""
    msg = EmailMessage()
    msg["Subject"] = (
        f"[crony/{result.host}] {result.job} {result.exit_class} "
        f"(exit {result.exit_code})"
    )
    msg["From"] = cfg.from_addr or cfg.smtp_user
    msg["To"] = cfg.to
    body = _format_summary(result)
    if attach_log and log_text:
        tail, truncated = _truncate_log(log_text, attach_max_kb)
        marker = (
            f"\n--- log (last {len(tail)} of {len(log_text)} bytes) ---\n"
            if truncated
            else "\n--- log ---\n"
        )
        body += marker + tail
    msg.set_content(body)
    return msg


def _send_email(msg: EmailMessage, cfg: NotifyEmail, password: str) -> None:
    """SMTP send with optional STARTTLS + AUTH. Raises smtplib errors."""
    with smtplib.SMTP(
        cfg.smtp_host, cfg.smtp_port, timeout=_NOTIFY_TIMEOUT_SEC
    ) as smtp:
        if cfg.smtp_starttls:
            smtp.starttls()
        smtp.login(cfg.smtp_user, password)
        smtp.send_message(msg)


def _post_ntfy(
    cfg: NotifyNtfy,
    token: str,
    title: str,
    exit_class: str,
    body: str,
    log_text: str,
    attach_log: bool,
    attach_max_kb: int,
) -> None:
    """POST to ntfy. Body is the log tail when attach_log is true,
    otherwise the human summary. urlopen raises HTTPError on >=400
    responses; the caller's broad except records that as
    notify_error.
    """
    headers = {
        "Authorization": f"Bearer {token}",
        "Title": title,
        "Tags": f"warning,{exit_class}",
    }
    if attach_log and log_text:
        tail, _trunc = _truncate_log(log_text, attach_max_kb)
        data = tail.encode("utf-8")
        headers["Filename"] = "run.log"
    else:
        data = body.encode("utf-8")
    req = urllib.request.Request(
        cfg.url, data=data, headers=headers, method="POST"
    )
    with urllib.request.urlopen(req, timeout=_NOTIFY_TIMEOUT_SEC):
        pass


def _send_email_for(
    result: JobRunResult, log_text: str, defaults: Defaults
) -> None:
    """Send the failure email. Raises on any error."""
    if defaults.notify_email is None:
        raise ConfigError("[defaults.notify.email] not configured")
    password = _retrieve_secret(
        keychain_service=defaults.notify_email.smtp_pass_keychain_service,
        keychain_account=defaults.notify_email.smtp_pass_keychain_account,
        file_path=defaults.notify_email.smtp_pass_file,
    )
    if password is None:
        raise ConfigError(
            "no SMTP password available (configure "
            "smtp_pass_keychain_service or smtp_pass_file)"
        )
    msg = _build_email_message(
        result,
        log_text,
        defaults.notify_email,
        defaults.notify_attach_log,
        defaults.notify_attach_max_kb,
    )
    _send_email(msg, defaults.notify_email, password)


def _send_ntfy_for(
    result: JobRunResult, log_text: str, defaults: Defaults
) -> None:
    """Send the failure ntfy POST. Raises on any error."""
    if defaults.notify_ntfy is None:
        raise ConfigError("[defaults.notify.ntfy] not configured")
    token = _retrieve_secret(
        keychain_service=defaults.notify_ntfy.token_keychain_service,
        keychain_account=defaults.notify_ntfy.token_keychain_account,
        file_path=defaults.notify_ntfy.token_file,
    )
    if token is None:
        raise ConfigError(
            "no ntfy token available (configure "
            "token_keychain_service or token_file)"
        )
    title = (
        f"[crony/{result.host}] {result.job} "
        f"{result.exit_class} (exit {result.exit_code})"
    )
    _post_ntfy(
        defaults.notify_ntfy,
        token,
        title,
        result.exit_class,
        _format_summary(result),
        log_text,
        defaults.notify_attach_log,
        defaults.notify_attach_max_kb,
    )


# Per-channel sender table. Each entry takes (result, log_text,
# defaults) and raises on failure. Adding a new channel is one new
# function plus one entry here.
_NOTIFY_DISPATCH: dict[str, Callable[[JobRunResult, str, Defaults], None]] = {
    "email": _send_email_for,
    "ntfy": _send_ntfy_for,
}

# Pin parser-side and dispatcher-side enumerations together so a new
# channel can never be accepted by the parser but unknown to dispatch
# (or vice versa). Module-import time assertion is sufficient: both
# sets are static.
assert set(_NOTIFY_DISPATCH.keys()) == _VALID_NOTIFY_CHANNELS, (
    "_NOTIFY_DISPATCH and _VALID_NOTIFY_CHANNELS have drifted"
)


def _dispatch_notify(
    result: JobRunResult, log_text: str, defaults: Defaults
) -> None:
    """Fan out to every channel in result.notifications.

    The runner pre-populates result.notifications with the resolved
    channel set (one entry per channel, sent=False). This function
    attempts each in order, catching any exception from a single
    channel so one transport failure can't suppress the others. The
    wrapped command's exit code remains the primary failure signal;
    a missed notification is recorded but never propagated.
    """
    for channel in list(result.notifications.keys()):
        sender = _NOTIFY_DISPATCH.get(channel)
        try:
            if sender is None:
                raise ConfigError(f"unknown notify channel: {channel!r}")
            sender(result, log_text, defaults)
            result.notifications[channel] = NotificationResult(
                sent=True, error=None, error_class=None
            )
        except Exception as e:
            # Notify is best-effort; record the failure on this
            # channel and continue with the next one.
            result.notifications[channel] = NotificationResult(
                sent=False,
                error=f"{type(e).__name__}: {e}",
                error_class=type(e).__name__,
            )


def run_job(
    config: Config,
    name: str,
    *,
    dry_run: bool = False,
    skip_gate: bool = False,
    bundle_name: str = DEFAULT_BUNDLE_NAME,
) -> int:
    """Run a single job through the per-job pipeline.

    `name` is the short name (as written in the bundle's TOML).
    `bundle_name` defaults to "default" so single-bundle callers
    work unchanged; the full namespaced name `<bundle_name>.<name>`
    is what lands on disk (state dir, last-run.json, log path).

    Returns an exit code suitable for the platform scheduler: the
    wrapped command's exit code on completion (0 on success or any
    nonzero code from the command), ExitCode.LOCK_BUSY on lock
    contention, ExitCode.TIMEOUT on wallclock cap, or 0 for a
    gated/dry-run skip. Precondition failures (missing script,
    unselected job, unknown name) are signalled by raising
    PreconditionError -- cli() maps that to ExitCode.PRECONDITION.
    """
    if name not in config.jobs:
        raise PreconditionError(f"unknown job: {name!r}")
    job = config.jobs[name]
    full_name = f"{bundle_name}.{name}"

    target = resolve_target(config, current_host(), current_platform())
    selected, _ = selected_jobs_and_groups(config, target)
    if name not in selected:
        raise PreconditionError(
            f"job {full_name!r} is not selected on this host"
        )

    if job.script is not None:
        sp = _resolve_script(job.script)
        if not sp.exists():
            raise PreconditionError(f"script not found: {sp}")
        if not os.access(sp, os.X_OK):
            raise PreconditionError(f"script not executable: {sp}")

    sd = _state_dir_for(full_name)
    lock_path = sd / "run.lock"
    log_path = sd / "run.log"
    last_run_path = sd / "last-run.json"

    notify_channels = resolved_notify_channels(config, target, job)
    timeout_sec = resolved_timeout_sec(config, target, job)
    env = _runtime_env(job)
    started = time.time()
    started_iso = _now_iso()
    host = current_host()
    platform = current_platform()

    try:
        with _acquire_lock(lock_path):
            if dry_run:
                return 0

            log_size_before = (
                log_path.stat().st_size if log_path.exists() else 0
            )
            log_file = open(log_path, "ab", buffering=0)
            try:
                header = (
                    f"\n=== {started_iso} {full_name} pid={os.getpid()} ===\n"
                ).encode()
                log_file.write(header)

                gate: str = "none"
                gate_argv = _gate_argv(job)
                if gate_argv is not None and not skip_gate:
                    log_file.write(f"gate: {shlex.join(gate_argv)}\n".encode())
                    gate_rc: int
                    try:
                        gate_proc = subprocess.run(
                            gate_argv,
                            stdout=log_file,
                            stderr=subprocess.STDOUT,
                            env=env,
                            timeout=30,
                        )
                        gate_rc = gate_proc.returncode
                    except subprocess.TimeoutExpired:
                        gate_rc = -1
                    gate = "passed" if gate_rc == 0 else "failed"

                    if gate == "failed":
                        log_file.write(
                            (f"gate exited {gate_rc}: skipping job\n").encode()
                        )
                        result = JobRunResult(
                            job=full_name,
                            host=host,
                            platform=platform,
                            started_at=started_iso,
                            ended_at=_now_iso(),
                            duration_sec=time.time() - started,
                            exit_class="gated",
                            exit_code=0,
                            signal=None,
                            gate=gate,
                            log_path=str(log_path),
                            log_bytes_this_run=(
                                log_path.stat().st_size - log_size_before
                            ),
                            notifications={},
                        )
                        _write_last_run(
                            last_run_path, dataclasses.asdict(result)
                        )
                        return 0

                argv = _command_argv(job)
                log_file.write(f"exec: {shlex.join(argv)}\n".encode())
                try:
                    rc, sig = _exec_with_timeout(
                        argv,
                        env=env,
                        timeout_sec=timeout_sec,
                        log_file=log_file,
                    )
                    if sig is not None:
                        exit_class = "signal"
                        exit_code: int | None = None
                    elif rc == 0:
                        exit_class = "ok"
                        exit_code = 0
                    else:
                        exit_class = "fail"
                        exit_code = rc
                    surfaced_rc = rc if sig is None else 128 + sig
                except subprocess.TimeoutExpired:
                    exit_class = "timeout"
                    exit_code = None
                    sig = None
                    surfaced_rc = int(ExitCode.TIMEOUT)

                # Pre-populate per-channel slots with sent=False so
                # the dispatcher can update each entry in place. Order
                # is preserved (Python dict insertion order) so the
                # JSON record reflects the configured channel order.
                notifications: dict[str, NotificationResult] = {
                    ch: NotificationResult(sent=False) for ch in notify_channels
                }
                result = JobRunResult(
                    job=full_name,
                    host=host,
                    platform=platform,
                    started_at=started_iso,
                    ended_at=_now_iso(),
                    duration_sec=time.time() - started,
                    exit_class=exit_class,
                    exit_code=exit_code,
                    signal=sig,
                    gate=gate,
                    log_path=str(log_path),
                    log_bytes_this_run=(
                        log_path.stat().st_size - log_size_before
                    ),
                    notifications=notifications,
                )

                if exit_class != "ok" and notify_channels:
                    log_text = ""
                    try:
                        log_text = log_path.read_text(
                            encoding="utf-8", errors="replace"
                        )[-200_000:]
                    except OSError:
                        pass
                    _dispatch_notify(result, log_text, config.defaults)

                _write_last_run(last_run_path, dataclasses.asdict(result))
                return surfaced_rc
            finally:
                log_file.close()
    except LockBusyError:
        with open(log_path, "ab", buffering=0) as f:
            f.write(
                f"[{_now_iso()}] LOCK_BUSY: skipping (already running)\n".encode()
            )
        return int(ExitCode.LOCK_BUSY)


def run_group(
    config: Config,
    name: str,
    *,
    dry_run: bool = False,
    skip_gate: bool = False,
    bundle_name: str = DEFAULT_BUNDLE_NAME,
) -> int:
    """Run a job-group: dispatch each child via `crony run <child>`.

    `name` is the short group name; `bundle_name` defaults to
    "default". Children dispatch via subprocess as
    `crony run <bundle_name>.<child-short>` so the child's runner
    resolves into the same bundle's defaults / target / job
    cascade.

    Children fire sequentially; one child failing does not stop the
    next. The group writes its own aggregate last-run.json with a
    per-child summary. The group itself never sends a notification;
    each child's own runner handles notify.
    """
    if name not in config.job_groups:
        raise PreconditionError(f"unknown group: {name!r}")
    group = config.job_groups[name]
    full_name = f"{bundle_name}.{name}"

    sd = _state_dir_for(full_name)
    lock_path = sd / "run.lock"
    log_path = sd / "run.log"
    last_run_path = sd / "last-run.json"

    started = time.time()
    started_iso = _now_iso()
    host = current_host()
    platform = current_platform()

    try:
        with _acquire_lock(lock_path):
            if dry_run:
                return 0

            log_file = open(log_path, "ab", buffering=0)
            children: list[GroupChildResult] = []
            try:
                child_full = [f"{bundle_name}.{c}" for c in group.jobs]
                header = (
                    f"\n=== {started_iso} group {full_name} "
                    f"children={child_full} ===\n"
                ).encode()
                log_file.write(header)

                for child_short, child_full_name in zip(group.jobs, child_full):
                    log_file.write(f"-> {child_full_name}\n".encode())
                    cmd = [
                        _crony_executable(),
                        "run",
                        child_full_name,
                    ]
                    if skip_gate:
                        cmd.append("--skip-gate")
                    proc = subprocess.run(
                        cmd, stdout=log_file, stderr=subprocess.STDOUT
                    )
                    rc = proc.returncode
                    if rc == 0:
                        cls = "ok"
                    elif rc == int(ExitCode.LOCK_BUSY):
                        cls = "lock_busy"
                    elif rc == int(ExitCode.TIMEOUT):
                        cls = "timeout"
                    elif rc == int(ExitCode.PRECONDITION):
                        cls = "precondition"
                    else:
                        cls = "fail"
                    children.append(
                        GroupChildResult(
                            name=child_full_name,
                            exit_class=cls,
                            exit_code=rc,
                        )
                    )

                result = GroupRunResult(
                    group=full_name,
                    host=host,
                    platform=platform,
                    started_at=started_iso,
                    ended_at=_now_iso(),
                    duration_sec=time.time() - started,
                    log_path=str(log_path),
                    jobs_run=children,
                )
                _write_last_run(last_run_path, dataclasses.asdict(result))
                return 0
            finally:
                log_file.close()
    except LockBusyError:
        with open(log_path, "ab", buffering=0) as f:
            f.write(
                f"[{_now_iso()}] LOCK_BUSY: skipping (already running)\n".encode()
            )
        return int(ExitCode.LOCK_BUSY)


# =============================================================================
# PLATFORM UNITS
# =============================================================================
# Render and (un)load platform-native scheduler units. crony's
# "behaves the same on both platforms" promise is concentrated here:
# darwin/linux divergence in apply/destroy lives in this section.
# Anywhere else in the file is platform-agnostic.

_DOW_TO_LAUNCHD: dict[str, int] = {
    "sun": 0,
    "mon": 1,
    "tue": 2,
    "wed": 3,
    "thu": 4,
    "fri": 5,
    "sat": 6,
}


def _label_for(name: str) -> str:
    """launchd Label for a job/group."""
    return f"org.{BASENAME}.{name}"


def _plist_path_for(name: str) -> Path:
    return LAUNCHAGENTS_DIR / f"{_label_for(name)}.plist"


def _service_path_for(name: str) -> Path:
    return SYSTEMD_USER_DIR / f"{BASENAME}-{name}.service"


def _timer_path_for(name: str) -> Path:
    return SYSTEMD_USER_DIR / f"{BASENAME}-{name}.timer"


def _hash_path_for(name: str) -> Path:
    return STATE_DIR / "installed" / f"{name}.hash"


def _systemd_unit_name(name: str) -> str:
    return f"{BASENAME}-{name}.timer"


def _oncalendar_to_plist_calendar(spec: str) -> dict[str, int]:
    """Translate an OnCalendar spec to a launchd StartCalendarInterval.

    Supports keywords (hourly, daily, weekly, monthly, yearly), bare
    HH:MM, and the `[DOW] *-*-* HH:MM` shape with a single concrete
    day or month. Step values, ranges, and comma-lists are rejected
    here -- they would require expanding to many entries that crony
    doesn't yet generate, so the error explicitly suggests using a
    simpler schedule form.
    """
    text = spec.strip()
    keywords: dict[str, dict[str, int]] = {
        "hourly": {"Minute": 0},
        "daily": {"Hour": 0, "Minute": 0},
        "weekly": {"Weekday": 1, "Hour": 0, "Minute": 0},
        "monthly": {"Day": 1, "Hour": 0, "Minute": 0},
        "yearly": {"Month": 1, "Day": 1, "Hour": 0, "Minute": 0},
        "annually": {"Month": 1, "Day": 1, "Hour": 0, "Minute": 0},
    }
    if text in keywords:
        return keywords[text]
    if "/" in text or ".." in text or "," in text:
        raise ConfigError(
            f"OnCalendar pattern {spec!r} uses step / range / list "
            f"features that crony does not translate to launchd. "
            f"Use a single concrete time or weekday/day entry."
        )
    parts = text.split()
    dow: int | None = None
    if parts and parts[0].lower() in _DOW_TO_LAUNCHD:
        dow = _DOW_TO_LAUNCHD[parts[0].lower()]
        parts = parts[1:]
    time_re = re.compile(r"^(\d{1,2}):(\d{2})(?::\d{2})?$")
    if len(parts) == 1 and time_re.fullmatch(parts[0]):
        m = time_re.fullmatch(parts[0])
        assert m is not None
        entry: dict[str, int] = {
            "Hour": int(m.group(1)),
            "Minute": int(m.group(2)),
        }
        if dow is not None:
            entry["Weekday"] = dow
        return entry
    date_re = re.compile(r"^(\*|\d{4})-(\*|\d{1,2})-(\*|\d{1,2})$")
    if len(parts) == 2:
        d = date_re.fullmatch(parts[0])
        t = time_re.fullmatch(parts[1])
        if d and t:
            e: dict[str, int] = {
                "Hour": int(t.group(1)),
                "Minute": int(t.group(2)),
            }
            if d.group(2) != "*":
                e["Month"] = int(d.group(2))
            if d.group(3) != "*":
                e["Day"] = int(d.group(3))
            if dow is not None:
                e["Weekday"] = dow
            return e
    raise ConfigError(
        f"crony does not yet translate OnCalendar pattern {spec!r} "
        f"to launchd. Try a simpler form like '03:15' or "
        f"'*-*-* 03:15' or 'Mon *-*-* 09:00'."
    )


def _render_plist(name: str, schedule: str | None, interval: str | None) -> str:
    """Render the LaunchAgent plist XML for a job or group."""
    label = _label_for(name)
    program_args = [_crony_executable(), "run", name]
    args_xml = "".join(
        f"        <string>{xml.sax.saxutils.escape(a)}</string>\n"
        for a in program_args
    )
    sched_block = ""
    if interval is not None:
        sec = parse_interval_seconds(interval)
        sched_block = (
            f"    <key>StartInterval</key>\n    <integer>{sec}</integer>\n"
        )
    elif schedule is not None:
        entry = _oncalendar_to_plist_calendar(schedule)
        sched_block = "    <key>StartCalendarInterval</key>\n"
        sched_block += "    <dict>\n"
        for k, v in sorted(entry.items()):
            sched_block += f"        <key>{k}</key>\n"
            sched_block += f"        <integer>{v}</integer>\n"
        sched_block += "    </dict>\n"
    return (
        '<?xml version="1.0" encoding="UTF-8"?>\n'
        '<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" '
        '"http://www.apple.com/DTDs/PropertyList-1.0.dtd">\n'
        '<plist version="1.0">\n'
        "<dict>\n"
        f"    <key>Label</key>\n"
        f"    <string>{label}</string>\n"
        f"    <key>ProgramArguments</key>\n"
        f"    <array>\n"
        f"{args_xml}"
        f"    </array>\n"
        "    <key>RunAtLoad</key>\n"
        "    <false/>\n"
        "    <key>KeepAlive</key>\n"
        "    <false/>\n"
        "    <key>AbandonProcessGroup</key>\n"
        "    <false/>\n"
        f"{sched_block}"
        "</dict>\n"
        "</plist>\n"
    )


def _render_systemd_service(name: str) -> str:
    """Render the systemd .service unit. Independent of schedule."""
    crony_path = _crony_executable()
    return (
        "[Unit]\n"
        f"Description=crony job {name}\n"
        "\n"
        "[Service]\n"
        "Type=oneshot\n"
        f"ExecStart={crony_path} run {name}\n"
        "WorkingDirectory=%h\n"
    )


def _render_systemd_timer(
    name: str, schedule: str | None, interval: str | None
) -> str:
    """Render the systemd .timer unit."""
    if interval is not None:
        spec_line = f"OnUnitActiveSec={interval}\n"
    else:
        assert schedule is not None
        spec_line = f"OnCalendar={schedule}\n"
    return (
        "[Unit]\n"
        f"Description=crony timer for {name}\n"
        "\n"
        "[Timer]\n"
        f"{spec_line}"
        "Persistent=true\n"
        "\n"
        "[Install]\n"
        "WantedBy=timers.target\n"
    )


def _render_units(
    name: str,
    schedule: str | None,
    interval: str | None,
    platform: str,
) -> dict[str, str]:
    """Return {filename: content} for the platform units of (name, schedule)."""
    if platform == "darwin":
        return {
            f"{_label_for(name)}.plist": _render_plist(name, schedule, interval)
        }
    return {
        f"{BASENAME}-{name}.service": _render_systemd_service(name),
        f"{BASENAME}-{name}.timer": _render_systemd_timer(
            name, schedule, interval
        ),
    }


def _entity_schedule(
    entry: Job | JobGroup,
) -> tuple[str | None, str | None]:
    """Return (schedule, interval) for either entity kind."""
    return entry.schedule, entry.interval


def _compute_unit_hash(name: str, entry: Job | JobGroup, platform: str) -> str:
    """SHA-256 of rendered unit content; the drift-detection signal."""
    schedule, interval = _entity_schedule(entry)
    units = _render_units(name, schedule, interval, platform)
    h = hashlib.sha256()
    for fname in sorted(units):
        h.update(fname.encode("utf-8"))
        h.update(b"\0")
        h.update(units[fname].encode("utf-8"))
        h.update(b"\0")
    return h.hexdigest()


def _has_platform_unit(name: str) -> bool:
    """True iff this entity has a schedulable platform unit on this host.

    Group-only jobs (no schedule, no interval) intentionally do not
    install a platform unit -- they only ever fire via a group's
    subprocess re-invocation.
    """
    return True  # caller already screened group-only jobs


def _activate_unit(
    name: str, platform: str, *, prior_disabled: bool = False
) -> None:
    """Load the unit into the platform scheduler.

    `prior_disabled=True` preserves a hand-disabled state across an
    apply re-render: the unit is reloaded so the new content takes
    effect, but the persistent disable record is restored afterward
    so the scheduler doesn't fire it. Without this, a `crony disable
    foo` followed by an unrelated config edit would silently re-arm
    foo.
    """
    if platform == "darwin":
        plist = _plist_path_for(name)
        # Validate the plist before asking launchd to load it -- a
        # parseable failure here is much clearer than launchd's silent
        # error path.
        subprocess.run(["plutil", str(plist)], check=True)
        # unload-then-load: tolerates "not loaded" (errok) so a clean
        # re-apply over a previously-installed unit just works.
        subprocess.run(
            ["launchctl", "unload", str(plist)],
            stderr=subprocess.DEVNULL,
        )
        subprocess.run(["launchctl", "load", str(plist)], check=True)
        if prior_disabled:
            label = _label_for(name)
            subprocess.run(
                ["launchctl", "unload", str(plist)],
                stderr=subprocess.DEVNULL,
            )
            subprocess.run(
                [
                    "launchctl",
                    "disable",
                    f"gui/{os.getuid()}/{label}",
                ],
                check=True,
            )
        return
    # linux: daemon-reload picks up the new content. Only enable +
    # start when the unit was NOT already deliberately disabled.
    subprocess.run(["systemctl", "--user", "daemon-reload"], check=True)
    if not prior_disabled:
        subprocess.run(
            [
                "systemctl",
                "--user",
                "enable",
                "--now",
                _systemd_unit_name(name),
            ],
            check=True,
        )


def _deactivate_unit(name: str, platform: str) -> None:
    """Remove the unit from the platform scheduler. Errok throughout
    so destroy never fails just because the unit was already gone.
    """
    if platform == "darwin":
        plist = _plist_path_for(name)
        if plist.exists():
            subprocess.run(
                ["launchctl", "unload", str(plist)],
                stderr=subprocess.DEVNULL,
            )
    else:
        subprocess.run(
            [
                "systemctl",
                "--user",
                "disable",
                "--now",
                _systemd_unit_name(name),
            ],
            stderr=subprocess.DEVNULL,
        )
        subprocess.run(
            ["systemctl", "--user", "daemon-reload"],
            stderr=subprocess.DEVNULL,
        )


def apply_one(
    config: Config,
    name: str,
    *,
    dry_run: bool = False,
    bundle_name: str = DEFAULT_BUNDLE_NAME,
) -> str:
    """Apply a single job or group; return "added", "updated", or
    "unchanged".

    `name` is the short name (as written in the bundle's TOML);
    `bundle_name` defaults to "default". The full namespaced name
    `<bundle_name>.<name>` is what lands on disk (hash stamp,
    plist / systemd unit identifier).

    Group-only jobs (no schedule, no interval) install no platform
    unit but still get a hash stamp so orphan-detection has a record.
    The same return values apply -- only the platform-unit IO differs.
    """
    if name in config.jobs:
        entry: Job | JobGroup = config.jobs[name]
    elif name in config.job_groups:
        entry = config.job_groups[name]
    else:
        raise PreconditionError(f"unknown job/group: {name!r}")
    full_name = f"{bundle_name}.{name}"

    schedule, interval = _entity_schedule(entry)
    has_unit = schedule is not None or interval is not None
    platform = current_platform()
    hash_path = _hash_path_for(full_name)
    new_hash = (
        _compute_unit_hash(full_name, entry, platform)
        if has_unit
        else "stamp-only"
    )
    old_hash = hash_path.read_text().strip() if hash_path.exists() else None

    if old_hash == new_hash:
        return "unchanged"

    if dry_run:
        return "added" if old_hash is None else "updated"

    if has_unit:
        # Capture runtime state BEFORE we re-render so a hand-disabled
        # unit stays disabled across the re-load. _sched_state returns
        # "unknown" for a not-yet-installed unit (no platform record
        # to query); we treat unknown as "not previously disabled" so
        # a fresh install lands enabled.
        prior_disabled = (
            old_hash is not None
            and _sched_state(full_name, platform) == "disabled"
        )
        units = _render_units(full_name, schedule, interval, platform)
        target_dir = (
            LAUNCHAGENTS_DIR if platform == "darwin" else SYSTEMD_USER_DIR
        )
        target_dir.mkdir(parents=True, exist_ok=True)
        for fname, content in units.items():
            (target_dir / fname).write_text(content, encoding="utf-8")
        _activate_unit(full_name, platform, prior_disabled=prior_disabled)

    hash_path.parent.mkdir(parents=True, exist_ok=True)
    hash_path.write_text(new_hash + "\n", encoding="utf-8")
    return "added" if old_hash is None else "updated"


def destroy_one(name: str, *, purge_state: bool = False) -> None:
    """Remove a single name's platform unit, hash stamp, and (if
    --purge-state) state directory. Errok throughout so a partially-
    installed unit can still be cleaned up.
    """
    platform = current_platform()
    _deactivate_unit(name, platform)
    if platform == "darwin":
        _plist_path_for(name).unlink(missing_ok=True)
    else:
        _service_path_for(name).unlink(missing_ok=True)
        _timer_path_for(name).unlink(missing_ok=True)
    _hash_path_for(name).unlink(missing_ok=True)
    if purge_state:
        sd = STATE_DIR / name
        if sd.exists():
            shutil.rmtree(sd)


def stamped_names() -> set[str]:
    """Names with a hash stamp on this host (i.e., crony installed them)."""
    inst = STATE_DIR / "installed"
    if not inst.exists():
        return set()
    return {p.stem for p in inst.glob("*.hash")}


# =============================================================================
# RUNTIME STATE (enable / disable / status / linger)
# =============================================================================
# Runtime state is the platform scheduler's "will I fire this unit?"
# answer. It's orthogonal to CONFIG state: a unit can be `synced` with
# config but `disabled` at runtime because the user paused it. apply
# preserves this state across re-renders so a hand-disabled job stays
# off when the user runs `crony apply` to push other changes.


def _current_user() -> str:
    """Best-effort resolution of the invoking user's name.

    Used for linger lookup. Falls back through env vars and getpwuid
    in turn so the typical Unix shell environment is enough.
    """
    for env_key in ("USER", "LOGNAME"):
        v = os.environ.get(env_key)
        if v:
            return v
    try:
        import pwd

        return pwd.getpwuid(os.getuid()).pw_name
    except (ImportError, KeyError):
        return ""


def linger_enabled(user: str | None = None) -> bool | None:
    """Return True/False/None for "is linger enabled for this user?"

    Linger keeps a user's systemd manager running across logouts, which
    is what allows scheduled timers to fire when the user isn't logged
    in. Without it, a "daily 03:00" job silently no-ops.

    Order of operations: check the world-readable sentinel file first
    so the common case is a single stat() with no subprocess. Fall
    back to `loginctl show-user --property=Linger` for systems that
    expose linger differently. Returns None when neither path can
    answer (no logind, command missing, etc.).
    """
    name = user or _current_user()
    if not name:
        return None
    sentinel = Path(f"/var/lib/systemd/linger/{name}")
    if sentinel.exists():
        return True
    try:
        result = subprocess.run(
            [
                "loginctl",
                "show-user",
                name,
                "--property=Linger",
            ],
            capture_output=True,
            text=True,
            timeout=5,
        )
    except (FileNotFoundError, subprocess.TimeoutExpired):
        return None
    if result.returncode != 0:
        return None
    line = result.stdout.strip()
    if line.endswith("=yes"):
        return True
    if line.endswith("=no"):
        return False
    return None


def _systemd_is_enabled(unit: str) -> str:
    """Return systemctl --user is-enabled output, or '' on failure."""
    try:
        r = subprocess.run(
            ["systemctl", "--user", "is-enabled", unit],
            capture_output=True,
            text=True,
            timeout=5,
        )
    except (FileNotFoundError, subprocess.TimeoutExpired):
        return ""
    return r.stdout.strip()


def _launchctl_print_disabled() -> str:
    """Stdout of `launchctl print-disabled gui/<uid>`; empty on failure."""
    try:
        r = subprocess.run(
            ["launchctl", "print-disabled", f"gui/{os.getuid()}"],
            capture_output=True,
            text=True,
            timeout=5,
        )
    except (FileNotFoundError, subprocess.TimeoutExpired):
        return ""
    return r.stdout


def _launchctl_list() -> str:
    """Stdout of `launchctl list`; empty on failure."""
    try:
        r = subprocess.run(
            ["launchctl", "list"],
            capture_output=True,
            text=True,
            timeout=5,
        )
    except (FileNotFoundError, subprocess.TimeoutExpired):
        return ""
    return r.stdout


def _sched_state(name: str, platform: str) -> str:
    """Return SCHED axis value for a stamped entity.

    Distinct from CONFIG: a unit can be configured-and-stamped while
    being disabled at the platform scheduler. Group-only jobs (no
    schedule, no interval) report `grouped`; their callers fire them
    via subprocess invocation rather than the scheduler.
    """
    if platform == "linux":
        unit = _systemd_unit_name(name)
        state = _systemd_is_enabled(unit)
        if state == "enabled":
            return "enabled"
        if state in ("disabled", "masked"):
            return "disabled"
        if state == "static":
            return "enabled"
        if state == "":
            return "unknown"
        return "unknown"
    # darwin
    label = _label_for(name)
    if _is_launchd_disabled(label):
        return "disabled"
    if _is_launchd_loaded(label):
        return "enabled"
    return "unknown"


def _is_launchd_disabled(label: str) -> bool:
    """True if `launchctl print-disabled` reports `label` disabled."""
    out = _launchctl_print_disabled()
    return f'"{label}" => disabled' in out or f'"{label}" => true' in out


def _is_launchd_loaded(label: str) -> bool:
    """True if `launchctl list` shows the label as loaded.

    `launchctl list` lines have the form `<pid>\\t<exit>\\t<label>`.
    A pid of `-` means loaded-but-idle (the normal between-fires state
    for a calendar-scheduled agent), so we don't filter on pid here.
    Trailing whitespace is tolerated for forward-compat with future
    launchctl output formats.
    """
    out = _launchctl_list()
    for raw in out.splitlines():
        line = raw.rstrip()
        if "\t" in line and line.split("\t")[-1] == label:
            return True
    return False


def _last_run_state(name: str) -> str:
    """Return LAST axis value for a stamped entity.

    Lock-held implies a run is currently in flight; otherwise read
    last-run.json's recorded exit_class. Absence of either means the
    entity has never run -- new install, group-only job that's never
    been triggered, etc.
    """
    sd = STATE_DIR / name
    lock_path = sd / "run.lock"
    if lock_path.exists():
        try:
            with _acquire_lock(lock_path):
                pass
        except LockBusyError:
            return "running"
    last_run = sd / "last-run.json"
    if not last_run.exists():
        return "never"
    try:
        raw = json.loads(last_run.read_text(encoding="utf-8"))
    except (OSError, json.JSONDecodeError):
        return "unknown"
    cls = raw.get("exit_class")
    if cls in ("ok", "fail", "timeout", "gated", "signal"):
        return cls if cls != "signal" else "fail"
    return "unknown"


def _config_state(
    config: Config,
    name: str,
    platform: str,
    *,
    bundle_name: str = DEFAULT_BUNDLE_NAME,
) -> str:
    """Default-bundle-flavored wrapper around _config_state_for.

    `name` is the short name; the full namespaced name is computed
    as `<bundle_name>.<name>` (default bundle by default).
    """
    return _config_state_for(config, name, f"{bundle_name}.{name}", platform)


def _config_state_for(
    config: Config, short: str, full_name: str, platform: str
) -> str:
    """Return CONFIG axis value: synced / stale / missing / orphan.

    `short` is the bundle-local name (used to look up the entry in
    `config`); `full_name` is the namespaced name used for the
    on-disk hash stamp and unit identifier.
    """
    in_config = short in config.jobs or short in config.job_groups
    has_stamp = _hash_path_for(full_name).exists()
    if not in_config and has_stamp:
        return "orphan"
    if in_config and not has_stamp:
        return "missing"
    if not in_config and not has_stamp:
        return "missing"
    entry: Job | JobGroup = config.jobs.get(short) or config.job_groups[short]
    schedule, interval = _entity_schedule(entry)
    has_unit = schedule is not None or interval is not None
    new_hash = (
        _compute_unit_hash(full_name, entry, platform)
        if has_unit
        else "stamp-only"
    )
    old_hash = _hash_path_for(full_name).read_text(encoding="utf-8").strip()
    return "synced" if old_hash == new_hash else "stale"


def _enable_unit(name: str, platform: str) -> None:
    """Move the platform scheduler into the `enabled` state for `name`."""
    if platform == "linux":
        subprocess.run(
            [
                "systemctl",
                "--user",
                "enable",
                "--now",
                _systemd_unit_name(name),
            ],
            check=True,
        )
        return
    label = _label_for(name)
    plist = _plist_path_for(name)
    subprocess.run(
        ["launchctl", "enable", f"gui/{os.getuid()}/{label}"],
        check=True,
    )
    # unload-then-load -- mirrors apply, tolerates a stale loaded
    # plist from before the enable.
    subprocess.run(
        ["launchctl", "unload", str(plist)],
        stderr=subprocess.DEVNULL,
    )
    subprocess.run(["launchctl", "load", str(plist)], check=True)


def _disable_unit(name: str, platform: str) -> None:
    """Move the platform scheduler into the `disabled` state for `name`."""
    if platform == "linux":
        subprocess.run(
            [
                "systemctl",
                "--user",
                "disable",
                "--now",
                _systemd_unit_name(name),
            ],
            stderr=subprocess.DEVNULL,
        )
        return
    label = _label_for(name)
    plist = _plist_path_for(name)
    # Unload first so the persistent disable record actually takes
    # effect; otherwise the still-loaded plist would keep firing
    # until the next launchd restart.
    subprocess.run(
        ["launchctl", "unload", str(plist)],
        stderr=subprocess.DEVNULL,
    )
    subprocess.run(
        ["launchctl", "disable", f"gui/{os.getuid()}/{label}"],
        check=True,
    )


# =============================================================================
# COMMAND HANDLERS
# =============================================================================
# Each handler's signature must match its argparse subparser's argument
# `dest` names exactly; the shared CmdCallbacksBase test enforces this.
# Handlers without behavior yet raise NotImplementedError so an
# unfinished feature surfaces immediately rather than silently no-oping.


def do_init(force: bool, bundle: str | None) -> None:
    """Generate a default config file.

    With `--bundle <name>`, writes `config/<name>.toml` (creating
    the dropin dir if missing). Otherwise writes `config.toml`.
    """
    if bundle is not None:
        if bundle == DEFAULT_BUNDLE_NAME:
            raise UsageError(
                f"--bundle {DEFAULT_BUNDLE_NAME!r} would shadow "
                f"config.toml; use plain `crony init` (without "
                f"--bundle) for the default bundle"
            )
        try:
            _validate_bundle_name(bundle, "--bundle")
        except ConfigError as e:
            raise UsageError(str(e)) from e
        target = CONFIG_DROPIN_DIR / f"{bundle}.toml"
        if target.exists() and not force:
            raise UsageError(
                f"{target} already exists; pass --force to overwrite"
            )
        CONFIG_DROPIN_DIR.mkdir(parents=True, exist_ok=True)
        target.write_text(_DEFAULT_CONFIG_TEMPLATE, encoding="utf-8")
        logger.info("wrote bundle config to %s", target)
        return
    if CONFIG_FILE.exists() and not force:
        raise UsageError(
            f"{CONFIG_FILE} already exists; pass --force to overwrite"
        )
    CONFIG_DIR.mkdir(parents=True, exist_ok=True)
    CONFIG_FILE.write_text(_DEFAULT_CONFIG_TEMPLATE, encoding="utf-8")
    logger.info("wrote default config to %s", CONFIG_FILE)


def _selected_full_names_per_bundle(
    bundles: Bundles,
) -> tuple[dict[str, tuple[Bundle, str]], set[str]]:
    """Return (full_name -> (bundle, short)) and full_names set,
    spanning every bundle's selection on the current host."""
    host = current_host()
    platform = current_platform()
    by_full: dict[str, tuple[Bundle, str]] = {}
    for b in bundles.bundles:
        target = resolve_target(b.config, host, platform)
        sel_jobs, sel_groups = selected_jobs_and_groups(b.config, target)
        for short in sel_jobs | sel_groups:
            by_full[b.full_name(short)] = (b, short)
    return by_full, set(by_full.keys())


def do_apply(jobs: list[str]) -> None:
    """Render and activate platform units to match config.

    No args: full sync across every bundle. Install missing, fix
    drift, remove orphans. With names: surgical update of those
    entries only -- orphans are left alone so a one-off apply
    doesn't have side effects on unrelated jobs.

    Names on the CLI are full namespaced names
    (`<bundle>.<short>`). Bare input is shorthand for
    `default.<short>` and only ever resolves to the default bundle.
    """
    bundles = load_all_bundles()
    by_full, selected = _selected_full_names_per_bundle(bundles)

    if jobs:
        # Normalize each CLI input to its full namespaced form.
        normalized: list[str] = []
        for arg in jobs:
            bn, short = parse_full_name(arg)
            normalized.append(f"{bn}.{short}")
        unknown = [n for n in normalized if n not in by_full]
        if unknown:
            raise UsageError(
                f"unknown or unselected on this host: {sorted(unknown)}"
            )
        full_names_to_apply = normalized
        remove_orphans = False
    else:
        full_names_to_apply = sorted(selected)
        remove_orphans = True

    # Pre-pass: render every selected entry so a darwin-specific
    # OnCalendar limitation (step / range / list) surfaces before we
    # touch any unit files. Without this, an apply failure leaves a
    # partial install and the user has to chase what landed.
    if current_platform() == "darwin":
        for full in full_names_to_apply:
            bundle, short = by_full[full]
            entry: Job | JobGroup = (
                bundle.config.jobs.get(short) or bundle.config.job_groups[short]
            )
            schedule, _interval = _entity_schedule(entry)
            if schedule is not None:
                _oncalendar_to_plist_calendar(schedule)

    for full in full_names_to_apply:
        bundle, short = by_full[full]
        result = apply_one(bundle.config, short, bundle_name=bundle.name)
        logger.info("apply %s: %s", full, result)

    if remove_orphans:
        orphans = stamped_names() - selected
        for orphan in sorted(orphans):
            destroy_one(orphan)
            logger.info("apply %s: orphan removed", orphan)


def do_destroy(jobs: list[str], purge_state: bool) -> None:
    """Remove platform units.

    No args: factory reset -- every crony-managed unit on this host
    (every stamped name across all bundles).

    With names: surgical removal by full namespaced name. Refuses
    if a name is in neither any bundle's config nor the stamped set;
    refuses if a name's run.lock is currently held.
    """
    if jobs:
        bundles = load_all_bundles()
        by_full, _ = _selected_full_names_per_bundle(bundles)
        # Defined names span every bundle's full names plus any
        # currently-stamped name (so an old stamp can still be
        # destroyed even after the bundle is gone).
        defined = set(by_full.keys()) | bundles.all_full_names()
        known = defined | stamped_names()
        normalized: list[str] = []
        for arg in jobs:
            bn, short = parse_full_name(arg)
            normalized.append(f"{bn}.{short}")
        unknown = [n for n in normalized if n not in known]
        if unknown:
            raise UsageError(f"unknown name(s): {sorted(unknown)}")
        full_names_to_destroy = normalized
    else:
        full_names_to_destroy = sorted(stamped_names())

    for full in full_names_to_destroy:
        # Refuse if a run is in progress; a partial destroy would
        # leave the running shim with deleted state under it.
        lock_path = STATE_DIR / full / "run.lock"
        if lock_path.exists():
            try:
                with _acquire_lock(lock_path):
                    pass
            except LockBusyError:
                raise SubprocessError(1, ["destroy", full]) from LockBusyError(
                    f"{full}: run in progress; will not destroy"
                )
        destroy_one(full, purge_state=purge_state)
        logger.info(
            "destroy %s%s", full, " --purge-state" if purge_state else ""
        )


def _refuse_stamp_only_full(
    bundles: Bundles, full_names: list[str], verb: str
) -> None:
    """Reject group-only entries that have a stamp but no platform unit."""
    stamp_only: list[str] = []
    for full in full_names:
        bn, short = parse_full_name(full)
        bundle = bundles.by_name(bn)
        if bundle is None:
            continue
        entry: Job | JobGroup | None = bundle.config.jobs.get(
            short
        ) or bundle.config.job_groups.get(short)
        if entry is None:
            continue
        sched, interval = _entity_schedule(entry)
        if sched is None and interval is None:
            stamp_only.append(full)
    if stamp_only:
        raise UsageError(
            f"cannot {verb} group-only entries (no platform unit): "
            f"{sorted(stamp_only)}"
        )


def do_enable(jobs: list[str]) -> None:
    """Move the platform scheduler into `enabled` for the named jobs.

    Names are full namespaced (`<bundle>.<short>`); bare input is
    shorthand for `default.<short>`. Refuses names not stamped on
    this host (run apply first) and group-only entries.
    """
    bundles = load_all_bundles()
    stamped = stamped_names()
    normalized = [
        f"{parse_full_name(n)[0]}.{parse_full_name(n)[1]}" for n in jobs
    ]
    unknown = [n for n in normalized if n not in stamped]
    if unknown:
        raise UsageError(
            f"not stamped on this host: {sorted(unknown)} "
            f"(run `crony apply` first)"
        )
    _refuse_stamp_only_full(bundles, normalized, "enable")
    platform = current_platform()
    for full in normalized:
        _enable_unit(full, platform)
        logger.info("enable %s", full)


def do_disable(jobs: list[str]) -> None:
    """Move the platform scheduler into `disabled` for the named jobs.

    Names are full namespaced (`<bundle>.<short>`); bare input is
    shorthand for `default.<short>`. Refuses names not stamped on
    this host (run apply first) and group-only entries.
    """
    bundles = load_all_bundles()
    stamped = stamped_names()
    normalized = [
        f"{parse_full_name(n)[0]}.{parse_full_name(n)[1]}" for n in jobs
    ]
    unknown = [n for n in normalized if n not in stamped]
    if unknown:
        raise UsageError(
            f"not stamped on this host: {sorted(unknown)} "
            f"(run `crony apply` first)"
        )
    _refuse_stamp_only_full(bundles, normalized, "disable")
    platform = current_platform()
    for full in normalized:
        _disable_unit(full, platform)
        logger.info("disable %s", full)


def do_status(jobs: list[str]) -> None:
    """Print the resolved (CONFIG, SCHED, LAST) tuple per job.

    With no args, the report covers selected jobs/groups plus any
    orphans across all bundles. Names are full namespaced
    (`<bundle>.<short>`); bare CLI input is shorthand for
    `default.<short>`. Linger status on linux surfaces above the
    table.
    """
    bundles = load_all_bundles()
    platform = current_platform()
    _by_full, selected = _selected_full_names_per_bundle(bundles)
    stamped = stamped_names()

    if platform == "linux":
        ling = linger_enabled()
        if ling is False:
            user = _current_user()
            logger.warning(
                "linger DISABLED -- jobs only fire while you have "
                "an active session. Fix: sudo loginctl enable-linger %s",
                user,
            )

    full_names: list[str]
    if jobs:
        full_names = [
            f"{parse_full_name(n)[0]}.{parse_full_name(n)[1]}" for n in jobs
        ]
    else:
        full_names = sorted(selected | stamped)

    print(f"{'JOB':30} {'CONFIG':10} {'SCHED':10} {'LAST':10}")
    for full in full_names:
        bn, short = parse_full_name(full)
        bundle = bundles.by_name(bn)
        if bundle is None:
            cfg_state = "orphan" if full in stamped else "missing"
            entry = None
        else:
            cfg_state = _config_state_for(bundle.config, short, full, platform)
            entry = bundle.config.jobs.get(
                short
            ) or bundle.config.job_groups.get(short)
        if cfg_state == "missing":
            sched = "unknown"
        else:
            schedule, interval = (
                _entity_schedule(entry) if entry is not None else (None, None)
            )
            if entry is not None and schedule is None and interval is None:
                sched = "grouped"
            else:
                sched = _sched_state(full, platform)
        last = _last_run_state(full)
        print(f"{full:30} {cfg_state:10} {sched:10} {last:10}")


def do_logs(
    name: str,
    n: int,
    since: str | None,
    tail: bool,
) -> None:
    """Print a job's recent log output.

    `name` is the full namespaced name (`<bundle>.<short>`); bare
    input is shorthand for `default.<short>`.

    -n N      print the last N lines (default 200)
    --since X parse X as a duration ('1h', '2d') or ISO timestamp
              and skip log content older than that. Run-header
              timestamps anchor the cut.
    --tail    follow appended output (-f semantics) until interrupted.
    """
    bn, short = parse_full_name(name)
    full = f"{bn}.{short}"
    log_path = STATE_DIR / full / "run.log"
    if not log_path.exists():
        raise UsageError(f"no log for {full!r} (state dir: {STATE_DIR / full})")
    if tail:
        _follow_log(log_path)
        return
    text = log_path.read_text(encoding="utf-8", errors="replace")
    if since is not None:
        text = _filter_since(text, since)
    if n > 0:
        lines = text.splitlines()
        if len(lines) > n:
            text = "\n".join(lines[-n:]) + "\n"
    sys.stdout.write(text)
    sys.stdout.flush()


def _follow_log(log_path: Path) -> None:
    """tail -f equivalent on the log file."""
    with open(log_path, encoding="utf-8", errors="replace") as f:
        f.seek(0, os.SEEK_END)
        while True:
            line = f.readline()
            if not line:
                time.sleep(0.5)
                continue
            try:
                sys.stdout.write(line)
                sys.stdout.flush()
            except BrokenPipeError:
                return


_DURATION_RE = re.compile(r"^(\d+)([smhd])$")


def _parse_since(spec: str) -> datetime.datetime:
    """Parse a --since argument as duration shorthand or ISO timestamp.

    Returns a tz-aware datetime. ISO inputs without an offset are
    rejected here -- comparing them against the runner's tz-aware
    run-header timestamps would raise TypeError mid-filter, so we
    surface the issue at parse time as a UsageError instead.
    """
    text = spec.strip()
    m = _DURATION_RE.fullmatch(text)
    if m:
        n = int(m.group(1))
        unit = m.group(2)
        delta = datetime.timedelta(
            seconds=n * {"s": 1, "m": 60, "h": 3600, "d": 86400}[unit]
        )
        return datetime.datetime.now(datetime.timezone.utc).astimezone() - delta
    try:
        ts = datetime.datetime.fromisoformat(text)
    except ValueError as e:
        raise UsageError(
            f"unparseable --since value: {spec!r} "
            f"(use NUMs/m/h/d or ISO timestamp)"
        ) from e
    if ts.tzinfo is None:
        raise UsageError(
            f"--since {spec!r} is missing a timezone offset; "
            f"use a form like 2026-04-01T12:00:00-07:00"
        )
    return ts


def _filter_since(text: str, since: str) -> str:
    """Drop log content older than --since by run-header timestamp."""
    cutoff = _parse_since(since)
    header_re = re.compile(r"^=== (\S+) ")
    keep_from: int | None = None
    lines = text.splitlines(keepends=True)
    for idx, line in enumerate(lines):
        m = header_re.match(line)
        if not m:
            continue
        try:
            ts = datetime.datetime.fromisoformat(m.group(1))
        except ValueError:
            continue
        if ts >= cutoff:
            keep_from = idx
            break
    if keep_from is None:
        return ""
    return "".join(lines[keep_from:])


def do_run(name: str, dry_run: bool, skip_gate: bool) -> None:
    """Runner shim. Platform schedulers invoke this.

    `name` is the full namespaced name (`<bundle>.<short>`); bare
    input is shorthand for `default.<short>`. Resolves whether the
    short name is a job or a job-group within the named bundle and
    dispatches to the appropriate pipeline. The wrapped command's
    exit code is surfaced via SystemExit so it propagates to
    launchd/systemd; cli() converts that into the process exit.
    """
    bn, short = parse_full_name(name)
    bundles = load_all_bundles()
    bundle = bundles.by_name(bn)
    if bundle is None:
        raise UsageError(f"unknown bundle: {bn!r} (in {name!r})")
    config = bundle.config
    if short in config.jobs and short in config.job_groups:
        # Validate already rejects collisions, but be defensive.
        raise ConfigError(f"name {short!r} is both a job and a group")
    if short in config.jobs:
        rc = run_job(
            config,
            short,
            dry_run=dry_run,
            skip_gate=skip_gate,
            bundle_name=bundle.name,
        )
    elif short in config.job_groups:
        rc = run_group(
            config,
            short,
            dry_run=dry_run,
            skip_gate=skip_gate,
            bundle_name=bundle.name,
        )
    else:
        raise UsageError(f"unknown job or group: {name!r}")
    raise SystemExit(rc)


def do_audit(exclude_disabled: bool, bundle: str | None) -> None:
    """Walk every job; print bad rows; exit AUDIT_FAILED on hits.

    With no --bundle, iterates every bundle's selection plus every
    orphan stamp on disk, and reports linger status. With --bundle
    <name>, scopes to that bundle's selected jobs and orphan stamps
    in that bundle's namespace (so a leftover `<name>.gone.hash` is
    still surfaced); cross-host checks like linger are skipped --
    they're about the whole-host picture, not any one bundle.

    Bad means CONFIG drift (stale/missing/orphan), the scheduler
    being unable to fire (failed/unknown, plus disabled by default),
    or a recent failed/timeout run. Names in output are full
    namespaced (`<bundle>.<short>`).
    """
    bundles = load_all_bundles()
    if bundle is not None and bundles.by_name(bundle) is None:
        raise UsageError(f"unknown bundle: {bundle!r}")
    platform = current_platform()
    _by_full, selected = _selected_full_names_per_bundle(bundles)
    stamped = stamped_names()
    if bundle is not None:
        prefix = f"{bundle}."
        selected = {n for n in selected if n.startswith(prefix)}
        scoped_stamped = {n for n in stamped if n.startswith(prefix)}
        candidates = sorted(selected | scoped_stamped)
    else:
        candidates = sorted(selected | stamped)

    bad_config = {"stale", "missing", "orphan"}
    bad_sched = {"failed", "unknown"}
    if not exclude_disabled:
        bad_sched = bad_sched | {"disabled"}
    bad_last = {"fail", "timeout"}

    rows: list[tuple[str, str, str, str]] = []
    for full in candidates:
        bn, short = parse_full_name(full)
        b = bundles.by_name(bn)
        if b is None:
            cfg_state = "orphan" if full in stamped else "missing"
            entry: Job | JobGroup | None = None
        else:
            cfg_state = _config_state_for(b.config, short, full, platform)
            entry = b.config.jobs.get(short) or b.config.job_groups.get(short)
        if cfg_state == "missing":
            sched_state = "unknown"
        else:
            if entry is None:
                sched_state = _sched_state(full, platform)
            else:
                schedule, interval = _entity_schedule(entry)
                if schedule is None and interval is None:
                    sched_state = "grouped"
                else:
                    sched_state = _sched_state(full, platform)
        last_state = _last_run_state(full)
        is_bad = (
            cfg_state in bad_config
            or sched_state in bad_sched
            or last_state in bad_last
        )
        if is_bad:
            rows.append((full, cfg_state, sched_state, last_state))

    warnings: list[str] = []
    # Linger is host-wide -- skip it under --bundle scoping; the
    # operator who needs that info runs without --bundle.
    if bundle is None and platform == "linux":
        ling = linger_enabled()
        if ling is False:
            warnings.append(
                f"linger DISABLED for {_current_user()} "
                "-- jobs only fire while logged in"
            )

    if not rows and not warnings:
        print("audit: all jobs nominal")
        return

    if warnings:
        print("warnings:")
        for w in warnings:
            print(f"  - {w}")
        print()
    if rows:
        print(f"{'JOB':30} {'CONFIG':10} {'SCHED':10} {'LAST':10}")
        for name, cs, ss, ls in rows:
            print(f"{name:30} {cs:10} {ss:10} {ls:10}")

    raise AuditFailedError(
        f"{len(rows)} job(s) in bad state, {len(warnings)} system warning(s)"
    )


def _secret_warning(
    label: str,
    *,
    keychain_service: str | None,
    keychain_account: str | None,
    file_path: str | None,
) -> str:
    """Build a precise validate warning for an unresolved secret.

    Distinguishes "no source configured" from "configured source(s)
    resolved empty" so a misconfigured keychain item or missing file
    isn't misreported as "you forgot to set anything".
    """
    if keychain_service is None and file_path is None:
        return (
            f"{label} unresolved: no source configured (set keychain or file)"
        )
    parts: list[str] = []
    if keychain_service is not None:
        ident = (
            f"{keychain_service!r}/{keychain_account!r}"
            if keychain_account is not None
            else f"{keychain_service!r}"
        )
        parts.append(f"keychain item {ident}")
    if file_path is not None:
        parts.append(f"file {file_path!r}")
    return f"{label} unresolved: tried {' and '.join(parts)}"


def _validate_bundle_warnings(
    bundle: Bundle,
) -> list[str]:
    """Return per-bundle warnings: notify channels listed without
    config blocks, secret paths that don't resolve, etc."""
    warnings: list[str] = []
    config = bundle.config
    listed_channels: set[str] = set(config.defaults.notify_channels)
    for j in config.jobs.values():
        if j.notify_channels is not None:
            listed_channels.update(j.notify_channels)
    for t in list(config.platform_targets.values()) + list(
        config.host_targets.values()
    ):
        if t.notify_channels is not None:
            listed_channels.update(t.notify_channels)

    if "email" in listed_channels:
        if config.defaults.notify_email is None:
            warnings.append(
                "email channel listed but [defaults.notify.email] "
                "is not configured"
            )
        else:
            em = config.defaults.notify_email
            try:
                secret = _retrieve_secret(
                    keychain_service=em.smtp_pass_keychain_service,
                    keychain_account=em.smtp_pass_keychain_account,
                    file_path=em.smtp_pass_file,
                )
                if secret is None:
                    warnings.append(
                        _secret_warning(
                            "email channel: SMTP password",
                            keychain_service=em.smtp_pass_keychain_service,
                            keychain_account=em.smtp_pass_keychain_account,
                            file_path=em.smtp_pass_file,
                        )
                    )
            except PreconditionError as e:
                warnings.append(str(e))
    if "ntfy" in listed_channels:
        if config.defaults.notify_ntfy is None:
            warnings.append(
                "ntfy channel listed but [defaults.notify.ntfy] "
                "is not configured"
            )
        else:
            nt = config.defaults.notify_ntfy
            try:
                token = _retrieve_secret(
                    keychain_service=nt.token_keychain_service,
                    keychain_account=nt.token_keychain_account,
                    file_path=nt.token_file,
                )
                if token is None:
                    warnings.append(
                        _secret_warning(
                            "ntfy channel: token",
                            keychain_service=nt.token_keychain_service,
                            keychain_account=nt.token_keychain_account,
                            file_path=nt.token_file,
                        )
                    )
            except PreconditionError as e:
                warnings.append(str(e))

    if not config.jobs and not config.job_groups:
        warnings.append(
            "bundle defines no jobs or groups (nothing it contains can fire)"
        )
    return warnings


def do_validate(bundle: str | None) -> None:
    """Lint configs; report orphans, linger status, broken secret files.

    load_all_bundles already enforces per-bundle structural rules and
    isolates failed bundles. This subcommand surfaces orphan / linger
    / per-bundle warnings as informational output and exits WARNING
    (1) when any are present, CONFIG (3) when no bundles load.

    With --bundle <name>, restricts the per-bundle warnings to just
    that bundle. Cross-bundle / cross-host checks (orphan detection,
    linger status) only run in the unfiltered case -- they're about
    the whole-host picture, not any one bundle.
    """
    bundles = load_all_bundles()
    if bundle is not None and bundles.by_name(bundle) is None:
        raise UsageError(f"unknown bundle: {bundle!r}")
    platform = current_platform()

    warnings: list[str] = []
    if bundle is None:
        _by_full, selected = _selected_full_names_per_bundle(bundles)
        stamped = stamped_names()
        orphans = sorted(stamped - selected)
        if orphans:
            warnings.append(f"orphans on this host: {orphans}")
        if platform == "linux":
            ling = linger_enabled()
            if ling is False:
                warnings.append(f"linger DISABLED for {_current_user()}")
            elif ling is None:
                warnings.append("linger status unknown")

    target_bundles = (
        [b for b in bundles.bundles if b.name == bundle]
        if bundle is not None
        else list(bundles.bundles)
    )
    for b in target_bundles:
        for w in _validate_bundle_warnings(b):
            warnings.append(f"{b.source}: {w}")

    print(f"bundles loaded: {len(target_bundles)}")
    for b in target_bundles:
        config = b.config
        print(
            f"  {b.name} ({b.source}): "
            f"jobs={len(config.jobs)}, groups={len(config.job_groups)}, "
            f"targets: platform={len(config.platform_targets)} "
            f"host={len(config.host_targets)}"
        )
    if warnings:
        print("warnings:")
        for w in warnings:
            print(f"  - {w}")
        # WARNING is not raisable as a CronyError; SystemExit forwards
        # the code through cli() unchanged.
        raise SystemExit(int(ExitCode.WARNING))
    print("ok")


def _notify_test_one_bundle(
    bundle: Bundle, channel: str | None
) -> tuple[list[str], list[tuple[str, NotificationResult]]]:
    """Run notify-test against one bundle. Returns (successes, failures)."""
    config = bundle.config
    if channel is not None:
        use_channels = [channel]
    else:
        synthetic_job = Job(name="notify-test", command="true")
        target = resolve_target(config, current_host(), current_platform())
        use_channels = resolved_notify_channels(config, target, synthetic_job)
    if not use_channels:
        return ([], [])
    result = JobRunResult(
        job=f"{bundle.name}.notify-test",
        host=current_host(),
        platform=current_platform(),
        started_at=_now_iso(),
        ended_at=_now_iso(),
        duration_sec=0.0,
        exit_class="fail",
        exit_code=1,
        signal=None,
        gate="none",
        log_path="(synthetic)",
        log_bytes_this_run=0,
        notifications={
            ch: NotificationResult(sent=False) for ch in use_channels
        },
    )
    log_text = (
        f"synthetic test message from `crony notify-test` "
        f"(bundle: {bundle.name}).\n"
        "if you can read this, the channel is working end-to-end.\n"
    )
    _dispatch_notify(result, log_text, config.defaults)
    successes = [ch for ch, nr in result.notifications.items() if nr.sent]
    failures = [
        (ch, nr) for ch, nr in result.notifications.items() if not nr.sent
    ]
    return (successes, failures)


def do_notify_test(channel: str | None, bundle: str | None) -> None:
    """Send a synthetic failure notification.

    Bundle / channel resolution follows crony's bare-input rule: when
    nothing is specified, only the default bundle is exercised (never
    a fan-out across every bundle).

    --bundle <name>      send only through that bundle's configured
                         channels.
    --channel <ch>       a bare channel name resolves against the
                         selected bundle (default if --bundle is
                         absent).
    --channel <bn>.<ch>  fully qualified; the bundle prefix wins,
                         and is required to match --bundle when both
                         are given.

    Verifies plumbing end-to-end without scheduling a real job. The
    exit code reflects whether every per-channel send succeeded: any
    per-channel failure surfaces as CONFIG (config-shaped) or ERROR
    (transport-shaped), preserving the original failure category.
    """
    bundles = load_all_bundles()

    # Resolve --channel into (bundle_from_channel, channel_or_None).
    channel_bundle: str | None = None
    channel_short: str | None = None
    if channel is not None:
        if "." in channel:
            channel_bundle, channel_short = parse_full_name(channel)
        else:
            channel_short = channel

    # Compose --bundle and --channel's bundle prefix.
    if channel_bundle is not None and bundle is not None:
        if channel_bundle != bundle:
            raise UsageError(
                f"--bundle {bundle!r} contradicts --channel "
                f"{channel!r} (bundle {channel_bundle!r}); pick one"
            )
    bundle_name = channel_bundle or bundle or DEFAULT_BUNDLE_NAME
    target_bundle = bundles.by_name(bundle_name)
    if target_bundle is None:
        raise UsageError(f"unknown bundle: {bundle_name!r}")

    successes, failures = _notify_test_one_bundle(target_bundle, channel_short)
    for ch in successes:
        logger.info("notification sent via %s.%s", target_bundle.name, ch)
    if not successes and not failures:
        logger.info("no notify channels configured; nothing to send")
        return
    if not failures:
        return
    all_failures: list[tuple[str, str, NotificationResult]] = [
        (target_bundle.name, ch, nr) for ch, nr in failures
    ]
    # Preserve the failure category: if every failure is config-shaped
    # surface CONFIG (3); otherwise ERROR (4). A mix of config and
    # transport failures gets ERROR -- the configurational issues
    # would block transport anyway.
    all_config = all(
        nr.error_class == "ConfigError" for _, _, nr in all_failures
    )
    detail = "; ".join(f"{bn}.{ch}: {nr.error}" for bn, ch, nr in all_failures)
    if all_config:
        raise ConfigError(f"notify-test failed: {detail}")
    raise CronyError(f"notify-test failed: {detail}")


def do_list(bundle: str | None) -> None:
    """One-line summary per defined job/group.

    With no --bundle, lists every bundle's contents. With --bundle
    <name>, restricts the table to that one bundle. Names are full
    namespaced (`<bundle>.<short>`).
    """
    bundles = load_all_bundles()
    if bundle is not None and bundles.by_name(bundle) is None:
        raise UsageError(f"unknown bundle: {bundle!r}")
    platform = current_platform()
    target_bundles = (
        [b for b in bundles.bundles if b.name == bundle]
        if bundle is not None
        else list(bundles.bundles)
    )
    print(f"{'NAME':40} {'KIND':6} {'SCHEDULE':22} {'SELECTED':8}")
    rows: list[tuple[str, str, str, str]] = []
    for b in target_bundles:
        target = resolve_target(b.config, current_host(), platform)
        sel_jobs, sel_groups = selected_jobs_and_groups(b.config, target)
        selected = sel_jobs | sel_groups
        for short in sorted(set(b.config.jobs) | set(b.config.job_groups)):
            full = b.full_name(short)
            kind = "group" if short in b.config.job_groups else "job"
            entry: Job | JobGroup = (
                b.config.jobs.get(short) or b.config.job_groups[short]
            )
            sched_disp = entry.schedule or (
                f"interval={entry.interval}"
                if entry.interval
                else "(group-only)"
            )
            is_selected = "yes" if short in selected else "no"
            rows.append((full, kind, sched_disp, is_selected))
    for full, kind, sched_disp, is_selected in sorted(rows):
        print(f"{full:40} {kind:6} {sched_disp:22} {is_selected:8}")


def do_self_test(*, verbose: bool = False, coverage: bool = False) -> int:
    """Run tests by invoking the test file directly."""
    repo_root = Path(__file__).parent.parent
    test_file = repo_root / "tests" / "test_crony.py"
    cmd = [str(test_file)]
    if verbose:
        cmd.append("--verbose")
    if coverage:
        cmd.append("--coverage")
    return subprocess.run(cmd, cwd=repo_root).returncode


# =============================================================================
# ARGUMENT PARSER
# =============================================================================


def build_parser() -> argparse.ArgumentParser:
    """Build and return the argument parser."""
    parser = argparse.ArgumentParser(
        description=(
            "User-level scheduled-job manager for macOS "
            "(launchd LaunchAgents) and Linux (systemd user timers)."
        ),
        epilog=f"{ExitCode.epilog()}\n\n{_CRONY_DESIGN}",
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )
    subparsers = parser.add_subparsers(dest="command", help="Subcommands")

    # init
    p_init = subparsers.add_parser(
        "init", help="Generate a default config file"
    )
    p_init.add_argument(
        "--force",
        action="store_true",
        help="Overwrite an existing config file",
    )
    p_init.add_argument(
        "--bundle",
        default=None,
        help=(
            "Write to config/<bundle>.toml instead of config.toml "
            "(creates the dropin dir if missing)"
        ),
    )

    # apply
    p_apply = subparsers.add_parser(
        "apply",
        help="Render and activate platform units to match config",
    )
    p_apply.add_argument(
        "jobs",
        nargs="*",
        help=(
            "Job/group names. With no args: full sync (install "
            "missing, fix drift, remove orphans). With names: "
            "surgical update of those entries only."
        ),
    )

    # destroy
    p_destroy = subparsers.add_parser(
        "destroy",
        help="Remove platform units",
    )
    p_destroy.add_argument(
        "jobs",
        nargs="*",
        help=(
            "Job/group names. With no args: factory reset. "
            "With names: surgical removal."
        ),
    )
    p_destroy.add_argument(
        "--purge-state",
        action="store_true",
        help="Also delete log/state dirs for affected jobs",
    )

    # enable
    p_enable = subparsers.add_parser(
        "enable",
        help="Tell the platform scheduler to fire the named jobs",
    )
    p_enable.add_argument(
        "jobs",
        nargs="+",
        help="Job names to enable",
    )

    # disable
    p_disable = subparsers.add_parser(
        "disable",
        help="Tell the platform scheduler to skip the named jobs",
    )
    p_disable.add_argument(
        "jobs",
        nargs="+",
        help="Job names to disable",
    )

    # status
    p_status = subparsers.add_parser(
        "status",
        help="Print resolved state per job",
    )
    p_status.add_argument(
        "jobs",
        nargs="*",
        help="Restrict to these jobs (default: all)",
    )

    # logs
    p_logs = subparsers.add_parser(
        "logs",
        help="Print a job's recent log output",
    )
    p_logs.add_argument(
        "name",
        help="Job name",
    )
    p_logs.add_argument(
        "-n",
        type=int,
        default=200,
        help="Print the last N lines (default 200)",
    )
    p_logs.add_argument(
        "--since",
        default=None,
        help='"1h", "2d", or ISO timestamp',
    )
    p_logs.add_argument(
        "--tail",
        action="store_true",
        help="Follow appended output",
    )

    # run
    p_run = subparsers.add_parser(
        "run",
        help="Runner shim (invoked by platform schedulers)",
    )
    p_run.add_argument(
        "name",
        help="Job or group name",
    )
    p_run.add_argument(
        "--dry-run",
        action="store_true",
        help="Acquire lock, run gate, but do not exec",
    )
    p_run.add_argument(
        "--skip-gate",
        action="store_true",
        help="Skip gate check (force run)",
    )

    # audit
    p_audit = subparsers.add_parser(
        "audit",
        help="Check every job; exit nonzero on any bad state",
    )
    p_audit.add_argument(
        "--exclude-disabled",
        action="store_true",
        help="Do not flag intentionally-disabled jobs as bad",
    )
    p_audit.add_argument(
        "--bundle",
        default=None,
        help="Restrict audit to jobs from one bundle",
    )

    # validate
    p_validate = subparsers.add_parser(
        "validate",
        help="Lint config; report orphans, linger, etc",
    )
    p_validate.add_argument(
        "--bundle",
        default=None,
        help=(
            "Restrict per-bundle warnings to one bundle. "
            "Cross-host checks (orphans, linger) are skipped in "
            "this mode -- run without --bundle for those."
        ),
    )

    # notify-test
    p_nt = subparsers.add_parser(
        "notify-test",
        help="Send a synthetic failure notification",
    )
    p_nt.add_argument(
        "--channel",
        default=None,
        help=(
            "Send through one specific channel. Bare name "
            "(`ntfy`) resolves against the selected bundle; "
            "fully qualified `<bundle>.<channel>` overrides --bundle."
        ),
    )
    p_nt.add_argument(
        "--bundle",
        default=None,
        help=(
            "Send through this bundle's notify config "
            "(default: the `default` bundle)"
        ),
    )

    # list
    p_list = subparsers.add_parser(
        "list",
        help="One-line summary per job",
    )
    p_list.add_argument(
        "--bundle",
        default=None,
        help="Restrict listing to one bundle",
    )

    # self-test
    p_st = subparsers.add_parser(
        "self-test",
        help="Run the bundled pytest suite",
    )
    p_st.add_argument(
        "-v",
        "--verbose",
        action="store_true",
        help="Verbose test output",
    )
    p_st.add_argument(
        "--coverage",
        action="store_true",
        help="Run with coverage report",
    )

    return parser


# =============================================================================
# COMMAND DISPATCH
# =============================================================================

COMMAND_CALLBACKS: dict[str, Callable[..., None]] = {
    "init": do_init,
    "apply": do_apply,
    "destroy": do_destroy,
    "enable": do_enable,
    "disable": do_disable,
    "status": do_status,
    "logs": do_logs,
    "run": do_run,
    "audit": do_audit,
    "validate": do_validate,
    "notify-test": do_notify_test,
    "list": do_list,
}


def cli() -> int:
    """CLI entry point with exception handling."""
    parser = build_parser()
    args = parser.parse_args()

    args_dict = vars(args)
    command = args_dict.pop("command")

    if not command:
        parser.print_help()
        return ExitCode.USAGE

    if command == "self-test":
        return do_self_test(
            verbose=args_dict.pop("verbose"),
            coverage=args_dict.pop("coverage"),
        )

    try:
        COMMAND_CALLBACKS[command](**args_dict)
    except SystemExit as e:
        # `crony run` raises SystemExit(<wrapped-rc>) so an
        # arbitrary exit code from the executed job (0-255) reaches
        # the platform scheduler unmodified rather than being
        # squashed to ExitCode.SUCCESS.
        if isinstance(e.code, int):
            return e.code
        return ExitCode.SUCCESS if e.code is None else ExitCode.ERROR
    except KeyError:
        raise UsageError(f"Unknown command '{command}'")
    except CronyError as e:
        logger.error("ERROR: %s", e)
        return e.exit_code
    except Exception:
        # Catch-all so an internal bug surfaces a traceback to the
        # user with a stable exit code rather than crashing the
        # process and leaving the scheduler with no exit code at all.
        traceback.print_exc()
        return ExitCode.ERROR
    return ExitCode.SUCCESS


if __name__ == "__main__":
    raise SystemExit(cli())
