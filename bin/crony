@dataclass
class NotifyEmail:
    """SMTP notification settings (used by the embedded SMTP channel)."""

    to: str
    smtp_host: str
    smtp_port: int
    smtp_user: str
    from_addr: str | None = None
    smtp_starttls: bool = True
    smtp_pass_keychain_service: str | None = None
    smtp_pass_keychain_account: str | None = None
    smtp_pass_file: str | None = None


@dataclass
class NotifyNtfy:
    """ntfy notification settings."""

    url: str
    token_keychain_service: str | None = None
    token_keychain_account: str | None = None
    token_file: str | None = None


@dataclass
class Defaults:
    """Tool-wide default settings cascaded to jobs."""

    # Empty list = no external dispatch (log + last-run.json are
    # always written regardless). On non-empty, every listed channel
    # fires per failure; per-channel results are recorded
    # independently in last-run.json's `notifications` dict.
    notify_channels: list[str] = field(default_factory=list)
    notify_attach_log: bool = True
    notify_attach_max_kb: int = 256
    timeout_sec: int = 1800
    log_keep_runs: int = 30
    notify_email: NotifyEmail | None = None
    notify_ntfy: NotifyNtfy | None = None


@dataclass
class Job:
    """A single schedulable unit of work."""

    name: str
    command: str | None = None
    script: str | None = None
    args: list[str] = field(default_factory=list)
    gate: str | None = None
    gate_script: str | None = None
    gate_args: list[str] = field(default_factory=list)
    schedule: str | None = None
    interval: str | None = None
    platforms: list[str] = field(default_factory=list)
    timeout_sec: int | None = None
    # None = inherit from target/defaults; [] = explicit empty (this
    # job sends no external notifications even if defaults / target
    # would).
    notify_channels: list[str] | None = None
    env: dict[str, str] = field(default_factory=dict)


@dataclass
class JobGroup:
    """A scheduled sequencer that fires named jobs in order.

    Groups don't carry notify settings: children run as fresh
    subprocesses via `crony run <child>` and resolve their own
    notify_channels through the target / job / defaults cascade. To
    apply a notify channel to all members of a group, set it at the
    target level (typical case) or per-job.
    """

    name: str
    jobs: list[str] = field(default_factory=list)
    schedule: str | None = None
    interval: str | None = None
    timeout_sec: int | None = None


@dataclass
class Target:
    """Per-platform or per-host selection of jobs/groups + cascading settings.

    `kind` is "platform" (e.g. darwin/linux) or "host" (a specific host).
    """

    name: str
    kind: str
    jobs: list[str] = field(default_factory=list)
    # None = inherit from job/defaults; [] = explicit empty.
    notify_channels: list[str] | None = None
    timeout_sec: int | None = None


@dataclass
class NotificationResult:
    """One channel's outcome inside a JobRunResult.notifications entry."""

    sent: bool
    error: str | None = None
    error_class: str | None = None


@dataclass
class Config:
    """Top-level parsed config (one bundle's content)."""

    defaults: Defaults = field(default_factory=Defaults)
    jobs: dict[str, Job] = field(default_factory=dict)
    job_groups: dict[str, JobGroup] = field(default_factory=dict)
    platform_targets: dict[str, Target] = field(default_factory=dict)
    host_targets: dict[str, Target] = field(default_factory=dict)


@dataclass
class Bundle:
    """One config file's contribution: a bundle name + parsed Config.

    The bundle name namespaces the bundle's job and group names: a
    short name `daily-update` defined in bundle `borgadm` has the
    full name `borgadm.daily-update` everywhere on disk
    (state dir, hash stamp, launchd label, systemd unit).
    """

    name: str
    source: Path
    config: Config

    def full_name(self, short: str) -> str:
        return f"{self.name}.{short}"


@dataclass
class Bundles:
    """All loaded bundles, keyed by bundle name. Order is the load
    order (config.toml first, then config/*.toml lex-sorted)."""

    bundles: list[Bundle] = field(default_factory=list)

    def by_name(self, bundle_name: str) -> Bundle | None:
        for b in self.bundles:
            if b.name == bundle_name:
                return b
        return None

    def find_for_short(self, bundle_name: str, short: str) -> Bundle | None:
        """Return the bundle defining `<bundle_name>.<short>` (job or
        group), or None if no such name exists in that bundle."""
        b = self.by_name(bundle_name)
        if b is None:
            return None
        if short in b.config.jobs or short in b.config.job_groups:
            return b
        return None

    def all_full_names(self) -> set[str]:
        """Return every defined `<bundle>.<short>` (jobs + groups)."""
        out: set[str] = set()
        for b in self.bundles:
            for short in b.config.jobs:
                out.add(b.full_name(short))
            for short in b.config.job_groups:
                out.add(b.full_name(short))
        return out


# =============================================================================
# PLATFORM & HOST DETECTION
# =============================================================================


def current_platform() -> str:
    """Return 'darwin' or 'linux'. Raise on anything else."""
    s = sys.platform
    if s == "darwin":
        return "darwin"
    if s.startswith("linux"):
        return "linux"
    raise CronyError(f"unsupported platform: {s}")


def current_host() -> str:
    """Return the short hostname (everything before the first dot)."""
    return socket.gethostname().split(".")[0]


# =============================================================================
# SCHEDULE FORMAT VALIDATION
# =============================================================================
# Schedules use systemd OnCalendar syntax (systemd.time(7)). Intervals
# use systemd time-span syntax. We do basic structural validation here;
# full translation to launchd `StartCalendarInterval` happens when units
# are rendered.


# Reserved OnCalendar keywords supported by both systemd and our darwin
# translator. systemd accepts more (e.g. "minutely", "quarterly") but
# we explicitly support these.
_ONCALENDAR_KEYWORDS: frozenset[str] = frozenset(
    {
        "hourly",
        "daily",
        "weekly",
        "monthly",
        "yearly",
        "annually",
    }
)


_INTERVAL_TOKEN_RE = re.compile(
    # Alternation is left-to-right; longer alternatives MUST come
    # before any shorter alternative that's a prefix of them.
    # `months?` precedes `minutes?` so that "1month" doesn't get
    # consumed as a minutes-`m` followed by garbage.
    r"\s*(\d+)\s*"
    r"(seconds?|sec|s"
    r"|months?"
    r"|minutes?|min|m"
    r"|hours?|hr|h"
    r"|days?|d"
    r"|weeks?|w"
    r"|years?|y"
    r"|M)",
)

_INTERVAL_UNIT_SECONDS: dict[str, int] = {
    "s": 1,
    "sec": 1,
    "second": 1,
    "seconds": 1,
    "m": 60,
    "min": 60,
    "minute": 60,
    "minutes": 60,
    "h": 3600,
    "hr": 3600,
    "hour": 3600,
    "hours": 3600,
    "d": 86400,
    "day": 86400,
    "days": 86400,
    "w": 604800,
    "week": 604800,
    "weeks": 604800,
    "M": 2592000,
    "month": 2592000,
    "months": 2592000,
    "y": 31536000,
    "year": 31536000,
    "years": 31536000,
}


def parse_interval_seconds(s: str) -> int:
    """Parse a systemd time-span string into seconds.

    Accepts forms like "30min", "2h", "1h30min", "90 seconds".
    Raises ConfigError on unparseable input.
    """
    text = s.strip()
    if not text:
        raise ConfigError("empty interval")
    total = 0
    pos = 0
    matched = False
    while pos < len(text):
        m = _INTERVAL_TOKEN_RE.match(text, pos)
        if not m:
            if text[pos].isspace():
                pos += 1
                continue
            raise ConfigError(
                f"unparseable interval at offset {pos}: {text[pos:]!r}"
            )
        unit = m.group(2)
        # 'M' (capital) means months; lowercase 'm' means minutes
        if unit != "M":
            unit_lc = unit.lower()
        else:
            unit_lc = unit
        total += int(m.group(1)) * _INTERVAL_UNIT_SECONDS[unit_lc]
        pos = m.end()
        matched = True
    if not matched:
        raise ConfigError(f"no time components in interval: {s!r}")
    if total <= 0:
        raise ConfigError(f"interval must be positive: {s!r}")
    return total


def validate_schedule(s: str) -> None:
    """Basic OnCalendar structural validation.

    Full grammar parsing happens at platform-render time. Here we
    just reject obviously-wrong input so config loading fails fast.
    The rule: either a known keyword by itself, or a
    string containing at least one HH:MM-style time component
    (digit-colon-digit). Anything else lacks the minimum shape
    of a real OnCalendar expression.
    """
    text = s.strip()
    if not text:
        raise ConfigError("empty schedule")
    if "\n" in text or "\r" in text:
        raise ConfigError(f"schedule must be one line: {s!r}")
    if text in _ONCALENDAR_KEYWORDS:
        return
    # Require a colon followed by a digit (a time component) so "*",
    # "1234", and "-not-a-real-schedule-" are rejected. This accepts
    # forms like "03:15", "*:0/15", "*:00,30", "Sun *-*-* 04:00".
    if not re.search(r":\d", text):
        raise ConfigError(
            f"schedule does not look like OnCalendar syntax: {s!r}"
        )


