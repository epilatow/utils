# Emitted by `crony init`. Every section is commented out so a user can
# uncomment the bits they want without touching the explanatory prose.

_DEFAULT_CONFIG_TEMPLATE: str = """\
# ============================================================================
# crony config bundle
# ============================================================================
# crony reads bundles from:
#   ~/.config/crony/config.toml      -> bundle name "default"
#   ~/.config/crony/config/<x>.toml  -> bundle name "<x>"
#                                       (filename stem matches
#                                       [A-Za-z0-9][A-Za-z0-9_-]*)
# Each bundle is independent: its [defaults], targets, groups, and
# notify config apply only to the jobs defined in the same file.
# Job and group names are namespaced as <bundle>.<short>; on the
# CLI, a bare name (`crony trigger foo`) is shorthand for
# `default.foo` and never falls through to other bundles. The
# `-b/--bundle <name>` flag on multi-job subcommands (apply,
# destroy, status, enable, disable, trigger) scopes the operation
# to <name>, so a bare arg resolves there instead of `default`.
#
# Schedules use systemd OnCalendar syntax; intervals use systemd
# time-span syntax. See:
#   https://www.freedesktop.org/software/systemd/man/systemd.time.html
# ============================================================================


# ----------------------------------------------------------------------------
# defaults section
# ----------------------------------------------------------------------------
# Settings cascaded to every job in THIS bundle. Per-job and
# per-target settings can override anything here. Defaults from
# other bundles never apply -- each bundle has its own.

# [defaults]
# notify_channels      = []           # any names defined below
# notify_attach_log    = true         # include log content in notifications
# notify_attach_max_kb = 256          # email-only cap (ntfy uses a 3 KB inline cap)
# job_timeout_sec      = 1800         # 30 min default per-job wallclock cap
# trigger_timeout_sec  = 15           # `crony trigger --wait` start-deadline
# log_keep_runs        = 30

# Each notify channel is a [defaults.notify.<name>] block. The name
# is whatever the user lists in `notify_channels`. The `transport`
# field selects the underlying sender ("email" or "ntfy"); when
# omitted, transport defaults to the channel name (so a block named
# `email` or `ntfy` picks up its like-named transport
# automatically). Optional `headers` is a table of arbitrary
# message headers crony will attach -- crony-controlled headers
# (To/From/Subject for email; Authorization/Tags/Title for ntfy)
# are reserved and rejected.

# Embedded SMTP channel.
# [defaults.notify.email]
# # transport defaults to "email" since the channel is named "email"
# to                         = "you@example.com"
# from                       = "crony@example.com"
# smtp_host                  = "smtp.gmail.com"
# smtp_port                  = 587
# smtp_user                  = "you@gmail.com"
# smtp_starttls              = true
# # Password retrieval -- first match wins. On macOS prefer the
# # keychain item (the optional _account narrows the lookup when
# # multiple items share a service name); on Linux fall back to a
# # 0600 secrets file.
# smtp_pass_keychain_service = "crony-smtp"
# smtp_pass_keychain_account = "you@gmail.com"   # optional
# smtp_pass_file             = "~/.config/crony/secrets/smtp-password"
# headers                    = { "Reply-To" = "you@example.com" }

# ntfy channel.
# [defaults.notify.ntfy]
# url                    = "https://ntfy.example.com/automation"
# token_keychain_service = "ntfy-automation"
# token_keychain_account = "edp"                 # optional
# token_file             = "~/.config/crony/secrets/ntfy-token"

# Custom-named ntfy channel that also relays through ntfy's email
# integration. The transport field is required because the channel
# name `ntfy-email` doesn't match a built-in transport.
# [defaults.notify.ntfy-email]
# transport              = "ntfy"
# url                    = "https://ntfy.example.com/automation"
# token_keychain_service = "ntfy-automation"
# headers                = { "Email" = "you@example.com", "Priority" = "high" }


# ----------------------------------------------------------------------------
# job sections
# ----------------------------------------------------------------------------
# A schedulable unit of work. Either `command` (one-line shell) or
# `script` (path under the dotfiles repo) is required. Schedule and
# interval are optional; a job with neither fires only when a
# scheduled group dispatches it. Validation rejects a target chain
# that reaches a job through a path with no schedule anywhere.

# [job.brew-update]
# command   = "brew update && brew upgrade && brew cleanup"
# platforms = ["darwin"]               # filter: skip on non-darwin hosts
# # hosts   = ["mymac"]                # filter: only on listed hostnames
# schedule  = "*-*-* 03:15"            # OnCalendar; daily at 03:15
# gate      = "command -v brew"        # skip benignly if absent
# # Optional per-job overrides of [defaults]:
# # notify_channels = ["email"]
# # job_timeout_sec = 7200
# # env supports $VAR / ${VAR} expansion against the running env, so
# # `PATH = "$HOME/.local/bin:$PATH"` extends the inherited PATH.
# # Unresolved vars stay literal; `$$` is a literal `$`.
# # env             = { "PATH" = "$HOME/.local/bin:$PATH", "RUST_BACKTRACE" = "1" }

# [job.git-pull-utils]
# script   = "scripts/git-pull.sh"     # path under the dotfiles repo
# args     = ["~/utils"]               # `~` and `$VAR` expanded
# interval = "30min"                   # 30 min after each completion

# Group-only job: no schedule, only fires via [job-group.*].
# [job.uv-update]
# command = "uv self update && uv tool upgrade --all"
# gate    = "command -v uv"


# ----------------------------------------------------------------------------
# job-group sections
# ----------------------------------------------------------------------------
# A sequencer that fires named jobs (or other groups) in order.
# Schedule / interval are optional: a group with no schedule is a
# "transit" group that fires only when a parent group dispatches it.
# Every chain from a target down through groups to a leaf job must
# contain a schedule somewhere, or validation rejects it.

# [job-group.daily-updates]
# schedule  = "*-*-* 03:00"
# jobs      = ["brew-update", "uv-update", "git-pull-utils"]
# # platforms = ["darwin"]             # filter: as on jobs
# # hosts     = ["mymac"]              # filter: as on jobs

# Nested group: this one has no schedule of its own; it fires only
# when the daily-updates group above (or some other scheduled
# parent) dispatches it.
# [job-group.uv-updates]
# jobs = ["uv-update"]


# ----------------------------------------------------------------------------
# target sections
# ----------------------------------------------------------------------------
# Selects which jobs and groups install on which hosts. A host
# target replaces the platform target when both apply; the explicit
# `jobs` list IS the selection (no inherits / exclude / add).

# [target.darwin]
# jobs            = ["brew-update", "git-pull-utils", "daily-updates"]
# notify_channels = ["email"]

# [target.linux]
# jobs            = ["git-pull-utils"]
# notify_channels = ["ntfy"]

# [target.host.work-laptop]
# jobs            = ["brew-update", "git-pull-utils"]
# notify_channels = []   # no external dispatch (run.log + last-run.json only)
"""


# =============================================================================
# EXIT CODES
# =============================================================================


class ExitCode(enum.IntEnum):
    SUCCESS = 0, "Success"
    WARNING = 1, "Warning (non-fatal issues)"
    USAGE = 2, "Usage/argument error"
    CONFIG = 3, "Configuration error"
    ERROR = 4, "General error"
    SUBPROCESS = 5, "Subprocess command failed"
    AUDIT_FAILED = 6, "audit found jobs in a bad state"
    LOCK_BUSY = 7, "run.lock held by another instance"
    PRECONDITION = 8, "run precondition failed before exec"
    TIMEOUT = 9, "run killed wrapped command on timeout"

    def __new__(cls, value: int, description: str = "") -> ExitCode:
        obj = int.__new__(cls, value)
        obj._value_ = value
        obj.description = description  # type: ignore[attr-defined]
        return obj

    @classmethod
    def epilog(cls) -> str:
        lines = ["exit codes:"]
        for member in cls:
            lines.append(
                f"  {member.value}  {member.description}"  # type: ignore[attr-defined]
            )
        return "\n".join(lines)


# =============================================================================
# EXCEPTIONS
# =============================================================================


class CronyError(RuntimeError):
    """Base exception for crony errors."""

    exit_code: ExitCode = ExitCode.ERROR


class UsageError(CronyError):
    """Bad argument or unknown subcommand."""

    exit_code = ExitCode.USAGE


class ConfigError(CronyError):
    """Unparseable or invalid config."""

    exit_code = ExitCode.CONFIG


class SubprocessError(subprocess.CalledProcessError, CronyError):
    """Subprocess (launchctl, systemctl, etc) failed."""

    exit_code = ExitCode.SUBPROCESS


class AuditFailedError(CronyError):
    """`crony audit` found jobs in a bad state."""

    exit_code = ExitCode.AUDIT_FAILED


class LockBusyError(CronyError):
    """`crony run` could not acquire the per-job lock."""

    exit_code = ExitCode.LOCK_BUSY


class PreconditionError(CronyError):
    """`crony run` precondition failed before exec."""

    exit_code = ExitCode.PRECONDITION


class JobTimeoutError(CronyError):
    """`crony run` killed the wrapped command on timeout."""

    exit_code = ExitCode.TIMEOUT


# =============================================================================
# DATA CLASSES
# =============================================================================


@dataclass
class NotifyEmail:
    """SMTP transport settings."""

    to: str
    smtp_host: str
    smtp_port: int
    smtp_user: str
    from_addr: str | None = None
    smtp_starttls: bool = True
    smtp_pass_keychain_service: str | None = None
    smtp_pass_keychain_account: str | None = None
    smtp_pass_file: str | None = None


@dataclass
class NotifyNtfy:
    """ntfy transport settings."""

    url: str
    token_keychain_service: str | None = None
    token_keychain_account: str | None = None
    token_file: str | None = None


@dataclass
class NotifyChannel:
    """A user-named notification channel.

    `name` is the identifier the user lists in `notify_channels`.
    `transport` selects which sender to use (currently "email" or
    "ntfy"). Exactly one of `email` / `ntfy` is populated based on
    transport. `headers` is an optional dict of user-supplied
    headers merged into the message at send time -- see
    `_send_*_for` for which keys are crony-controlled and may not
    be overridden.
    """

    name: str
    transport: str
    headers: dict[str, str] = field(default_factory=dict)
    email: NotifyEmail | None = None
    ntfy: NotifyNtfy | None = None


@dataclass
class Defaults:
    """Tool-wide default settings cascaded to jobs."""

    # Empty list = no external dispatch (log + last-run.json are
    # always written regardless). On non-empty, every listed channel
    # fires per failure; per-channel results are recorded
    # independently in last-run.json's `notifications` dict. Each
    # entry must name a key in `notify_channel_defs` below.
    notify_channels: list[str] = field(default_factory=list)
    notify_attach_log: bool = True
    # Cap on log content included in EMAIL notifications. ntfy
    # bodies use a fixed 3 KB inline cap (ntfy's per-message limit
    # is 4 KB) and ignore this setting -- adjusting it here will
    # not affect ntfy.
    notify_attach_max_kb: int = 256
    job_timeout_sec: int = 1800
    # How long `crony trigger --wait` waits for a runner to come
    # online after asking the platform scheduler to fire the unit.
    # Catches "trigger seemed to succeed but nothing happened"
    # cases (broken plist, queue stalled, etc.).
    trigger_timeout_sec: int = 15
    log_keep_runs: int = 30
    # Per-bundle channel definitions: { name -> NotifyChannel }.
    notify_channel_defs: dict[str, NotifyChannel] = field(default_factory=dict)


@dataclass
class Job:
    """A single schedulable unit of work."""

    name: str
    command: str | None = None
    script: str | None = None
    args: list[str] = field(default_factory=list)
    gate: str | None = None
    gate_script: str | None = None
    gate_args: list[str] = field(default_factory=list)
    schedule: str | None = None
    interval: str | None = None
    # Empty list = applies to every platform / host. Non-empty
    # list = applies only on listed platforms / hosts; otherwise
    # the entry is silently skipped at selection time (so a
    # bundle can describe both darwin and linux jobs and have
    # each host pick up only its applicable subset).
    platforms: list[str] = field(default_factory=list)
    hosts: list[str] = field(default_factory=list)
    job_timeout_sec: int | None = None
    # None = inherit from target/defaults; [] = explicit empty (this
    # job sends no external notifications even if defaults / target
    # would).
    notify_channels: list[str] | None = None
    env: dict[str, str] = field(default_factory=dict)


@dataclass
class JobGroup:
    """A scheduled sequencer that fires named jobs in order.

    Groups don't carry notify settings: children run independently
    (via the platform scheduler dispatch that crony orchestrates)
    and resolve their own notify_channels through the target / job
    / defaults cascade. To apply a notify channel to all members of
    a group, set it at the target level (typical case) or per-job.

    Groups also don't carry `job_timeout_sec` -- timeouts are a
    per-leaf-job concern. A group's effective deadline is
    auto-computed from its children (`resolved_group_timeout_sec`,
    1.05 * sum of children's effective timeouts) and is not a
    user-facing knob: it acts as defense-in-depth so each child
    can hit its own per-job timeout before the parent's
    cumulative deadline fires.

    `platforms` / `hosts` work the same way as on Job: empty
    means "applies everywhere", non-empty restricts selection.
    A group filtered out doesn't recurse into its children; a
    child filtered out is skipped while siblings continue.
    """

    name: str
    jobs: list[str] = field(default_factory=list)
    schedule: str | None = None
    interval: str | None = None
    platforms: list[str] = field(default_factory=list)
    hosts: list[str] = field(default_factory=list)


@dataclass
class Target:
    """Per-platform or per-host selection of jobs/groups + cascading settings.

    `kind` is "platform" (e.g. darwin/linux) or "host" (a specific host).

    A target deliberately carries no timeout knob: timeouts are a
    per-leaf-job concern (`Job.job_timeout_sec` cascading to
    `Defaults.job_timeout_sec`) because a target / group is a
    selection-or-sequencing concept, not an executor. Effective
    deadlines for groups are auto-computed from their children
    (`resolved_group_timeout_sec`) as defense-in-depth, not as a
    user-tunable surface.
    """

    name: str
    kind: str
    jobs: list[str] = field(default_factory=list)
    # None = inherit from job/defaults; [] = explicit empty.
    notify_channels: list[str] | None = None


@dataclass
class NotificationResult:
    """One channel's outcome inside a JobRunResult.notifications entry."""

    sent: bool
    error: str | None = None
    error_class: str | None = None


@dataclass
class Config:
    """Top-level parsed config (one bundle's content)."""

    defaults: Defaults = field(default_factory=Defaults)
    jobs: dict[str, Job] = field(default_factory=dict)
    job_groups: dict[str, JobGroup] = field(default_factory=dict)
    platform_targets: dict[str, Target] = field(default_factory=dict)
    host_targets: dict[str, Target] = field(default_factory=dict)


@dataclass
class Bundle:
    """One config file's contribution: a bundle name + parsed Config.

    The bundle name namespaces the bundle's job and group names: a
    short name `daily-update` defined in bundle `borgadm` has the
    full name `borgadm.daily-update` everywhere on disk
    (state dir, hash stamp, launchd label, systemd unit).
    """

    name: str
    source: Path
    config: Config

    def full_name(self, short: str) -> str:
        return f"{self.name}.{short}"


@dataclass
class Bundles:
    """All loaded bundles, keyed by bundle name. Order is the load
    order (config.toml first, then config/*.toml lex-sorted)."""

    bundles: list[Bundle] = field(default_factory=list)

    def by_name(self, bundle_name: str) -> Bundle | None:
        for b in self.bundles:
            if b.name == bundle_name:
                return b
        return None

    def find_for_short(self, bundle_name: str, short: str) -> Bundle | None:
        """Return the bundle defining `<bundle_name>.<short>` (job or
        group), or None if no such name exists in that bundle."""
        b = self.by_name(bundle_name)
        if b is None:
            return None
        if short in b.config.jobs or short in b.config.job_groups:
            return b
        return None

    def all_full_names(self) -> set[str]:
        """Return every defined `<bundle>.<short>` (jobs + groups)."""
        out: set[str] = set()
        for b in self.bundles:
            for short in b.config.jobs:
                out.add(b.full_name(short))
            for short in b.config.job_groups:
                out.add(b.full_name(short))
        return out


# =============================================================================
# PLATFORM & HOST DETECTION
# =============================================================================


def current_platform() -> str:
    """Return 'darwin' or 'linux'. Raise on anything else."""
    s = sys.platform
    if s == "darwin":
        return "darwin"
    if s.startswith("linux"):
        return "linux"
    raise CronyError(f"unsupported platform: {s}")


def current_host() -> str:
    """Return the short hostname (everything before the first dot)."""
    return socket.gethostname().split(".")[0]


# =============================================================================
# SCHEDULE FORMAT VALIDATION
# =============================================================================
# Schedules use systemd OnCalendar syntax (systemd.time(7)). Intervals
# use systemd time-span syntax. We do basic structural validation here;
# full translation to launchd `StartCalendarInterval` happens when units
# are rendered.


# Reserved OnCalendar keywords supported by both systemd and our darwin
# translator. systemd accepts more (e.g. "minutely", "quarterly") but
# we explicitly support these.
_ONCALENDAR_KEYWORDS: frozenset[str] = frozenset(
    {
        "hourly",
        "daily",
        "weekly",
        "monthly",
        "yearly",
        "annually",
    }
)


_INTERVAL_TOKEN_RE = re.compile(
    # Alternation is left-to-right; longer alternatives MUST come
    # before any shorter alternative that's a prefix of them.
    # `months?` precedes `minutes?` so that "1month" doesn't get
    # consumed as a minutes-`m` followed by garbage.
    r"\s*(\d+)\s*"
    r"(seconds?|sec|s"
    r"|months?"
    r"|minutes?|min|m"
    r"|hours?|hr|h"
    r"|days?|d"
    r"|weeks?|w"
    r"|years?|y"
    r"|M)",
)

_INTERVAL_UNIT_SECONDS: dict[str, int] = {
    "s": 1,
    "sec": 1,
    "second": 1,
    "seconds": 1,
    "m": 60,
    "min": 60,
    "minute": 60,
    "minutes": 60,
    "h": 3600,
    "hr": 3600,
    "hour": 3600,
    "hours": 3600,
    "d": 86400,
    "day": 86400,
    "days": 86400,
    "w": 604800,
    "week": 604800,
    "weeks": 604800,
    "M": 2592000,
    "month": 2592000,
    "months": 2592000,
    "y": 31536000,
    "year": 31536000,
    "years": 31536000,
}


def parse_interval_seconds(s: str) -> int:
    """Parse a systemd time-span string into seconds.

    Accepts forms like "30min", "2h", "1h30min", "90 seconds".
    Raises ConfigError on unparseable input.
    """
    text = s.strip()
    if not text:
        raise ConfigError("empty interval")
    total = 0
    pos = 0
    matched = False
    while pos < len(text):
        m = _INTERVAL_TOKEN_RE.match(text, pos)
        if not m:
            if text[pos].isspace():
                pos += 1
                continue
            raise ConfigError(
                f"unparseable interval at offset {pos}: {text[pos:]!r}"
            )
        unit = m.group(2)
        # 'M' (capital) means months; lowercase 'm' means minutes
        if unit != "M":
            unit_lc = unit.lower()
        else:
            unit_lc = unit
        total += int(m.group(1)) * _INTERVAL_UNIT_SECONDS[unit_lc]
        pos = m.end()
        matched = True
    if not matched:
        raise ConfigError(f"no time components in interval: {s!r}")
    if total <= 0:
        raise ConfigError(f"interval must be positive: {s!r}")
    return total


def validate_schedule(s: str) -> None:
    """Basic OnCalendar structural validation.

    Full grammar parsing happens at platform-render time. Here we
    just reject obviously-wrong input so config loading fails fast.
    The rule: either a known keyword by itself, or a
    string containing at least one HH:MM-style time component
    (digit-colon-digit). Anything else lacks the minimum shape
    of a real OnCalendar expression.
    """
    text = s.strip()
    if not text:
        raise ConfigError("empty schedule")
    if "\n" in text or "\r" in text:
        raise ConfigError(f"schedule must be one line: {s!r}")
    if text in _ONCALENDAR_KEYWORDS:
        return
    # Require a colon followed by a digit (a time component) so "*",
    # "1234", and "-not-a-real-schedule-" are rejected. This accepts
    # forms like "03:15", "*:0/15", "*:00,30", "Sun *-*-* 04:00".
    if not re.search(r":\d", text):
        raise ConfigError(
            f"schedule does not look like OnCalendar syntax: {s!r}"
        )


# =============================================================================
# CONFIG LOADING
# =============================================================================
# Reads TOML, validates structurally and cross-cuttingly, and returns a
# fully-typed Config. Raises ConfigError on any problem.


_KNOWN_TOPLEVEL: frozenset[str] = frozenset(
    {
        "defaults",
        "job",
        "job-group",
        "target",
    }
)

_KNOWN_DEFAULTS: frozenset[str] = frozenset(
    {
        "notify_channels",
        "notify_attach_log",
        "notify_attach_max_kb",
        "job_timeout_sec",
        "trigger_timeout_sec",
        "log_keep_runs",
        "notify",
    }
)

_KNOWN_JOB: frozenset[str] = frozenset(
    {
        "command",
        "script",
        "args",
        "gate",
        "gate_script",
        "gate_args",
        "schedule",
        "interval",
        "platforms",
        "hosts",
        "job_timeout_sec",
        "notify_channels",
        "env",
    }
)

_KNOWN_JOB_GROUP: frozenset[str] = frozenset(
    {
        "jobs",
        "schedule",
        "interval",
        "platforms",
        "hosts",
    }
)

_KNOWN_TARGET: frozenset[str] = frozenset(
    {
        "jobs",
        "notify_channels",
    }
)

# Channel-level keys -- valid in any [defaults.notify.<name>] block
# regardless of transport.
_KNOWN_NOTIFY_CHANNEL: frozenset[str] = frozenset(
    {
        "transport",
        "headers",
    }
)

# Transport-specific keys. Valid alongside the channel-level keys
# inside a [defaults.notify.<name>] block whose transport matches.
_KNOWN_TRANSPORT_EMAIL: frozenset[str] = frozenset(
    {
        "to",
        "from",
        "smtp_host",
        "smtp_port",
        "smtp_user",
        "smtp_starttls",
        "smtp_pass_keychain_service",
        "smtp_pass_keychain_account",
        "smtp_pass_file",
    }
)

_KNOWN_TRANSPORT_NTFY: frozenset[str] = frozenset(
    {
        "url",
        "token_keychain_service",
        "token_keychain_account",
        "token_file",
    }
)

# Built-in transport names. A channel whose name matches one of
# these may omit `transport=` -- the shorthand
# `[defaults.notify.email]` is equivalent to
# `[defaults.notify.email] transport = "email"`. A channel named
# anything else must declare `transport=` explicitly so the
# parser knows which schema to validate the block against.
_VALID_NOTIFY_TRANSPORTS: frozenset[str] = frozenset(
    {
        "email",
        "ntfy",
    }
)

# Headers crony controls per transport. User-supplied `headers`
# entries that match (case-insensitively) are rejected at parse
# time so a config can never silently overwrite them.
_RESERVED_HEADERS_EMAIL: frozenset[str] = frozenset({"to", "from", "subject"})
# `filename` is reserved even though _post_ntfy never sets it: a
# user-supplied `Filename` would make ntfy render the body as a
# downloadable file (publicly addressable by URL guessing), which
# is exactly what the inline-body design avoids. Reserve it to
# keep that behavior consistent across configs.
_RESERVED_HEADERS_NTFY: frozenset[str] = frozenset(
    {"authorization", "tags", "title", "filename"}
)

_VALID_PLATFORMS: frozenset[str] = frozenset({"darwin", "linux"})


def _reject_unknown_keys(
    raw: dict[str, Any], known: frozenset[str], where: str
) -> None:
    """Raise ConfigError if raw has keys not in `known`."""
    unknown = set(raw.keys()) - known
    if unknown:
        raise ConfigError(f"{where}: unknown key(s) {sorted(unknown)}")


def _typed_field(
    raw: dict[str, Any],
    key: str,
    expected: type,
    where: str,
    *,
    default: Any = None,
) -> Any:
    """Extract `key` from `raw` with a type check. Returns `default` if absent.

    `bool` and `int` are distinct here, even though `isinstance(True, int)`
    is True in Python -- we explicitly reject booleans for int-typed fields
    so `job_timeout_sec = true` raises clearly rather than silently meaning 1.
    """
    if key not in raw:
        return default
    val = raw[key]
    # bool is a subclass of int; require strict separation here.
    if expected is int and isinstance(val, bool):
        raise ConfigError(f"{where}: '{key}' must be int, got bool")
    if expected is bool and not isinstance(val, bool):
        raise ConfigError(
            f"{where}: '{key}' must be bool, got {type(val).__name__}"
        )
    if not isinstance(val, expected):
        raise ConfigError(
            f"{where}: '{key}' must be {expected.__name__}, "
            f"got {type(val).__name__}"
        )
    return val


# Short job/group/host names appear inside a single bundle's TOML.
# They become part of filesystem paths (alongside the bundle name)
# and platform unit labels, so they must be safe filename characters.
# Dots are allowed: a job written as `[job."foo.bar"]` still maps
# cleanly into `<bundle>.foo.bar` on disk.
_NAME_RE: re.Pattern[str] = re.compile(r"^[A-Za-z0-9][A-Za-z0-9._-]*$")

# Bundle names come from filenames (config.toml -> "default";
# config/<x>.toml -> "x"). The dot is reserved as the namespace
# separator between bundle and short name, so bundle names cannot
# themselves contain dots.
_BUNDLE_NAME_RE: re.Pattern[str] = re.compile(r"^[A-Za-z0-9][A-Za-z0-9_-]*$")


def _validate_name(name: str, where: str) -> None:
    """Reject names that would break filesystem paths or unit labels."""
    if not _NAME_RE.match(name):
        raise ConfigError(
            f"{where}: name {name!r} must match "
            f"[A-Za-z0-9][A-Za-z0-9._-]* (no slashes, spaces, "
            f"empty, or leading punctuation)"
        )


def _validate_bundle_name(name: str, where: str) -> None:
    """Reject filenames whose stem can't be a bundle name."""
    if not _BUNDLE_NAME_RE.match(name):
        raise ConfigError(
            f"{where}: bundle name {name!r} must match "
            f"[A-Za-z0-9][A-Za-z0-9_-]* (no dots -- the dot is "
            f"reserved as the bundle/job-name separator)"
        )


def parse_full_name(arg: str) -> tuple[str, str]:
    """Parse a CLI job/group reference into (bundle_name, short).

    Bare 'foo' -> ('default', 'foo') -- bare input only ever
    selects the default bundle, never falls through to others.
    'borgadm.foo' -> ('borgadm', 'foo'). Multi-dot forms split on
    the first dot, so '<bundle>.<short>' where short itself
    contains dots stays intact.
    """
    if "." not in arg:
        return (DEFAULT_BUNDLE_NAME, arg)
    bundle, _, short = arg.partition(".")
    if not bundle or not short:
        raise UsageError(f"invalid job reference: {arg!r}")
    return (bundle, short)


def normalize_full_name(arg: str) -> str:
    """CLI input -> canonical `<bundle>.<short>` form.

    Convenience wrapper over `parse_full_name`: bare 'foo'
    becomes 'default.foo', already-namespaced inputs round-trip.
    Used at the entry point of every CLI handler that takes
    user-supplied job references so downstream code can rely on
    one normalized form.
    """
    bundle, short = parse_full_name(arg)
    return f"{bundle}.{short}"


def resolve_cli_name(arg: str, scope_bundle: str | None) -> str:
    """CLI input -> canonical `<bundle>.<short>` honoring `-b`.

    With `scope_bundle` None this is `normalize_full_name`. With
    `scope_bundle` set, bare `arg` resolves in that bundle (so
    `-b foo bar` -> `foo.bar`), already-qualified `<scope>.<short>`
    round-trips, and `<other>.<short>` is rejected -- under `-b`
    every name on the command line must belong to that bundle so
    a bulk operation can't sneak in a cross-bundle reference.
    """
    if scope_bundle is None:
        return normalize_full_name(arg)
    bundle, short = parse_full_name(arg)
    if "." not in arg:
        return f"{scope_bundle}.{short}"
    if bundle != scope_bundle:
        raise UsageError(
            f"{arg!r} is in bundle {bundle!r} but --bundle "
            f"{scope_bundle!r} is set"
        )
    return f"{bundle}.{short}"


def require_known_bundle(bundles: Bundles, bundle: str | None) -> None:
    """Reject `--bundle <name>` if `<name>` isn't a loaded bundle."""
    if bundle is not None and bundles.by_name(bundle) is None:
        raise UsageError(f"unknown bundle: {bundle!r}")


def bundle_prefix_filter(names: Iterable[str], bundle: str) -> set[str]:
    """Subset of `names` whose `<bundle>.` prefix matches."""
    prefix = f"{bundle}."
    return {n for n in names if n.startswith(prefix)}


def _string_list(raw: dict[str, Any], key: str, where: str) -> list[str]:
    """Extract a list-of-strings field, defaulting to []."""
    val = raw.get(key)
    if val is None:
        return []
    if not isinstance(val, list) or not all(isinstance(x, str) for x in val):
        raise ConfigError(f"{where}: '{key}' must be a list of strings")
    return list(val)


def _parse_platforms_field(raw: dict[str, Any], where: str) -> list[str]:
    """Parse a `platforms = [...]` field with allowed-value check.

    Both Job and JobGroup carry `platforms`; the allowed values
    (`darwin`, `linux`) are the same. Hosts have no fixed allow-
    list -- they're whatever the user names their machines.
    """
    platforms = _string_list(raw, "platforms", where)
    for p in platforms:
        if p not in _VALID_PLATFORMS:
            raise ConfigError(
                f"{where}: platforms entry {p!r} not in "
                f"{sorted(_VALID_PLATFORMS)}"
            )
    return platforms


def _string_dict(raw: dict[str, Any], key: str, where: str) -> dict[str, str]:
    """Extract a dict-of-string-to-string field, defaulting to {}."""
    val = raw.get(key)
    if val is None:
        return {}
    if not isinstance(val, dict):
        raise ConfigError(f"{where}: '{key}' must be a table (dict)")
    out: dict[str, str] = {}
    for k, v in val.items():
        if not isinstance(k, str) or not isinstance(v, str):
            raise ConfigError(
                f"{where}: '{key}' values must be string -> string"
            )
        out[k] = v
    return out


def _parse_notify_email_settings(
    raw: dict[str, Any], where: str
) -> NotifyEmail:
    """Parse the email-transport keys from a channel block."""
    to = _typed_field(raw, "to", str, where)
    smtp_host = _typed_field(raw, "smtp_host", str, where)
    smtp_user = _typed_field(raw, "smtp_user", str, where)
    smtp_port = _typed_field(raw, "smtp_port", int, where, default=587)
    if to is None or smtp_host is None or smtp_user is None:
        raise ConfigError(
            f"{where}: 'to', 'smtp_host', 'smtp_user' are required"
        )
    return NotifyEmail(
        to=to,
        from_addr=_typed_field(raw, "from", str, where),
        smtp_host=smtp_host,
        smtp_port=smtp_port,
        smtp_user=smtp_user,
        smtp_starttls=_typed_field(
            raw, "smtp_starttls", bool, where, default=True
        ),
        smtp_pass_keychain_service=_typed_field(
            raw, "smtp_pass_keychain_service", str, where
        ),
        smtp_pass_keychain_account=_typed_field(
            raw, "smtp_pass_keychain_account", str, where
        ),
        smtp_pass_file=_typed_field(raw, "smtp_pass_file", str, where),
    )


def _parse_notify_ntfy_settings(raw: dict[str, Any], where: str) -> NotifyNtfy:
    """Parse the ntfy-transport keys from a channel block."""
    url = _typed_field(raw, "url", str, where)
    if url is None:
        raise ConfigError(f"{where}: 'url' is required")
    return NotifyNtfy(
        url=url,
        token_keychain_service=_typed_field(
            raw, "token_keychain_service", str, where
        ),
        token_keychain_account=_typed_field(
            raw, "token_keychain_account", str, where
        ),
        token_file=_typed_field(raw, "token_file", str, where),
    )


def _parse_notify_channel(name: str, raw: dict[str, Any]) -> NotifyChannel:
    """Parse a single [defaults.notify.<name>] block.

    Channel-level keys: `transport` (defaults to the channel name
    when name is "email" or "ntfy"; required otherwise) and
    `headers` (optional dict of user-supplied headers).
    Transport-specific keys live alongside.
    """
    where = f"[defaults.notify.{name}]"
    _validate_name(name, where)

    transport = _typed_field(raw, "transport", str, where)
    if transport is None:
        if name in _VALID_NOTIFY_TRANSPORTS:
            transport = name
        else:
            raise ConfigError(
                f"{where}: 'transport' required for channel {name!r} "
                f"(only {sorted(_VALID_NOTIFY_TRANSPORTS)} can omit it)"
            )
    if transport not in _VALID_NOTIFY_TRANSPORTS:
        raise ConfigError(
            f"{where}: transport {transport!r} not in "
            f"{sorted(_VALID_NOTIFY_TRANSPORTS)}"
        )

    headers = _string_dict(raw, "headers", where)
    reserved = (
        _RESERVED_HEADERS_EMAIL
        if transport == "email"
        else _RESERVED_HEADERS_NTFY
    )
    for k in headers:
        if k.lower() in reserved:
            raise ConfigError(
                f"{where}: header {k!r} is set by crony and cannot "
                f"be overridden"
            )

    # Reject keys outside (channel-level + this transport's keys).
    transport_keys = (
        _KNOWN_TRANSPORT_EMAIL
        if transport == "email"
        else _KNOWN_TRANSPORT_NTFY
    )
    _reject_unknown_keys(raw, _KNOWN_NOTIFY_CHANNEL | transport_keys, where)

    email_cfg: NotifyEmail | None = None
    ntfy_cfg: NotifyNtfy | None = None
    if transport == "email":
        email_cfg = _parse_notify_email_settings(raw, where)
    else:
        ntfy_cfg = _parse_notify_ntfy_settings(raw, where)
    return NotifyChannel(
        name=name,
        transport=transport,
        headers=headers,
        email=email_cfg,
        ntfy=ntfy_cfg,
    )


def _positive_int(
    raw: dict[str, Any], key: str, where: str, default: int
) -> int:
    """Read a positive int defaulting to `default`. Reject 0 / negative."""
    val: int = _typed_field(raw, key, int, where, default=default)
    if val <= 0:
        raise ConfigError(f"{where}: '{key}' must be positive, got {val}")
    return val


def _parse_notify_channels(
    raw: dict[str, Any], where: str, *, required: bool
) -> list[str] | None:
    """Parse a `notify_channels` list (structural validation only).

    `required=True` (Defaults) returns [] when the key is absent.
    `required=False` (Job/Target) returns None when absent so the
    cascade can inherit from a layer below. Duplicate entries and
    non-string entries raise. Whether each entry actually resolves
    to a defined channel is checked later in `_validate_config`,
    once the bundle's channel definitions are known.
    """
    if "notify_channels" not in raw:
        return [] if required else None
    val = raw["notify_channels"]
    if not isinstance(val, list) or not all(isinstance(x, str) for x in val):
        raise ConfigError(
            f"{where}: 'notify_channels' must be a list of strings"
        )
    seen: set[str] = set()
    out: list[str] = []
    for ch in val:
        if ch in seen:
            raise ConfigError(
                f"{where}: notify_channels entry {ch!r} listed twice"
            )
        seen.add(ch)
        out.append(ch)
    return out


def _parse_defaults(raw: dict[str, Any]) -> Defaults:
    """Parse [defaults]."""
    where = "[defaults]"
    _reject_unknown_keys(raw, _KNOWN_DEFAULTS, where)
    channels = _parse_notify_channels(raw, where, required=True)
    notify_channel_defs: dict[str, NotifyChannel] = {}
    nested = raw.get("notify", {})
    if not isinstance(nested, dict):
        raise ConfigError(f"{where}.notify must be a table (dict)")
    for sub_key, sub_body in nested.items():
        if not isinstance(sub_body, dict):
            raise ConfigError(f"[defaults.notify.{sub_key}]: must be a table")
        notify_channel_defs[sub_key] = _parse_notify_channel(sub_key, sub_body)
    return Defaults(
        notify_channels=channels or [],
        notify_attach_log=_typed_field(
            raw, "notify_attach_log", bool, where, default=True
        ),
        notify_attach_max_kb=_positive_int(
            raw, "notify_attach_max_kb", where, default=256
        ),
        job_timeout_sec=_positive_int(
            raw, "job_timeout_sec", where, default=1800
        ),
        trigger_timeout_sec=_positive_int(
            raw, "trigger_timeout_sec", where, default=15
        ),
        log_keep_runs=_positive_int(raw, "log_keep_runs", where, default=30),
        notify_channel_defs=notify_channel_defs,
    )


def _parse_job(name: str, raw: dict[str, Any]) -> Job:
    """Parse [job.<name>]."""
    _validate_name(name, f"[job.{name}]")
    where = f"[job.{name}]"
    _reject_unknown_keys(raw, _KNOWN_JOB, where)
    command = _typed_field(raw, "command", str, where)
    script = _typed_field(raw, "script", str, where)
    if (command is None) == (script is None):
        raise ConfigError(
            f"{where}: must have exactly one of 'command' or 'script'"
        )
    args = _string_list(raw, "args", where)
    if args and command is not None:
        raise ConfigError(
            f"{where}: 'args' is only valid with 'script', not 'command'"
        )
    gate = _typed_field(raw, "gate", str, where)
    gate_script = _typed_field(raw, "gate_script", str, where)
    if gate is not None and gate_script is not None:
        raise ConfigError(
            f"{where}: 'gate' and 'gate_script' are mutually exclusive"
        )
    gate_args = _string_list(raw, "gate_args", where)
    if gate_args and gate_script is None:
        raise ConfigError(
            f"{where}: 'gate_args' is only valid with 'gate_script'"
        )
    schedule = _typed_field(raw, "schedule", str, where)
    interval = _typed_field(raw, "interval", str, where)
    if schedule is not None and interval is not None:
        raise ConfigError(
            f"{where}: 'schedule' and 'interval' are mutually exclusive"
        )
    if schedule is not None:
        validate_schedule(schedule)
    if interval is not None:
        parse_interval_seconds(interval)
    platforms = _parse_platforms_field(raw, where)
    hosts = _string_list(raw, "hosts", where)
    channels = _parse_notify_channels(raw, where, required=False)
    job_timeout_sec = _typed_field(raw, "job_timeout_sec", int, where)
    if job_timeout_sec is not None and job_timeout_sec <= 0:
        raise ConfigError(f"{where}: job_timeout_sec must be positive")
    return Job(
        name=name,
        command=command,
        script=script,
        args=args,
        gate=gate,
        gate_script=gate_script,
        gate_args=gate_args,
        schedule=schedule,
        interval=interval,
        platforms=platforms,
        hosts=hosts,
        job_timeout_sec=job_timeout_sec,
        notify_channels=channels,
        env=_string_dict(raw, "env", where),
    )


def _parse_job_group(name: str, raw: dict[str, Any]) -> JobGroup:
    """Parse [job-group.<name>].

    schedule / interval are both optional: a group with neither is a
    "transit" group that fires only when a parent group dispatches
    it. Cross-cutting validation (per-target chain) ensures every
    selected group is reachable from a scheduled root.
    """
    _validate_name(name, f"[job-group.{name}]")
    where = f"[job-group.{name}]"
    _reject_unknown_keys(raw, _KNOWN_JOB_GROUP, where)
    jobs = _string_list(raw, "jobs", where)
    if not jobs:
        raise ConfigError(f"{where}: 'jobs' must be a non-empty list")
    schedule = _typed_field(raw, "schedule", str, where)
    interval = _typed_field(raw, "interval", str, where)
    if schedule is not None and interval is not None:
        raise ConfigError(
            f"{where}: 'schedule' and 'interval' are mutually exclusive"
        )
    if schedule is not None:
        validate_schedule(schedule)
    if interval is not None:
        parse_interval_seconds(interval)
    platforms = _parse_platforms_field(raw, where)
    hosts = _string_list(raw, "hosts", where)
    return JobGroup(
        name=name,
        jobs=jobs,
        schedule=schedule,
        interval=interval,
        platforms=platforms,
        hosts=hosts,
    )


def _parse_target(name: str, kind: str, raw: dict[str, Any]) -> Target:
    """Parse [target.<platform>] or [target.host.<name>]."""
    where = (
        f"[target.{name}]" if kind == "platform" else f"[target.host.{name}]"
    )
    if kind == "host":
        _validate_name(name, where)
    _reject_unknown_keys(raw, _KNOWN_TARGET, where)
    jobs = _string_list(raw, "jobs", where)
    channels = _parse_notify_channels(raw, where, required=False)
    return Target(
        name=name,
        kind=kind,
        jobs=jobs,
        notify_channels=channels,
    )


def _validate_config(config: Config) -> None:
    """Cross-cutting validation: name collisions, references, applicability."""
    # Job/group name collision
    overlap = set(config.jobs) & set(config.job_groups)
    if overlap:
        raise ConfigError(
            f"name collision: {sorted(overlap)} appear as both "
            f"[job.*] and [job-group.*]"
        )
    all_names = set(config.jobs) | set(config.job_groups)
    # Group children must reference a defined job or group (nested
    # groups are supported; the chain validation below ensures every
    # path bottoms out in a schedule).
    for gname, group in config.job_groups.items():
        for child in group.jobs:
            if child not in all_names:
                raise ConfigError(
                    f"[job-group.{gname}]: 'jobs' references "
                    f"undefined name {child!r}"
                )
    # Targets reference defined jobs or groups
    for tname, target in config.platform_targets.items():
        for ref in target.jobs:
            if ref not in all_names:
                raise ConfigError(
                    f"[target.{tname}]: 'jobs' references "
                    f"undefined name {ref!r}"
                )
        if tname not in _VALID_PLATFORMS:
            raise ConfigError(
                f"[target.{tname}]: platform must be one of "
                f"{sorted(_VALID_PLATFORMS)}"
            )
    for hname, target in config.host_targets.items():
        for ref in target.jobs:
            if ref not in all_names:
                raise ConfigError(
                    f"[target.host.{hname}]: 'jobs' references "
                    f"undefined name {ref!r}"
                )
    # `platforms` / `hosts` filter at selection time, not at
    # validate time: a single bundle is allowed to describe both
    # darwin and linux entries (or per-host overrides) and have
    # each host pick up only its applicable subset. A
    # configuration that's contradictory on a given host (e.g. a
    # target.linux that references a darwin-only entry) just
    # produces an empty selection on that host -- exactly the
    # filter-and-skip semantics the cross-platform bundle pattern
    # needs.

    # Per-target chain validation: every path from a target reference
    # down through groups to a leaf job must contain a schedule/interval
    # somewhere. This catches both schedule-less jobs that nothing
    # would dispatch and broken chains where the user added a layer
    # of grouping but forgot to schedule any of it. Cycle detection
    # piggy-backs on the same walk.
    def _walk_chain(
        ref: str,
        target_label: str,
        path: tuple[str, ...],
        seen_schedule: bool,
    ) -> None:
        if ref in path:
            cycle = " -> ".join(path[path.index(ref) :] + (ref,))
            raise ConfigError(f"{target_label}: cycle in group chain: {cycle}")
        path = path + (ref,)
        if ref in config.jobs:
            job = config.jobs[ref]
            scheduled = job.schedule is not None or job.interval is not None
            if not seen_schedule and not scheduled:
                raise ConfigError(
                    f"{target_label}: chain "
                    f"{' -> '.join(path)} has no schedule "
                    f"anywhere -- {ref!r} would never fire"
                )
            return
        # Group: recurse with updated seen_schedule.
        group = config.job_groups[ref]
        scheduled = group.schedule is not None or group.interval is not None
        new_seen = seen_schedule or scheduled
        for child in group.jobs:
            _walk_chain(child, target_label, path, new_seen)

    targets_to_check: list[tuple[str, Target]] = [
        (f"[target.{tname}]", t) for tname, t in config.platform_targets.items()
    ] + [
        (f"[target.host.{hname}]", t)
        for hname, t in config.host_targets.items()
    ]
    for label, target in targets_to_check:
        for ref in target.jobs:
            _walk_chain(ref, label, (), seen_schedule=False)

    # notify_channels references must resolve to defined channels in
    # this bundle's [defaults.notify.*] section. The reference checks
    # run only when channels are actually selected somewhere -- an
    # absent channels list at every layer means the bundle never
    # dispatches, regardless of what's defined.
    defined_channels = set(config.defaults.notify_channel_defs.keys())

    def _check(layer_name: str, channels: list[str]) -> None:
        for ch in channels:
            if ch not in defined_channels:
                raise ConfigError(
                    f"{layer_name}: notify_channels entry {ch!r} "
                    f"is not defined; expected one of "
                    f"{sorted(defined_channels) or '[]'}"
                )

    _check("[defaults]", config.defaults.notify_channels)
    for jname, job in config.jobs.items():
        if job.notify_channels is not None:
            _check(f"[job.{jname}]", job.notify_channels)
    for tname, target in config.platform_targets.items():
        if target.notify_channels is not None:
            _check(f"[target.{tname}]", target.notify_channels)
    for hname, target in config.host_targets.items():
        if target.notify_channels is not None:
            _check(f"[target.host.{hname}]", target.notify_channels)


def _load_one_bundle(name: str, path: Path) -> Bundle:
    """Parse a single bundle file and validate it. Raises ConfigError
    on parse / schema failure, naming the source path for context.
    """
    try:
        raw = tomllib.loads(path.read_text(encoding="utf-8"))
    except tomllib.TOMLDecodeError as e:
        raise ConfigError(f"TOML parse error in {path}: {e}") from e
    try:
        config = parse_config(raw)
    except ConfigError as e:
        raise ConfigError(f"{path}: {e}") from e
    return Bundle(name=name, source=path, config=config)


def load_all_bundles() -> Bundles:
    """Load every bundle: `config.toml` (-> bundle 'default') plus
    `config/*.toml` (each -> bundle named after its filename stem).

    Per-bundle failures are isolated: a bundle that fails to parse,
    fails schema validation, or has an invalid filename is dropped
    with a CONFIG-level error logged for that source. Subsequent
    bundles continue loading. The returned Bundles contains only
    the bundles that loaded successfully.

    It is an error if no bundles load -- either every config file is
    broken or no config files exist at all.
    """
    bundles = Bundles()
    errors: list[str] = []
    seen_names: set[str] = set()

    candidates: list[tuple[str, Path]] = []
    if CONFIG_FILE.exists():
        candidates.append((DEFAULT_BUNDLE_NAME, CONFIG_FILE))
    if CONFIG_DROPIN_DIR.exists():
        for path in sorted(CONFIG_DROPIN_DIR.glob("*.toml")):
            candidates.append((path.stem, path))

    if not candidates:
        raise ConfigError(
            f"no config: expected {CONFIG_FILE} or {CONFIG_DROPIN_DIR}/*.toml"
        )

    for bundle_name, path in candidates:
        try:
            _validate_bundle_name(bundle_name, str(path))
        except ConfigError as e:
            errors.append(str(e))
            continue
        if bundle_name in seen_names:
            errors.append(
                f"{path}: bundle name {bundle_name!r} collides with "
                f"already-loaded bundle; this file will not load"
            )
            continue
        try:
            bundle = _load_one_bundle(bundle_name, path)
        except ConfigError as e:
            errors.append(str(e))
            continue
        bundles.bundles.append(bundle)
        seen_names.add(bundle_name)

    if errors:
        for msg in errors:
            logger.error("%s", msg)
    if not bundles.bundles:
        raise ConfigError("no bundles loaded successfully")
    return bundles


def load_config(path: Path | None = None) -> Config:
    """Load a single config file as a `Config` (single-bundle view).

    Suited to tests and any caller that has one specific config
    path in hand and wants the parsed `Config` for that file
    alone. Production code paths walk every bundle and should use
    `load_all_bundles()` instead.
    """
    if path is None:
        path = CONFIG_FILE
    if not path.exists():
        raise ConfigError(f"config not found: {path}")
    try:
        raw = tomllib.loads(path.read_text(encoding="utf-8"))
    except tomllib.TOMLDecodeError as e:
        raise ConfigError(f"TOML parse error in {path}: {e}") from e
    return parse_config(raw)


def parse_config(raw: dict[str, Any]) -> Config:
    """Parse a top-level config dict into a validated Config."""
    _reject_unknown_keys(raw, _KNOWN_TOPLEVEL, "(top level)")

    config = Config()

    if "defaults" in raw:
        if not isinstance(raw["defaults"], dict):
            raise ConfigError("[defaults] must be a table")
        config.defaults = _parse_defaults(raw["defaults"])

    job_section = raw.get("job", {})
    if not isinstance(job_section, dict):
        raise ConfigError("[job] must be a table")
    for name, body in job_section.items():
        if not isinstance(body, dict):
            raise ConfigError(f"[job.{name}] must be a table")
        config.jobs[name] = _parse_job(name, body)

    group_section = raw.get("job-group", {})
    if not isinstance(group_section, dict):
        raise ConfigError("[job-group] must be a table")
    for name, body in group_section.items():
        if not isinstance(body, dict):
            raise ConfigError(f"[job-group.{name}] must be a table")
        config.job_groups[name] = _parse_job_group(name, body)

    target_section = raw.get("target", {})
    if not isinstance(target_section, dict):
        raise ConfigError("[target] must be a table")
    for name, body in target_section.items():
        if name == "host":
            # [target.host.<host>] entries
            if not isinstance(body, dict):
                raise ConfigError("[target.host] must be a table")
            for hostname, hostbody in body.items():
                if not isinstance(hostbody, dict):
                    raise ConfigError(
                        f"[target.host.{hostname}] must be a table"
                    )
                config.host_targets[hostname] = _parse_target(
                    hostname, "host", hostbody
                )
        else:
            # [target.<platform>] entry
            if not isinstance(body, dict):
                raise ConfigError(f"[target.{name}] must be a table")
            config.platform_targets[name] = _parse_target(
                name, "platform", body
            )

    _validate_config(config)
    return config


# =============================================================================
# RESOLUTION
# =============================================================================


def resolve_target(config: Config, host: str, platform: str) -> Target | None:
    """Pick the effective target for (host, platform).

    Host target wins; otherwise the platform target; otherwise None
    (nothing selected on this host).
    """
    if host in config.host_targets:
        return config.host_targets[host]
    if platform in config.platform_targets:
        return config.platform_targets[platform]
    return None


def _mask_reason(
    platforms: list[str],
    hosts: list[str],
    *,
    host: str,
    platform: str,
) -> str | None:
    """Return the axis (or axes) that mask this entry, or None.

    Empty list = "applies everywhere" (the common case). A
    non-empty list with no match on its axis contributes that
    axis name to the reason. Both axes can mask simultaneously
    (`"host,platform"`); a single-axis mask returns
    `"platform"` or `"host"`. None means the entry applies on
    this (host, platform).
    """
    parts: list[str] = []
    if hosts and host not in hosts:
        parts.append("host")
    if platforms and platform not in platforms:
        parts.append("platform")
    if not parts:
        return None
    return ",".join(parts)


def _entry_applies_here(
    platforms: list[str],
    hosts: list[str],
    *,
    host: str,
    platform: str,
) -> bool:
    """True if the entry's `platforms` / `hosts` allow this host.

    Empty list = "applies everywhere" (the common case).
    Non-empty = restricts selection to listed values. A non-match
    on either axis filters the entry out at selection time;
    apply / status / audit then never see it on this host.
    """
    return _mask_reason(platforms, hosts, host=host, platform=platform) is None


def selected_jobs_and_groups(
    config: Config, target: Target | None
) -> tuple[set[str], set[str]]:
    """Compute the set of job and group names selected by target.

    A target's `jobs` list names roots; each root's transitive
    descendants (group children, which may themselves be groups)
    are also selected so they get stamped on this host and don't
    appear as orphans. Per-entry `platforms` / `hosts` filters
    exclude entries from the selected sets; a child reachable
    only through a filtered group is excluded as well, while a
    child reachable via at least one unfiltered path remains
    selected.

    Cycle protection is defensive -- `_validate_config` should
    have already rejected cycles.
    """
    jobs, groups, _ = selected_and_masked_jobs_and_groups(config, target)
    return jobs, groups


def selected_and_masked_jobs_and_groups(
    config: Config, target: Target | None
) -> tuple[set[str], set[str], dict[str, str]]:
    """Walk the target's selection, distinguishing selected from masked.

    Mirrors `selected_jobs_and_groups` for the selected sets; in
    addition, returns a `masked` mapping of name -> reason (axis
    string from `_mask_reason`) for entries reached through the
    target whose own filters exclude them, plus children of a
    masked group (which inherit the parent's reason -- they're
    inactive on this host even if their own filters would pass).
    A group whose every direct child is itself masked on this
    host has nothing to dispatch and joins the masked set with
    reason `"empty"`; the cascade iterates to a fixed point so a
    parent whose only effective child was a now-empty group is
    demoted as well. The selected sets are identical to what
    `selected_jobs_and_groups` returns; `masked` is the strictly-
    additional set that `--all` exposes.
    """
    jobs: set[str] = set()
    groups: set[str] = set()
    masked: dict[str, str] = {}
    if target is None:
        return jobs, groups, masked
    host = current_host()
    platform = current_platform()

    def _walk(name: str, parent_mask: str | None, seen: set[str]) -> None:
        if name in seen:
            return
        seen = seen | {name}
        if name in config.jobs:
            j = config.jobs[name]
            own_reason = _mask_reason(
                j.platforms, j.hosts, host=host, platform=platform
            )
            effective = own_reason or parent_mask
            if effective is None:
                jobs.add(name)
            else:
                masked[name] = effective
        elif name in config.job_groups:
            g = config.job_groups[name]
            own_reason = _mask_reason(
                g.platforms, g.hosts, host=host, platform=platform
            )
            effective = own_reason or parent_mask
            if effective is None:
                groups.add(name)
            else:
                masked[name] = effective
            for child in g.jobs:
                _walk(child, effective, seen)

    for name in target.jobs:
        _walk(name, None, set())
    # A name reachable through both a masked and an unmasked path
    # should appear as selected, not masked. Drop any masked entry
    # that also made it into the selected sets.
    for n in jobs | groups:
        masked.pop(n, None)
    # Empty-group cascade: a selected group with no unmasked
    # direct child has nothing to dispatch on this host, so the
    # reference is treated as a no-op and the group joins the
    # masked set with reason "empty". Iterate to a fixed point so
    # a parent whose only remaining child was itself a now-empty
    # group cascades too. Cycles are rejected by `_validate_config`,
    # so the loop terminates in O(group_count) iterations.
    while True:
        empties: list[str] = []
        for gname in groups:
            g = config.job_groups[gname]
            if not g.jobs or not any(
                (c in jobs) or (c in groups) for c in g.jobs
            ):
                empties.append(gname)
        if not empties:
            break
        for gname in empties:
            groups.discard(gname)
            masked[gname] = "empty"
    return jobs, groups, masked


def resolved_notify_channels(
    config: Config, target: Target | None, job: Job
) -> list[str]:
    """Cascade notify_channels: target > job > defaults.

    Each layer's value is either None ("inherit from below") or a
    list ("override; this is the value for this layer"). An empty
    list at any layer is a deliberate "no external dispatch" choice
    that wins over lower layers. The bottom-most fallback is the
    defaults' list, which may itself be empty.
    """
    if target is not None and target.notify_channels is not None:
        return list(target.notify_channels)
    if job.notify_channels is not None:
        return list(job.notify_channels)
    return list(config.defaults.notify_channels)


def resolved_job_timeout_sec(
    config: Config, target: Target | None, job: Job
) -> int:
    """Cascade job_timeout_sec: job > defaults.

    `target` is accepted for signature symmetry with
    `resolved_notify_channels` (and to keep callers unaware of the
    cascade shape) but does not contribute -- targets and groups
    intentionally have no user-tunable timeout knob; see the
    `Target` and `JobGroup` docstrings for the rationale.
    """
    del target
    if job.job_timeout_sec is not None:
        return job.job_timeout_sec
    return config.defaults.job_timeout_sec


# Padding factor applied to a group's effective timeout. The 5%
# slack lets a leaf job hit its own timeout (and propagate the
# error up through last-run.json) before the parent group's own
# cumulative deadline fires. Compounds with nesting depth, by
# design.
_GROUP_TIMEOUT_PADDING: float = 1.05


def resolved_group_timeout_sec(
    config: Config, target: Target | None, group_name: str
) -> int:
    """Auto-computed effective timeout for a group.

    Returns 1.05 * sum of children's effective timeouts (jobs use
    `resolved_job_timeout_sec`; sub-groups recurse into this same
    helper). Floor at 1 second. Used by:
    - `run_group` to bound its cumulative dispatch loop.
    - The waiter in `_trigger_unit_sync` to bound its pid-watch
      when waiting for a group.
    Cycle-safety: `_validate_config` rejects cycles in group
    references, so the recursion always terminates.

    Children not selected on this host contribute zero (own
    filter excludes them or empty-group cascade demoted them) --
    the parent won't trigger them here, so the budget shouldn't
    reserve their time either.
    """
    group = config.job_groups[group_name]
    sel_jobs, sel_groups = selected_jobs_and_groups(config, target)
    total = 0.0
    for child in group.jobs:
        if child not in sel_jobs and child not in sel_groups:
            continue
        if child in config.jobs:
            total += resolved_job_timeout_sec(
                config, target, config.jobs[child]
            )
        else:
            total += resolved_group_timeout_sec(config, target, child)
    return max(1, int(total * _GROUP_TIMEOUT_PADDING))


# =============================================================================
# APPLIED SNAPSHOT
# =============================================================================
# Apply pins each entry's runtime parameters into a JSON snapshot
# next to the platform unit. The runner reads the snapshot, never
# the live config: editing the toml without `apply` therefore has
# no effect on running units. The hash includes the snapshot so
# any drift forces a re-apply (and audit catches the mismatch).
#
# notify_channels are deliberately NOT pinned -- routing is
# separable from "what runs", and notify edits should take effect
# without a re-apply.


_SNAPSHOT_SCHEMA: int = 2


@dataclass
class JobSnapshot:
    """Resolved runtime parameters for a single job. Most fields are
    final values: paths are pre-expanded (`~` and `$VAR`), timeouts
    are post-cascade. `env` is the deliberate exception -- it stores
    the user's literal toml `env` dict (no parent-process overlay,
    no $VAR expansion). The runner merges it with the inherited
    process env at fire time. Pinning the inherited env would (a)
    make the hash unstable across shell sessions, (b) hand the
    runner whatever SSH_AUTH_SOCK / PATH was in scope when `crony
    apply` happened to run.
    """

    schema: int
    kind: str  # "job"
    name: str  # full namespaced name
    command: str | None
    script: str | None
    args: list[str]
    gate: str | None
    gate_script: str | None
    gate_args: list[str]
    env: dict[str, str]
    job_timeout_sec: int
    # `schedule` and `interval` capture the per-entry config that
    # drove the rendered platform unit, so `crony status` can show
    # the currently-active (applied) schedule independently of any
    # later edit to the live config. Default-None for back-compat
    # with snapshots written before these fields existed; loaders
    # rely on the dataclass default rather than a schema bump.
    schedule: str | None = None
    interval: str | None = None


@dataclass
class GroupSnapshot:
    """Resolved runtime parameters for a job-group. `children` are
    full namespaced names; `group_budget_sec` is the pre-padded
    cumulative deadline computed once at apply time.
    """

    schema: int
    kind: str  # "group"
    name: str  # full namespaced name
    children: list[str]
    group_budget_sec: int
    trigger_timeout_sec: int
    schedule: str | None = None
    interval: str | None = None


def _snapshot_path_for(full_name: str) -> Path:
    return STATE_DIR / full_name / "snapshot.json"


def _resolve_job_snapshot(
    config: Config, target: Target | None, job: Job, full_name: str
) -> JobSnapshot:
    """Build a JobSnapshot by applying every cascade once."""
    args = [_expand_path_field(a) for a in job.args]
    gate_args = [_expand_path_field(a) for a in job.gate_args]
    script = (
        str(_resolve_script(job.script)) if job.script is not None else None
    )
    gate_script = (
        str(_resolve_script(job.gate_script))
        if job.gate_script is not None
        else None
    )
    return JobSnapshot(
        schema=_SNAPSHOT_SCHEMA,
        kind="job",
        name=full_name,
        command=job.command,
        script=script,
        args=args,
        gate=job.gate,
        gate_script=gate_script,
        gate_args=gate_args,
        env=dict(job.env),
        job_timeout_sec=resolved_job_timeout_sec(config, target, job),
        schedule=job.schedule,
        interval=job.interval,
    )


def _resolve_group_snapshot(
    config: Config,
    target: Target | None,
    group: JobGroup,
    bundle_name: str,
    full_name: str,
) -> GroupSnapshot:
    """Build a GroupSnapshot. `group_budget_sec` is recomputed from
    the live config (not from children's pinned snapshots), so an
    apply pass that walks topologically still produces the right
    parent budget regardless of children's prior applied state.

    Children that aren't selected on this host are dropped from
    `children`. That covers both own-filter masks (the child's
    own `platforms` / `hosts` exclude this host) and the
    empty-group cascade (a child group whose own children are all
    masked here). The reference becomes a no-op on this host, so
    a shared bundle can list a host-restricted child from a
    parent group that runs everywhere without the parent
    dispatcher trying to trigger a unit that wasn't installed.
    """
    sel_jobs, sel_groups = selected_jobs_and_groups(config, target)
    children = [
        f"{bundle_name}.{c}"
        for c in group.jobs
        if c in sel_jobs or c in sel_groups
    ]
    return GroupSnapshot(
        schema=_SNAPSHOT_SCHEMA,
        kind="group",
        name=full_name,
        children=children,
        group_budget_sec=resolved_group_timeout_sec(config, target, group.name),
        trigger_timeout_sec=config.defaults.trigger_timeout_sec,
        schedule=group.schedule,
        interval=group.interval,
    )


def _resolve_snapshot_for(
    config: Config,
    short: str,
    bundle_name: str = DEFAULT_BUNDLE_NAME,
) -> JobSnapshot | GroupSnapshot:
    """Resolve a snapshot for a single config entry by short name.

    Convenience for callers that have a Config + short name and
    want the resolved snapshot in one step (apply pipeline + tests
    that exercise the runner without going through full apply).
    """
    full_name = f"{bundle_name}.{short}"
    target = resolve_target(config, current_host(), current_platform())
    if short in config.jobs:
        return _resolve_job_snapshot(
            config, target, config.jobs[short], full_name
        )
    if short in config.job_groups:
        return _resolve_group_snapshot(
            config, target, config.job_groups[short], bundle_name, full_name
        )
    raise PreconditionError(f"unknown job/group: {short!r}")


def _serialize_snapshot(snap: JobSnapshot | GroupSnapshot) -> str:
    """Stable JSON for hash inclusion: sorted keys, no whitespace
    variance. Hash stability matters more than human readability
    -- audit and apply use this same serialization."""
    return json.dumps(
        dataclasses.asdict(snap), sort_keys=True, separators=(",", ":")
    )


def _load_snapshot(full_name: str) -> JobSnapshot | GroupSnapshot:
    """Load and validate a snapshot file. Raises PreconditionError
    if missing (entry not applied) or schema mismatch (re-apply
    required)."""
    p = _snapshot_path_for(full_name)
    if not p.exists():
        raise PreconditionError(
            f"no snapshot for {full_name!r} (run `crony apply` first)"
        )
    try:
        raw = json.loads(p.read_text(encoding="utf-8"))
    except (OSError, json.JSONDecodeError) as e:
        raise PreconditionError(
            f"snapshot for {full_name!r} is unreadable: {e}"
        ) from e
    schema = raw.get("schema")
    if schema != _SNAPSHOT_SCHEMA:
        raise PreconditionError(
            f"snapshot for {full_name!r} has schema {schema!r}, "
            f"expected {_SNAPSHOT_SCHEMA} (re-apply required)"
        )
    kind = raw.get("kind")
    if kind == "job":
        return JobSnapshot(**raw)
    if kind == "group":
        return GroupSnapshot(**raw)
    raise PreconditionError(
        f"snapshot for {full_name!r} has unknown kind {kind!r}"
    )


# =============================================================================
# RUNNER
# =============================================================================
# `crony run <name>` is the platform unit's entry point -- launchd /
# systemd invoke it; it is not a user-facing subcommand. It loads the
# pinned applied snapshot and dispatches to the per-job pipeline or
# the group pipeline. The per-job pipeline acquires a per-job flock,
# runs the optional gate, execs the main command with a wallclock
# cap, writes a structured last-run.json record, and dispatches a
# notification on non-ok exits via the configured channel (log-only,
# email, or ntfy). The group pipeline acquires a group-level lock
# and triggers each named child through its own platform unit
# (launchctl kickstart / systemctl start), waiting synchronously for
# each to exit via a kqueue or pidfd watcher; per-job notifications
# happen inside each child's own run.


@dataclass
class JobRunResult:
    """Recorded as last-run.json for each completed job run."""

    job: str
    host: str
    platform: str
    started_at: str
    ended_at: str
    duration_sec: float
    exit_class: str
    exit_code: int | None
    signal: int | None
    # "none" if no gate ran (no config, or --skip-gate), "passed" on
    # exit 0, "failed" on any non-zero or timeout. The numeric exit
    # code stays in run.log for diagnosis; this field is the binary
    # answer "did the gate let the job run?".
    gate: str
    log_path: str
    log_bytes_this_run: int
    # Per-channel outcomes. Keys are channel names that were
    # attempted (e.g. "email", "ntfy"); values are NotificationResult
    # records. Empty dict means no external dispatch was attempted
    # (notify_channels resolved to []).
    notifications: dict[str, NotificationResult] = field(default_factory=dict)


@dataclass
class GroupChildResult:
    """One child's outcome inside a group run."""

    name: str
    exit_class: str
    exit_code: int


@dataclass
class GroupRunResult:
    """Recorded as last-run.json for each completed group run.

    `exit_class` is a rollup from `jobs_run`: timeout outranks
    fail / signal (which are equally severe), and ok / gated tie
    at the bottom (gating is "intentionally not run", not a
    group-level outcome). The status / audit / list readers
    consult this single field for the group's LAST axis instead
    of re-deriving the rollup on every query.
    """

    group: str
    host: str
    platform: str
    started_at: str
    ended_at: str
    duration_sec: float
    exit_class: str
    log_path: str
    jobs_run: list[GroupChildResult]


def _rollup_group_exit_class(children: list[GroupChildResult]) -> str:
    """Worst-of children's exit_class, with a precedence ladder.

    A group with no children, or one whose children are all `ok`
    or `gated`, rolls up as `ok`: gating is a per-child concept
    ("intentionally not run") that doesn't describe a group-level
    outcome. Any child failure (fail / signal / timeout) surfaces
    as the worst child's exit_class -- timeout outranks fail /
    signal so a group with a timed-out child shows TIMEOUT in the
    status view rather than being masked by a sibling's plain
    fail.
    """
    precedence = {
        "ok": 0,
        "gated": 0,
        "fail": 1,
        "signal": 1,
        "timeout": 2,
    }
    worst_score = 0
    worst_class = "ok"
    for c in children:
        score = precedence.get(c.exit_class, 1)
        if score > worst_score:
            worst_score = score
            worst_class = c.exit_class
    return worst_class


def _state_dir_for(name: str) -> Path:
    """State directory for a named job or group, created on demand."""
    d = STATE_DIR / name
    d.mkdir(parents=True, exist_ok=True)
    return d


def _now_iso() -> str:
    """Current local time in ISO 8601 format with timezone offset."""
    return (
        datetime.datetime.now(datetime.timezone.utc)
        .astimezone()
        .isoformat(timespec="seconds")
    )


@contextlib.contextmanager
def _acquire_lock(lock_path: Path) -> Iterator[None]:
    """Hold an exclusive non-blocking flock on lock_path.

    Raises LockBusyError if another holder has the lock. The lock
    file is left in place across runs; flock guards mutual exclusion.
    """
    fd = open(lock_path, "w")
    try:
        try:
            fcntl.flock(fd, fcntl.LOCK_EX | fcntl.LOCK_NB)
        except BlockingIOError as e:
            raise LockBusyError(
                f"another instance of {lock_path.parent.name} is running"
            ) from e
        try:
            yield
        finally:
            fcntl.flock(fd, fcntl.LOCK_UN)
    finally:
        fd.close()


def _expand_env_value(raw: str, env: dict[str, str]) -> str:
    """Expand `$VAR` / `${VAR}` references in `raw` against `env`.

    Uses `string.Template.safe_substitute` so unresolved references
    stay literal (shell-like behavior: `$NOTHING` becomes the string
    `"$NOTHING"`, not an error). `$$` escapes to a literal `$`. The
    expansion is single-pass: a value that contains another expanded
    value's reference resolves once, not recursively.
    """
    return string.Template(raw).safe_substitute(env)


def _runtime_env(user_env: dict[str, str]) -> dict[str, str]:
    """Build the env dict passed to the wrapped command.

    Carries forward the small set of shell-essential vars from the
    invoking process and overlays `user_env` (the literal dict the
    user wrote in the toml) on top, so users can inject custom
    settings without leaking the full parent env. SSH_AUTH_SOCK is
    included so jobs that need to ssh out (e.g. a remote backup or
    a git pull from a private repo) can talk to the user's running
    ssh-agent without the user having to wire it up per-job. Each
    user_env value is expanded against the running merged env, so a
    job can write `PATH = "/extra:$PATH"` and have $PATH resolve to
    the inherited PATH (or to a value an earlier user_env key set).

    Called at runtime, not apply time: the inherited env is process-
    contextual (SSH_AUTH_SOCK in particular is per-shell-session)
    and pinning it would (a) make the hash unstable across shells,
    (b) hand the runner a stale agent socket from whatever shell
    happened to run `crony apply`. The snapshot stores `user_env`
    only; this helper produces the merged + expanded env at fire
    time.
    """
    env: dict[str, str] = {}
    for k in (
        "HOME",
        "PATH",
        "LANG",
        "LC_ALL",
        "TZ",
        "USER",
        "LOGNAME",
        "SSH_AUTH_SOCK",
    ):
        v = os.environ.get(k)
        if v is not None:
            env[k] = v
    for k, raw in user_env.items():
        env[k] = _expand_env_value(raw, env)
    return env


def _expand_path_field(value: str) -> str:
    """Expand `~` and `$VAR` / `${VAR}` against os.environ.

    Mirrors the `env` value expansion so script paths and argv
    elements can refer to `$HOME` / `$XDG_CONFIG_HOME` / etc. the
    same way a shell-string `command` would. Unresolved variables
    stay literal (matches `_expand_env_value`'s shell-style
    behavior). Path-resolution timing means we expand against
    os.environ, not the per-job runtime env.
    """
    return os.path.expandvars(os.path.expanduser(value))


def _resolve_script(script: str) -> Path:
    """Resolve a `script` field to an absolute path."""
    p = Path(_expand_path_field(script))
    if not p.is_absolute():
        p = (CONFIG_DIR / p).resolve()
    return p


def _command_argv(snap: JobSnapshot) -> list[str]:
    """argv for the job's main command, drawn from the snapshot.

    Snapshot fields are pre-resolved at apply time (script paths
    absolute, `~` and `$VAR` expanded), so this is just argv
    assembly with no further substitution.
    """
    if snap.command is not None:
        return ["/bin/sh", "-c", snap.command]
    assert snap.script is not None
    return [snap.script, *snap.args]


def _gate_argv(snap: JobSnapshot) -> list[str] | None:
    """argv for the gate, or None if the snapshot has no gate."""
    if snap.gate is not None:
        return ["/bin/sh", "-c", snap.gate]
    if snap.gate_script is not None:
        return [snap.gate_script, *snap.gate_args]
    return None


def _crony_executable() -> str:
    """Absolute path to bin/crony for re-invocation by groups.

    Uses `__file__` rather than `sys.argv[0]` so the subprocess
    re-invocation reaches the right binary even when crony has
    been imported as a module (e.g. by the test suite, where
    sys.argv[0] is pytest, not crony).
    """
    return str(Path(__file__).resolve())


def _uv_executable() -> str:
    """Absolute path to `uv`, baked into platform unit files.

    Platform schedulers (launchd, systemd) start a unit's program
    with a minimal PATH that does not include $HOME/.local/bin or
    /opt/homebrew/bin. Crony's PEP 723 shebang `env -S uv run
    --script` therefore can't find uv and exits 127 before the
    script even starts. Resolving uv to an absolute path at apply
    time and writing it directly into the unit's argv sidesteps
    PATH entirely.

    Errors clearly if uv isn't on the agent's PATH at apply time;
    a misconfigured environment shouldn't silently render a unit
    that will fail at run time.
    """
    path = shutil.which("uv")
    if path is None:
        raise PreconditionError(
            "uv not found on PATH; install it (https://docs.astral.sh/uv/) "
            "before running `crony apply`. Platform units bake uv's "
            "absolute path so launchd / systemd don't have to find it "
            "on their minimal PATH."
        )
    return str(Path(path).resolve())


class ExitOutcome(NamedTuple):
    """Outcome of a wrapped subprocess invocation.

    `signal` is set to the killing signal number when the process was
    terminated by a signal, and None when it exited normally. `rc` is
    0 in the signal case and the process's own exit code otherwise.
    """

    rc: int
    signal: int | None


def _exec_with_timeout(
    argv: list[str],
    *,
    env: dict[str, str],
    job_timeout_sec: int,
    log_file: IO[bytes],
) -> ExitOutcome:
    """Exec argv, piping stdout+stderr into log_file.

    On timeout, sends SIGTERM, then SIGKILL after a grace window, and
    re-raises subprocess.TimeoutExpired.
    """
    proc = subprocess.Popen(
        argv,
        stdout=log_file,
        stderr=subprocess.STDOUT,
        env=env,
    )
    try:
        rc = proc.wait(timeout=job_timeout_sec)
    except subprocess.TimeoutExpired:
        proc.terminate()
        try:
            proc.wait(timeout=10)
        except subprocess.TimeoutExpired:
            proc.kill()
            proc.wait()
        raise
    if rc < 0:
        return ExitOutcome(rc=0, signal=-rc)
    return ExitOutcome(rc=rc, signal=None)


def _wait_for_pid_exit(pid: int, timeout: float | None) -> str:
    """Block until `pid` exits, using kernel-level notification.

    Returns "exit" if the pid is gone (exited, never existed, or
    raced into reuse); "timeout" if `timeout` seconds elapsed
    without an exit notification. No polling: darwin uses
    kqueue + EVFILT_PROC + NOTE_EXIT; linux uses
    `os.pidfd_open` + `select.poll`.

    `timeout=None` waits indefinitely. The race-safe path -- pid
    already gone before we register -- is the same on both
    platforms: kqueue.control raises ProcessLookupError, pidfd_open
    raises ProcessLookupError; both translate to "exit".
    """
    if sys.platform == "darwin":
        return _wait_for_pid_exit_kqueue(pid, timeout)
    if sys.platform.startswith("linux"):
        return _wait_for_pid_exit_pidfd(pid, timeout)
    raise CronyError(f"unsupported platform: {sys.platform}")


def _wait_for_pid_exit_kqueue(pid: int, timeout: float | None) -> str:
    # mypy's stubs for `select` are platform-specific: kqueue,
    # kevent, and the KQ_* constants are absent from the Linux
    # stubs. wait_for_pid_exit only dispatches here when
    # sys.platform == "darwin", so the runtime contract is fine;
    # silence the static-checker on each macOS-only attribute.
    import select as _select

    kq = _select.kqueue()  # type: ignore[attr-defined]
    try:
        ev = _select.kevent(  # type: ignore[attr-defined]
            pid,
            filter=_select.KQ_FILTER_PROC,  # type: ignore[attr-defined]
            flags=(
                _select.KQ_EV_ADD  # type: ignore[attr-defined]
                | _select.KQ_EV_ENABLE  # type: ignore[attr-defined]
            ),
            fflags=_select.KQ_NOTE_EXIT,  # type: ignore[attr-defined]
        )
        try:
            kq.control([ev], 0, 0)
        except ProcessLookupError:
            return "exit"
        events = kq.control([], 1, timeout)
        return "exit" if events else "timeout"
    finally:
        kq.close()


def _wait_for_pid_exit_pidfd(pid: int, timeout: float | None) -> str:
    import select as _select

    try:
        fd = os.pidfd_open(pid)  # type: ignore[attr-defined]
    except ProcessLookupError:
        return "exit"
    try:
        poll = _select.poll()
        poll.register(fd, _select.POLLIN)
        ms = -1 if timeout is None else int(timeout * 1000)
        events = poll.poll(ms)
        return "exit" if events else "timeout"
    finally:
        os.close(fd)


def _write_last_run(path: Path, payload: dict[str, Any]) -> None:
    """Atomically write last-run.json so partial writes can't corrupt it.

    Insertion order is preserved (no `sort_keys=True`): top-level keys
    follow dataclass field order, and `notifications` keeps the
    configured channel order so the on-disk record matches what the
    user wrote in the toml.
    """
    tmp = path.with_suffix(".json.tmp")
    tmp.write_text(json.dumps(payload, indent=2))
    tmp.replace(path)


_NOTIFY_TIMEOUT_SEC: int = 15


def _retrieve_secret(
    *,
    keychain_service: str | None,
    keychain_account: str | None = None,
    file_path: str | None,
) -> str | None:
    """Look up a secret value from macOS Keychain or a 0600 file.

    Tries `security find-generic-password` first when a keychain
    service is configured and the host is darwin; falls back to
    reading file_path if the file exists. `keychain_account` is
    optional and disambiguates when multiple keychain items share the
    same service name (the (service, account) pair is the keychain's
    composite identity for generic-password items). Returns None if
    no source is configured or the keychain lookup fails on a darwin
    host. Raises PreconditionError if a secrets file exists but its
    mode allows group / world access -- a config-time check that
    surfaces leaked-credential risk before the runtime path tries to
    use it.
    """
    if keychain_service is not None and sys.platform == "darwin":
        argv = [
            "security",
            "find-generic-password",
            "-s",
            keychain_service,
        ]
        if keychain_account is not None:
            argv.extend(["-a", keychain_account])
        argv.append("-w")
        try:
            r = subprocess.run(
                argv,
                capture_output=True,
                text=True,
                timeout=5,
            )
            if r.returncode == 0:
                return r.stdout.rstrip("\n")
        except (FileNotFoundError, subprocess.TimeoutExpired):
            pass
    if file_path is not None:
        p = Path(os.path.expanduser(file_path))
        if p.exists():
            # Parent directory: require no group / world bits. A
            # 0700 (or 0500) parent prevents leaks of file names /
            # mtimes / sibling presence even when the secret file
            # itself is locked down to 0600.
            parent = p.parent
            parent_mode = parent.stat().st_mode & 0o777
            if parent_mode & 0o077:
                raise PreconditionError(
                    f"secret directory {parent} is mode "
                    f"0o{parent_mode:o}; require no group / world "
                    f"bits (e.g. 0700)"
                )
            mode = p.stat().st_mode & 0o777
            if mode & 0o077:
                raise PreconditionError(
                    f"secret file {p} is mode 0o{mode:o}; require 0600 "
                    f"(group / world readable secrets are unsafe)"
                )
            return p.read_text(encoding="utf-8").rstrip("\n")
    return None


def _format_summary(result: JobRunResult) -> str:
    """One-line-per-field human summary for notification bodies."""
    return (
        f"Job:        {result.job}\n"
        f"Host:       {result.host}\n"
        f"Platform:   {result.platform}\n"
        f"Started:    {result.started_at}\n"
        f"Ended:      {result.ended_at}\n"
        f"Duration:   {result.duration_sec:.1f}s\n"
        f"Exit class: {result.exit_class}\n"
        f"Exit code:  {result.exit_code}\n"
        f"Signal:     {result.signal}\n"
        f"Gate:       {result.gate}\n"
        f"Log path:   {result.log_path}\n"
    )


# Each `crony run` invocation writes a header line to run.log of
# the form:
#   === <ISO ts> <full.name> pid=<N> ===
# `_extract_latest_log_entry` finds the last such header and
# returns everything from there to EOF (the most recent run's
# trace). Used by `crony logs --latest` (single-run readout) and
# the ntfy notify path (3KB inline body instead of a full-log
# attachment).
_RUN_HEADER_RE = re.compile(r"^=== ", re.MULTILINE)


def _extract_latest_log_entry(text: str) -> str:
    """Return the slice from the last `=== ... ===` header to EOF.

    If there is no header (log empty or pre-header content), the
    full text is returned as-is so callers degrade gracefully.
    """
    matches = list(_RUN_HEADER_RE.finditer(text))
    if not matches:
        return text
    return text[matches[-1].start() :]


def _head_truncate_to_kb(text: str, max_kb: int) -> tuple[str, bool]:
    """Tail a string to at most max_kb KB, head-truncating.

    When truncation occurs, the returned text is prepended with a
    one-line marker noting how many bytes were dropped, so
    recipients know the head is missing. The marker counts toward
    the byte cap so the result still fits within max_kb.

    Used by ntfy notifications (where the goal is "show the most
    recent few KB of failure output") and reusable by any other
    transport with a similar size constraint.
    """
    max_bytes = max_kb * 1024
    encoded = text.encode("utf-8")
    if len(encoded) <= max_bytes:
        return text, False
    dropped = len(encoded) - max_bytes
    marker = f"[... {dropped} bytes truncated ...]\n"
    marker_bytes = marker.encode("utf-8")
    keep = max_bytes - len(marker_bytes)
    if keep <= 0:
        # Cap is smaller than the marker itself; degrade to marker
        # alone so the result still indicates truncation rather
        # than silently returning a marker-less stub.
        return marker[:max_bytes], True
    tail = encoded[-keep:].decode("utf-8", errors="replace")
    return marker + tail, True


def _build_email_message(
    result: JobRunResult,
    log_text: str,
    cfg: NotifyEmail,
    attach_log: bool,
    attach_max_kb: int,
    extra_headers: dict[str, str] | None = None,
) -> EmailMessage:
    """Construct the RFC822 EmailMessage for a job failure.

    `extra_headers` is the channel's user-supplied `headers` dict
    -- arbitrary headers like `Reply-To` or `X-Priority` to attach
    to the message. Crony-controlled headers (To / From / Subject)
    are validated out at parse time, so anything reaching here
    is safe to set directly.
    """
    msg = EmailMessage()
    msg["Subject"] = (
        f"[crony/{result.host}] {result.job} {result.exit_class} "
        f"(exit {result.exit_code})"
    )
    msg["From"] = cfg.from_addr or cfg.smtp_user
    msg["To"] = cfg.to
    if extra_headers:
        for k, v in extra_headers.items():
            msg[k] = v
    body = _format_summary(result)
    if attach_log and log_text:
        body += _LOG_SEPARATOR + _format_log_for_notification(
            log_text, attach_max_kb
        )
    msg.set_content(body)
    return msg


def _send_email(msg: EmailMessage, cfg: NotifyEmail, password: str) -> None:
    """SMTP send with optional STARTTLS + AUTH. Raises smtplib errors."""
    with smtplib.SMTP(
        cfg.smtp_host, cfg.smtp_port, timeout=_NOTIFY_TIMEOUT_SEC
    ) as smtp:
        if cfg.smtp_starttls:
            smtp.starttls()
        smtp.login(cfg.smtp_user, password)
        smtp.send_message(msg)


_NTFY_MAX_BODY_KB: int = 3
_LOG_SEPARATOR: str = "\n--- log (latest run) ---\n"


def _format_log_for_notification(log_text: str, max_kb: int) -> str:
    """Most recent run's log entry, head-truncated to max_kb.

    Both notify transports show only the latest run's slice of
    `run.log`: the structured summary already has the metadata
    for the failing run, and the log content older than the
    most recent header would just be noise (and on ntfy would
    bump out the actual diagnostic detail under the 3 KB cap).
    """
    latest = _extract_latest_log_entry(log_text)
    truncated, _trunc = _head_truncate_to_kb(latest, max_kb)
    return truncated


def _build_ntfy_body(summary: str, log_text: str, attach_log: bool) -> bytes:
    """Construct the ntfy POST body.

    Mirrors the email layout (human summary block followed by the
    log) so a recipient subscribed to both transports sees the same
    structured information. The whole body fits inside ntfy's per-
    message budget by sizing the log section to whatever remains
    after the summary; if the log is bigger than that, head-
    truncate it (keeping the tail) so the most recent failure
    output stays visible.

    `attach_log = false` returns the summary alone (matches the
    email path's "summary only when the user opted out of log
    content").
    """
    summary_bytes = summary.encode("utf-8")
    if not (attach_log and log_text):
        return summary_bytes
    sep_bytes = _LOG_SEPARATOR.encode("utf-8")
    max_bytes = _NTFY_MAX_BODY_KB * 1024
    log_budget_bytes = max_bytes - len(summary_bytes) - len(sep_bytes)
    if log_budget_bytes <= 0:
        # Pathological: summary alone exceeds the budget. Keep the
        # summary intact (its structured fields are more useful to
        # the recipient than a truncated stub) and skip the log.
        return summary_bytes
    log_budget_kb = max(1, log_budget_bytes // 1024)
    tail = _format_log_for_notification(log_text, log_budget_kb)
    # Tighten to the byte budget if the kb-rounded helper produced
    # a slightly oversized result (happens when log_budget_bytes
    # isn't a clean multiple of 1024).
    tail_bytes = tail.encode("utf-8")
    if len(tail_bytes) > log_budget_bytes:
        tail_bytes = tail_bytes[-log_budget_bytes:]
    return summary_bytes + sep_bytes + tail_bytes


def _post_ntfy(
    cfg: NotifyNtfy,
    token: str,
    title: str,
    exit_class: str,
    body: str,
    log_text: str,
    attach_log: bool,
    extra_headers: dict[str, str] | None = None,
) -> None:
    """POST to ntfy. Body mirrors the email layout (human summary +
    latest log entry), capped at _NTFY_MAX_BODY_KB. urlopen raises
    HTTPError on >=400 responses; the caller's broad except records
    that as notify_error.

    Inline body, not an attachment: ntfy attachments are publicly
    addressable by URL guessing, so log content goes in the body
    where it's auth-gated by ntfy's regular delivery channel.
    ntfy's per-message limit is 4KB; we cap at 3KB to leave room
    for headers and to keep notifications scannable.

    `extra_headers` is the channel's user-supplied `headers` dict
    -- e.g. `Email = "you@host"` to relay through ntfy's email
    integration, or `Priority = "urgent"` to bump severity. ntfy's
    user-facing headers are unconstrained; crony-controlled keys
    (Authorization / Tags / Title / Filename) are filtered out at
    parse time.
    """
    headers = dict(extra_headers) if extra_headers else {}
    headers["Authorization"] = f"Bearer {token}"
    headers["Title"] = title
    headers["Tags"] = f"warning,{exit_class}"
    data = _build_ntfy_body(body, log_text, attach_log)
    req = urllib.request.Request(
        cfg.url, data=data, headers=headers, method="POST"
    )
    with urllib.request.urlopen(req, timeout=_NOTIFY_TIMEOUT_SEC):
        pass


def _send_email_for(
    channel: NotifyChannel,
    result: JobRunResult,
    log_text: str,
    defaults: Defaults,
) -> None:
    """Send the failure email through the given channel. Raises on any error."""
    if channel.email is None:
        raise ConfigError(
            f"channel {channel.name!r} has no email transport config"
        )
    password = _retrieve_secret(
        keychain_service=channel.email.smtp_pass_keychain_service,
        keychain_account=channel.email.smtp_pass_keychain_account,
        file_path=channel.email.smtp_pass_file,
    )
    if password is None:
        raise ConfigError(
            f"channel {channel.name!r}: no SMTP password available "
            f"(configure smtp_pass_keychain_service or smtp_pass_file)"
        )
    msg = _build_email_message(
        result,
        log_text,
        channel.email,
        defaults.notify_attach_log,
        defaults.notify_attach_max_kb,
        extra_headers=channel.headers,
    )
    _send_email(msg, channel.email, password)


def _send_ntfy_for(
    channel: NotifyChannel,
    result: JobRunResult,
    log_text: str,
    defaults: Defaults,
) -> None:
    """Send the failure ntfy POST through the given channel. Raises on any error."""
    if channel.ntfy is None:
        raise ConfigError(
            f"channel {channel.name!r} has no ntfy transport config"
        )
    token = _retrieve_secret(
        keychain_service=channel.ntfy.token_keychain_service,
        keychain_account=channel.ntfy.token_keychain_account,
        file_path=channel.ntfy.token_file,
    )
    if token is None:
        raise ConfigError(
            f"channel {channel.name!r}: no ntfy token available "
            f"(configure token_keychain_service or token_file)"
        )
    title = (
        f"[crony/{result.host}] {result.job} "
        f"{result.exit_class} (exit {result.exit_code})"
    )
    _post_ntfy(
        channel.ntfy,
        token,
        title,
        result.exit_class,
        _format_summary(result),
        log_text,
        defaults.notify_attach_log,
        extra_headers=channel.headers,
    )


# Per-transport sender table. Each entry takes (channel, result,
# log_text, defaults) and raises on failure. Adding a new transport
# is one new function plus one entry here plus a name in
# _VALID_NOTIFY_TRANSPORTS.
_NOTIFY_DISPATCH: dict[
    str,
    Callable[[NotifyChannel, JobRunResult, str, Defaults], None],
] = {
    "email": _send_email_for,
    "ntfy": _send_ntfy_for,
}

# Pin parser-side and dispatcher-side enumerations together so a
# new transport can never be accepted by the parser but unknown to
# dispatch (or vice versa).
assert set(_NOTIFY_DISPATCH.keys()) == _VALID_NOTIFY_TRANSPORTS, (
    "_NOTIFY_DISPATCH and _VALID_NOTIFY_TRANSPORTS have drifted"
)


def _dispatch_notify(
    result: JobRunResult, log_text: str, defaults: Defaults
) -> None:
    """Fan out to every channel in result.notifications.

    The runner pre-populates result.notifications with the resolved
    channel set (one entry per channel, sent=False). For each, look
    up the bundle's channel definition (containing transport +
    headers + transport config), then dispatch through the
    transport's sender. Per-channel exceptions are recorded so one
    failure doesn't suppress the others.
    """
    for channel_name in list(result.notifications.keys()):
        try:
            channel = defaults.notify_channel_defs.get(channel_name)
            if channel is None:
                raise ConfigError(
                    f"unknown notify channel: {channel_name!r} "
                    f"(no [defaults.notify.{channel_name}] block)"
                )
            sender = _NOTIFY_DISPATCH.get(channel.transport)
            if sender is None:
                raise ConfigError(
                    f"unknown notify transport: {channel.transport!r}"
                )
            sender(channel, result, log_text, defaults)
            result.notifications[channel_name] = NotificationResult(
                sent=True, error=None, error_class=None
            )
        except Exception as e:
            # Notify is best-effort; record the failure on this
            # channel and continue with the next one.
            result.notifications[channel_name] = NotificationResult(
                sent=False,
                error=f"{type(e).__name__}: {e}",
                error_class=type(e).__name__,
            )


def _resolve_notify_at_runtime(
    full_name: str,
) -> tuple[list[str], Defaults]:
    """Look up notify channels + bundle defaults from the live config.

    Notify routing is intentionally NOT pinned in the snapshot:
    edits to notify channels / defaults take effect on the next
    fire without requiring a re-apply. Falls back gracefully when
    the toml entry has been removed -- audit will already be
    flagging the orphan, so log-only here is a coherent degraded
    behavior.
    """
    bn, short = parse_full_name(full_name)
    try:
        bundles = load_all_bundles()
    except (OSError, ConfigError, UsageError):
        return [], Defaults()
    bundle = bundles.by_name(bn)
    if bundle is None:
        return [], Defaults()
    config = bundle.config
    target = resolve_target(config, current_host(), current_platform())
    job = config.jobs.get(short)
    if job is None:
        return list(config.defaults.notify_channels), config.defaults
    return (
        resolved_notify_channels(config, target, job),
        config.defaults,
    )


def run_job(
    snap: JobSnapshot,
    *,
    dry_run: bool = False,
    skip_gate: bool = False,
) -> int:
    """Run a single job from its applied snapshot.

    Returns an exit code suitable for the platform scheduler: the
    wrapped command's exit code on completion (0 on success or any
    nonzero code from the command), ExitCode.LOCK_BUSY on lock
    contention, ExitCode.TIMEOUT on wallclock cap, or 0 for a
    gated/dry-run skip. Precondition failures (missing script) are
    signalled by raising PreconditionError -- cli() maps that to
    ExitCode.PRECONDITION.
    """
    full_name = snap.name

    if snap.script is not None:
        sp = Path(snap.script)
        if not sp.exists():
            raise PreconditionError(f"script not found: {sp}")
        if not os.access(sp, os.X_OK):
            raise PreconditionError(f"script not executable: {sp}")

    sd = _state_dir_for(full_name)
    lock_path = sd / "run.lock"
    log_path = sd / "run.log"
    last_run_path = sd / "last-run.json"
    pid_path = sd / "run.pid"

    notify_channels, notify_defaults = _resolve_notify_at_runtime(full_name)
    job_timeout_sec = snap.job_timeout_sec
    # snap.env stores the user-written env literally; merge with
    # the inherited (process-contextual) env at fire time so
    # SSH_AUTH_SOCK and friends reach the wrapped command.
    env = _runtime_env(snap.env)
    started = time.time()
    started_iso = _now_iso()
    host = current_host()
    platform = current_platform()

    try:
        with _acquire_lock(lock_path):
            if dry_run:
                return 0
            # Publish our pid for waiters (parent groups, `crony
            # trigger --wait`) to watch via kqueue / pidfd. The
            # pid file lives only for the duration of the lock-
            # holding run; cleaned up in `finally`.
            pid_path.write_text(f"{os.getpid()}\n", encoding="utf-8")

            log_size_before = (
                log_path.stat().st_size if log_path.exists() else 0
            )
            log_file = open(log_path, "ab", buffering=0)
            try:
                header = (
                    f"\n=== {started_iso} {full_name} pid={os.getpid()} ===\n"
                ).encode()
                log_file.write(header)

                gate: str = "none"
                gate_argv = _gate_argv(snap)
                if gate_argv is not None and not skip_gate:
                    log_file.write(f"gate: {shlex.join(gate_argv)}\n".encode())
                    gate_rc: int
                    try:
                        gate_proc = subprocess.run(
                            gate_argv,
                            stdout=log_file,
                            stderr=subprocess.STDOUT,
                            env=env,
                            timeout=30,
                        )
                        gate_rc = gate_proc.returncode
                    except subprocess.TimeoutExpired:
                        gate_rc = -1
                    gate = "passed" if gate_rc == 0 else "failed"

                    if gate == "failed":
                        log_file.write(
                            (f"gate exited {gate_rc}: skipping job\n").encode()
                        )
                        result = JobRunResult(
                            job=full_name,
                            host=host,
                            platform=platform,
                            started_at=started_iso,
                            ended_at=_now_iso(),
                            duration_sec=time.time() - started,
                            exit_class="gated",
                            exit_code=0,
                            signal=None,
                            gate=gate,
                            log_path=str(log_path),
                            log_bytes_this_run=(
                                log_path.stat().st_size - log_size_before
                            ),
                            notifications={},
                        )
                        _write_last_run(
                            last_run_path, dataclasses.asdict(result)
                        )
                        return 0

                argv = _command_argv(snap)
                log_file.write(f"exec: {shlex.join(argv)}\n".encode())
                try:
                    rc, sig = _exec_with_timeout(
                        argv,
                        env=env,
                        job_timeout_sec=job_timeout_sec,
                        log_file=log_file,
                    )
                    if sig is not None:
                        exit_class = "signal"
                        exit_code: int | None = None
                    elif rc == 0:
                        exit_class = "ok"
                        exit_code = 0
                    else:
                        exit_class = "fail"
                        exit_code = rc
                    surfaced_rc = rc if sig is None else 128 + sig
                except subprocess.TimeoutExpired:
                    exit_class = "timeout"
                    exit_code = None
                    sig = None
                    surfaced_rc = int(ExitCode.TIMEOUT)

                # Pre-populate per-channel slots with sent=False so
                # the dispatcher can update each entry in place. Order
                # is preserved (Python dict insertion order) so the
                # JSON record reflects the configured channel order.
                notifications: dict[str, NotificationResult] = {
                    ch: NotificationResult(sent=False) for ch in notify_channels
                }
                result = JobRunResult(
                    job=full_name,
                    host=host,
                    platform=platform,
                    started_at=started_iso,
                    ended_at=_now_iso(),
                    duration_sec=time.time() - started,
                    exit_class=exit_class,
                    exit_code=exit_code,
                    signal=sig,
                    gate=gate,
                    log_path=str(log_path),
                    log_bytes_this_run=(
                        log_path.stat().st_size - log_size_before
                    ),
                    notifications=notifications,
                )

                if exit_class != "ok" and notify_channels:
                    log_text = ""
                    try:
                        log_text = log_path.read_text(
                            encoding="utf-8", errors="replace"
                        )[-200_000:]
                    except OSError:
                        pass
                    _dispatch_notify(result, log_text, notify_defaults)

                _write_last_run(last_run_path, dataclasses.asdict(result))
                return surfaced_rc
            finally:
                log_file.close()
                pid_path.unlink(missing_ok=True)
    except LockBusyError:
        with open(log_path, "ab", buffering=0) as f:
            f.write(
                f"[{_now_iso()}] LOCK_BUSY: skipping (already running)\n".encode()
            )
        return int(ExitCode.LOCK_BUSY)


def _child_timeout_from_snapshot(child_full_name: str) -> float:
    """Per-child wait cap for the group runner. Reads the child's
    pinned snapshot rather than the live config, so the cap is
    consistent with what the child's own runner will enforce.
    Falls back to a generous default if the child snapshot is
    missing -- that's an audit-flagged condition, but the trigger
    itself will fail fast and the group's group_budget_sec still
    bounds the wait.
    """
    try:
        cs = _load_snapshot(child_full_name)
    except PreconditionError:
        return float(_DEFAULT_CHILD_TIMEOUT_FALLBACK)
    if isinstance(cs, JobSnapshot):
        return float(cs.job_timeout_sec)
    return float(cs.group_budget_sec)


_DEFAULT_CHILD_TIMEOUT_FALLBACK: int = 1800


def run_group(
    snap: GroupSnapshot,
    *,
    dry_run: bool = False,
    skip_gate: bool = False,
) -> int:
    """Run a job-group from its applied snapshot.

    Fires each child through the platform scheduler in order,
    waiting for completion via kernel-level pid-exit notification
    (`_trigger_unit_sync`). The group's `run.log` becomes a
    sequencer trace (fired/finished lines per child); child
    stdout/stderr stays in each child's own log. The group never
    sends notifications; each child's own runner handles notify
    per the cascade.

    The cumulative deadline (`snap.group_budget_sec`) was pinned
    at apply time. Per-child wait cap pulls the child's pinned
    timeout from its own snapshot so cap and child enforcement
    agree. `skip_gate` is intentionally unused -- the child's
    runner reads its own snapshot and applies the gate itself.
    """
    full_name = snap.name
    group_budget = snap.group_budget_sec
    trigger_timeout = snap.trigger_timeout_sec

    sd = _state_dir_for(full_name)
    lock_path = sd / "run.lock"
    log_path = sd / "run.log"
    last_run_path = sd / "last-run.json"
    pid_path = sd / "run.pid"

    started = time.time()
    started_iso = _now_iso()
    host = current_host()
    platform = current_platform()

    try:
        with _acquire_lock(lock_path):
            if dry_run:
                return 0
            pid_path.write_text(f"{os.getpid()}\n", encoding="utf-8")

            log_file = open(log_path, "ab", buffering=0)
            children: list[GroupChildResult] = []
            try:
                child_full = list(snap.children)
                header = (
                    f"\n=== {started_iso} group {full_name} "
                    f"budget={group_budget}s "
                    f"children={child_full} ===\n"
                ).encode()
                log_file.write(header)

                deadline = time.monotonic() + group_budget
                for child_full_name in child_full:
                    remaining = deadline - time.monotonic()
                    if remaining <= 0:
                        log_file.write(
                            (
                                f"-> {child_full_name}: TIMEOUT "
                                f"(group budget exhausted)\n"
                            ).encode()
                        )
                        children.append(
                            GroupChildResult(
                                name=child_full_name,
                                exit_class="timeout",
                                exit_code=int(ExitCode.TIMEOUT),
                            )
                        )
                        continue

                    child_timeout = _child_timeout_from_snapshot(
                        child_full_name
                    )
                    child_wait = min(child_timeout, remaining)

                    log_file.write(
                        (
                            f"-> {child_full_name} "
                            f"(timeout={child_wait:.0f}s)\n"
                        ).encode()
                    )
                    try:
                        rec = _trigger_unit_sync(
                            child_full_name,
                            job_timeout=child_wait,
                            trigger_timeout=trigger_timeout,
                        )
                    except TriggerStartTimeout as e:
                        log_file.write(f"   {e}\n".encode())
                        children.append(
                            GroupChildResult(
                                name=child_full_name,
                                exit_class="timeout",
                                exit_code=int(ExitCode.TIMEOUT),
                            )
                        )
                        continue
                    cls = rec.get("exit_class", "fail")
                    rc = _trigger_exit_code(rec)
                    log_file.write(f"   finished: {cls} (exit {rc})\n".encode())
                    children.append(
                        GroupChildResult(
                            name=child_full_name,
                            exit_class=cls,
                            exit_code=rc,
                        )
                    )

                result = GroupRunResult(
                    group=full_name,
                    host=host,
                    platform=platform,
                    started_at=started_iso,
                    ended_at=_now_iso(),
                    duration_sec=time.time() - started,
                    exit_class=_rollup_group_exit_class(children),
                    log_path=str(log_path),
                    jobs_run=children,
                )
                _write_last_run(last_run_path, dataclasses.asdict(result))
                return 0
            finally:
                log_file.close()
                pid_path.unlink(missing_ok=True)
    except LockBusyError:
        with open(log_path, "ab", buffering=0) as f:
            f.write(
                f"[{_now_iso()}] LOCK_BUSY: skipping (already running)\n".encode()
            )
        return int(ExitCode.LOCK_BUSY)


# =============================================================================
# PLATFORM UNITS
# =============================================================================
# Render and (un)load platform-native scheduler units. crony's
# "behaves the same on both platforms" promise is concentrated here:
# darwin/linux divergence in apply/destroy lives in this section.
# Anywhere else in the file is platform-agnostic.

_DOW_TO_LAUNCHD: dict[str, int] = {
    "sun": 0,
    "mon": 1,
    "tue": 2,
    "wed": 3,
    "thu": 4,
    "fri": 5,
    "sat": 6,
}


def _label_for(name: str) -> str:
    """launchd Label for a job/group."""
    return f"org.{BASENAME}.{name}"


def _plist_path_for(name: str) -> Path:
    return LAUNCHAGENTS_DIR / f"{_label_for(name)}.plist"


def _service_path_for(name: str) -> Path:
    return SYSTEMD_USER_DIR / f"{BASENAME}-{name}.service"


def _timer_path_for(name: str) -> Path:
    return SYSTEMD_USER_DIR / f"{BASENAME}-{name}.timer"


def _hash_path_for(name: str) -> Path:
    return STATE_DIR / name / "hash"


def _systemd_unit_name(name: str) -> str:
    return f"{BASENAME}-{name}.timer"


def _oncalendar_to_plist_calendar(spec: str) -> dict[str, int]:
    """Translate an OnCalendar spec to a launchd StartCalendarInterval.

    Supports keywords (hourly, daily, weekly, monthly, yearly), bare
    HH:MM, and the `[DOW] *-*-* HH:MM` shape with a single concrete
    day or month. Step values, ranges, and comma-lists are rejected
    here -- they would require expanding to many entries that crony
    doesn't yet generate, so the error explicitly suggests using a
    simpler schedule form.
    """
    text = spec.strip()
    keywords: dict[str, dict[str, int]] = {
        "hourly": {"Minute": 0},
        "daily": {"Hour": 0, "Minute": 0},
        "weekly": {"Weekday": 1, "Hour": 0, "Minute": 0},
        "monthly": {"Day": 1, "Hour": 0, "Minute": 0},
        "yearly": {"Month": 1, "Day": 1, "Hour": 0, "Minute": 0},
        "annually": {"Month": 1, "Day": 1, "Hour": 0, "Minute": 0},
    }
    if text in keywords:
        return keywords[text]
    if "/" in text or ".." in text or "," in text:
        raise ConfigError(
            f"OnCalendar pattern {spec!r} uses step / range / list "
            f"features that crony does not translate to launchd. "
            f"Use a single concrete time or weekday/day entry."
        )
    parts = text.split()
    dow: int | None = None
    if parts and parts[0].lower() in _DOW_TO_LAUNCHD:
        dow = _DOW_TO_LAUNCHD[parts[0].lower()]
        parts = parts[1:]
    time_re = re.compile(r"^(\d{1,2}):(\d{2})(?::\d{2})?$")
    if len(parts) == 1 and time_re.fullmatch(parts[0]):
        m = time_re.fullmatch(parts[0])
        assert m is not None
        entry: dict[str, int] = {
            "Hour": int(m.group(1)),
            "Minute": int(m.group(2)),
        }
        if dow is not None:
            entry["Weekday"] = dow
        return entry
    date_re = re.compile(r"^(\*|\d{4})-(\*|\d{1,2})-(\*|\d{1,2})$")
    if len(parts) == 2:
        d = date_re.fullmatch(parts[0])
        t = time_re.fullmatch(parts[1])
        if d and t:
            e: dict[str, int] = {
                "Hour": int(t.group(1)),
                "Minute": int(t.group(2)),
            }
            if d.group(2) != "*":
                e["Month"] = int(d.group(2))
            if d.group(3) != "*":
                e["Day"] = int(d.group(3))
            if dow is not None:
                e["Weekday"] = dow
            return e
    raise ConfigError(
        f"crony does not yet translate OnCalendar pattern {spec!r} "
        f"to launchd. Try a simpler form like '03:15' or "
        f"'*-*-* 03:15' or 'Mon *-*-* 09:00'."
    )


def _render_plist(name: str, schedule: str | None, interval: str | None) -> str:
    """Render the LaunchAgent plist XML for a job or group.

    ProgramArguments invokes uv with absolute paths rather than
    relying on the script's `env -S uv run --script` shebang.
    launchd's per-agent PATH is `/usr/bin:/bin:/usr/sbin:/sbin`,
    which doesn't contain uv, so the shebang's `env` lookup fails
    with exit 127 before crony can run at all.
    """
    label = _label_for(name)
    program_args = [
        _uv_executable(),
        "run",
        "--script",
        _crony_executable(),
        "run",
        name,
    ]
    args_xml = "".join(
        f"        <string>{xml.sax.saxutils.escape(a)}</string>\n"
        for a in program_args
    )
    sched_block = ""
    if interval is not None:
        sec = parse_interval_seconds(interval)
        sched_block = (
            f"    <key>StartInterval</key>\n    <integer>{sec}</integer>\n"
        )
    elif schedule is not None:
        entry = _oncalendar_to_plist_calendar(schedule)
        sched_block = "    <key>StartCalendarInterval</key>\n"
        sched_block += "    <dict>\n"
        for k, v in sorted(entry.items()):
            sched_block += f"        <key>{k}</key>\n"
            sched_block += f"        <integer>{v}</integer>\n"
        sched_block += "    </dict>\n"
    return (
        '<?xml version="1.0" encoding="UTF-8"?>\n'
        '<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" '
        '"http://www.apple.com/DTDs/PropertyList-1.0.dtd">\n'
        '<plist version="1.0">\n'
        "<dict>\n"
        f"    <key>Label</key>\n"
        f"    <string>{label}</string>\n"
        f"    <key>ProgramArguments</key>\n"
        f"    <array>\n"
        f"{args_xml}"
        f"    </array>\n"
        "    <key>RunAtLoad</key>\n"
        "    <false/>\n"
        "    <key>KeepAlive</key>\n"
        "    <false/>\n"
        "    <key>AbandonProcessGroup</key>\n"
        "    <false/>\n"
        f"{sched_block}"
        "</dict>\n"
        "</plist>\n"
    )


def _render_systemd_service(name: str) -> str:
    """Render the systemd .service unit. Independent of schedule.

    ExecStart invokes uv with absolute paths -- same reason as for
    plist (see _render_plist's docstring).
    """
    uv_path = _uv_executable()
    crony_path = _crony_executable()
    return (
        "[Unit]\n"
        f"Description=crony job {name}\n"
        "\n"
        "[Service]\n"
        "Type=oneshot\n"
        f"ExecStart={uv_path} run --script {crony_path} run {name}\n"
        "WorkingDirectory=%h\n"
    )


def _render_systemd_timer(
    name: str, schedule: str | None, interval: str | None
) -> str:
    """Render the systemd .timer unit."""
    if interval is not None:
        spec_line = f"OnUnitActiveSec={interval}\n"
    else:
        assert schedule is not None
        spec_line = f"OnCalendar={schedule}\n"
    return (
        "[Unit]\n"
        f"Description=crony timer for {name}\n"
        "\n"
        "[Timer]\n"
        f"{spec_line}"
        "Persistent=true\n"
        "\n"
        "[Install]\n"
        "WantedBy=timers.target\n"
    )


def _render_units(
    name: str,
    schedule: str | None,
    interval: str | None,
    platform: str,
) -> dict[str, str]:
    """Return {filename: content} for the platform units of (name, schedule).

    Every job and group gets a unit so it's individually triggerable
    via the platform scheduler, regardless of whether it has its own
    schedule. Schedule-less entries (transit groups, group-only jobs)
    install a unit that just sits dormant until something fires it
    -- either `crony trigger` or a parent group dispatching it.

    On darwin, that's a plist with no Start* keys (RunAtLoad=false,
    so loading doesn't auto-fire). On linux, only the .service file
    is rendered for schedule-less entries; the .timer is omitted
    because a timer with no triggering condition is dead weight.
    """
    if platform == "darwin":
        return {
            f"{_label_for(name)}.plist": _render_plist(name, schedule, interval)
        }
    units = {
        f"{BASENAME}-{name}.service": _render_systemd_service(name),
    }
    if schedule is not None or interval is not None:
        units[f"{BASENAME}-{name}.timer"] = _render_systemd_timer(
            name, schedule, interval
        )
    return units


def _entity_schedule(
    entry: Job | JobGroup,
) -> tuple[str | None, str | None]:
    """Return (schedule, interval) for either entity kind."""
    return entry.schedule, entry.interval


def _schedule_display(schedule: str | None, interval: str | None) -> str:
    """Render a (schedule, interval) pair into one cell value.

    Schedule wins over interval when both are set (matching apply's
    rendering precedence). An entry with neither -- a transit group
    or a group-only job -- displays as `grouped` to mirror the
    UNIT axis value for the same condition.
    """
    if schedule is not None:
        return schedule
    if interval is not None:
        return f"interval={interval}"
    return "grouped"


def _compute_unit_hash(
    name: str,
    entry: Job | JobGroup,
    platform: str,
    snapshot: JobSnapshot | GroupSnapshot,
) -> str:
    """SHA-256 of rendered unit content + serialized snapshot.

    The snapshot covers everything the runner consumes (command,
    gate, env, timeouts, group children + budget); including it
    in the hash means an edit to any of those fields flips the
    hash, so apply reports updated and audit catches drift.
    """
    schedule, interval = _entity_schedule(entry)
    units = _render_units(name, schedule, interval, platform)
    h = hashlib.sha256()
    for fname in sorted(units):
        h.update(fname.encode("utf-8"))
        h.update(b"\0")
        h.update(units[fname].encode("utf-8"))
        h.update(b"\0")
    h.update(b"snapshot\0")
    h.update(_serialize_snapshot(snapshot).encode("utf-8"))
    return h.hexdigest()


def _activate_unit(
    name: str,
    platform: str,
    *,
    prior_disabled: bool = False,
    scheduled: bool = True,
) -> None:
    """Load the unit into the platform scheduler.

    `prior_disabled=True` preserves a hand-disabled state across an
    apply re-render: the unit is reloaded so the new content takes
    effect, but the persistent disable record is restored afterward
    so the scheduler doesn't fire it. Without this, a `crony disable
    foo` followed by an unrelated config edit would silently re-arm
    foo.

    `scheduled=False` means the entry has no schedule / interval.
    On linux that means there's no .timer to enable; only the
    .service is registered (oneshot, sits dormant until something
    starts it). The plist analog is the same -- a plist with no
    Start* keys loads fine and just doesn't auto-fire.
    """
    if platform == "darwin":
        plist = _plist_path_for(name)
        # Validate the plist before asking launchd to load it -- a
        # parseable failure here is much clearer than launchd's
        # silent error path. `-s` keeps stdout quiet on success
        # (default plutil prints `<path>: OK` per file, which
        # would clutter `apply`'s per-entry output).
        subprocess.run(["plutil", "-s", str(plist)], check=True)
        # unload-then-load: tolerates "not loaded" (errok) so a clean
        # re-apply over a previously-installed unit just works.
        subprocess.run(
            ["launchctl", "unload", str(plist)],
            stderr=subprocess.DEVNULL,
        )
        subprocess.run(["launchctl", "load", str(plist)], check=True)
        if prior_disabled:
            label = _label_for(name)
            subprocess.run(
                ["launchctl", "unload", str(plist)],
                stderr=subprocess.DEVNULL,
            )
            subprocess.run(
                [
                    "launchctl",
                    "disable",
                    f"gui/{os.getuid()}/{label}",
                ],
                check=True,
            )
        return
    # linux: daemon-reload picks up the new content. `enable --now`
    # only applies to the .timer, which we only render for scheduled
    # entries; for schedule-less entries the .service alone is
    # enough (it sits in the unit catalog, ready for `systemctl
    # start` to fire it).
    # `--quiet` suppresses systemctl's "Created symlink ..."
    # informational chatter on enable/disable so `crony apply`
    # output stays focused on the apply-level summary lines.
    # Real errors still print to stderr; --quiet only suppresses
    # the success-path notices.
    subprocess.run(
        ["systemctl", "--user", "--quiet", "daemon-reload"], check=True
    )
    if scheduled and not prior_disabled:
        subprocess.run(
            [
                "systemctl",
                "--user",
                "--quiet",
                "enable",
                "--now",
                _systemd_unit_name(name),
            ],
            check=True,
        )


def _deactivate_unit(name: str, platform: str) -> None:
    """Remove the unit from the platform scheduler. Errok throughout
    so destroy never fails just because the unit was already gone.
    """
    if platform == "darwin":
        plist = _plist_path_for(name)
        if plist.exists():
            subprocess.run(
                ["launchctl", "unload", str(plist)],
                stderr=subprocess.DEVNULL,
            )
    else:
        subprocess.run(
            [
                "systemctl",
                "--user",
                "--quiet",
                "disable",
                "--now",
                _systemd_unit_name(name),
            ],
            stderr=subprocess.DEVNULL,
        )
        subprocess.run(
            ["systemctl", "--user", "--quiet", "daemon-reload"],
            stderr=subprocess.DEVNULL,
        )


def apply_one(
    config: Config,
    name: str,
    *,
    dry_run: bool = False,
    bundle_name: str = DEFAULT_BUNDLE_NAME,
) -> str:
    """Apply a single job or group; return "added", "updated", or
    "unchanged".

    `name` is the short name (as written in the bundle's TOML);
    `bundle_name` defaults to "default". The full namespaced name
    `<bundle_name>.<name>` is what lands on disk (hash stamp,
    plist / systemd unit identifier).

    Every entry installs a platform unit, even schedule-less ones:
    a transit group's plist sits dormant until a parent dispatches
    it (or `crony trigger` fires it explicitly). On linux, only the
    .service file is installed for schedule-less entries; the
    .timer (which would have nothing to trigger on) is omitted, and
    apply cleans up a stale .timer if an entry transitions
    scheduled -> unscheduled.
    """
    if name in config.jobs:
        entry: Job | JobGroup = config.jobs[name]
    elif name in config.job_groups:
        entry = config.job_groups[name]
    else:
        raise PreconditionError(f"unknown job/group: {name!r}")
    full_name = f"{bundle_name}.{name}"

    schedule, interval = _entity_schedule(entry)
    platform = current_platform()
    hash_path = _hash_path_for(full_name)
    snapshot_path = _snapshot_path_for(full_name)
    target = resolve_target(config, current_host(), platform)
    if isinstance(entry, Job):
        snapshot: JobSnapshot | GroupSnapshot = _resolve_job_snapshot(
            config, target, entry, full_name
        )
    else:
        snapshot = _resolve_group_snapshot(
            config, target, entry, bundle_name, full_name
        )
    new_hash = _compute_unit_hash(full_name, entry, platform, snapshot)
    old_hash = hash_path.read_text().strip() if hash_path.exists() else None

    if old_hash == new_hash:
        return "unchanged"

    if dry_run:
        return "added" if old_hash is None else "updated"

    # Capture runtime state BEFORE we re-render so a hand-disabled
    # unit stays disabled across the re-load. The scheduler view
    # is the source of truth here (the platform unit can outlive
    # the state-dir hash); _unit_state returns "none" for a
    # not-yet-installed unit, so only an explicit "disabled"
    # answer counts and a fresh install still lands enabled.
    prior_disabled = _unit_state(full_name, platform) == "disabled"
    units = _render_units(full_name, schedule, interval, platform)
    target_dir = LAUNCHAGENTS_DIR if platform == "darwin" else SYSTEMD_USER_DIR
    target_dir.mkdir(parents=True, exist_ok=True)
    # Clean up any previously-installed unit files for this name
    # that aren't in the current render set (handles a scheduled
    # -> unscheduled transition where the .timer should be removed).
    if platform == "linux":
        timer_path = _timer_path_for(full_name)
        if timer_path.name not in units and timer_path.exists():
            # Disable the orphaned timer in the scheduler's view
            # before unlinking the file.
            subprocess.run(
                [
                    "systemctl",
                    "--user",
                    "--quiet",
                    "disable",
                    "--now",
                    timer_path.name,
                ],
                stderr=subprocess.DEVNULL,
            )
            timer_path.unlink()
    for fname, content in units.items():
        (target_dir / fname).write_text(content, encoding="utf-8")
    _activate_unit(
        full_name,
        platform,
        prior_disabled=prior_disabled,
        scheduled=schedule is not None or interval is not None,
    )

    # Snapshot first, hash second: a stale snapshot without a
    # matching hash is detectable by audit (hash mismatch); the
    # reverse (hash present, snapshot missing) would let the
    # runner fail to load the snapshot on a fire it should have
    # been able to handle.
    snapshot_path.parent.mkdir(parents=True, exist_ok=True)
    snapshot_path.write_text(
        json.dumps(dataclasses.asdict(snapshot), indent=2, sort_keys=True)
        + "\n",
        encoding="utf-8",
    )
    hash_path.parent.mkdir(parents=True, exist_ok=True)
    hash_path.write_text(new_hash + "\n", encoding="utf-8")
    return "added" if old_hash is None else "updated"


def destroy_one(name: str, *, preserve_runtime: bool = False) -> None:
    """Remove a single name's platform unit and apply-time state.

    Default wipes the entire entry dir along with the platform
    unit files, leaving no on-disk trace of the entry on this
    host. `preserve_runtime=True` keeps the run-time artifacts
    (run.log, last-run.json, run.lock) so a later post-mortem is
    still possible -- only the unit, hash, and snapshot are
    removed. Errok throughout so a partially-installed unit can
    still be cleaned up.
    """
    platform = current_platform()
    _deactivate_unit(name, platform)
    if platform == "darwin":
        _plist_path_for(name).unlink(missing_ok=True)
    else:
        _service_path_for(name).unlink(missing_ok=True)
        _timer_path_for(name).unlink(missing_ok=True)
    if preserve_runtime:
        _hash_path_for(name).unlink(missing_ok=True)
        _snapshot_path_for(name).unlink(missing_ok=True)
    else:
        sd = STATE_DIR / name
        if sd.exists():
            shutil.rmtree(sd)


def _state_dir_stamps() -> set[str]:
    """Names whose state dir contains a `hash` stamp."""
    if not STATE_DIR.exists():
        return set()
    return {d.name for d in STATE_DIR.iterdir() if (d / "hash").is_file()}


def _state_dir_names() -> set[str]:
    """Names with a state dir on this host, with or without a hash.

    Broader than `_state_dir_stamps()`: a state dir whose `hash`
    was stripped by a `--preserve-runtime` destroy still counts.
    These are the leftover-runtime cases (`run.log`,
    `last-run.json`, `run.lock`) that the opt-in
    `--preserve-runtime` flag deliberately keeps for post-mortem.
    """
    if not STATE_DIR.exists():
        return set()
    return {d.name for d in STATE_DIR.iterdir() if d.is_dir()}


def _platform_unit_names() -> set[str]:
    """Names with a crony-managed platform unit file on this host.

    Walks the platform's user-unit directory and returns every
    full-namespaced name encoded in a crony-shaped filename. Used
    to discover entries whose unit landed on disk but whose state
    dir is missing -- e.g. a state wipe (rm -rf
    ~/.local/state/crony/) without `crony destroy` first. Without
    this, those units would be invisible to status / audit /
    destroy and the user would have to track them down manually.
    """
    names: set[str] = set()
    if LAUNCHAGENTS_DIR.exists():
        prefix = f"org.{BASENAME}."
        suffix = ".plist"
        for p in LAUNCHAGENTS_DIR.iterdir():
            if p.name.startswith(prefix) and p.name.endswith(suffix):
                names.add(p.name[len(prefix) : -len(suffix)])
    if SYSTEMD_USER_DIR.exists():
        prefix = f"{BASENAME}-"
        for suffix in (".service", ".timer"):
            for p in SYSTEMD_USER_DIR.iterdir():
                if p.name.startswith(prefix) and p.name.endswith(suffix):
                    names.add(p.name[len(prefix) : -len(suffix)])
    return names


def stamped_names() -> set[str]:
    """Names crony has actively installed on this host.

    Union of `_state_dir_stamps()` (hash present, the normal
    "applied via crony" case) and `_platform_unit_names()` (units
    lingering on disk after a state wipe). Either signal is enough
    to treat the entry as actionable: with hash-only, we have the
    hash to detect drift; with unit-only, we can still report
    the entry as `orphan` and let `crony destroy` clean up the
    unit files.

    Used by callers that need an entry actually wired up on the
    host: `apply` (orphan removal), `enable`, `disable`,
    `trigger`. For the broader "any leftover" set that includes
    state-dir-only remnants from prior non-purge destroys, see
    `discovered_names()`.
    """
    return _state_dir_stamps() | _platform_unit_names()


def discovered_names() -> set[str]:
    """Every name crony has any on-disk remnant of on this host.

    Superset of `stamped_names()` that also includes state dirs
    surviving from a `--preserve-runtime` destroy -- the dir
    lingers with `run.log` / `last-run.json` / `run.lock` but no
    hash and no unit. Without this set those names would be
    invisible to status / audit / destroy, and a follow-up
    destroy could not find them to clean up.
    """
    return _state_dir_names() | _platform_unit_names()


# =============================================================================
# RUNTIME STATE (enable / disable / status / linger)
# =============================================================================
# Runtime state is the platform scheduler's "will I fire this unit?"
# answer. It's orthogonal to CONFIG state: a unit can be `synced` with
# config but `disabled` at runtime because the user paused it. apply
# preserves this state across re-renders so a hand-disabled job stays
# off when the user runs `crony apply` to push other changes.


def _current_user() -> str:
    """Best-effort resolution of the invoking user's name.

    Used for linger lookup. Falls back through env vars and getpwuid
    in turn so the typical Unix shell environment is enough.
    """
    for env_key in ("USER", "LOGNAME"):
        v = os.environ.get(env_key)
        if v:
            return v
    try:
        import pwd

        return pwd.getpwuid(os.getuid()).pw_name
    except (ImportError, KeyError):
        return ""


def linger_enabled(user: str | None = None) -> bool | None:
    """Return True/False/None for "is linger enabled for this user?"

    Linger keeps a user's systemd manager running across logouts, which
    is what allows scheduled timers to fire when the user isn't logged
    in. Without it, a "daily 03:00" job silently no-ops.

    Order of operations: check the world-readable sentinel file first
    so the common case is a single stat() with no subprocess. Fall
    back to `loginctl show-user --property=Linger` for systems that
    expose linger differently. Returns None when neither path can
    answer (no logind, command missing, etc.).
    """
    name = user or _current_user()
    if not name:
        return None
    sentinel = Path(f"/var/lib/systemd/linger/{name}")
    if sentinel.exists():
        return True
    try:
        result = subprocess.run(
            [
                "loginctl",
                "show-user",
                name,
                "--property=Linger",
            ],
            capture_output=True,
            text=True,
            timeout=5,
        )
    except (FileNotFoundError, subprocess.TimeoutExpired):
        return None
    if result.returncode != 0:
        return None
    line = result.stdout.strip()
    if line.endswith("=yes"):
        return True
    if line.endswith("=no"):
        return False
    return None


def _systemd_is_enabled(unit: str) -> str:
    """Return systemctl --user is-enabled output, or '' on failure."""
    try:
        r = subprocess.run(
            ["systemctl", "--user", "is-enabled", unit],
            capture_output=True,
            text=True,
            timeout=5,
        )
    except (FileNotFoundError, subprocess.TimeoutExpired):
        return ""
    return r.stdout.strip()


def _launchctl_print_disabled() -> str:
    """Stdout of `launchctl print-disabled gui/<uid>`; empty on failure."""
    try:
        r = subprocess.run(
            ["launchctl", "print-disabled", f"gui/{os.getuid()}"],
            capture_output=True,
            text=True,
            timeout=5,
        )
    except (FileNotFoundError, subprocess.TimeoutExpired):
        return ""
    return r.stdout


def _launchctl_list() -> str:
    """Stdout of `launchctl list`; empty on failure."""
    try:
        r = subprocess.run(
            ["launchctl", "list"],
            capture_output=True,
            text=True,
            timeout=5,
        )
    except (FileNotFoundError, subprocess.TimeoutExpired):
        return ""
    return r.stdout


def _unit_state(name: str, platform: str) -> str:
    """Return UNIT axis value for a stamped entity.

    Distinct from CONFIG: a unit can be configured-and-stamped while
    being disabled at the platform scheduler. Group-only entries
    (no schedule, no interval) report `grouped`; their callers fire
    them via subprocess invocation rather than the scheduler.
    `none` means the platform scheduler doesn't know about a unit
    by this name -- nothing instantiated to flip on or off.
    """
    if platform == "linux":
        unit = _systemd_unit_name(name)
        state = _systemd_is_enabled(unit)
        if state == "enabled":
            return "enabled"
        if state in ("disabled", "masked"):
            return "disabled"
        if state == "static":
            return "enabled"
        return "none"
    # darwin
    label = _label_for(name)
    if _is_launchd_disabled(label):
        return "disabled"
    if _is_launchd_loaded(label):
        return "enabled"
    return "none"


def _is_launchd_disabled(label: str) -> bool:
    """True if `launchctl print-disabled` reports `label` disabled."""
    out = _launchctl_print_disabled()
    return f'"{label}" => disabled' in out or f'"{label}" => true' in out


def _is_launchd_loaded(label: str) -> bool:
    """True if `launchctl list` shows the label as loaded.

    `launchctl list` lines have the form `<pid>\\t<exit>\\t<label>`.
    A pid of `-` means loaded-but-idle (the normal between-fires state
    for a calendar-scheduled agent), so we don't filter on pid here.
    Trailing whitespace is tolerated for forward-compat with future
    launchctl output formats.
    """
    out = _launchctl_list()
    for raw in out.splitlines():
        line = raw.rstrip()
        if "\t" in line and line.split("\t")[-1] == label:
            return True
    return False


def _last_run_state(name: str) -> str:
    """Return LAST axis value for a stamped entity.

    Lock-held implies a run is currently in flight; otherwise read
    last-run.json's recorded exit_class. Absence of either means the
    entity has never run -- new install, group-only job that's never
    been triggered, etc.
    """
    sd = STATE_DIR / name
    lock_path = sd / "run.lock"
    if lock_path.exists():
        try:
            with _acquire_lock(lock_path):
                pass
        except LockBusyError:
            return "running"
    last_run = sd / "last-run.json"
    if not last_run.exists():
        return "never"
    try:
        raw = json.loads(last_run.read_text(encoding="utf-8"))
    except (OSError, json.JSONDecodeError):
        return "unknown"
    cls = raw.get("exit_class")
    if cls in ("ok", "fail", "timeout", "gated", "signal"):
        return cls if cls != "signal" else "fail"
    return "unknown"


def _last_ran_at(name: str) -> str:
    """Return a compact "when did this last run" string for status.

    Reads the entity's `last-run.json` and formats `started_at` as
    a relative-time string (e.g. "5m ago", "3h ago", "2d ago").
    Returns "never" when there's no last-run record and "unknown"
    when the file exists but its timestamp is unreadable.
    """
    sd = STATE_DIR / name
    last_run = sd / "last-run.json"
    if not last_run.exists():
        return "never"
    try:
        raw = json.loads(last_run.read_text(encoding="utf-8"))
    except (OSError, json.JSONDecodeError):
        return "unknown"
    started = raw.get("started_at")
    if not started:
        return "unknown"
    try:
        dt = datetime.datetime.fromisoformat(started)
    except ValueError:
        return "unknown"
    now = datetime.datetime.now(datetime.timezone.utc).astimezone()
    secs = int((now - dt).total_seconds())
    if secs < 0:
        # Clock skew or a future-dated record; surface explicitly
        # rather than rendering "0s ago" which would mislead.
        return "future"
    if secs < 60:
        return f"{secs}s ago"
    if secs < 3600:
        return f"{secs // 60}m ago"
    if secs < 86400:
        return f"{secs // 3600}h ago"
    return f"{secs // 86400}d ago"


def _config_state(
    config: Config,
    name: str,
    platform: str,
    *,
    bundle_name: str = DEFAULT_BUNDLE_NAME,
) -> str:
    """Default-bundle-flavored wrapper around _config_state_for.

    `name` is the short name; the full namespaced name is computed
    as `<bundle_name>.<name>` (default bundle by default).
    """
    return _config_state_for(config, name, f"{bundle_name}.{name}", platform)


def _config_state_for(
    config: Config, short: str, full_name: str, platform: str
) -> str:
    """Return CONFIG axis value: synced / stale / missing / orphan.

    `short` is the bundle-local name (used to look up the entry in
    `config`); `full_name` is the namespaced name used for the
    on-disk hash stamp and unit identifier.

    A "remnant" here is any signal that crony has on-disk state
    for this entry: the state-dir hash, a leftover platform unit
    file, or a state dir surviving a non-purge destroy. All three
    surface as orphans for destroy when the entry isn't in config.
    A "stamp" is the narrower hash-or-unit set -- the entry is
    actively installed and apply / enable / disable / trigger can
    operate on it.
    """
    in_config = short in config.jobs or short in config.job_groups
    hash_path = _hash_path_for(full_name)
    has_hash = hash_path.exists()
    has_unit = full_name in _platform_unit_names()
    has_state_dir = (STATE_DIR / full_name).is_dir()
    has_stamp = has_hash or has_unit
    has_remnant = has_stamp or has_state_dir
    if not in_config:
        return "orphan" if has_remnant else "missing"
    if not has_stamp:
        return "missing"
    if not has_hash:
        # Unit on disk but no hash to compare against (state was
        # wiped). Treat as drift so the user gets a clear "re-
        # apply" signal.
        return "stale"
    entry: Job | JobGroup = config.jobs.get(short) or config.job_groups[short]
    bn, _ = parse_full_name(full_name)
    target = resolve_target(config, current_host(), platform)
    if isinstance(entry, Job):
        snapshot: JobSnapshot | GroupSnapshot = _resolve_job_snapshot(
            config, target, entry, full_name
        )
    else:
        snapshot = _resolve_group_snapshot(config, target, entry, bn, full_name)
    new_hash = _compute_unit_hash(full_name, entry, platform, snapshot)
    old_hash = hash_path.read_text(encoding="utf-8").strip()
    return "synced" if old_hash == new_hash else "stale"


def _enable_unit(name: str, platform: str) -> None:
    """Move the platform scheduler into the `enabled` state for `name`."""
    if platform == "linux":
        subprocess.run(
            [
                "systemctl",
                "--user",
                "--quiet",
                "enable",
                "--now",
                _systemd_unit_name(name),
            ],
            check=True,
        )
        return
    label = _label_for(name)
    plist = _plist_path_for(name)
    subprocess.run(
        ["launchctl", "enable", f"gui/{os.getuid()}/{label}"],
        check=True,
    )
    # unload-then-load -- mirrors apply, tolerates a stale loaded
    # plist from before the enable.
    subprocess.run(
        ["launchctl", "unload", str(plist)],
        stderr=subprocess.DEVNULL,
    )
    subprocess.run(["launchctl", "load", str(plist)], check=True)


def _disable_unit(name: str, platform: str) -> None:
    """Move the platform scheduler into the `disabled` state for `name`."""
    if platform == "linux":
        subprocess.run(
            [
                "systemctl",
                "--user",
                "--quiet",
                "disable",
                "--now",
                _systemd_unit_name(name),
            ],
            check=True,
        )
        return
    label = _label_for(name)
    plist = _plist_path_for(name)
    # Unload first so the persistent disable record actually takes
    # effect; otherwise the still-loaded plist would keep firing
    # until the next launchd restart.
    subprocess.run(
        ["launchctl", "unload", str(plist)],
        stderr=subprocess.DEVNULL,
    )
    subprocess.run(
        ["launchctl", "disable", f"gui/{os.getuid()}/{label}"],
        check=True,
    )


def _trigger_unit(name: str, platform: str) -> None:
    """Ask the platform scheduler to fire `name` immediately.

    On darwin, `launchctl kickstart` invokes the agent now (rather
    than `launchctl start` which only queues the next scheduled
    fire). On linux, `systemctl --user start <unit>.service` runs
    the timer's underlying service directly.

    Both platforms treat "trigger an already-running unit" as a
    no-op -- the in-flight run continues and there is no fresh
    fire. Waiters that need to know the next completion's outcome
    use `_trigger_unit_sync` instead.
    """
    if platform == "linux":
        # The timer's job is to fire the .service; trigger by
        # starting the service directly.
        service_unit = f"{BASENAME}-{name}.service"
        subprocess.run(
            ["systemctl", "--user", "start", service_unit],
            check=True,
        )
        return
    label = _label_for(name)
    subprocess.run(
        ["launchctl", "kickstart", f"gui/{os.getuid()}/{label}"],
        check=True,
    )


class TriggerStartTimeout(JobTimeoutError):
    """The platform never produced a runner within
    `trigger_timeout_sec` after we asked it to fire the unit.
    Suggests a broken plist / unit, a stalled scheduler queue, or
    the unit not being loaded (run `crony apply` first).

    Subclass of `JobTimeoutError` so it shares the TIMEOUT exit
    code; the specialization conveys 'the trigger never started'
    rather than 'the runner exceeded its timeout'.
    """


def _read_pid_file(pid_path: Path) -> int | None:
    try:
        text = pid_path.read_text(encoding="utf-8").strip()
    except FileNotFoundError:
        return None
    try:
        return int(text)
    except ValueError:
        return None


def _trigger_unit_sync(
    full_name: str,
    *,
    job_timeout: float,
    trigger_timeout: float,
) -> dict[str, Any]:
    """Fire `full_name` via the platform and wait for completion.

    Returns the parsed `last-run.json` dict for the run we observed
    completing. Raises `TriggerStartTimeout` if no sign of life
    (no pid file, no fresh last-run.json) appears within
    `trigger_timeout` seconds of the trigger -- that's the
    "platform never started anything" detector (broken plist,
    stalled queue, unloaded unit). Once we've observed activity,
    the wait is bounded by `job_timeout` (the runner's own
    wallclock cap) rather than `trigger_timeout`, so a long-
    running job doesn't get spuriously declared a start failure.

    Mechanism: a pre-trigger timestamp T is taken, the platform
    is asked to fire the unit, and the waiter watches for the
    runner's pid (published via `<state>/<full_name>/run.pid`) to
    exit via kqueue / pidfd kernel-level notification. When the
    pid is gone, last-run.json is read; if its `ended_at` is at
    or after T, the run is "ours" (semantics: the next completion
    after the trigger). Otherwise we sleep briefly, re-read the
    pid file, and try again.

    Triggering an already-running unit is a no-op on both
    platforms; the waiter still attaches to the in-flight pid and
    returns its result. That's what we want -- "the next
    completion" is well-defined and serves the group-dispatch use
    case (we wanted the child's run; an in-flight run satisfies).
    """
    # Match the runner's `_now_iso()` precision (whole seconds): if
    # pre_trigger captured microseconds and the runner's ended_at
    # truncated them, a sub-second run could compare ended_at <
    # pre_trigger and the loop would conclude "no fresh run yet"
    # for the entire trigger_timeout window.
    pre_trigger_dt = datetime.datetime.fromisoformat(_now_iso())
    sd = _state_dir_for(full_name)
    pid_path = sd / "run.pid"
    last_run_path = sd / "last-run.json"
    platform = current_platform()

    _trigger_unit(full_name, platform)

    started_at = time.monotonic()
    while True:
        elapsed = time.monotonic() - started_at
        pid = _read_pid_file(pid_path)
        # `last-run.json` check goes first so a sub-second run
        # whose pid file came and went between iterations is
        # still observable via the file the runner wrote at exit.
        if last_run_path.exists():
            try:
                rec = json.loads(last_run_path.read_text(encoding="utf-8"))
            except (OSError, json.JSONDecodeError):
                rec = None
            ended_at = rec.get("ended_at") if rec is not None else None
            if ended_at:
                try:
                    ended_dt = datetime.datetime.fromisoformat(ended_at)
                except ValueError:
                    ended_dt = None
                if ended_dt is not None and ended_dt >= pre_trigger_dt:
                    return rec
        if pid is not None:
            # Activity confirmed; trigger_timeout no longer
            # applies. Block on kernel-level pid-exit, capped at
            # the runner's own wallclock budget. After the wait,
            # loop back to re-read last-run.json (the runner
            # writes it just before unlinking the pid).
            remaining_job = max(1.0, job_timeout - elapsed)
            _wait_for_pid_exit(pid, timeout=remaining_job)
            continue
        # No pid and no fresh result: still in the start window.
        # Bound this state by trigger_timeout so a broken /
        # unloaded unit fails fast instead of hanging.
        if elapsed > trigger_timeout:
            raise TriggerStartTimeout(
                f"trigger of {full_name!r} never produced a fresh "
                f"run within {trigger_timeout}s"
            )
        time.sleep(1.0)


# =============================================================================
# COMMAND HANDLERS
# =============================================================================
# Each handler's signature must match its argparse subparser's argument
# `dest` names exactly; the shared CmdCallbacksBase test enforces this.
# Handlers without behavior yet raise NotImplementedError so an
# unfinished feature surfaces immediately rather than silently no-oping.


def do_init(force: bool, bundle: str | None) -> None:
    """Generate a default config file.

    With `--bundle <name>`, writes `config/<name>.toml` (creating
    the dropin dir if missing). Otherwise writes `config.toml`.
    """
    if bundle is not None:
        if bundle == DEFAULT_BUNDLE_NAME:
            raise UsageError(
                f"--bundle {DEFAULT_BUNDLE_NAME!r} would shadow "
                f"config.toml; use plain `crony init` (without "
                f"--bundle) for the default bundle"
            )
        try:
            _validate_bundle_name(bundle, "--bundle")
        except ConfigError as e:
            raise UsageError(str(e)) from e
        target = CONFIG_DROPIN_DIR / f"{bundle}.toml"
        if target.exists() and not force:
            raise UsageError(
                f"{target} already exists; pass --force to overwrite"
            )
        CONFIG_DROPIN_DIR.mkdir(parents=True, exist_ok=True)
        target.write_text(_DEFAULT_CONFIG_TEMPLATE, encoding="utf-8")
        logger.info("wrote bundle config to %s", target)
        return
    if CONFIG_FILE.exists() and not force:
        raise UsageError(
            f"{CONFIG_FILE} already exists; pass --force to overwrite"
        )
    CONFIG_DIR.mkdir(parents=True, exist_ok=True)
    CONFIG_FILE.write_text(_DEFAULT_CONFIG_TEMPLATE, encoding="utf-8")
    logger.info("wrote default config to %s", CONFIG_FILE)


def _selected_full_names_per_bundle(
    bundles: Bundles,
) -> tuple[dict[str, tuple[Bundle, str]], set[str]]:
    """Return (full_name -> (bundle, short)) and full_names set,
    spanning every bundle's selection on the current host.

    `by_full`'s key set is the same set as `selected`; this is the
    contract `do_apply` / `_expand_apply_subtree` rely on to
    distinguish "names known to this host's selection" from
    "everything else".  Callers that also need to inspect masked
    entries use `_selected_and_masked_full_names_per_bundle`.
    """
    host = current_host()
    platform = current_platform()
    by_full: dict[str, tuple[Bundle, str]] = {}
    for b in bundles.bundles:
        target = resolve_target(b.config, host, platform)
        sel_jobs, sel_groups = selected_jobs_and_groups(b.config, target)
        for short in sel_jobs | sel_groups:
            by_full[b.full_name(short)] = (b, short)
    return by_full, set(by_full.keys())


def _selected_and_masked_full_names_per_bundle(
    bundles: Bundles,
) -> tuple[dict[str, tuple[Bundle, str]], set[str], dict[str, str]]:
    """Spans every bundle, returning selected and masked names.

    `by_full` maps full_name -> (bundle, short) for every entry
    that is selected OR masked OR defined-but-unused on this host
    -- the wider set is needed only by status callers that surface
    masked rows. `selected` is the set of full_names that pass the
    host's `platforms` / `hosts` filters. `masked_by_full` maps
    everything else: entries reached through `target.jobs` but
    excluded by per-entry filters get the axis reason from
    `_mask_reason` (`host`, `platform`, ...); entries defined in
    a bundle's config but not reached by the host's resolved
    target get the literal reason `unused`.
    """
    host = current_host()
    platform = current_platform()
    by_full: dict[str, tuple[Bundle, str]] = {}
    selected: set[str] = set()
    masked_by_full: dict[str, str] = {}
    for b in bundles.bundles:
        target = resolve_target(b.config, host, platform)
        sel_jobs, sel_groups, masked = selected_and_masked_jobs_and_groups(
            b.config, target
        )
        for short in sel_jobs | sel_groups:
            full = b.full_name(short)
            by_full[full] = (b, short)
            selected.add(full)
        for short, reason in masked.items():
            full = b.full_name(short)
            by_full[full] = (b, short)
            masked_by_full[full] = reason
        defined = set(b.config.jobs) | set(b.config.job_groups)
        accounted = sel_jobs | sel_groups | set(masked.keys())
        for short in defined - accounted:
            full = b.full_name(short)
            by_full[full] = (b, short)
            masked_by_full[full] = "unused"
    return by_full, selected, masked_by_full


def _expand_apply_subtree(
    by_full: dict[str, tuple[Bundle, str]], full_names: list[str]
) -> list[str]:
    """Expand each name to include its transitive group children.

    `crony apply <group>` cascades to the group's children so the
    group's snapshot reflects each child's freshly-applied state.
    Children outside the current host's selection are silently
    skipped (they shouldn't have units installed here).
    """
    seen: set[str] = set()

    def walk(full: str) -> None:
        if full in seen or full not in by_full:
            return
        seen.add(full)
        bundle, short = by_full[full]
        group = bundle.config.job_groups.get(short)
        if group is None:
            return
        for child_short in group.jobs:
            walk(bundle.full_name(child_short))

    for f in full_names:
        walk(f)
    return sorted(seen)


def _topo_apply_order(
    by_full: dict[str, tuple[Bundle, str]], full_names: list[str]
) -> list[str]:
    """Order names so each group's children are applied first.

    Groups depend on their children (the group's snapshot pulls
    `group_budget_sec` from the children's resolved timeouts via
    the live config; ordering leaves-first keeps both pinned and
    in-progress state consistent within the same apply pass).

    `_validate_config` rejects cycles, so a real cycle here is
    defensive: if the in-degree never drops to zero, fall back to
    input order (the apply itself will fail loudly on whatever
    inconsistency the cycle implies).
    """
    pool = set(full_names)
    indeg: dict[str, int] = {n: 0 for n in pool}
    parents: dict[str, list[str]] = {n: [] for n in pool}
    for full in pool:
        bundle, short = by_full[full]
        group = bundle.config.job_groups.get(short)
        if group is None:
            continue
        for child_short in group.jobs:
            child_full = bundle.full_name(child_short)
            if child_full in pool:
                indeg[full] += 1
                parents[child_full].append(full)
    queue = sorted(n for n, d in indeg.items() if d == 0)
    out: list[str] = []
    while queue:
        n = queue.pop(0)
        out.append(n)
        for parent in sorted(parents[n]):
            indeg[parent] -= 1
            if indeg[parent] == 0:
                queue.append(parent)
    if len(out) != len(pool):
        return list(full_names)
    return out


def do_apply(jobs: list[str], verbose: bool, bundle: str | None) -> None:
    """Render and activate platform units to match config.

    No args: full sync across every bundle. Install missing, fix
    drift, remove orphans. With names: surgical update of those
    entries only -- orphans are left alone so a one-off apply
    doesn't have side effects on unrelated jobs.

    Names on the CLI are full namespaced names
    (`<bundle>.<short>`). Bare input is shorthand for
    `default.<short>` and only ever resolves to the default bundle.

    With `--bundle <name>`, scopes the apply to that bundle: bare
    CLI input resolves there instead of `default`, qualified names
    must match `<name>`, and a no-args sync only touches that
    bundle's selected jobs and its own orphan stamps -- other
    bundles' state is untouched.

    `unchanged` results are suppressed by default so the output
    only shows the entries the apply actually touched. `-v` /
    `--verbose` prints them too.
    """
    bundles = load_all_bundles()
    require_known_bundle(bundles, bundle)
    by_full, selected = _selected_full_names_per_bundle(bundles)
    if bundle is not None:
        selected = bundle_prefix_filter(selected, bundle)

    if jobs:
        normalized = [resolve_cli_name(arg, bundle) for arg in jobs]
        unknown = [n for n in normalized if n not in by_full]
        if bundle is not None:
            # Under `-b`, a name that exists in `by_full` but is
            # outside the scoped `selected` set means the entry
            # belongs to that bundle but isn't selected on this
            # host; surface it the same as unknown.
            unknown.extend(
                n
                for n in normalized
                if n in by_full and n not in selected and n not in unknown
            )
        if unknown:
            raise UsageError(
                f"unknown or unselected on this host: {sorted(unknown)}"
            )
        # Cascade `crony apply <group>` to the group's transitive
        # children so the group's snapshot reflects each child's
        # freshly-applied state.
        full_names_to_apply = _expand_apply_subtree(by_full, normalized)
        remove_orphans = False
    else:
        full_names_to_apply = sorted(selected)
        remove_orphans = True

    # Topological sort: leaves first, so each group's snapshot is
    # computed against children whose own snapshots have already
    # landed in this apply pass.
    full_names_to_apply = _topo_apply_order(by_full, full_names_to_apply)

    # Pre-pass: render every selected entry so a darwin-specific
    # OnCalendar limitation (step / range / list) surfaces before we
    # touch any unit files. Without this, an apply failure leaves a
    # partial install and the user has to chase what landed.
    if current_platform() == "darwin":
        for full in full_names_to_apply:
            b, short = by_full[full]
            entry: Job | JobGroup = (
                b.config.jobs.get(short) or b.config.job_groups[short]
            )
            schedule, _interval = _entity_schedule(entry)
            if schedule is not None:
                _oncalendar_to_plist_calendar(schedule)

    for full in full_names_to_apply:
        b, short = by_full[full]
        result = apply_one(b.config, short, bundle_name=b.name)
        if verbose or result != "unchanged":
            logger.info("%s: %s", full, result)

    if remove_orphans:
        stamps = stamped_names()
        if bundle is not None:
            stamps = bundle_prefix_filter(stamps, bundle)
        orphans = stamps - selected
        for orphan in sorted(orphans):
            destroy_one(orphan)
            logger.info("%s: orphan removed", orphan)


def do_destroy(
    jobs: list[str],
    preserve_runtime: bool,
    bundle: str | None,
    orphans: bool,
) -> None:
    """Remove platform units.

    No args: factory reset -- every crony-managed remnant on this
    host. Discovery covers state dirs (with or without hash) plus
    platform unit files, so leftovers from an earlier
    `--preserve-runtime` destroy are reachable without tracking
    paths down by hand.

    With `--bundle <name>` and no positional args: scope the reset
    to that bundle's discovered names. Other bundles' remnants
    stay intact.

    With `--orphans`: limit removal to entries with on-disk
    remnants that no bundle's live config selects to install on
    this host. Combinable with `--bundle` (orphans within that
    bundle namespace). Mutually exclusive with positional names.

    With names: surgical removal by full namespaced name. Refuses
    if a name is in neither any bundle's config nor the
    discovered set; refuses if a name's run.lock is currently
    held. Under `--bundle`, bare names resolve in that bundle and
    qualified names must match it.

    `preserve_runtime=True` (CLI: `--preserve-runtime`) keeps
    `run.log`, `last-run.json`, and `run.lock` for post-mortem
    review; the unit, hash, and snapshot are still removed. The
    default fully wipes the entry's state dir so destroy leaves
    no on-disk trace.
    """
    if orphans and jobs:
        raise UsageError(
            "--orphans and positional names are mutually exclusive"
        )
    bundles = load_all_bundles()
    require_known_bundle(bundles, bundle)
    if jobs:
        by_full, _ = _selected_full_names_per_bundle(bundles)
        # Defined names span every bundle's full names plus any
        # name with an on-disk remnant (so a leftover state dir or
        # unit can still be destroyed after the bundle is gone).
        defined = set(by_full.keys()) | bundles.all_full_names()
        known = defined | discovered_names()
        if bundle is not None:
            known = bundle_prefix_filter(known, bundle)
        normalized = [resolve_cli_name(arg, bundle) for arg in jobs]
        unknown = [n for n in normalized if n not in known]
        if unknown:
            raise UsageError(f"unknown name(s): {sorted(unknown)}")
        full_names_to_destroy = normalized
    else:
        names = discovered_names()
        if orphans:
            _by_full, selected = _selected_full_names_per_bundle(bundles)
            names = names - selected
        if bundle is not None:
            names = bundle_prefix_filter(names, bundle)
        full_names_to_destroy = sorted(names)

    for full in full_names_to_destroy:
        # Refuse if a run is in progress; a partial destroy would
        # leave the running shim with deleted state under it.
        lock_path = STATE_DIR / full / "run.lock"
        if lock_path.exists():
            try:
                with _acquire_lock(lock_path):
                    pass
            except LockBusyError:
                raise LockBusyError(
                    f"{full}: run in progress; will not destroy"
                )
        destroy_one(full, preserve_runtime=preserve_runtime)
        logger.info(
            "%s: %s",
            full,
            "destroyed (runtime kept)" if preserve_runtime else "destroyed",
        )


def _entry_schedule_state(bundles: Bundles, full: str) -> str:
    """Return 'unresolved' / 'unscheduled' / 'scheduled' for `full`.

    `unresolved` covers a name whose bundle or short doesn't
    currently exist (a stale stamp, say). `unscheduled` is a
    defined entry with neither schedule nor interval. `scheduled`
    is anything with a schedule or interval.
    """
    bn, short = parse_full_name(full)
    b = bundles.by_name(bn)
    if b is None:
        return "unresolved"
    entry: Job | JobGroup | None = b.config.jobs.get(
        short
    ) or b.config.job_groups.get(short)
    if entry is None:
        return "unresolved"
    sched, interval = _entity_schedule(entry)
    if sched is None and interval is None:
        return "unscheduled"
    return "scheduled"


def _resolve_bulk_names(
    jobs: list[str],
    bundle: str | None,
    stamped: set[str],
    bundles: Bundles,
    scheduled_only: bool,
) -> list[str]:
    """Derive the operate-on name set for enable / disable / trigger.

    With positional `jobs`, normalize each via `resolve_cli_name`
    (which honors `-b`'s bundle-scoping rules). With no positionals,
    `bundle` is required and the set expands to that bundle's
    stamped names; `scheduled_only` drops unscheduled entries so a
    bulk `enable -b foo` skips schedule-less group containers
    rather than rejecting the whole call.
    """
    if jobs:
        return [resolve_cli_name(arg, bundle) for arg in jobs]
    if bundle is None:
        raise UsageError("specify job names or --bundle")
    expanded = sorted(bundle_prefix_filter(stamped, bundle))
    if scheduled_only:
        expanded = [
            n
            for n in expanded
            if _entry_schedule_state(bundles, n) == "scheduled"
        ]
    return expanded


def _refuse_unscheduled_full(
    bundles: Bundles, full_names: list[str], verb: str
) -> None:
    """Reject entries with no schedule (nothing to enable/disable)."""
    unscheduled = [
        full
        for full in full_names
        if _entry_schedule_state(bundles, full) == "unscheduled"
    ]
    if unscheduled:
        raise UsageError(
            f"cannot {verb} grouped entries: {sorted(unscheduled)}. "
            f"Grouped entries are triggered by parent jobs with their "
            f"own schedule."
        )


def do_enable(jobs: list[str], bundle: str | None) -> None:
    """Move the platform scheduler into `enabled` for the named jobs.

    Names are full namespaced (`<bundle>.<short>`); bare input is
    shorthand for `default.<short>`. Refuses names not stamped on
    this host (run apply first) and entries with no schedule (no
    platform timer to enable / disable).

    With `--bundle <name>` and no positional args, enables every
    scheduled stamped entry in `<name>` (unscheduled entries in
    that bundle are skipped, not rejected). With `--bundle` plus
    positional args, bare names resolve in `<name>` and qualified
    names must match it.
    """
    bundles = load_all_bundles()
    require_known_bundle(bundles, bundle)
    stamped = stamped_names()
    normalized = _resolve_bulk_names(
        jobs, bundle, stamped, bundles, scheduled_only=True
    )
    unknown = [n for n in normalized if n not in stamped]
    if unknown:
        raise UsageError(
            f"not stamped on this host: {sorted(unknown)} "
            f"(run `crony apply` first)"
        )
    _refuse_unscheduled_full(bundles, normalized, "enable")
    platform = current_platform()
    for full in normalized:
        _enable_unit(full, platform)
        logger.info("%s: enabled", full)


def do_disable(jobs: list[str], bundle: str | None) -> None:
    """Move the platform scheduler into `disabled` for the named jobs.

    Names are full namespaced (`<bundle>.<short>`); bare input is
    shorthand for `default.<short>`. Refuses names not stamped on
    this host (run apply first) and entries with no schedule (no
    platform timer to enable / disable).

    With `--bundle <name>` and no positional args, disables every
    scheduled stamped entry in `<name>` (unscheduled entries in
    that bundle are skipped, not rejected). With `--bundle` plus
    positional args, bare names resolve in `<name>` and qualified
    names must match it.
    """
    bundles = load_all_bundles()
    require_known_bundle(bundles, bundle)
    stamped = stamped_names()
    normalized = _resolve_bulk_names(
        jobs, bundle, stamped, bundles, scheduled_only=True
    )
    unknown = [n for n in normalized if n not in stamped]
    if unknown:
        raise UsageError(
            f"not stamped on this host: {sorted(unknown)} "
            f"(run `crony apply` first)"
        )
    _refuse_unscheduled_full(bundles, normalized, "disable")
    platform = current_platform()
    for full in normalized:
        _disable_unit(full, platform)
        logger.info("%s: disabled", full)


def _trigger_exit_code(rec: dict[str, Any]) -> int:
    """Map a last-run.json record to a process exit code.

    `exit_code` is None whenever the job didn't reach a normal exit
    (timeout, signal, gate refusal, precondition fail, lock contention).
    `... or 0` would mask all of those as success; instead, derive the
    code from the exit_class so a `crony trigger --wait` against a
    timed-out job exits non-zero.
    """
    rc = rec.get("exit_code")
    if rc is not None:
        return int(rc)
    cls = rec.get("exit_class", "ok")
    if cls == "timeout":
        return int(ExitCode.TIMEOUT)
    if cls == "signal":
        sig = rec.get("signal")
        return 128 + int(sig) if sig else int(ExitCode.ERROR)
    if cls == "lock_busy":
        return int(ExitCode.LOCK_BUSY)
    if cls == "precondition":
        return int(ExitCode.PRECONDITION)
    if cls == "gated":
        return 0
    return 0


def do_trigger(
    jobs: list[str],
    wait: bool,
    trigger_timeout: int | None,
    bundle: str | None,
) -> None:
    """Ask the platform scheduler to fire the named jobs.

    `trigger` exercises the same launchd / systemd path a
    scheduled fire would, so the run uses the exact execution
    context (env, working dir, signal handling) the next
    scheduled invocation would use. This is the user-facing way
    to do an immediate run; the underlying `run` subcommand is
    the platform unit's entry point and not user-facing. Works
    on every stamped entry, including transit groups and group-
    only jobs (every entry installs a platform unit; schedule-
    less entries' units just sit dormant until kickstarted).

    Default mode is async (matches `launchctl kickstart` /
    `systemctl start`): the trigger returns as soon as the
    platform has accepted it. With `--wait`, blocks until each
    named entry's next completion and exits with that exit code
    (the worst exit code across multiple names if more than one).

    `--trigger-timeout <sec>` (only with `--wait`) overrides the
    default 15s "trigger never produced a run" deadline.

    Names are full namespaced (`<bundle>.<short>`); bare input is
    shorthand for `default.<short>`. Refuses names not stamped on
    this host (run apply first).

    With `--bundle <name>` and no positional args, triggers every
    stamped entry in `<name>` (including schedule-less ones, since
    trigger is meaningful for them too). With `--bundle` plus
    positional args, bare names resolve in `<name>` and qualified
    names must match it.
    """
    if trigger_timeout is not None and not wait:
        raise UsageError(
            "--trigger-timeout requires --wait (only meaningful in "
            "synchronous mode)"
        )
    bundles = load_all_bundles()
    require_known_bundle(bundles, bundle)
    stamped = stamped_names()
    normalized = _resolve_bulk_names(
        jobs, bundle, stamped, bundles, scheduled_only=False
    )
    unknown = [n for n in normalized if n not in stamped]
    if unknown:
        raise UsageError(
            f"not stamped on this host: {sorted(unknown)} "
            f"(run `crony apply` first)"
        )
    platform = current_platform()

    if not wait:
        for full in normalized:
            _trigger_unit(full, platform)
            logger.info("%s: triggered", full)
        return

    # Synchronous waiter mode. Resolve per-name timeouts via each
    # name's bundle; bundles can disagree about defaults so we look
    # up trigger_timeout_sec per-bundle too.
    worst_rc = 0
    for full in normalized:
        bn, short = parse_full_name(full)
        b = bundles.by_name(bn)
        if b is None:
            raise UsageError(
                f"unknown bundle for {full!r} (apply may be stale)"
            )
        b_target = resolve_target(b.config, current_host(), platform)
        if short in b.config.jobs:
            timeout = float(
                resolved_job_timeout_sec(
                    b.config, b_target, b.config.jobs[short]
                )
            )
        else:
            timeout = float(
                resolved_group_timeout_sec(b.config, b_target, short)
            )
        tt = (
            float(trigger_timeout)
            if trigger_timeout is not None
            else float(b.config.defaults.trigger_timeout_sec)
        )
        rec = _trigger_unit_sync(full, job_timeout=timeout, trigger_timeout=tt)
        cls = rec.get("exit_class", "ok")
        rc = _trigger_exit_code(rec)
        logger.info("%s: %s (exit %s)", full, cls, rc)
        if rc and (not worst_rc or abs(rc) > abs(worst_rc)):
            worst_rc = rc
    if worst_rc:
        raise SystemExit(worst_rc)


_STATUS_COL_HEADERS: dict[str, str] = {
    "job": "JOB",
    "kind": "KIND",
    "config": "CONFIG",
    "schedule": "SCHEDULE",
    "groups": "GROUPS",
    "unit": "UNIT",
    "last": "LAST",
    "last-ran": "LAST RAN",
    "masked-by": "MASKED BY",
    "unit-name": "UNIT NAME",
    "unit-schedule": "UNIT SCHEDULE",
    "pending-schedule": "PENDING SCHEDULE",
}
_DEFAULT_STATUS_COLS: tuple[str, ...] = (
    "job",
    "config",
    "schedule",
    "last",
    "last-ran",
)
_STATUS_COL_ALIASES: dict[str, tuple[str, ...]] = {
    "default": _DEFAULT_STATUS_COLS,
    "all": tuple(_STATUS_COL_HEADERS.keys()),
}


_STATUS_HELP_EPILOG_TEMPLATE: str = """\
Columns
-------
  config            synced | stale | missing | orphan | masked.
  groups            Comma-separated full names of groups containing this
                    entry. Same default-vs-pending rules as `schedule`:
                    starred when the applied membership differs from the
                    pending config; --config-current / --config-pending
                    force a single source. Empty when the entry isn't a
                    member of any group.
  job               Full namespaced name `<bundle>.<short>`. Always shown.
  kind              "job" or "group". Falls back to the snapshot's recorded
                    kind for rows whose live config no longer
                    defines the entry.
  last              Last-run outcome: ok | fail | timeout | gated | running
                    | never | unknown.
  last-ran          Compact relative time of the last run, e.g. "5m ago".
  masked-by         `host` and / or `platform` joined with `,`
                    (e.g. `host,platform` when both axes exclude
                    the entry), or one of `unused` / `empty`. Set
                    when the entry is filter-excluded on this host
                    -- which surfaces as `config=masked` for
                    entries with no on-disk state, and as
                    `config=orphan` for entries with leftover
                    units / hashes / state dirs from a prior apply
                    (the same `destroy --orphans` cleanup path
                    applies in both cases). `unused` means defined
                    in config but not listed in the host's
                    resolved target.jobs. `empty` means a group
                    whose every direct child is itself masked on
                    this host -- the reference is a no-op here,
                    so the group is masked too.
  pending-schedule  The schedule from the live config, with no asterisk
                    and no fallback to applied. Empty when the entry is
                    not in any bundle.
  schedule          Default mode shows the applied (current) schedule. When
                    the pending schedule differs, the cell carries a
                    trailing "*" and a footer prints below the table
                    pointing at `crony apply`. --config-current and
                    --config-pending force a single source. When the
                    unit is disabled at the platform scheduler the cell
                    renders as `disabled` -- the cron expression is
                    misleading there since the unit won't fire. Add the
                    opt-in `unit` column to see the platform-scheduler
                    state for the rest of the rows. --config-pending
                    suppresses this override (the pending schedule is
                    a config fact, independent of runtime state).
  unit              Platform scheduler view: enabled | disabled | grouped
                    | none. `grouped` means the entry has no schedule
                    (parent group dispatches it); `none` means the
                    scheduler doesn't see a unit by this name.
  unit-name         Platform unit identifier: `org.crony.<name>` on macOS;
                    `crony-<name>.timer` (scheduled) or
                    `crony-<name>.service` (grouped) on Linux. Empty when
                    neither config nor snapshot describes the entry.
  unit-schedule     The applied schedule from the on-disk snapshot, with
                    no asterisk and no fallback to pending. Empty when
                    no snapshot exists or it predates the schedule field.

Aliases
-------
{aliases_block}
"""


def _build_status_aliases_block() -> str:
    """Render the Aliases help block from `_STATUS_COL_ALIASES`.

    Each alias becomes one line: `  <name>  <expansion>`. `all`
    is rendered with a descriptive label instead of the full
    column list (which would just enumerate everything in the
    Columns section above) so the block stays scannable.
    """
    lines: list[str] = []
    for alias, expansion in _STATUS_COL_ALIASES.items():
        if alias == "all":
            label = "all"
        else:
            label = ", ".join(expansion)
        lines.append(f"  {alias:<8}  {label}")
    return "\n".join(lines)


_STATUS_HELP_EPILOG: str = _STATUS_HELP_EPILOG_TEMPLATE.format(
    aliases_block=_build_status_aliases_block(),
)


def _parse_status_cols(spec: str | None) -> list[str]:
    """Parse the `--cols` argument into an ordered column list.

    Comma-separated; whitespace around names is ignored. `job` is
    always included (and forced to the first column) because
    everything else is meaningless without the entity name.
    `default` and `all` are aliases that expand to the default
    column set and every column respectively; mixing aliases with
    explicit names is allowed (`default,masked-by`). Order is
    preserved across the resolved list with duplicates dropped.
    Unknown names raise UsageError so a typo is loud, not a silent
    missing column.
    """
    if not spec:
        return list(_DEFAULT_STATUS_COLS)
    raw = [c.strip() for c in spec.split(",") if c.strip()]
    valid = set(_STATUS_COL_HEADERS) | set(_STATUS_COL_ALIASES)
    unknown = [c for c in raw if c not in valid]
    if unknown:
        raise UsageError(
            f"unknown status column(s): {sorted(unknown)} "
            f"(valid: {sorted(_STATUS_COL_HEADERS)}; "
            f"aliases: {sorted(_STATUS_COL_ALIASES)})"
        )
    expanded: list[str] = []
    for c in raw:
        if c in _STATUS_COL_ALIASES:
            expanded.extend(_STATUS_COL_ALIASES[c])
        else:
            expanded.append(c)
    seen: set[str] = set()
    cols: list[str] = []
    for c in expanded:
        if c in seen:
            continue
        seen.add(c)
        cols.append(c)
    if "job" in cols:
        cols.remove("job")
    return ["job"] + cols


def _resolve_state_axes(
    bundles: Bundles,
    full: str,
    platform: str,
    remnants: set[str],
    *,
    mask_reason: str = "",
) -> tuple[str, str, str]:
    """Compute the (cfg, unit, last) status axes for one full name.

    `do_status` and `do_audit` share this pipeline so a future
    change to any axis stays consistent across the two views.
    Returns the values straight from the underlying state readers
    -- no opinion about whether a given combination is "bad" --
    so each caller applies its own filtering / display logic on
    top.

    `mask_reason` is the entry's filter-exclusion reason on this
    host (from `selected_and_masked_jobs_and_groups`'s masked
    map, or the literal `"unused"`); when non-empty, the cfg axis
    becomes `"orphan"` if on-disk remnants exist and `"masked"`
    otherwise. Both `do_status` and `do_audit` flow through this
    override so the two views converge: status surfaces the
    cleanup row in the default view, audit flags the orphan as
    a CONFIG drift.
    """
    bn, short = parse_full_name(full)
    bundle = bundles.by_name(bn)
    if bundle is None:
        cfg_state = "orphan" if full in remnants else "missing"
        entry: Job | JobGroup | None = None
    else:
        cfg_state = _config_state_for(bundle.config, short, full, platform)
        entry = bundle.config.jobs.get(short) or bundle.config.job_groups.get(
            short
        )
    if mask_reason:
        cfg_state = "orphan" if full in remnants else "masked"
    if cfg_state == "missing":
        unit_state = "none"
    else:
        schedule, interval = (
            _entity_schedule(entry) if entry is not None else (None, None)
        )
        if entry is not None and schedule is None and interval is None:
            unit_state = "grouped"
        else:
            unit_state = _unit_state(full, platform)
    last_state = _last_run_state(full)
    return cfg_state, unit_state, last_state


def _entry_is_scheduled(entry: Job | JobGroup | None) -> bool:
    if entry is None:
        return False
    sched, interval = _entity_schedule(entry)
    return sched is not None or interval is not None


def _snapshot_says_scheduled(full: str) -> bool | None:
    """`True` / `False` if a snapshot is present and records its
    schedule fields; `None` otherwise (legacy snapshots and missing
    snapshots both fall through). Used to guess UNIT NAME for
    entries whose live config no longer exists.
    """
    snap_path = _snapshot_path_for(full)
    if not snap_path.exists():
        return None
    try:
        raw = json.loads(snap_path.read_text(encoding="utf-8"))
    except (OSError, json.JSONDecodeError):
        return None
    if not isinstance(raw, dict):
        return None
    sched, interval = raw.get("schedule"), raw.get("interval")
    if sched is None and interval is None and "schedule" not in raw:
        # Legacy snapshot pre-dating these fields: can't decide.
        return None
    return sched is not None or interval is not None


def _unit_name_for(
    full: str, entry: Job | JobGroup | None, platform: str
) -> str:
    """Platform unit identifier for the UNIT NAME column.

    On macOS, every entry is a launchd plist with the same label
    shape regardless of schedule. On Linux, scheduled entries are
    driven by a `<name>.timer`; grouped (no-schedule) entries
    install only `<name>.service`. Falls back to the snapshot's
    schedule fields when the live config no longer describes the
    entry; returns "" when nothing on disk or in config can decide.
    """
    if platform == "darwin":
        return _label_for(full)
    if entry is not None:
        scheduled = _entry_is_scheduled(entry)
    else:
        snap_says = _snapshot_says_scheduled(full)
        if snap_says is None:
            return ""
        scheduled = snap_says
    return (
        _timer_path_for(full).name
        if scheduled
        else _service_path_for(full).name
    )


def _kind_from_snapshot(full: str) -> str:
    """Best-effort `job` / `group` for entries no longer in config.

    Orphan rows have lost their bundle entry but still carry an
    on-disk snapshot from the last apply. The snapshot records
    its `kind`, so KIND can fill in even though the config-side
    lookup turns up nothing. Returns "" if no snapshot is present
    or the file is unreadable.
    """
    snap_path = _snapshot_path_for(full)
    if not snap_path.exists():
        return ""
    try:
        raw = json.loads(snap_path.read_text(encoding="utf-8"))
    except (OSError, json.JSONDecodeError):
        return ""
    if isinstance(raw, dict):
        kind = raw.get("kind")
        if kind in ("job", "group"):
            return kind
    return ""


_STALE_VALUE_FOOTER: str = (
    "* -- One or more starred cells are stale: the currently "
    "active value differs from the pending config. Use "
    "--config-pending to see the pending value, or run "
    "`crony apply` to bring the active value in sync."
)


def _build_group_membership(
    bundles: Bundles,
) -> tuple[dict[str, list[str]], dict[str, list[str]]]:
    """Reverse-index group membership across all bundles.

    Returns `(pending, current)`. `pending[<full>]` lists the group
    full names that include `<full>` as a child in the live config.
    `current[<full>]` lists the group full names whose on-disk
    snapshot's `children` list still records `<full>` as a member.
    The two diverge when a group has been edited but not re-applied.
    Each value list is sorted for stable display order.
    """
    pending: dict[str, list[str]] = {}
    for b in bundles.bundles:
        for g_short, g in b.config.job_groups.items():
            g_full = b.full_name(g_short)
            for child_short in g.jobs:
                pending.setdefault(b.full_name(child_short), []).append(g_full)
    current: dict[str, list[str]] = {}
    if STATE_DIR.exists():
        for entry_dir in STATE_DIR.iterdir():
            if not entry_dir.is_dir():
                continue
            snap = entry_dir / "snapshot.json"
            if not snap.exists():
                continue
            try:
                raw = json.loads(snap.read_text(encoding="utf-8"))
            except (OSError, json.JSONDecodeError):
                continue
            if not isinstance(raw, dict) or raw.get("kind") != "group":
                continue
            children = raw.get("children")
            if not isinstance(children, list):
                continue
            g_full = raw.get("name") or entry_dir.name
            for child in children:
                if isinstance(child, str):
                    current.setdefault(child, []).append(g_full)
    for table in (pending, current):
        for v in table.values():
            v.sort()
    return pending, current


def _groups_cells(
    pending: list[str], current: list[str], config_source: str
) -> tuple[str, bool]:
    """Return `(cell, is_stale)` for the GROUPS column.

    Mirrors `_schedule_cells`: default mode shows current with
    `is_stale=True` when pending differs (so the renderer can
    annotate the cell and print the shared stale-value footer);
    `current` and `pending` force a single source. Empty groups
    list -> empty cell.
    """
    p_str = ",".join(pending)
    c_str = ",".join(current)
    if config_source == "current":
        return (c_str, False)
    if config_source == "pending":
        return (p_str, False)
    if not c_str:
        return (p_str, False)
    return (c_str, p_str != c_str)


def _schedule_cells(
    bundles: Bundles,
    full: str,
    config_source: str,
) -> tuple[str, bool]:
    """Return (cell, is_stale) for the SCHEDULE column.

    `config_source` is "default", "current", or "pending". The
    default source shows the applied (current) schedule when one
    exists, with `is_stale` true if the pending schedule differs;
    falls back to pending for entries that have never been
    applied. `current` and `pending` force a single source and
    never set is_stale (the user picked the source explicitly).
    Cells with no value at all return an empty string.
    """
    bn, short = parse_full_name(full)
    bundle = bundles.by_name(bn)
    pending: str | None = None
    if bundle is not None:
        entry = bundle.config.jobs.get(short) or bundle.config.job_groups.get(
            short
        )
        if entry is not None:
            sched, interval = _entity_schedule(entry)
            pending = _schedule_display(sched, interval)
    current: str | None = None
    snap_path = _snapshot_path_for(full)
    if snap_path.exists():
        try:
            raw = json.loads(snap_path.read_text(encoding="utf-8"))
        except (OSError, json.JSONDecodeError):
            raw = None
        if isinstance(raw, dict) and ("schedule" in raw or "interval" in raw):
            # Both keys present-but-None means the entry was grouped
            # at apply time; render as `grouped` to match the
            # pending-schedule and schedule columns. Legacy
            # snapshots written before these fields existed have
            # neither key and fall through with current=None so
            # status doesn't fabricate a schedule it doesn't know.
            cs, ci = raw.get("schedule"), raw.get("interval")
            current = _schedule_display(cs, ci)
    if config_source == "current":
        return (current or "", False)
    if config_source == "pending":
        return (pending or "", False)
    if current is None:
        return (pending or "", False)
    return (current, pending is not None and pending != current)


def do_status(
    jobs: list[str],
    cols: str | None,
    show_masked: bool,
    bundle: str | None,
    config_current: bool,
    config_pending: bool,
) -> None:
    """Print the resolved state per job in a tabular view.

    With no args, the report covers selected jobs/groups plus any
    orphans across all bundles. Names are full namespaced
    (`<bundle>.<short>`); bare CLI input is shorthand for
    `default.<short>`. Linger status on linux surfaces above the
    table.

    With `--bundle <name>`, restricts the table (and the masked-
    entries set surfaced by `-a`) to that bundle. Bare CLI input
    resolves in `<name>` and qualified names must match it.

    Column selection is via `--cols`; valid names, aliases, and
    descriptions live in `crony status --help`'s epilog. `-a` /
    `--all` lists every defined entry, including ones masked on
    the current host (target-unused or excluded by the entry's
    `platforms` / `hosts` filters). `--config-current` and
    `--config-pending` force the SCHEDULE and GROUPS columns to a
    single source and suppress the stale-marker asterisk; the two
    flags are mutually exclusive.
    """
    if config_current and config_pending:
        raise UsageError(
            "--config-current and --config-pending are mutually exclusive"
        )
    config_source = (
        "current"
        if config_current
        else "pending"
        if config_pending
        else "default"
    )
    selected_cols = _parse_status_cols(cols)
    bundles = load_all_bundles()
    require_known_bundle(bundles, bundle)
    platform = current_platform()
    _by_full, selected, masked_by_full = (
        _selected_and_masked_full_names_per_bundle(bundles)
    )
    remnants = discovered_names()
    if bundle is not None:
        selected = bundle_prefix_filter(selected, bundle)
        remnants = bundle_prefix_filter(remnants, bundle)
        masked_by_full = {
            n: r
            for n, r in masked_by_full.items()
            if n.startswith(f"{bundle}.")
        }

    if platform == "linux":
        ling = linger_enabled()
        if ling is False:
            user = _current_user()
            logger.warning(
                "linger DISABLED -- jobs only fire while you have "
                "an active session. Fix: sudo loginctl enable-linger %s",
                user,
            )

    full_names: list[str]
    if jobs:
        full_names = [resolve_cli_name(n, bundle) for n in jobs]
    else:
        active = selected | remnants
        if show_masked:
            active = active | set(masked_by_full)
        full_names = sorted(active)

    pending_groups, current_groups = _build_group_membership(bundles)
    rows: list[dict[str, str]] = []
    any_stale = False
    for full in full_names:
        mask_reason = masked_by_full.get(full, "")
        bn, short = parse_full_name(full)
        bdl = bundles.by_name(bn)
        entry = (
            bdl.config.jobs.get(short) or bdl.config.job_groups.get(short)
            if bdl is not None
            else None
        )
        if isinstance(entry, JobGroup):
            kind = "group"
        elif entry is not None:
            kind = "job"
        else:
            kind = _kind_from_snapshot(full)
        # Resolve the runtime axes up-front. The schedule cell
        # below uses unit_state to decide whether to surface
        # "disabled" instead of the cron expression. The mask-
        # aware override inside `_resolve_state_axes` keeps the
        # cfg cell in sync with `do_audit`: a filter-excluded
        # entry shows as `orphan` if there's on-disk state to
        # clean up, `masked` otherwise.
        cfg_state, unit_state, last = _resolve_state_axes(
            bundles, full, platform, remnants, mask_reason=mask_reason
        )
        last_ran = _last_ran_at(full)
        sched_cell, sched_stale = _schedule_cells(bundles, full, config_source)
        if config_source != "pending" and unit_state == "disabled":
            # The default and --config-current views describe
            # what the host will actually run. A disabled timer
            # doesn't fire on its schedule, so the cron expression
            # is misleading -- show the runtime fact instead.
            # Drop the stale-marker too: the cell is no longer
            # the schedule it would have been compared against.
            sched_cell = "disabled"
            sched_stale = False
        if sched_stale:
            any_stale = True
            sched_cell = f"{sched_cell} *"
        unit_sched_cell, _ = _schedule_cells(bundles, full, "current")
        pending_sched_cell, _ = _schedule_cells(bundles, full, "pending")
        groups_cell, groups_stale = _groups_cells(
            pending_groups.get(full, []),
            current_groups.get(full, []),
            config_source,
        )
        if groups_stale:
            any_stale = True
            groups_cell = f"{groups_cell} *"
        unit_name = _unit_name_for(full, entry, platform)
        rows.append(
            {
                "job": full,
                "kind": kind,
                "config": cfg_state,
                "schedule": sched_cell,
                "groups": groups_cell,
                "unit": unit_state,
                "last": last,
                "last-ran": last_ran,
                "masked-by": mask_reason,
                "unit-name": unit_name,
                "unit-schedule": unit_sched_cell,
                "pending-schedule": pending_sched_cell,
            }
        )

    # Per-column width: max of the header label and the longest
    # cell, so a long "last-ran" value (`12d ago`) doesn't get
    # squeezed by the 8-char header.
    widths: dict[str, int] = {}
    for col in selected_cols:
        header = _STATUS_COL_HEADERS[col]
        cell_max = max((len(r[col]) for r in rows), default=0)
        widths[col] = max(len(header), cell_max)

    # Two-space separator: a single space ran headers and cells
    # together at narrow column widths (e.g. CONFIG=6 vs UNIT=8
    # produced columns visually flush against each other).
    sep = "  "
    header_line = sep.join(
        f"{_STATUS_COL_HEADERS[c]:<{widths[c]}}" for c in selected_cols
    )
    print(header_line.rstrip())
    for row in rows:
        line = sep.join(f"{row[c]:<{widths[c]}}" for c in selected_cols)
        print(line.rstrip())
    # The footer applies to any starred cell. Suppress when the
    # user picked a column set that hides the columns that can
    # carry the marker.
    starred_cols = {"schedule", "groups"}
    if any_stale and any(c in selected_cols for c in starred_cols):
        print()
        print(_STALE_VALUE_FOOTER)


def do_logs(
    name: str,
    n: int,
    since: str | None,
    tail: bool,
    path: bool,
    latest: bool,
) -> None:
    """Print a job's recent log output.

    `name` is the full namespaced name (`<bundle>.<short>`); bare
    input is shorthand for `default.<short>`.

    -p/--path   print the log file's path and exit (no content read).
                Path resolution is purely structural -- prints even
                when the file doesn't exist yet (e.g. for a job
                that's been applied but never run), so it composes
                with other tools: `$EDITOR "$(crony logs j -p)"`.
    -l/--latest print only the most recent run's entry (from the
                last `=== ... ===` header to EOF). Overrides -n /
                --since; mutually exclusive with --tail.
    -n N        print the last N lines (default 200). With
                `--tail`, also controls how many lines of history
                are shown before live-tailing begins; `-n 0`
                skips the history.
    -s/--since X
                parse X as a duration ('1h', '2d') or ISO timestamp
                and skip log content older than that. Run-header
                timestamps anchor the cut.
    -t/--tail   show the last `-n` lines (default 200) and then
                follow appended output (-f semantics) until
                interrupted.
    """
    full = normalize_full_name(name)
    log_path = STATE_DIR / full / "run.log"
    if path:
        print(log_path)
        return
    if not log_path.exists():
        raise UsageError(f"no log for {full!r} (state dir: {STATE_DIR / full})")
    if tail and latest:
        raise UsageError("--tail and --latest are mutually exclusive")
    if tail:
        _follow_log(log_path, n=n)
        return
    text = log_path.read_text(encoding="utf-8", errors="replace")
    if latest:
        # `--latest` is a single-run readout; it overrides -n /
        # --since since the entry is bounded by run-header
        # markers, not line count or wallclock.
        text = _extract_latest_log_entry(text)
    else:
        if since is not None:
            text = _filter_since(text, since)
        if n > 0:
            lines = text.splitlines()
            if len(lines) > n:
                text = "\n".join(lines[-n:]) + "\n"
    sys.stdout.write(text)
    sys.stdout.flush()


def _follow_log(log_path: Path, *, n: int = 0) -> None:
    """tail -f equivalent on the log file.

    Prints the last `n` lines of the file before entering the
    follow loop (so `crony logs -t` mirrors `tail -f`'s "show
    history then live-tail" behavior); pass `n=0` to skip the
    history and start with new content only.

    Returns cleanly on Ctrl-C and on a closed downstream pipe so
    `crony logs -t | head` and an interactive interrupt both
    terminate without a stack trace.
    """
    try:
        with open(log_path, encoding="utf-8", errors="replace") as f:
            if n > 0:
                # Print the last `n` lines, then continue from
                # wherever those landed in the file. Using
                # readlines() over f then slicing is fine at log
                # sizes crony manages (run.log rotates per
                # `log_keep_runs`); a streaming reverse-read
                # would matter for multi-GB files we don't
                # produce.
                lines = f.readlines()
                tail = lines[-n:] if len(lines) > n else lines
                try:
                    sys.stdout.writelines(tail)
                    sys.stdout.flush()
                except BrokenPipeError:
                    return
            else:
                f.seek(0, os.SEEK_END)
            while True:
                line = f.readline()
                if not line:
                    time.sleep(0.5)
                    continue
                try:
                    sys.stdout.write(line)
                    sys.stdout.flush()
                except BrokenPipeError:
                    return
    except KeyboardInterrupt:
        return


_DURATION_RE = re.compile(r"^(\d+)([smhd])$")


def _parse_since(spec: str) -> datetime.datetime:
    """Parse a --since argument as duration shorthand or ISO timestamp.

    Returns a tz-aware datetime. ISO inputs without an offset are
    rejected here -- comparing them against the runner's tz-aware
    run-header timestamps would raise TypeError mid-filter, so we
    surface the issue at parse time as a UsageError instead.
    """
    text = spec.strip()
    m = _DURATION_RE.fullmatch(text)
    if m:
        n = int(m.group(1))
        unit = m.group(2)
        delta = datetime.timedelta(
            seconds=n * {"s": 1, "m": 60, "h": 3600, "d": 86400}[unit]
        )
        return datetime.datetime.now(datetime.timezone.utc).astimezone() - delta
    try:
        ts = datetime.datetime.fromisoformat(text)
    except ValueError as e:
        raise UsageError(
            f"unparseable --since value: {spec!r} "
            f"(use NUMs/m/h/d or ISO timestamp)"
        ) from e
    if ts.tzinfo is None:
        raise UsageError(
            f"--since {spec!r} is missing a timezone offset; "
            f"use a form like 2026-04-01T12:00:00-07:00"
        )
    return ts


def _filter_since(text: str, since: str) -> str:
    """Drop log content older than --since by run-header timestamp."""
    cutoff = _parse_since(since)
    header_re = re.compile(r"^=== (\S+) ")
    keep_from: int | None = None
    lines = text.splitlines(keepends=True)
    for idx, line in enumerate(lines):
        m = header_re.match(line)
        if not m:
            continue
        try:
            ts = datetime.datetime.fromisoformat(m.group(1))
        except ValueError:
            continue
        if ts >= cutoff:
            keep_from = idx
            break
    if keep_from is None:
        return ""
    return "".join(lines[keep_from:])


def do_run(name: str, dry_run: bool, skip_gate: bool) -> None:
    """Runner shim. Platform schedulers invoke this; not user-facing.

    `name` is the full namespaced name (`<bundle>.<short>`); bare
    input is shorthand for `default.<short>`. Loads the pinned
    snapshot written by the most recent apply and dispatches to
    the per-job or per-group pipeline. The wrapped command's exit
    code is surfaced via SystemExit so it propagates to launchd /
    systemd; cli() converts that into the process exit.
    """
    full_name = normalize_full_name(name)
    snap = _load_snapshot(full_name)
    if isinstance(snap, JobSnapshot):
        rc = run_job(snap, dry_run=dry_run, skip_gate=skip_gate)
    else:
        rc = run_group(snap, dry_run=dry_run, skip_gate=skip_gate)
    raise SystemExit(rc)


def do_audit(exclude_disabled: bool, bundle: str | None) -> None:
    """Walk every job; print bad rows; exit AUDIT_FAILED on hits.

    With no --bundle, iterates every bundle's selection plus every
    on-disk remnant (hash, unit file, or leftover state dir from a
    prior non-purge destroy), and reports linger status. With
    --bundle <name>, scopes to that bundle's selected jobs and
    remnants in that bundle's namespace; cross-host checks like
    linger are skipped -- they're about the whole-host picture,
    not any one bundle.

    Bad means CONFIG drift (stale/missing/orphan), the scheduler
    being unable to fire (unknown, plus disabled by default), or
    a recent failed/timeout run. Names in output are full
    namespaced (`<bundle>.<short>`).
    """
    bundles = load_all_bundles()
    require_known_bundle(bundles, bundle)
    platform = current_platform()
    _by_full, selected, masked_by_full = (
        _selected_and_masked_full_names_per_bundle(bundles)
    )
    remnants = discovered_names()
    if bundle is not None:
        selected = bundle_prefix_filter(selected, bundle)
        candidates = sorted(selected | bundle_prefix_filter(remnants, bundle))
    else:
        candidates = sorted(selected | remnants)

    bad_config = {"stale", "missing", "orphan"}
    bad_unit_state = {"none"}
    if not exclude_disabled:
        bad_unit_state = bad_unit_state | {"disabled"}
    bad_last = {"fail", "timeout"}

    rows: list[tuple[str, str, str, str]] = []
    for full in candidates:
        mask_reason = masked_by_full.get(full, "")
        cfg_state, unit_state, last_state = _resolve_state_axes(
            bundles, full, platform, remnants, mask_reason=mask_reason
        )
        is_bad = (
            cfg_state in bad_config
            or unit_state in bad_unit_state
            or last_state in bad_last
        )
        if is_bad:
            rows.append((full, cfg_state, unit_state, last_state))

    warnings: list[str] = []
    # Linger is host-wide -- skip it under --bundle scoping; the
    # operator who needs that info runs without --bundle.
    if bundle is None and platform == "linux":
        ling = linger_enabled()
        if ling is False:
            warnings.append(
                f"linger DISABLED for {_current_user()} "
                "-- jobs only fire while logged in"
            )

    if not rows and not warnings:
        print("audit: all jobs nominal")
        return

    if warnings:
        print("warnings:")
        for w in warnings:
            print(f"  - {w}")
        print()
    if rows:
        name_w = max(len(r[0]) for r in rows)
        name_w = max(name_w, len("JOB"))
        print(f"{'JOB':<{name_w}} {'CONFIG':10} {'UNIT':10} {'LAST':10}")
        for name, cs, ss, ls in rows:
            print(f"{name:<{name_w}} {cs:10} {ss:10} {ls:10}")

    raise AuditFailedError(
        f"{len(rows)} job(s) in bad state, {len(warnings)} system warning(s)"
    )


def _secret_warning(
    label: str,
    *,
    keychain_service: str | None,
    keychain_account: str | None,
    file_path: str | None,
) -> str:
    """Build a precise validate warning for an unresolved secret.

    Distinguishes "no source configured" from "configured source(s)
    resolved empty" so a misconfigured keychain item or missing file
    isn't misreported as "you forgot to set anything".
    """
    if keychain_service is None and file_path is None:
        return (
            f"{label} unresolved: no source configured (set keychain or file)"
        )
    parts: list[str] = []
    if keychain_service is not None:
        ident = (
            f"{keychain_service!r}/{keychain_account!r}"
            if keychain_account is not None
            else f"{keychain_service!r}"
        )
        parts.append(f"keychain item {ident}")
    if file_path is not None:
        parts.append(f"file {file_path!r}")
    return f"{label} unresolved: tried {' and '.join(parts)}"


def _validate_bundle_warnings(
    bundle: Bundle,
) -> list[str]:
    """Return per-bundle warnings: defined channels whose secrets
    don't resolve, channels defined but never referenced, etc."""
    warnings: list[str] = []
    config = bundle.config

    # Walk every layer that might select channels and confirm any
    # we'll actually try to send through has its secrets resolvable.
    listed: set[str] = set(config.defaults.notify_channels)
    for j in config.jobs.values():
        if j.notify_channels is not None:
            listed.update(j.notify_channels)
    for t in list(config.platform_targets.values()) + list(
        config.host_targets.values()
    ):
        if t.notify_channels is not None:
            listed.update(t.notify_channels)

    for ch_name in sorted(listed):
        channel = config.defaults.notify_channel_defs.get(ch_name)
        if channel is None:
            # Cross-cutting validation already raises on this; be
            # defensive in case a future caller bypasses it.
            warnings.append(
                f"channel {ch_name!r} listed but not defined in "
                f"[defaults.notify.{ch_name}]"
            )
            continue
        if channel.transport == "email":
            assert channel.email is not None
            label = f"channel {ch_name!r}: SMTP password"
            try:
                secret = _retrieve_secret(
                    keychain_service=channel.email.smtp_pass_keychain_service,
                    keychain_account=channel.email.smtp_pass_keychain_account,
                    file_path=channel.email.smtp_pass_file,
                )
                if secret is None:
                    warnings.append(
                        _secret_warning(
                            label,
                            keychain_service=(
                                channel.email.smtp_pass_keychain_service
                            ),
                            keychain_account=(
                                channel.email.smtp_pass_keychain_account
                            ),
                            file_path=channel.email.smtp_pass_file,
                        )
                    )
            except PreconditionError as e:
                warnings.append(str(e))
        elif channel.transport == "ntfy":
            assert channel.ntfy is not None
            label = f"channel {ch_name!r}: ntfy token"
            try:
                token = _retrieve_secret(
                    keychain_service=channel.ntfy.token_keychain_service,
                    keychain_account=channel.ntfy.token_keychain_account,
                    file_path=channel.ntfy.token_file,
                )
                if token is None:
                    warnings.append(
                        _secret_warning(
                            label,
                            keychain_service=(
                                channel.ntfy.token_keychain_service
                            ),
                            keychain_account=(
                                channel.ntfy.token_keychain_account
                            ),
                            file_path=channel.ntfy.token_file,
                        )
                    )
            except PreconditionError as e:
                warnings.append(str(e))

    # Defined-but-unreferenced channels: not an error (may be staged
    # for future use), but worth flagging.
    defined = set(config.defaults.notify_channel_defs.keys())
    unused = defined - listed
    for ch_name in sorted(unused):
        warnings.append(
            f"channel {ch_name!r} is defined in "
            f"[defaults.notify.{ch_name}] but never referenced "
            f"by any notify_channels list"
        )

    if not config.jobs and not config.job_groups:
        warnings.append(
            "bundle defines no jobs or groups (nothing it contains can fire)"
        )
    return warnings


def do_validate(bundle: str | None) -> None:
    """Lint configs; report orphans, linger status, broken secret files.

    load_all_bundles already enforces per-bundle structural rules and
    isolates failed bundles. This subcommand surfaces orphan / linger
    / per-bundle warnings as informational output and exits WARNING
    (1) when any are present, CONFIG (3) when no bundles load.

    With --bundle <name>, restricts the per-bundle warnings to just
    that bundle. Cross-bundle / cross-host checks (orphan detection,
    linger status) only run in the unfiltered case -- they're about
    the whole-host picture, not any one bundle.
    """
    bundles = load_all_bundles()
    require_known_bundle(bundles, bundle)
    platform = current_platform()

    warnings: list[str] = []
    if bundle is None:
        _by_full, selected = _selected_full_names_per_bundle(bundles)
        remnants = discovered_names()
        orphans = sorted(remnants - selected)
        if orphans:
            warnings.append(f"orphans on this host: {orphans}")
        if platform == "linux":
            ling = linger_enabled()
            if ling is False:
                warnings.append(f"linger DISABLED for {_current_user()}")
            elif ling is None:
                warnings.append("linger status unknown")

    target_bundles = (
        [b for b in bundles.bundles if b.name == bundle]
        if bundle is not None
        else list(bundles.bundles)
    )
    for b in target_bundles:
        for w in _validate_bundle_warnings(b):
            warnings.append(f"{b.source}: {w}")

    print(f"bundles loaded: {len(target_bundles)}")
    for b in target_bundles:
        config = b.config
        print(
            f"  {b.name} ({b.source}): "
            f"jobs={len(config.jobs)}, groups={len(config.job_groups)}, "
            f"targets: platform={len(config.platform_targets)} "
            f"host={len(config.host_targets)}"
        )
    if warnings:
        print("warnings:")
        for w in warnings:
            print(f"  - {w}")
        # WARNING is not raisable as a CronyError; SystemExit forwards
        # the code through cli() unchanged.
        raise SystemExit(int(ExitCode.WARNING))
    print("ok")


def _notify_test_one_bundle(
    bundle: Bundle, channel: str | None
) -> tuple[list[str], list[tuple[str, NotificationResult]]]:
    """Run notify-test against one bundle. Returns (successes, failures)."""
    config = bundle.config
    if channel is not None:
        use_channels = [channel]
    else:
        synthetic_job = Job(name="notify-test", command="true")
        target = resolve_target(config, current_host(), current_platform())
        use_channels = resolved_notify_channels(config, target, synthetic_job)
    if not use_channels:
        return ([], [])
    result = JobRunResult(
        job=f"{bundle.name}.notify-test",
        host=current_host(),
        platform=current_platform(),
        started_at=_now_iso(),
        ended_at=_now_iso(),
        duration_sec=0.0,
        exit_class="fail",
        exit_code=1,
        signal=None,
        gate="none",
        log_path="(synthetic)",
        log_bytes_this_run=0,
        notifications={
            ch: NotificationResult(sent=False) for ch in use_channels
        },
    )
    log_text = (
        f"synthetic test message from `crony notify-test` "
        f"(bundle: {bundle.name}).\n"
        "if you can read this, the channel is working end-to-end.\n"
    )
    _dispatch_notify(result, log_text, config.defaults)
    successes = [ch for ch, nr in result.notifications.items() if nr.sent]
    failures = [
        (ch, nr) for ch, nr in result.notifications.items() if not nr.sent
    ]
    return (successes, failures)


def do_notify_test(channel: str | None, bundle: str | None) -> None:
    """Send a synthetic failure notification.

    Bundle / channel resolution follows crony's bare-input rule: when
    nothing is specified, only the default bundle is exercised (never
    a fan-out across every bundle).

    --bundle <name>      send only through that bundle's configured
                         channels.
    --channel <ch>       a bare channel name resolves against the
                         selected bundle (default if --bundle is
                         absent).
    --channel <bn>.<ch>  fully qualified; the bundle prefix wins,
                         and is required to match --bundle when both
                         are given.

    Verifies plumbing end-to-end without scheduling a real job. The
    exit code reflects whether every per-channel send succeeded: any
    per-channel failure surfaces as CONFIG (config-shaped) or ERROR
    (transport-shaped), preserving the original failure category.
    """
    bundles = load_all_bundles()

    # Resolve --channel into (bundle_from_channel, channel_or_None).
    channel_bundle: str | None = None
    channel_short: str | None = None
    if channel is not None:
        if "." in channel:
            channel_bundle, channel_short = parse_full_name(channel)
        else:
            channel_short = channel

    # Compose --bundle and --channel's bundle prefix.
    if channel_bundle is not None and bundle is not None:
        if channel_bundle != bundle:
            raise UsageError(
                f"--bundle {bundle!r} contradicts --channel "
                f"{channel!r} (bundle {channel_bundle!r}); pick one"
            )
    bundle_name = channel_bundle or bundle or DEFAULT_BUNDLE_NAME
    require_known_bundle(bundles, bundle_name)
    target_bundle = bundles.by_name(bundle_name)
    assert target_bundle is not None  # require_known_bundle guarantees

    successes, failures = _notify_test_one_bundle(target_bundle, channel_short)
    for ch in successes:
        logger.info("notification sent via %s.%s", target_bundle.name, ch)
    if not successes and not failures:
        logger.info("no notify channels configured; nothing to send")
        return
    if not failures:
        return
    all_failures: list[tuple[str, str, NotificationResult]] = [
        (target_bundle.name, ch, nr) for ch, nr in failures
    ]
    # Preserve the failure category: if every failure is config-shaped
    # surface CONFIG (3); otherwise ERROR (4). A mix of config and
    # transport failures gets ERROR -- the configurational issues
    # would block transport anyway.
    all_config = all(
        nr.error_class == "ConfigError" for _, _, nr in all_failures
    )
    detail = "; ".join(f"{bn}.{ch}: {nr.error}" for bn, ch, nr in all_failures)
    if all_config:
        raise ConfigError(f"notify-test failed: {detail}")
    raise CronyError(f"notify-test failed: {detail}")


def do_self_test(*, verbose: bool = False, coverage: bool = False) -> int:
    """Run tests by invoking the test file directly."""
    repo_root = Path(__file__).parent.parent
    test_file = repo_root / "tests" / "test_crony.py"
    cmd = [str(test_file)]
    if verbose:
        cmd.append("--verbose")
    if coverage:
        cmd.append("--coverage")
    return subprocess.run(cmd, cwd=repo_root).returncode


# =============================================================================
# ARGUMENT PARSER
# =============================================================================


def build_parser() -> argparse.ArgumentParser:
    """Build and return the argument parser."""
    parser = argparse.ArgumentParser(
        description=(
            "User-level scheduled-job manager for macOS "
            "(launchd LaunchAgents) and Linux (systemd user timers)."
        ),
        epilog=f"{ExitCode.epilog()}\n\n{_CRONY_DESIGN}",
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )
    # `metavar=` overrides argparse's auto-generated `{a,b,c,...}`
    # choices summary so internal subcommands like `run` (the
    # platform unit's entry point, not user-facing) don't leak
    # into the top-level help.
    subparsers = parser.add_subparsers(
        dest="command",
        metavar="<command>",
        help="Subcommands",
    )

    # init
    p_init = subparsers.add_parser(
        "init", help="Generate a default config file"
    )
    p_init.add_argument(
        "--force",
        action="store_true",
        help="Overwrite an existing config file",
    )
    p_init.add_argument(
        "-b",
        "--bundle",
        default=None,
        help=(
            "Write to config/<bundle>.toml instead of config.toml "
            "(creates the dropin dir if missing)"
        ),
    )

    # apply
    p_apply = subparsers.add_parser(
        "apply",
        help="Render and activate platform units to match config",
    )
    p_apply.add_argument(
        "jobs",
        nargs="*",
        help=(
            "Job/group names. With no args: full sync (install "
            "missing, fix drift, remove orphans). With names: "
            "surgical update of those entries only."
        ),
    )
    p_apply.add_argument(
        "-v",
        "--verbose",
        action="store_true",
        help="Also print 'unchanged' lines (default: suppressed)",
    )
    p_apply.add_argument(
        "-b",
        "--bundle",
        default=None,
        help=(
            "Scope the apply to one bundle. Bare names resolve in "
            "<bundle>; qualified names must match it. With no "
            "positional args, only that bundle's selection and "
            "orphans are touched."
        ),
    )

    # destroy
    p_destroy = subparsers.add_parser(
        "destroy",
        help="Remove platform units",
    )
    p_destroy.add_argument(
        "jobs",
        nargs="*",
        help=(
            "Job/group names. With no args: factory reset. "
            "With names: surgical removal."
        ),
    )
    p_destroy.add_argument(
        "--preserve-runtime",
        action="store_true",
        help=(
            "Keep run.log, last-run.json, and run.lock for "
            "post-mortem; only the unit, hash, and snapshot "
            "are removed. Default: full wipe."
        ),
    )
    p_destroy.add_argument(
        "--orphans",
        action="store_true",
        help=(
            "Limit removal to entries with on-disk remnants "
            "that no live config selects on this host. "
            "Combinable with -b/--bundle; mutually exclusive "
            "with positional names."
        ),
    )
    p_destroy.add_argument(
        "-b",
        "--bundle",
        default=None,
        help=(
            "Scope the destroy to one bundle. Bare names resolve in "
            "<bundle>; qualified names must match it. With no "
            "positional args, only that bundle's on-disk remnants "
            "are removed."
        ),
    )

    # enable
    p_enable = subparsers.add_parser(
        "enable",
        help="Tell the platform scheduler to fire the named jobs",
    )
    p_enable.add_argument(
        "jobs",
        nargs="*",
        help=(
            "Job names to enable. Omit when --bundle is given to "
            "enable every scheduled stamped entry in that bundle."
        ),
    )
    p_enable.add_argument(
        "-b",
        "--bundle",
        default=None,
        help=(
            "Scope the enable to one bundle. With no positional "
            "args, enables every scheduled stamped entry in "
            "<bundle>; with positional args, bare names resolve in "
            "<bundle> and qualified names must match it."
        ),
    )

    # disable
    p_disable = subparsers.add_parser(
        "disable",
        help="Tell the platform scheduler to skip the named jobs",
    )
    p_disable.add_argument(
        "jobs",
        nargs="*",
        help=(
            "Job names to disable. Omit when --bundle is given to "
            "disable every scheduled stamped entry in that bundle."
        ),
    )
    p_disable.add_argument(
        "-b",
        "--bundle",
        default=None,
        help=(
            "Scope the disable to one bundle. With no positional "
            "args, disables every scheduled stamped entry in "
            "<bundle>; with positional args, bare names resolve in "
            "<bundle> and qualified names must match it."
        ),
    )

    # trigger
    p_trigger = subparsers.add_parser(
        "trigger",
        help="Ask the platform scheduler to fire the named jobs now",
    )
    p_trigger.add_argument(
        "jobs",
        nargs="*",
        help=(
            "Job names to trigger via launchd / systemctl. Omit "
            "when --bundle is given to trigger every stamped entry "
            "in that bundle."
        ),
    )
    p_trigger.add_argument(
        "-b",
        "--bundle",
        default=None,
        help=(
            "Scope the trigger to one bundle. With no positional "
            "args, fires every stamped entry in <bundle>; with "
            "positional args, bare names resolve in <bundle> and "
            "qualified names must match it."
        ),
    )
    p_trigger.add_argument(
        "-w",
        "--wait",
        action="store_true",
        help=(
            "Block until each named entry's next completion and "
            "exit with that exit code (worst across multiple names)"
        ),
    )
    p_trigger.add_argument(
        "--trigger-timeout",
        type=int,
        default=None,
        dest="trigger_timeout",
        help=(
            "Override [defaults].trigger_timeout_sec (seconds to "
            "wait for a runner to come online after kickstart). "
            "Only meaningful with --wait."
        ),
    )

    # status
    p_status = subparsers.add_parser(
        "status",
        help="Print resolved state per job",
        epilog=_STATUS_HELP_EPILOG,
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )
    p_status.add_argument(
        "jobs",
        nargs="*",
        help="Restrict to these jobs (default: all)",
    )
    p_status.add_argument(
        "-a",
        "--all",
        dest="show_masked",
        action="store_true",
        help=(
            "List all defined entries, including ones masked on the "
            "current host. Entries can be masked because they are "
            "unused or associated with a different platform and/or "
            "host."
        ),
    )
    p_status.add_argument(
        "--cols",
        default=None,
        help=(
            "Comma-separated columns to display. See the Columns "
            "sections in the help epilog for valid names, aliases, "
            "and descriptions."
        ),
    )
    p_status.add_argument(
        "-b",
        "--bundle",
        default=None,
        help=(
            "Restrict the table to one bundle. Bare names resolve "
            "in <bundle>; qualified names must match it."
        ),
    )
    p_status.add_argument(
        "--config-current",
        action="store_true",
        help=(
            "SCHEDULE and GROUPS columns show only currently-"
            "active (applied) values (no asterisk on divergence)"
        ),
    )
    p_status.add_argument(
        "--config-pending",
        action="store_true",
        help=(
            "SCHEDULE and GROUPS columns show only pending values "
            "from the live config (no asterisk on divergence)"
        ),
    )

    # logs
    p_logs = subparsers.add_parser(
        "logs",
        help="Print a job's recent log output",
    )
    p_logs.add_argument(
        "name",
        help="Job name",
    )
    p_logs.add_argument(
        "-n",
        type=int,
        default=200,
        help="Print the last N lines (default 200)",
    )
    p_logs.add_argument(
        "-s",
        "--since",
        default=None,
        help='"1h", "2d", or ISO timestamp',
    )
    p_logs.add_argument(
        "-t",
        "--tail",
        action="store_true",
        help="Follow appended output",
    )
    p_logs.add_argument(
        "-p",
        "--path",
        action="store_true",
        help="Print the log file path and exit (no content)",
    )
    p_logs.add_argument(
        "-l",
        "--latest",
        action="store_true",
        help="Print only the latest run's entry",
    )

    # run -- internal entry point for platform units; hidden from
    # `crony --help` since end users should never invoke it directly
    # (use `crony trigger` instead, which goes through the platform
    # scheduler so the run uses the same execution context as a
    # scheduled fire).
    # No `help=` here -- argparse omits subparsers without a help
    # string from the top-level subcommand listing. Passing
    # argparse.SUPPRESS surfaces the literal "==SUPPRESS==" string
    # instead of hiding the entry.
    p_run = subparsers.add_parser("run")
    p_run.add_argument(
        "name",
        help="Full namespaced name (`<bundle>.<short>`)",
    )
    p_run.add_argument(
        "--dry-run",
        action="store_true",
        help="Acquire lock, run gate, but do not exec",
    )
    p_run.add_argument(
        "--skip-gate",
        action="store_true",
        help="Skip gate check (force run)",
    )

    # audit
    p_audit = subparsers.add_parser(
        "audit",
        help="Check every job; exit nonzero on any bad state",
    )
    p_audit.add_argument(
        "--exclude-disabled",
        action="store_true",
        help="Do not flag intentionally-disabled jobs as bad",
    )
    p_audit.add_argument(
        "-b",
        "--bundle",
        default=None,
        help="Restrict audit to jobs from one bundle",
    )

    # validate
    p_validate = subparsers.add_parser(
        "validate",
        help="Lint config; report orphans, linger, etc",
    )
    p_validate.add_argument(
        "-b",
        "--bundle",
        default=None,
        help=(
            "Restrict per-bundle warnings to one bundle. "
            "Cross-host checks (orphans, linger) are skipped in "
            "this mode -- run without --bundle for those."
        ),
    )

    # notify-test
    p_nt = subparsers.add_parser(
        "notify-test",
        help="Send a synthetic failure notification",
    )
    p_nt.add_argument(
        "--channel",
        default=None,
        help=(
            "Send through one specific channel. Bare name "
            "(`ntfy`) resolves against the selected bundle; "
            "fully qualified `<bundle>.<channel>` overrides --bundle."
        ),
    )
    p_nt.add_argument(
        "-b",
        "--bundle",
        default=None,
        help=(
            "Send through this bundle's notify config "
            "(default: the `default` bundle)"
        ),
    )

    # self-test
    p_st = subparsers.add_parser(
        "self-test",
        help="Run the bundled pytest suite",
    )
    p_st.add_argument(
        "-v",
        "--verbose",
        action="store_true",
        help="Verbose test output",
    )
    p_st.add_argument(
        "--coverage",
        action="store_true",
        help="Run with coverage report",
    )

    return parser


# =============================================================================
# COMMAND DISPATCH
# =============================================================================

COMMAND_CALLBACKS: dict[str, Callable[..., None]] = {
    "init": do_init,
    "apply": do_apply,
    "destroy": do_destroy,
    "enable": do_enable,
    "disable": do_disable,
    "trigger": do_trigger,
    "status": do_status,
    "logs": do_logs,
    "run": do_run,
    "audit": do_audit,
    "validate": do_validate,
    "notify-test": do_notify_test,
}


def cli() -> int:
    """CLI entry point with exception handling."""
    parser = build_parser()
    args = parser.parse_args()

    args_dict = vars(args)
    command = args_dict.pop("command")

    if not command:
        parser.print_help()
        return ExitCode.USAGE

    if command == "self-test":
        return do_self_test(
            verbose=args_dict.pop("verbose"),
            coverage=args_dict.pop("coverage"),
        )

    try:
        COMMAND_CALLBACKS[command](**args_dict)
    except SystemExit as e:
        # `crony run` raises SystemExit(<wrapped-rc>) so an
        # arbitrary exit code from the executed job (0-255) reaches
        # the platform scheduler unmodified rather than being
        # squashed to ExitCode.SUCCESS.
        if isinstance(e.code, int):
            return e.code
        return ExitCode.SUCCESS if e.code is None else ExitCode.ERROR
    except CronyError as e:
        logger.error("ERROR: %s", e)
        return e.exit_code
    except Exception:
        # Catch-all so an internal bug surfaces a traceback to the
        # user with a stable exit code rather than crashing the
        # process and leaving the scheduler with no exit code at all.
        traceback.print_exc()
        return ExitCode.ERROR
    return ExitCode.SUCCESS


if __name__ == "__main__":
    raise SystemExit(cli())
