#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.11"
# dependencies = ["tomlkit", "pydantic>=2"]
# ///
# This is AI generated code
#
# IMPORTANT: This script has tests in tests/test_crony.py
#
# The implementation lives in the importable `crony` package under
# <repo>/src; this entry is just the platform-unit-invocable shim that
# puts that package on sys.path and hands off to crony.cli.

from __future__ import annotations

import sys
from pathlib import Path

# First-party code lives under <repo>/src. The entry script's own
# directory (bin/) is on sys.path, but the package dir is not, so
# prepend it. resolve() follows any symlink to the real file first, so
# the parent walk reaches the repo root even when the entry is invoked
# through a symlink.
sys.path.insert(0, str(Path(__file__).resolve().parent.parent / "src"))

import crony.cli  # noqa: E402

if __name__ == "__main__":
    raise SystemExit(crony.cli.cli())
