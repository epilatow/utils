#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.14"
# dependencies = [
#     "tomlkit",
#     "pydantic>=2",
#     "mdformat",
#     "mdformat-gfm",
#     "mdformat-tables",
# ]
# ///
# This is AI generated code
#
# IMPORTANT: This script has tests in tests/test_render_docs.py
"""Generate reference docs for the repo's argparse-based utilities.

A utility is described by a `ManSpec`; the generic machinery renders it
from its argparse parser into two final docs, by two format-specific
renderers off the one spec so neither can drift from the CLI:

    parser (ManSpec) -+-> share/man/man<N>/<prog>.<section>  (roff man page)
                      +-> docs/<prog>.md                     (GFM doc)

There is no committed intermediate. The man page goes through a transient
pandoc-Markdown form (definition lists, the idiomatic man layout) piped
straight to pandoc; the GFM doc is built directly in GitHub-idiomatic
shapes (bold-term bullets with the description indented beneath, a
code-span heading per subcommand, EXIT STATUS as a table) and run through
mdformat. The two are rendered separately because the definition lists
that read well in roff have no native GFM equivalent (pandoc's GFM writer
flattens them), so a single shared source can't serve both.

Each utility's `ManSpec` (see `common.docspec`) supplies the per-utility
bits the parser doesn't carry: the NAME one-liner, the DESCRIPTION
overview, extra prose sections, an optional reference section
(structured `(label, description)` data, e.g. crony's status columns), a
FILES list, and an EXIT STATUS table. Everything else -- SYNOPSIS, the
SUBCOMMANDS list, and COMMON ARGUMENTS (the args shared across
subcommands, detected from the parser and shown with each argument's
extended help) -- is derived generically. A utility opts in by exposing
a module-level `MAN_SPEC`; `_discover_specs` finds them, so adding one
touches only that utility.

It also generates the repo `README.md`: the authored preamble from
`scripts/readme-intro.md`, the documented utilities (those with a
`MAN_SPEC`, blurbed from their DESCRIPTION and linked to their `docs/`
page), and the undocumented `bin/` utilities (blurbed from each one's
`--help`). See `build_readme`.

Run with no arguments to (re)write every utility's man page and GFM doc
plus the README (pandoc required for the roff). `--check` re-renders the
GFM docs and the README -- pure Python plus mdformat (and each
undocumented tool's `--help`) -- and exits non-zero on drift without
writing (no pandoc needed); the pandoc-built roff is gated by the pytest
freshness test instead.
"""

import argparse
import importlib
import json
import re
import subprocess
import sys
import tomllib
from collections.abc import Callable
from pathlib import Path
from typing import NamedTuple, assert_never

import mdformat

_REPO_ROOT = Path(__file__).resolve().parent.parent
# First-party packages live under <repo>/src; put it on the path before
# importing any utility's parser, the same way each bin/ entry does.
sys.path.insert(0, str(_REPO_ROOT / "src"))

from common.argparse_ext import (  # noqa: E402
    default_help_suffix,
    get_extended_help,
    help_with_default,
    is_common,
)
from common.docspec import (  # noqa: E402
    ItemListsSection,
    ItemsSection,
    ManSpec,
    Section,
    TextSection,
)

# pandoc renders the Markdown to roff. Its roff output varies between
# versions, so a single pandoc is pinned in `scripts/pandoc-pin.json`
# (version + per-asset sha256); `scripts/pandoc install` fetches and
# checksum-verifies it into `.tools/`, and the freshness gate renders
# with it. The version is read from that pin file so it stays the single
# source for both the gate and the installer.
PANDOC_VERSION: str = json.loads(
    (_REPO_ROOT / "scripts" / "pandoc-pin.json").read_text()
)["version"]
_PANDOC_DIR = _REPO_ROOT / ".tools" / f"pandoc-{PANDOC_VERSION}"

_MD_SPECIAL = set("\\`*_[]<>#|")


def _md(text: str) -> str:
    """Backslash-escape Markdown inline metacharacters so parser-derived
    text renders verbatim (as `--help` shows it)."""
    return "".join("\\" + c if c in _MD_SPECIAL else c for c in text)


# GitHub renders backtick code spans, so the GFM escaper -- unlike `_md`,
# which escapes backticks too (roff has no code span) -- leaves them alone
# and escapes only the prose around them.
_GFM_SPECIAL = _MD_SPECIAL - {"`"}
# A code span: a run of N backticks closed by a run of N (the `(?<!`)` /
# `(?!`)` guards make each run maximal), with the inner text in between.
_GFM_CODE_SPAN = re.compile(r"(?<!`)(`+)(?:.+?)\1(?!`)", re.S)


def _gfm_escape(text: str) -> str:
    return "".join("\\" + c if c in _GFM_SPECIAL else c for c in text)


def _gfm_inline(text: str) -> str:
    """Escape GFM inline metacharacters in `text`, but pass backtick code
    spans through verbatim so authored `code` renders as code on GitHub."""
    out: list[str] = []
    last = 0
    for match in _GFM_CODE_SPAN.finditer(text):
        out.append(_gfm_escape(text[last : match.start()]))
        out.append(match.group(0))
        last = match.end()
    out.append(_gfm_escape(text[last:]))
    return "".join(out)


# ---------------------------------------------------------------------------
# Spec discovery
# ---------------------------------------------------------------------------
#
# A utility opts into generated docs by exposing a module-level `MAN_SPEC`
# (see `common.docspec.ManSpec`). Discovery imports each `src/*.py` alias
# that points at a `bin/` entry and collects any `MAN_SPEC`, so adding a
# utility's docs touches only that utility -- never this file. The alias
# is imported only when its source actually defines `MAN_SPEC`, so an
# undocumented tool's dependencies aren't pulled in here. crony is the one
# exception: it has no alias (its logic is the `src/crony` package), so it
# is imported by name.


def _discover_specs() -> list[ManSpec]:
    """Every utility's `MAN_SPEC`, crony first then the alias'd `bin/`
    entries in name order. Order is immaterial -- each man / GFM doc is a
    separate file and the README sorts by `prog` -- but kept stable."""
    specs: list[ManSpec] = [importlib.import_module("crony.cli").MAN_SPEC]
    for alias in sorted((_REPO_ROOT / "src").glob("*.py")):
        if not alias.is_symlink():
            continue
        target = alias.resolve()
        # Only bin/ utilities, and only import one whose source names
        # MAN_SPEC -- so an undocumented tool's deps aren't pulled in
        # here. The substring check can false-positive (a mention in a
        # comment), so confirm the attribute actually exists.
        if target.parent.name != "bin" or "MAN_SPEC" not in target.read_text():
            continue
        spec = getattr(importlib.import_module(alias.stem), "MAN_SPEC", None)
        if spec is not None:
            specs.append(spec)
    return specs


# ---------------------------------------------------------------------------
# Generic parser introspection
# ---------------------------------------------------------------------------
#
# argparse exposes no public API for walking a built parser, so a few
# internal accesses are unavoidable -- the same ones argparse-manpage
# relies on: `parser._actions` (the action list has no public iterator),
# `argparse._SubParsersAction` (to recognise the subparsers action), and
# its `_choices_actions` (the only place a subcommand's help string and
# its listed-in-`--help` status live). Everything else here is built from
# public `Action` attributes (`option_strings`, `metavar`, `nargs`,
# `dest`, `choices`, `help`) rather than argparse's formatter internals.


def _has_subcommands(parser: argparse.ArgumentParser) -> bool:
    return any(
        isinstance(a, argparse._SubParsersAction) for a in parser._actions
    )


def _build_parser(spec: ManSpec) -> argparse.ArgumentParser:
    """Build the spec's parser with `prog` forced (argparse otherwise
    takes it from `sys.argv[0]`, which varies by how this is invoked)."""
    saved_argv0 = sys.argv[0]
    sys.argv[0] = spec.prog
    try:
        parser = spec.build_parser()
    finally:
        sys.argv[0] = saved_argv0
    return parser


def _signature(parser: argparse.ArgumentParser) -> str:
    """The option / argument part of a parser's usage, collapsed to one
    logical line so the man renderer -- not argparse's width-based usage
    formatter -- handles wrapping. `-h` is dropped: every parser has it,
    so repeating it in each signature is noise."""
    usage = " ".join(parser.format_usage().split())
    prefix = f"usage: {parser.prog} "
    sig = usage[len(prefix) :] if usage.startswith(prefix) else usage
    return sig.removeprefix("[-h] ").removeprefix("[-h]").strip()


def _metavar(action: argparse.Action, default: str) -> str:
    """The display name for an action's value: an explicit `metavar`, else
    the `{a,b,c}` choices set, else `default`. Mirrors argparse's own
    metavar selection without reaching into its formatter."""
    if action.metavar is not None:
        return (
            action.metavar
            if isinstance(action.metavar, str)
            else " ".join(action.metavar)
        )
    if action.choices is not None:
        return "{" + ",".join(str(c) for c in action.choices) + "}"
    return default


def _format_args(action: argparse.Action, metavar: str) -> str:
    """An option's value placeholder, accounting for `nargs` (e.g. `X`,
    `[X]`, `[X ...]`)."""
    nargs = action.nargs
    if nargs is None:
        return metavar
    if nargs == argparse.OPTIONAL:
        return f"[{metavar}]"
    if nargs == argparse.ZERO_OR_MORE:
        return f"[{metavar} ...]"
    if nargs == argparse.ONE_OR_MORE:
        return f"{metavar} [{metavar} ...]"
    if nargs == argparse.REMAINDER:
        return "..."
    if isinstance(nargs, int):
        return " ".join([metavar] * nargs)
    return metavar


def _invocation(action: argparse.Action) -> str:
    """An action's invocation as `--help` shows it (`-b, --bundle BUNDLE`
    for value options, joined flags for switches, the metavar for
    positionals), built from public attributes. Matches argparse's
    Python 3.13+ formatting, which prints the value placeholder once after
    the joined option strings rather than after each."""
    if not action.option_strings:
        return _metavar(action, action.dest)
    if action.nargs == 0:
        return ", ".join(action.option_strings)
    args = _format_args(action, _metavar(action, action.dest.upper()))
    return ", ".join(action.option_strings) + " " + args


def _documented_actions(
    parser: argparse.ArgumentParser,
) -> list[argparse.Action]:
    """Every documented option / positional action, skipping the universal
    `-h/--help` and the subparsers pseudo-action."""
    return [
        action
        for action in parser._actions
        if not isinstance(action, argparse._SubParsersAction)
        and "-h" not in action.option_strings
    ]


def _options(
    parser: argparse.ArgumentParser,
) -> list[tuple[str, str]]:
    """(invocation, help) for each documented option / positional."""
    return [
        (_invocation(action), help_with_default(action))
        for action in _documented_actions(parser)
    ]


def _walk_subcommands(
    parser: argparse.ArgumentParser,
    acc: list[tuple[argparse.ArgumentParser, str]],
) -> None:
    """Collect `(subparser, summary)` for every leaf subcommand,
    depth-first, so nested verbs follow their parent. Intermediary
    parents (which just group their actions) are recursed through but not
    documented -- their leaves carry the full path. Subcommands registered
    without a help string (internal entry points argparse omits from
    `--help`) are skipped. The summary prefers the subparser's
    `description` (the fuller text, which carries any subcommand-specific
    argument behavior) over the short list `help`."""
    for action in parser._actions:
        if isinstance(action, argparse._SubParsersAction):
            help_by_name = {
                ca.dest: ca.help or "" for ca in action._choices_actions
            }
            for name, sub in action.choices.items():
                if name not in help_by_name:
                    continue
                if not _has_subcommands(sub):
                    acc.append((sub, sub.description or help_by_name[name]))
                _walk_subcommands(sub, acc)


# ---------------------------------------------------------------------------
# Markdown rendering
# ---------------------------------------------------------------------------


def _code_block(text: str) -> list[str]:
    """Pre-formatted text as a fenced code block (pandoc renders it as a
    verbatim roff block, preserving hand-aligned columns)."""
    return ["```text", *text.splitlines(), "```", ""]


def _next_is_indented(lines: list[str], i: int) -> bool:
    """Whether the next non-blank line at or after index `i` is indented."""
    while i < len(lines) and not lines[i].strip():
        i += 1
    return i < len(lines) and lines[i][:1].isspace()


def _is_bullet(line: str) -> bool:
    """Whether `line` is a flush-left Markdown bullet (`- `)."""
    return line.startswith("- ")


def _overview_md(
    overview: str,
    inline: Callable[[str], str] = _md,
) -> list[str]:
    """A description / overview as Markdown, segmented by line into prose
    paragraphs (flush-left text, reflowed), bullet lists (`- ` lines), and
    verbatim code blocks (indented lines, e.g. a shell example).

    A flush-left lead-in line stays prose -- it is not pulled into a
    following bullet list or indented block. (A blank line still separates
    the lead-in from the list / block: both pandoc and mdformat require it
    to recognise the list / block, so it is structural, not cosmetic.) A
    blank line between indented lines is kept inside the one code block, so
    a single example with an internal blank renders whole. A bullet item
    that wraps continues on flush-left lines (an indented line would start
    a code block instead). `inline` escapes prose for the target dialect
    (`_md` for pandoc/man, `_gfm_inline` for GFM)."""
    out: list[str] = []
    lines = overview.split("\n")
    n = len(lines)
    i = 0
    while i < n:
        if not lines[i].strip():
            i += 1
            continue
        if lines[i][:1].isspace():
            run: list[str] = []
            while i < n:
                if lines[i].strip() and lines[i][:1].isspace():
                    run.append(lines[i])
                elif not lines[i].strip() and _next_is_indented(lines, i + 1):
                    run.append("")
                else:
                    break
                i += 1
            out += _code_block("\n".join(run))
        elif _is_bullet(lines[i]):
            while i < n and lines[i].strip() and not lines[i][:1].isspace():
                if _is_bullet(lines[i]):
                    out.append(f"- {inline(lines[i][2:])}")
                elif out:
                    out[-1] += f" {inline(lines[i].strip())}"
                i += 1
            out.append("")
        else:
            # Join the wrapped source lines before escaping so a code span
            # that wraps across lines is seen (and preserved) whole.
            run = []
            while (
                i < n
                and lines[i].strip()
                and not lines[i][:1].isspace()
                and not _is_bullet(lines[i])
            ):
                run.append(lines[i])
                i += 1
            out += [inline(" ".join(run)), ""]
    return out


def _definition(term: str, description: str, *, indent: str = "") -> list[str]:
    """A pandoc definition-list entry (`term` / `: description`), at an
    optional indent so it can nest under another definition."""
    return [
        f"{indent}{term}",
        "",
        f"{indent}:   {description}",
        "",
    ]


class _CommonArg(NamedTuple):
    """An argument shared across subcommands, hoisted into COMMON
    ARGUMENTS. `extended_help` (when set on the argument) is the longer
    description shown there; `help` is argparse's terse one-liner."""

    invocation: str
    help: str
    extended_help: str | None
    is_positional: bool


def _shared_options(
    subs: list[tuple[argparse.ArgumentParser, str]],
) -> tuple[list[_CommonArg], set[str]]:
    """Drive COMMON ARGUMENTS, shared by both renderers so they agree on
    what is hoisted out of the per-subcommand listing.

    Collect every argument tagged common (`add_argument_ext(common=True)`)
    from the subcommands -- the tag is the single source -- deduplicated by
    invocation. Return them ordered shared-positionals-first (so a `job`
    positional leads) then by invocation, plus the invocations used to
    prune them from each subcommand."""
    by_invocation: dict[str, _CommonArg] = {}
    for sub, _ in subs:
        for action in _documented_actions(sub):
            if not is_common(action):
                continue
            # A common arg is documented once via extended_help (if set) or
            # help; append the default to whichever the renderer will use so
            # the docs and --help agree.
            extended = get_extended_help(action)
            if extended is not None and not (
                "(default:" in extended or "%(default)" in extended
            ):
                extended += default_help_suffix(action)
            arg = _CommonArg(
                _invocation(action),
                help_with_default(action),
                extended,
                not action.option_strings,
            )
            existing = by_invocation.setdefault(arg.invocation, arg)
            # A common argument is documented once, so every subcommand
            # that tags it must describe it identically; otherwise the
            # single COMMON ARGUMENTS entry would silently pick one.
            assert existing == arg, (
                f"common argument {arg.invocation!r} is tagged "
                f"inconsistently across subcommands"
            )
    shared = sorted(
        by_invocation.values(),
        key=lambda a: (not a.is_positional, a.invocation),
    )
    return shared, set(by_invocation)


def _section_md(section: Section) -> list[str]:
    """Render a free-form spec section as pandoc Markdown, dispatching on
    its shape: prose, a definition list, or an intro plus titled
    sub-lists."""
    out = [f"# {section.title}", ""]
    if isinstance(section, TextSection):
        out += _overview_md(section.body)
    elif isinstance(section, ItemsSection):
        for term, description in section.items:
            out += _definition(f"`{term}`", _md(description))
    elif isinstance(section, ItemListsSection):
        if section.intro:
            out += [_md(section.intro), ""]
        for title, lead, items in section.subsections:
            out += [f"## {title}", ""]
            if lead:
                out += [_md(lead), ""]
            for label, description in items:
                # Emphasis (italic -> underline in a terminal) sets the
                # key apart from its description when both share a line.
                out += _definition(f"*{_md(label)}*", _md(description))
    else:
        assert_never(section)
    return out


def build_markdown(spec: ManSpec) -> str:
    """Render a utility's man page as pandoc Markdown. Pure and
    deterministic. Transient: piped to pandoc for the roff man page, not
    committed."""
    parser = _build_parser(spec)
    # The pandoc title block carries no date, so pandoc renders an empty
    # `.TH` date field. That is deliberate: the page is a build artifact
    # gated for byte-equality, and a real date would make every render
    # differ. man renders the blank date slot without complaint.
    out: list[str] = [
        f"% {spec.prog}({spec.section}) {spec.prog} | {spec.prog} manual",
        "",
        "# NAME",
        "",
        f"{spec.prog} - {spec.name_description}",
        "",
        "# SYNOPSIS",
        "",
        f"**{spec.prog}** {_md(_signature(parser))}".rstrip(),
        "",
        "# DESCRIPTION",
        "",
    ]
    out += _overview_md(spec.description or parser.description or "")

    for sec in spec.pre_sections:
        out += _section_md(sec)

    subs: list[tuple[argparse.ArgumentParser, str]] = []
    _walk_subcommands(parser, subs)
    shared, pruned = _shared_options(subs)

    if shared:
        out += ["# COMMON ARGUMENTS", ""]
        for arg in shared:
            # The authored extended help is doc Markdown rendered verbatim;
            # argparse's terse help is escaped like any parser-derived text.
            description = arg.extended_help or _md(arg.help)
            out += _definition(f"`{arg.invocation}`", description)

    out += ["# SUBCOMMANDS", ""]
    for sub, summary in subs:
        path = sub.prog.removeprefix(f"{spec.prog} ")
        # rstrip so a no-argument subcommand (empty signature) doesn't
        # leave a trailing space after the bold name.
        out += [f"**{path}** {_md(_signature(sub))}".rstrip(), ""]
        out += [f":   {_md(summary)}", ""]
        for invocation, opt_help in _options(sub):
            if invocation in pruned:
                continue
            out += _definition(f"`{invocation}`", _md(opt_help), indent="    ")

    for sec in spec.post_sections:
        out += _section_md(sec)

    if spec.exit_status:
        out += ["# EXIT STATUS", ""]
        # A compact definition list: the term and definition adjacent (no
        # blank between them) renders each as a tight `.TP` with no gap,
        # since the codes are short and loose spacing wastes vertical room.
        for code, description in spec.exit_status:
            out += [f"`{code}`", f":   {_md(description)}", ""]

    return "\n".join(out).rstrip("\n") + "\n"


def _pandoc_version(pandoc: str) -> str | None:
    """The version a pandoc binary reports (e.g. `3.10`), or None if it
    can't be run."""
    try:
        out = subprocess.run(
            [pandoc, "--version"],
            capture_output=True,
            text=True,
            check=True,
        ).stdout
    except OSError, subprocess.CalledProcessError:
        return None
    first = out.splitlines()[0].split() if out else []
    return first[1] if len(first) >= 2 and first[0] == "pandoc" else None


def _pinned_pandoc() -> str | None:
    """The pinned pandoc to render with: the repo-local `.tools/` binary
    placed by `scripts/pandoc install`, or None if it isn't installed.
    Only this binary is used -- never a `PATH` pandoc -- so the rendered
    roff can't vary with whatever pandoc happens to be on `PATH`."""
    local = _PANDOC_DIR / "bin" / "pandoc"
    return str(local) if local.exists() else None


def _render_roff(markdown: str) -> str:
    """pandoc-render Markdown to a standalone man page."""
    pandoc = _pinned_pandoc()
    if pandoc is None:
        raise SystemExit(
            f"pandoc {PANDOC_VERSION} not found; run scripts/pandoc install "
            "to fetch the pinned version into .tools/."
        )
    result = subprocess.run(
        # `-smart` keeps pandoc from rewriting `--` as an en-dash and
        # `'`/`"` as curly quotes -- option spellings must stay literal.
        # `--wrap=none` doesn't word-wrap the roff, so the man renderer
        # reflows prose at its own width instead of baking in pandoc's
        # wrap. (Inter-sentence spacing is handled below.)
        [
            pandoc,
            "--standalone",
            "--from=markdown-smart",
            "--to=man",
            "--wrap=none",
        ],
        input=markdown,
        capture_output=True,
        text=True,
        check=True,
    )
    src = [
        line
        for line in result.stdout.splitlines()
        if not line.startswith('.\\" Automatically generated by Pandoc')
    ]
    # pandoc precedes a code block with a bare `.IP` (indented paragraph),
    # which double-indents the following `.EX` verbatim block. Swap it for
    # `.PP`: that keeps the paragraph break separating the block from its
    # neighbors but drops the extra indent, so the block sits at its
    # section's one indent level.
    lines = [
        ".PP"
        if (line == ".IP" and i + 1 < len(src) and src[i + 1] == ".EX")
        else line
        for i, line in enumerate(src)
    ]
    # pandoc writes one sentence per roff line; roff then inserts a double
    # space wherever a line ends in sentence punctuation. Append `\&`
    # (zero-width) to those line ends so roff keeps a single space. roff
    # looks through trailing closing delimiters (`)`, `]`, `'`, `"`) to
    # find the punctuation, so a line ending `etc.)` counts too.
    # Verbatim (.EX/.EE) blocks print literally, so skip them.
    out: list[str] = []
    in_verbatim = False
    for line in lines:
        if line == ".EX":
            in_verbatim = True
        elif line == ".EE":
            in_verbatim = False
        elif (
            not in_verbatim
            and line[:1] not in (".", "'")
            and line.rstrip(")]'\"").endswith((".", "!", "?"))
        ):
            line += "\\&"
        out.append(line)
        # EXIT STATUS is a list of short codes; `.PD 0` zeroes the
        # paragraph distance so mandoc renders the entries compactly
        # instead of with `.TP`'s default blank line between each. It is
        # the last section, so no reset is needed.
        if line == ".SH EXIT STATUS":
            out.append(".PD 0")
    # Bullet lists get the same compaction: groff spaces consecutive
    # `.IP \(bu` items by `.PD`'s default paragraph distance (a blank line
    # between bullets). Wrap each run in `.PD 0` / `.PD` (reset) so the
    # items render tight without affecting the surrounding paragraphs.
    tightened: list[str] = []
    in_bullets = False
    for line in out:
        is_bullet = line.startswith(".IP \\(bu")
        if is_bullet and not in_bullets:
            tightened.append(".PD 0")
            in_bullets = True
        elif in_bullets and not is_bullet and line.startswith("."):
            tightened.append(".PD")
            in_bullets = False
        tightened.append(line)
    if in_bullets:
        tightened.append(".PD")
    return "\n".join(tightened).strip("\n") + "\n"


def _md_wrap() -> int:
    """The prose wrap width the repo's markdown gates enforce, read from
    `[tool.repo-shared.markdown]` in pyproject.toml so the GFM render stays
    mdformat-canonical without a second copy of the number."""
    pyproject = tomllib.loads((_REPO_ROOT / "pyproject.toml").read_text())
    return int(pyproject["tool"]["repo-shared"]["markdown"]["wrap"])


def _gfm_break_item(term_md: str, description: str) -> str:
    """A bulleted list item whose `term_md` (already-formatted markdown --
    a link, bold text, or inline code) sits on its own line, then a `\\`
    hard break and the GFM-escaped description indented two spaces beneath.
    Preferred over a table for wide terms (option / value / utility
    names), which a GitHub table wraps across lines."""
    return f"- {term_md}\\\n  {_gfm_inline(description)}"


def _gfm_item(term: str, description: str) -> str:
    """A definition as a bulleted list item: the bold inline-code term on
    its own line (a `\\` hard break), the description indented beneath it."""
    return _gfm_break_item(f"**`{term.strip('`')}`**", description)


def _gfm_table(
    items: list[tuple[str, str]],
    term_header: str,
    desc_header: str,
) -> list[str]:
    """A two-column GFM table -- the term in inline code, its description
    as prose -- which is GitHub's native way to render a definition list
    (aligned columns, a reflowing description, code spans that render as
    code). Explicit left-align (`:---`) so GitHub left-aligns the header
    cells too, not just the body."""
    rows = [
        f"| {term_header} | {desc_header} |",
        "| :--- | :--- |",
    ]
    rows += [f"| `{term}` | {_gfm_inline(desc)} |" for term, desc in items]
    rows.append("")
    return rows


def _section_gfm(section: Section) -> list[str]:
    """Render a free-form spec section as GFM, dispatching on its shape:
    prose, a bulleted definition list, or an intro plus titled
    sub-lists."""
    out = [f"## {section.title}", ""]
    if isinstance(section, TextSection):
        out += _overview_md(section.body, _gfm_inline)
    elif isinstance(section, ItemsSection):
        out += [_gfm_item(term, desc) for term, desc in section.items]
        out.append("")
    elif isinstance(section, ItemListsSection):
        if section.intro:
            out += [_gfm_inline(section.intro), ""]
        for title, lead, items in section.subsections:
            out += [f"### {title}", ""]
            if lead:
                out += [_gfm_inline(lead), ""]
            out += [_gfm_item(label, desc) for label, desc in items]
            out.append("")
    else:
        assert_never(section)
    return out


def build_gfm(spec: ManSpec) -> str:
    """Render a utility's doc as GitHub-Flavored Markdown: a single
    `# <prog> - <summary>` title (the man page's NAME line, which a
    GitHub doc needs no separate section for) with man-style sections
    demoted to `##`, option / argument / reference entries as bulleted
    definitions (bold-code term, description indented beneath), a code-span
    heading per subcommand carrying its signature, and EXIT STATUS as a
    table (its single-digit codes never wrap). Run through mdformat so the
    result satisfies the repo's prose mdformat / markdownlint gates. Pure
    Python (no pandoc); deterministic."""
    parser = _build_parser(spec)
    synopsis = f"{spec.prog} {_signature(parser)}".rstrip()
    out: list[str] = [
        f"# {spec.prog} - {spec.name_description}",
        "",
        "## SYNOPSIS",
        "",
        f"`{synopsis}`",
        "",
        "## DESCRIPTION",
        "",
    ]
    out += _overview_md(
        spec.description or parser.description or "", _gfm_inline
    )

    for sec in spec.pre_sections:
        out += _section_gfm(sec)

    subs: list[tuple[argparse.ArgumentParser, str]] = []
    _walk_subcommands(parser, subs)
    shared, pruned = _shared_options(subs)

    if shared:
        out += ["## COMMON ARGUMENTS", ""]
        out += [
            _gfm_item(arg.invocation, arg.extended_help or arg.help)
            for arg in shared
        ]
        out.append("")

    out += ["## SUBCOMMANDS", ""]
    for sub, summary in subs:
        path = sub.prog.removeprefix(f"{spec.prog} ")
        # The command and its signature go in the one heading (so it reads
        # once and still anchors in GitHub's outline), not a heading plus a
        # repeated usage block. The heading is a code span so the command
        # and its arguments render in the monospace font.
        signature = f"{path} {_signature(sub)}".rstrip()
        out += [f"### `{signature}`", ""]
        out += [_gfm_inline(summary), ""]
        own = [
            (invocation, opt_help)
            for invocation, opt_help in _options(sub)
            if invocation not in pruned
        ]
        if own:
            out += [_gfm_item(inv, opt_help) for inv, opt_help in own]
            out.append("")

    for sec in spec.post_sections:
        out += _section_gfm(sec)

    if spec.exit_status:
        out += ["## EXIT STATUS", ""]
        out += _gfm_table(spec.exit_status, "Code", "Meaning")

    return mdformat.text(
        "\n".join(out),
        options={"wrap": _md_wrap(), "number": True},
        extensions={"gfm", "tables"},
    )


# ---------------------------------------------------------------------------
# Repo README
# ---------------------------------------------------------------------------

_BIN_DIR = _REPO_ROOT / "bin"

# The authored README preamble (title, intro, Installation). Everything
# below it is derived -- documented utilities from their DESCRIPTION,
# undocumented ones from their `--help` -- so this fragment is the only
# hand-edited part of the generated README.
_README_INTRO_PATH = _REPO_ROOT / "scripts" / "readme-intro.md"


def _first_paragraph(text: str) -> str:
    """The first blank-line-delimited paragraph of `text`, collapsed to a
    single line (a utility's one-line blurb for the README)."""
    for block in text.split("\n\n"):
        collapsed = " ".join(block.split())
        if collapsed:
            return collapsed
    return ""


def _help_blurb(prog: str) -> str:
    """The first paragraph of an undocumented utility's `--help`: the text
    after the usage block, which argparse renders from its parser
    `description`."""
    output = subprocess.run(
        [str(_BIN_DIR / prog), "--help"],
        capture_output=True,
        text=True,
        check=True,
    ).stdout
    lines = output.splitlines()
    cursor = 0
    if lines and lines[0].startswith("usage:"):
        cursor = 1
        while cursor < len(lines) and lines[cursor].strip():
            cursor += 1
    return _first_paragraph("\n".join(lines[cursor:]))


def build_readme() -> str:
    """Render the repo README: the authored preamble from
    `scripts/readme-intro.md`, the documented utilities (linked to their
    generated docs, blurbed from their DESCRIPTION), then the undocumented
    utilities (blurbed from their `--help`). Run through mdformat so it
    satisfies the repo's prose gates. Needs no pandoc, but runs each
    undocumented utility's `--help`."""
    specs = sorted(_discover_specs(), key=lambda s: s.prog)
    documented = {spec.prog for spec in specs}
    intro = _README_INTRO_PATH.read_text().strip()
    out = [intro, "", "## Documented utilities", ""]
    for spec in specs:
        blurb = _first_paragraph(spec.description)
        term = f"**[{spec.prog}](docs/{spec.prog}.md)**"
        out.append(_gfm_break_item(term, blurb))
    out += ["", "## Undocumented utilities", ""]
    undocumented = sorted(
        entry.name
        for entry in _BIN_DIR.iterdir()
        if entry.is_file() and not entry.name.startswith(".")
        if entry.name not in documented
    )
    for prog in undocumented:
        out.append(_gfm_break_item(f"**{prog}**", _help_blurb(prog)))
    return mdformat.text(
        "\n".join(out),
        options={"wrap": _md_wrap(), "number": True},
        extensions={"gfm", "tables"},
    )


def _is_stale(path: Path, content: str) -> bool:
    return (path.read_text() if path.exists() else "") != content


def main() -> int:
    ap = argparse.ArgumentParser(
        description="Generate reference docs (man pages, GFM docs, README) "
        "from the utilities' argparse parsers."
    )
    ap.add_argument(
        "--check",
        action="store_true",
        help="Exit non-zero if any checked-in GFM doc or the README is "
        "stale; do not write (no pandoc needed).",
    )
    args = ap.parse_args()

    stale: list[Path] = []
    for spec in _discover_specs():
        # The GFM doc is pure Python (plus mdformat), so --check verifies
        # it without pandoc; the roff man page needs pandoc and is gated by
        # the pytest freshness test instead.
        gfm = build_gfm(spec)
        if args.check:
            if _is_stale(spec.docs_path, gfm):
                stale.append(spec.docs_path)
        else:
            roff = _render_roff(build_markdown(spec))
            for path in (spec.man_path, spec.docs_path):
                path.parent.mkdir(parents=True, exist_ok=True)
            spec.man_path.write_text(roff)
            spec.docs_path.write_text(gfm)
            print(f"wrote {spec.man_path}\nwrote {spec.docs_path}")

    # The README is pure Python plus each undocumented utility's `--help`
    # (no pandoc), so --check gates it alongside the GFM docs.
    readme = build_readme()
    readme_path = _REPO_ROOT / "README.md"
    if args.check:
        if _is_stale(readme_path, readme):
            stale.append(readme_path)
    else:
        readme_path.write_text(readme)
        print(f"wrote {readme_path}")

    if stale:
        for path in stale:
            print(f"{path} is stale", file=sys.stderr)
        print("run scripts/render-docs to refresh", file=sys.stderr)
        return 1
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
