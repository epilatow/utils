{
  // markdownlint-cli2 reads this file as JSONC; `//` comments are
  // allowed despite the `.json` extension.
  "default": true,
  // Custom rules registered via ``customRules`` in
  // ``.markdownlint-cli2.jsonc`` need an explicit ``true`` here --
  // ``default: true`` only enables markdownlint's built-in rules.
  "no-squashed-file-references": true,
  // MD004 ul-style: bulleted-list marker character.
  "MD004": { "style": "dash" },
  // MD013 line-length: max line length for prose. Code blocks,
  // tables, and headings are exempt.
  "MD013": {
    "line_length": 79,
    "code_blocks": false,
    "tables": false,
    "headings": false
  },
  // MD024 no-duplicate-heading: duplicate headings only flagged
  // when they're siblings under the same parent heading.
  "MD024": { "siblings_only": true },
  // MD029 ol-prefix: ordered-list numbering style. `ordered` =
  // `1./2./3./...` (vs `one` = `1./1./1./...`).
  "MD029": { "style": "ordered" },
  // MD033 no-inline-html: disabled. Inline HTML (`<br>`, `<sub>`,
  // etc.) is allowed.
  "MD033": false,
  // MD046 code-block-style: fenced code blocks (```...```)
  // required; indented code blocks rejected.
  "MD046": { "style": "fenced" },
  // MD049 emphasis-style: italic marker. `*text*` (not `_text_`).
  "MD049": { "style": "asterisk" },
  // MD050 strong-style: bold marker. `**text**` (not `__text__`).
  "MD050": { "style": "asterisk" },
  // MD060 table-column-style: tables use the `aligned` style --
  // cells padded with spaces so column pipes align vertically.
  "MD060": { "style": "aligned" }
}
